
;標的のステータス表示
;ARG：飛んできた場所　0：SHOP　1：全奴隷一覧　2：標的キャラ行動選択
@GUILD_STATUS_DETAIL(ARG)

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT
CALL PRINT_NAME_STATUS
CALL PRINT_AFFILIATION_DATA
PRINTFORM  Lv{BASE:レベル,2}　★{CFLAG:ランク}
SIF CFLAG:仲間規模 && BASE:仲間戦闘力1 
	PRINTFORM ／{CFLAG:仲間ランク}
PRINTL
CALL PRINT_BUST_DETAIL
PRINTFORM 　Personality：【%PERSONALITY_ENG(CSTR:性格)%】
CALL PRINT_EXTERIOR
PRINTL
CALL SHOW_EQUIP
CALL PRINT_NOW_PURPOSE
PRINTL
CALL SHOW_TALENT_LIST
CALL SHOW_TALENT_NASTY
CALL SHOW_MARK_LIST(1)

;メインメニューから見るとき用に分割
CALL PRINT_CHASE_STATUS



;追跡者情報など
;ARG→1なら次の関数でHPとかOFF
@PRINT_CHASE_STATUS(ARG)

CALL PRINT_TARGET_BATTLE_STATUS(ARG)
PRINTL
SELECTCASE CFLAG:追跡対象
CASE 1
	SELECTCASE CFLAG:追跡者
	CASE 0
		PRINTL Tracking（Currently no pursuers）
	CASE 1
		PRINTFORML {CFLAG:追跡人数} Goblin Army Troops In Pursuit
	CASE 2
		PRINTFORML {CFLAG:追跡人数} Rookie Mercenaries In Pursuit
	CASE 3
		PRINTFORML {CFLAG:追跡人数} Veteran Mercenaries In Pursuit
	CASE 4
		PRINTFORML {CFLAG:追跡人数} Oni Mercenaries In Pursuit
	ENDSELECT
CASE 2
	PRINTFORML Captured Rape Count：{CFLAG:輪姦回数} 
CASE 3
	PRINTL In Transit 
CASEELSE
	PRINTL You Bugged Out
ENDSELECT
DRAWLINE




