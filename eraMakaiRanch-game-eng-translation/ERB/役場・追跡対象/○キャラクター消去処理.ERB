
;キャラクター消去処理
@TARGET_CHARA_DELETE
#DIM DELETE_CHARA
#DIM DELETE_CHARA_ID
#DIM CFLAG_REF

;TARGET指定状態で来ること
DELETE_CHARA = TARGET
DELETE_CHARA_ID = CFLAG:ID

;傭兵バイトが追ってる場合帰還させる
;FLAG:傭兵バイト標的ID／ゴブリン→440
FLAG_REF = 440
FLAG_MAX = 4
FOR LOCAL,FLAG_REF,FLAG_REF +FLAG_MAX
	SIF FLAG:LOCAL == DELETE_CHARA_ID
		FLAG:LOCAL = 0
NEXT

;調教対象にしている場合自由時間にリセット
;CFLAG:自動スケジュール／調教対象ID／Ａ→520
;CSTR:自動スケジュール／月→350
CFLAG_REF = 520
CSTR_REF = 350
FOR TARGET_COUNT,0,CHARANUM
	SIF TARGET_COUNT == DELETE_CHARA
		CONTINUE
	TARGET = TARGET_COUNT
	
	;調教対象のときリセット
	IF CFLAG:調教対象ID == DELETE_CHARA_ID
		CFLAG:調教対象ID = -1
		CSTR:スケジュール = 自由
	ENDIF
	
	;自動スケジュールリセット
	FOR LOCAL,0,3
		SIF CFLAG:(CFLAG_REF +LOCAL) != DELETE_CHARA_ID
			CONTINUE
		CFLAG:(CFLAG_REF +LOCAL) = 0
	NEXT
	CALL AUTO_SCHEDULE_REST_FIX
NEXT

;フラグ入れ替え終えたら消去
DELCHARA DELETE_CHARA
CALL CALC_PEOPLE_FLAG


