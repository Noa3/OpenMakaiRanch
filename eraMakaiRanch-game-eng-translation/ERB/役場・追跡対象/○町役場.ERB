
;ニンゲン監視所もしくは町役場
@TOWN_HALL

;役場画面で居場所、部屋数、魔力枷数計算しとく
CALL CALC_PEOPLE_FLAG
CALL CHARA_WHEREABOUTS_ALL
CALL PRINT_ROOM_ALLOCATION

CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_HALL
CALL CHASE_SLAVE_CHECK
CALL PRINT_CHASE_SLAVE
CALL CHASE_SLAVE_REQUEST
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTLC [90] Search Owned Slaves
PRINTLC [98] Tip
PRINTLC [99] Done
BINPUT
INPUT_NUM = RESULT
SELECTCASE INPUT_NUM
CASE 0
	CALL TARGET_DECIDE
CASE 1
	CALL ORDER_CHARACTER
CASE 2
	CALL SELF_CHARA_MAKE_ENTRANCE
CASE 3
	CALL CHARA_DATA_LOAD
CASE 90
	CALL SLAVE_SEARCH
CASE 98
	CALL BROWSE_HINT("町役場")
CASE 99
	RETURN
CASEELSE
	TARGET = INPUT_NUM -100
	CALL TARGET_STATUS
	TARGET = -1
ENDSELECT
RESTART



;追跡するキャラ指定の選択肢
@CHASE_SLAVE_REQUEST

IF FLAG:追跡中人数 >= 10
	CALL PRINTL_WORD_COLOR("　追跡キャラ上限","灰")
	RETURN
ENDIF
IF FLAG:魔力枷使用可能数 < 1
	CALL PRINTL_WORD_COLOR("　＜魔力枷＞不足","灰")
	RETURN
ENDIF
PRINTL [ 0] Select character to chase
IF FLAG:ランダムキャラのみ許可
	CALL PRINTL_WORD_COLOR("Disabled by [Only Random Characters]","灰")
	RETURN
ENDIF
PRINTLC [ 1] Special Release Gate 
PRINTL （Read from .CSV file）
PRINTLC [ 2] Ningen Search
PRINTL （Make a custom character）
PRINTLC [ 3] Recollection
PRINTL （Read from .dat file）



