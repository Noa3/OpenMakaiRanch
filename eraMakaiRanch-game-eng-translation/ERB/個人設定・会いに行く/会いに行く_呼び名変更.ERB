
;呼び名を変更する
@VISIT_SETTING_NEW_CALLNAME_BEFORE

;呼び名を変えてる場合
IF EQUIP:家畜管理タグ／呼び名
	PRINTFORML Change name back to %CSTR:初期値／呼び名%？（Remove ＜Livestock Tag＞）
	CALL ASK_YN
	SIF RESULT
		RETURN
	EQUIP:家畜管理タグ／呼び名 = 0
	CALLNAME = %CSTR:初期値／呼び名%
	IF ＃陥落状態／隷属＃ && CSTR:一人称 != CSTR:初期値／一人称
		PRINTFORML Change how %CALLNAME% refers to herself back to「%CSTR:初期値／一人称%」?
		CALL ASK_YN
		IF !RESULT
			CSTR:一人称 = %CSTR:初期値／一人称%
			PRINTW You order her to revert how she refers to herself.
		ELSE
			PRINTW You order her to keep calling herself the same.
		ENDIF
	ENDIF
	RETURN
ENDIF

;5500～,身分・名前候補文面
STR_REF = 5500
STR_MAX = 50
CALL VISIT_SETTING_NEW_CALLNAME



;新呼び名
@VISIT_SETTING_NEW_CALLNAME
#DIMS DYNAMIC NEW_CALLNAME
#DIMS DYNAMIC LC_NEW_CALLNAME
#DIMS DYNAMIC NEW_CALLNAME_JP
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML Combine words to set a new name for %CALLNAME%.（＜Livestock Tag＞ Owned：{ITEM:家畜管理タグ}）
PRINTFORML Current selection：【%NEW_CALLNAME%】
CALL PRINT_TAG_WORD_CATEGORY(PAGE)
DRAWLINE
BR = 0
FOR LOCAL,STR_REF,STR_REF +STR_MAX
	SIF STR:LOCAL == ""
		CONTINUE
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
NEXT
PRINTL
CALL PRINTL_ALIGN(-5)
PRINTFORMLC [101] %RACE_ENG(CSTR:種族)%
SIF CSTR:ジョブ != ""
	PRINTFORMLC [102] %JOB_ENG(CSTR:ジョブ)%
PRINTFORMLC [103] %CSTR:あなた呼び方／陥落後%
SIF CSTR:初期値／呼び名 != ""
	PRINTFORMLC [104] %CSTR:初期値／呼び名%
SIF CSTR:所属 != ""
	PRINTFORMLC [105] %JOB_ENG(CSTR:所属)%
PRINTFORMLC [106] %TOSTR(CFLAG:ID,"0000")%（ID Number）
PRINTL
PRINTLC [110] （Manual Input）
PRINTLC [111] （Reset）
PRINTFORML [112] Species Display：\@ CFLAG:表示OFF／種族表示 ? OFF # ON \@
DRAWLINE
PRINTLC [ 90] Done
PRINTFORMLC [ 91] Switch Page：{PAGE}／{PAGE_MAX}
PRINTL [ 99] Cancel
INPUT
PRINTL
SELECTCASE RESULT
CASE 101
	NEW_CALLNAME += RACE_ENG(CSTR:種族)
	NEW_CALLNAME_JP += CSTR:種族
CASE 102
	NEW_CALLNAME += JOB_ENG(CSTR:ジョブ)
	NEW_CALLNAME_JP += CSTR:ジョブ
CASE 103
	NEW_CALLNAME += CSTR:あなた呼び方／陥落後
	NEW_CALLNAME_JP += CSTR:あなた呼び方／陥落後
CASE 104
	NEW_CALLNAME += CSTR:初期値／呼び名
	NEW_CALLNAME_JP += CSTR:初期値／呼び名
CASE 105
	NEW_CALLNAME += JOB_ENG(CSTR:所属)
	NEW_CALLNAME_JP += CSTR:所属
CASE 106
	NEW_CALLNAME += TOSTR(CFLAG:ID,"0000")
	NEW_CALLNAME_JP += TOSTR(CFLAG:ID,"0000")
CASE 110
	PRINTL Please Enter.（This will be added after the current selection）
	INPUTS
	NEW_CALLNAME += RESULTS
	NEW_CALLNAME_JP += RESULTS
CASE 111
	NEW_CALLNAME =
	NEW_CALLNAME_JP =
CASE 112
	INVERTBIT CFLAG:表示OFF／種族表示,0
	
CASE 90
	SIF NEW_CALLNAME == ""
		RETURN
	PRINTFORML Do you want to make 【%NEW_CALLNAME%】 the new name for %CALLNAME%? （Consumes 1x ＜Livestock Tag＞）
	CALL ASK_YN
	SIF RESULT
		RESTART
	ITEM:家畜管理タグ --
	EQUIP:家畜管理タグ／呼び名 = 1
	LC_NEW_CALLNAME = %TOLOWER(NEW_CALLNAME)%
	PRINTFORML You give %CALLNAME% an ＜Livestock Tag＞.
	PRINTFORML The tag is inscribed with 【%NEW_CALLNAME%】, %CALLNAME%'s new name...
	CALLNAME = %NEW_CALLNAME%
	
	;屈辱的な名前かチェック
	CALL CHECK_DISGRACE_WORD(LC_NEW_CALLNAME)
	IF RESULT
		CALL KOJO_PRINT("訪問","呼び名変更","屈辱的")
	ELSE
		CALL KOJO_PRINT("訪問","呼び名変更","通常")
	ENDIF
	PRINTW
	
	;隷属している場合一人称もそれにするか尋ねる
	IF ＃陥落状態／隷属＃
		PRINTFORML %CALLNAME% asks you, if she should refer to herself as 「%CALLNAME%」 from now on, as proof of your ownership.
		PRINTFORML Change how she refers to herself to 【%CALLNAME%】? （Currently：「%CSTR:一人称%」）
		CALL ASK_YN
		IF !RESULT
			CSTR:一人称 = %CALLNAME%
			PRINTFORMW You order %CALLNAME% to refer to herself as 「%CALLNAME%」 from now on.
		ELSE
			PRINTW You order her to keep referring to herself as before.
		ENDIF
	ENDIF
	RETURN
	
CASE 91
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	STR_REF = 5500 +(PAGE -1) *50
	
CASE 99
	RETURN
CASEELSE
	SIF RESULT >= 0 && RESULT < 50
		NEW_CALLNAME += STR:(RESULT +STR_REF)
ENDSELECT
RESTART



