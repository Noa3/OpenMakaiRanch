
;ドット絵・画像個人設定
@SLAVE_CONFIG_PORTRAIT

CLEARLINE LINECOUNT
CALL SHOW_SLAVE_STATE
PRINTLC [ 0] Hide Character Images
CALL PRINT_ONOFF(CFLAG:表示OFF／顔グラ)
CALL PRINTL_WORD_COLOR,@"　Global Setting：\@ FLAG:顔グラ／表示 ? ON 　 # OFF　 \@","黄"
PRINTLC [ 1] Hide Pixel Images
CALL PRINT_ONOFF(CFLAG:表示OFF／ドット絵)
CALL PRINTL_WORD_COLOR,@"　Global Setting：\@ FLAG:ドット絵／表示 ? ON 　 # OFF　 \@","黄"
PRINTL
PRINTL 　《 ドット絵調整 》
PRINTLC [ 2] Disable Pixel Racial Features
CALL PRINT_ONOFF(CFLAG:ドット絵設定／背後特徴OFF,1)
PRINTLC [ 3] Disable Pixel Image Background
CALL PRINT_ONOFF(CFLAG:ドット絵設定／背景OFF,1)

IF CFLAG:身長 < FLAG:ドット絵／低身長適用上限数値
	PRINTLC [ 4] Height Based Wing Adjustment
	CALL PRINT_ONOFF(CFLAG:ドット絵設定／背後高さ調整,1)
ELSE
	CALL PRINTL_WORD_COLOR("　低身長扱いではないため無効","灰")
ENDIF

CALL PRINTL_ALIGN
DRAWLINE
PRINTL [99] Done
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	INVERTBIT CFLAG:表示OFF／顔グラ,0
CASE 1
	INVERTBIT CFLAG:表示OFF／ドット絵,0
CASE 2
	INVERTBIT CFLAG:ドット絵設定／背後特徴OFF,0
CASE 3
	INVERTBIT CFLAG:ドット絵設定／背景OFF,0
CASE 4
	SIF CFLAG:身長 < FLAG:ドット絵／低身長適用上限数値
		INVERTBIT CFLAG:ドット絵設定／背後高さ調整,0
CASE 99
	RETURN
ENDSELECT
RESTART


