;髪色・髪型変更
@VISIT_HAIR_STYLE_CHANGE_BEFORE

CHANGE_PLANS:0 = %CSTR:髪色%
CHANGE_PLANS:1 = %CSTR:髪特徴%
CHANGE_PLANS:2 = %CSTR:髪型%
CHANGE_PLANS:3= %CSTR:カテゴリ／髪色%
CHANGE_PLANS:4= %CSTR:カテゴリ／髪特徴%
CHANGE_PLANS:5= %CSTR:カテゴリ／髪型%
CHANGE_PLAN:0 = CFLAG:カラーコード／髪
CALL VISIT_HAIR_STYLE_CHANGE

VARSET CHANGE_PLANS
VARSET CHANGE_PLAN



;ここで設定
@VISIT_HAIR_STYLE_CHANGE

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT
CALL MANYL(3)
PRINT 　Original Hairstyle：
SIF CFLAG:初期値／カラーコード／髪
	SETCOLOR CFLAG:初期値／カラーコード／髪
PRINTFORML 【%ADD_SPACE(HAIR_CHAR_ENG(CSTR:初期値／髪特徴))%%HAIR_COLOR_ENG(CSTR:初期値／髪色)% (%HAIR_STYLE_ENG(CSTR:初期値／髪型)%)】
RESETCOLOR
PRINT Current Hairstyle：
SIF CHANGE_PLAN:0
	SETCOLOR CHANGE_PLAN:0
PRINTFORML 【%ADD_SPACE(HAIR_CHAR_ENG(CHANGE_PLANS:1))%%HAIR_COLOR_ENG(CHANGE_PLANS:0)% (%HAIR_STYLE_ENG(CHANGE_PLANS:2)%)】
RESETCOLOR
PRINTL
PRINTFORMLC Hair Color　：%HAIR_COLOR_ENG(CSTR:髪色)%
IF ITEM:ヘアカラー
	PRINTL [ 0] Change Hair Color
ELSE
	CALL PRINTL_WORD_COLOR("Requires ＜Hair Dye＞","灰")
ENDIF
PRINTLC 　
PRINTL [ 1] Change Hair Color By Code
IF CSTR:髪特徴 == ""
	PRINTLC Hair Characteristic：（None）
ELSE
	PRINTFORMLC Hair Characteristic：%HAIR_CHAR_ENG(CSTR:髪特徴)%
ENDIF
PRINTL [ 2] Change Hair Characteristic
PRINTFORMLC Hairstyle　：%HAIR_STYLE_ENG(CSTR:髪型)%
PRINTL [ 3] Change Hairstyle
PRINTL
PRINT After Changes：
CALL PRINT_HAIR_STYLE
PRINTL
DRAWLINE
PRINTLC [90] Cancel
IF CFLAG:ヘアスタイル変更中
	PRINTLC [91] Revert to Original Hairstlye
ELSE
	PRINTLC 　
ENDIF
PRINTL [99] Done
INPUT
PRINTL

SELECTCASE RESULT
CASE 0
	SIF !ITEM:ヘアカラー
		RESTART
	
	;STR:黒髪→200
	STR_REF = 200
	PRINTL Choose a hair color
	FOR LOCAL,STR_REF,STR_REF+50
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL-STR_REF,3}] %HAIR_COLOR_ENG(STR:LOCAL)%
	NEXT
	CALL INPUTBUTTON
	BINPUT
	IF RESULT >= 0 && RESULT < 50
		CSTR:髪色 = %STR:(RESULT+STR_REF)%
		CALL AUTOSET_HAIR_COLOR_CODE
	ELSEIF RESULT == 901
		PRINTL Enter a hair color
		INPUTS
		CSTR:髪色 = %RESULTS%
	ENDIF
	CALL CATEGORY_HAIR_COLOR
	
CASE 1
	CALL EDIT_COLOR_CODE(CFLAG:カラーコード／髪,1)
	SIF RESULT
		CFLAG:カラーコード／髪 = RESULT
	
CASE 2
	;STR:ぱっつん→300
	STR_REF = 300
	PRINTL Choose a hair characteristic
	FOR LOCAL,STR_REF,STR_REF+100
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL-STR_REF,3}] %HAIR_CHAR_ENG(STR:LOCAL)%
	NEXT
	CALL INPUTBUTTON(1)
	BINPUT
	IF RESULT >= 0 && RESULT < 100
		CSTR:髪特徴 = %STR:(RESULT+STR_REF)%
	ELSEIF RESULT == 900
		CSTR:髪特徴 =
	ELSEIF RESULT == 901
		PRINTL Enter a hair characteristic
		INPUTS
		CSTR:髪特徴 = %RESULTS%
	ENDIF
	CALL CATEGORY_HAIR_FEATURE
	
CASE 3
	;STR:ロング→500
	STR_REF = 500
	PRINTL Choose a hairstyle
	FOR LOCAL,STR_REF,STR_REF+100
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL-STR_REF,3}] %HAIR_STYLE_ENG(STR:LOCAL)%
	NEXT
	CALL INPUTBUTTON(1)
	BINPUT
	IF RESULT >= 0 && RESULT < 100
		CSTR:髪型 = %STR:(RESULT+STR_REF)%
	ELSEIF RESULT == 901
		PRINTL Enter a hairstyle
		INPUTS
		CSTR:髪型 = %RESULTS%
	ENDIF
	CALL CATEGORY_HAIR_STYLE

CASE 90
	CSTR:髪色 = %CHANGE_PLANS:0%
	CSTR:髪特徴 = %CHANGE_PLANS:1%
	CSTR:髪型 = %CHANGE_PLANS:2%
	CSTR:カテゴリ／髪色 = %CHANGE_PLANS:3%
	CSTR:カテゴリ／髪特徴 = %CHANGE_PLANS:4%
	CSTR:カテゴリ／髪型 = %CHANGE_PLANS:5%
	CFLAG:カラーコード／髪 = CHANGE_PLAN:0
	RETURN
	
CASE 91
	SIF !CFLAG:ヘアスタイル変更中
		RESTART
	PRINTL Revert to the original hairstyle?
	CALL ASK_YN
	IF !RESULT
		CFLAG:ヘアスタイル変更中 = 0
		CSTR:髪色 = %CSTR:初期値／髪色%
		CFLAG:カラーコード／髪 = CFLAG:初期値／カラーコード／髪
		CSTR:髪特徴 = %CSTR:初期値／髪特徴%
		CSTR:髪型 = %CSTR:初期値／髪型%
		CALL CATEGORY_HAIR_COLOR
		CALL CATEGORY_HAIR_FEATURE
		CALL CATEGORY_HAIR_STYLE
		PRINTW Original hairstyle restored
		RETURN
	ENDIF
	
CASE 99
	PRINT Change hairstyle to
	CALL PRINT_HAIR_STYLE
	RESETCOLOR
	PRINTL ?
	SIF CHANGE_PLANS:0 != CSTR:髪色
		CALL PRINTL_WORD_COLOR("1x ＜air Dye＞ used in the process","黄")
	CALL ASK_YN
	IF !RESULT
		SIF CHANGE_PLANS:0 != CSTR:髪色
			ITEM:ヘアカラー --
		CFLAG:ヘアスタイル変更中 = 1
		PRINTFORML %CALLNAME%'s hairstyle has been modified.
		CALL KOJO_PRINT("訪問","ヘアスタイル変更")
		PRINTW
		RETURN
	ENDIF
ENDSELECT
RESTART

