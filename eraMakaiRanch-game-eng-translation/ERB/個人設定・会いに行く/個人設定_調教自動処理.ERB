	PRINTL [ 3] Outside
	INPUT
	SIF RESULT >= 0 && RESULT <= 3
		CFLAG:個別設定／射精箇所／Ａセックス = RESULT -1

CASE 98
	PRINTL Reset All To ＜Use Common Setting＞？
	CALL ASK_YN
	SIF !RESULT
		VARSET CFLAG,0,540,550
	
ENDSELECT



;ローション使用
@SLAVE_CONFIG_TRAIN_AUTO_CHANGE_LOTION

CLEARLINE LINECOUNT
PRINTL Set whether to automatically use ＜Lotion＞ at the start of training.
PRINTL ※Will be used if in an exposed state; if there are insufficient items, priority will be given from the top.
PRINTL
LOCALS = 全体コンフィグに準拠
PRINTFORMLC [ 0] %LOCALS,12%
CALL PRINT_ONOFF(!GETBIT(CFLAG:個別設定／調教開始自動処理／ローション,0),1)
IF GETBIT(CFLAG:個別設定／調教開始自動処理／ローション,0)
	PRINTFORMLC [ 1] %SAVESTR:表記／膣,12%
	CALL PRINT_ONOFF(GETBIT(CFLAG:個別設定／調教開始自動処理／ローション,1),1)
	PRINTFORMLC [ 2] %SAVESTR:表記／アナル,12%
	CALL PRINT_ONOFF(GETBIT(CFLAG:個別設定／調教開始自動処理／ローション,2),1)
	PRINTFORMLC [ 3] %SAVESTR:表記／乳房,12%
	CALL PRINT_ONOFF(GETBIT(CFLAG:個別設定／調教開始自動処理／ローション,3),1)
ELSE
	CALL PRINTL_WORD_COLOR,@"< 1> %SAVESTR:表記／膣,12%","灰"
	CALL PRINTL_WORD_COLOR,@"< 2> %SAVESTR:表記／アナル,12%","灰"
	CALL PRINTL_WORD_COLOR,@"< 3> %SAVESTR:表記／乳房,12%","灰"
ENDIF
PRINTL [ 99] Return
BINPUT
SELECTCASE RESULT
CASE 99
	RETURN
CASEELSE
	INVERTBIT CFLAG:個別設定／調教開始自動処理／ローション,RESULT
ENDSELECT
RESTART

