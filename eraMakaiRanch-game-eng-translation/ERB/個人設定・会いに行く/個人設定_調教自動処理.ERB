;変更部分
;ARG→INPUT
@SLAVE_CONFIG_TRAIN_AUTO_CHANGE(ARG)

SELECTCASE ARG
CASE 0
	;STR:デフォルト脱衣状態→8130
	STR_REF = 8130
	PRINTL Set State Of Slaves Clothes At Start Of Training.
	PRINTL
	PRINTL [ 0] Use Common Setting
	FOR LOCAL,0,7
		PRINTFORM [{(LOCAL + 1),2}] %STRIP_SELECT_ENG(STR:(STR_REF +LOCAL))%
		PRINTL
		IF LOCAL == 2 && !CFLAG:無抵抗
			CALL PRINTL_WORD_COLOR("　【Resistance】Prevents Stripping","灰")
			BREAK
		ENDIF
	NEXT
	BINPUT
	CFLAG:個別設定／調教開始自動処理／脱衣 = RESULT

CASE 1
	;別関数使う
	PRINTL Set Restraints At Start Of Training
	CALL BIND_CHOICE("個人設定")
	SIF RESULT >= 0
		CFLAG:個別設定／調教開始自動処理／拘束 = RESULT
CASE 2
	CALL SLAVE_CONFIG_TRAIN_AUTO_CHANGE_LOTION
CASE 3
	PRINTL Set whether to use ＜Aphrodisiac＞ or ＜Aphrodisiac Slime＞ at the start of training.
	PRINTL ※Will not be used if there are no items / magic not learned or insufficient magic power
	PRINTL
	PRINTL [ 0] Follows overall configuration
	PRINTL [ 1] Do not use
	PRINTL [ 2] Using ＜Aphrodisiac＞
	PRINTL [ 3] Using ＜Aphrodisiac Slime＞
	BINPUT
	CFLAG:個別設定／調教開始自動処理／媚薬 = RESULT

CASE 10
	PRINTL Choose Paizuri Ejaculation Target.
	PRINTL
	PRINTL [ 0] Always Ask
	PRINTL [ 1] Use Common Setting
	IF ABL:バストサイズ >= BUSTSIZE_並乳
		PRINTL [ 2] In-Between Breasts
	ELSE
		CALL PRINTL_WORD_COLOR("　 Ejaculating Between Breasts Is Only Possible For B Size【Average】Or Above","灰")
	ENDIF
	PRINTL [ 3] On Breasts
	PRINTL [ 4] On Face
	INPUT
	SIF RESULT >= 0 && RESULT <= 4 && !(RESULT == 2 && ABL:バストサイズ < BUSTSIZE_並乳)
		CFLAG:個別設定／射精箇所／パイズリ = RESULT -1

CASE 11
	;豊乳未満ならおわり
	SIF ABL:バストサイズ < BUSTSIZE_豊乳
		RETURN
	PRINTL Choose Horizontal Paizuri Ejaculation Target.
	PRINTL
	PRINTL [ 0] Always Ask
	PRINTL [ 1] Use Common Setting
	PRINTL [ 2] In-Between Breasts
	PRINTL [ 3] On Breasts
	PRINTL [ 4] On Face
	INPUT
	SIF RESULT >= 0 && RESULT <= 4
		CFLAG:個別設定／射精箇所／縦パイズリ = RESULT -1

CASE 12
	PRINTL Choose Blowjob Ejaculation Target.
	PRINTL
	PRINTL [ 0] Always Ask
	PRINTL [ 1] Use Common Setting
	PRINTL [ 2] In Mouth
	PRINTL [ 3] On Face
	INPUT
	SIF RESULT >= 0 && RESULT <= 3
		CFLAG:個別設定／射精箇所／フェラチオ = RESULT -1

CASE 13
	PRINTL Choose Facefuck Ejaculation Target.
	PRINTL
	PRINTL [ 0] Always Ask
	PRINTL [ 1] Use Common Setting
	PRINTL [ 2] In Mouth
	PRINTL [ 3] On Face
	INPUT
	SIF RESULT >= 0 && RESULT <= 3
		CFLAG:個別設定／射精箇所／イラマチオ = RESULT -1

CASE 14
	PRINTL Choose V Sex Ejaculation Target.
	PRINTL
	PRINTL [ 0] Always Ask
	PRINTL [ 1] Use Common Setting
	PRINTL [ 2] In Pussy
	PRINTL [ 3] Outside
	INPUT
	SIF RESULT >= 0 && RESULT <= 3
		CFLAG:個別設定／射精箇所／Ｖセックス = RESULT -1

CASE 15
	PRINTL Choose A Sex Ejaculation Target.
	PRINTL
	PRINTL [ 0] Always Ask
	PRINTL [ 1] Use Common Setting
