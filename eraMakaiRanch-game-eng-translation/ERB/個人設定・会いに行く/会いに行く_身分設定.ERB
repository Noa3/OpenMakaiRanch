
;新身分
@VISIT_SETTING_NEW_POSITION_BEFORE

;身分を変えてる場合
IF EQUIP:家畜管理タグ／身分
	PRINTL Reset to original identity?（Remove ＜Livestock Tag＞）
	CALL ASK_YN
	SIF RESULT
		RETURN
	EQUIP:家畜管理タグ／身分 = 0
	CSTR:身分 = %CSTR:初期値／身分%
	CFLAG:表示OFF／種族表示 = 0
	RETURN
ENDIF

;STR:身分・名前候補文面→5500
STR_REF = 5500
STR_MAX = 50
CALL VISIT_SETTING_NEW_POSITION



;新身分
@VISIT_SETTING_NEW_POSITION
#DIMS DYNAMIC NEW_POSITION
#DIMS DYNAMIC LC_NEW_POSITION
#DIMS DYNAMIC NEW_POS_JP
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML Combine words to make a new identity for %CALLNAME%（＜Livestock Tag＞ Owned：{ITEM:家畜管理タグ}）
PRINT Current identity：
IF CSTR:身分 == ""
	CALL PRINTL_WORD_COLOR("【None】","灰")
ELSE
	PRINTFORML 【%CSTR:身分%】
ENDIF
PRINT Current：
SIF !CFLAG:表示OFF／種族表示
	CALL PRINT_TRIVE
PRINTFORML 【%NEW_POSITION%】
CALL PRINT_TAG_WORD_CATEGORY(PAGE)
DRAWLINE
BR = 0
FOR LOCAL,STR_REF,STR_REF +STR_MAX
	SIF STR:LOCAL == ""
		CONTINUE
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
NEXT
CALL PRINTL_ALIGN(-5)
PRINTFORMLC [101] %RACE_ENG(CSTR:種族)%
SIF CSTR:ジョブ != ""
	PRINTFORMLC [102] %JOB_ENG(CSTR:ジョブ)%
PRINTFORMLC [103] %CSTR:あなた呼び方／陥落後%
SIF CSTR:初期値／身分 != ""
	PRINTFORMLC [104] %CSTR:初期値／身分%
SIF CSTR:所属 != ""
	PRINTFORMLC [105] %JOB_ENG(CSTR:所属)%
PRINTL
PRINTLC [110] （Manual Input）
PRINTLC [111] （Reset）
PRINTFORML [112] Race Indicator：\@ CFLAG:表示OFF／種族表示 ? OFF # ON \@
DRAWLINE
PRINTLC [ 90] Done
PRINTFORMLC [ 91] Switch Page：{PAGE}／{PAGE_MAX}
PRINTL [ 99] Cancel
BINPUT
PRINTL
SELECTCASE RESULT
CASE 101
	NEW_POSITION += RACE_ENG(CSTR:種族)
	NEW_POS_JP += CSTR:種族
CASE 102
	NEW_POSITION += JOB_ENG(CSTR:ジョブ)
	NEW_POS_JP += CSTR:ジョブ
CASE 103
	NEW_POSITION += CSTR:あなた呼び方／陥落後
	NEW_POS_JP += CSTR:あなた呼び方／陥落後
CASE 104
	NEW_POSITION += CSTR:初期値／身分
	NEW_POS_JP += CSTR:初期値／身分
CASE 105
	NEW_POSITION += JOB_ENG(CSTR:所属)
	NEW_POS_JP += CSTR:所属
CASE 110
	PRINTL Enter here
	INPUTS
	NEW_POSITION += RESULTS
	NEW_POS_JP += RESULTS
CASE 111
	NEW_POSITION =
	NEW_POS_JP =
CASE 112
	INVERTBIT CFLAG:表示OFF／種族表示,0
CASE 90
	PRINTFORML Change %CALLNAME%'s status to【%NEW_POSITION%】?（Consumes 1x ＜Livestock Tag＞）
	CALL ASK_YN
	SIF RESULT
		RESTART
	ITEM:家畜管理タグ --
	EQUIP:家畜管理タグ／身分 = 1
	CSTR:身分 = %NEW_POSITION%
	LC_NEW_POSITION = %TOLOWER(NEW_POSITION)%
	PRINTFORML You give %CALLNAME% an ＜Livestock Tag＞.
	PRINTFORML The tag is inscribed with 【%LC_NEW_POSITION%】, which is %CALLNAME%'s new identity...
	
	;屈辱的な名前かチェック
	CALL CHECK_DISGRACE_WORD(LC_NEW_POSITION)
	IF RESULT
		CALL KOJO_PRINT("訪問","身分変更","屈辱的")
	ELSE
		CALL KOJO_PRINT("訪問","身分変更","通常")
	ENDIF
	PRINTW
	RETURN
	
CASE 91
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	STR_REF = 5500 +(PAGE -1) *50
CASE 99
	SIF CSTR:身分 == CSTR:初期値／身分
		CFLAG:表示OFF／種族表示 = 0
	RETURN
CASE 51
	NEW_POSITION += TOSTR_SPACE(1) 
CASEELSE
	NEW_POSITION += STR:(RESULT +STR_REF)
ENDSELECT
RESTART



;カテゴリ表示
;ARG→PAGE
@PRINT_TAG_WORD_CATEGORY(ARG)

ALIGNMENT CENTER
SELECTCASE ARG
CASE 1
	PRINTFORML --- %SAVESTR:表記／乳房% ---
CASE 2
	PRINTL --- Genitalia・Sex ---
CASE 3
	PRINTL --- Sex Slave, Livestock, Property ---
ENDSELECT
ALIGNMENT LEFT

