
;動作確認用口上の全部表示
@KOJO_OPERATION_CHECK(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

TRYCALLFORM KOJO_GENERAL_INDEX_動作確認用口上(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

;箱に中身が入っていたら表示
SIF MESSAGE_COUNT
	CALL MESSAGE_PRINT_OPERATION_CHECK

; ======================================
; 汎用口上 口上選出・表示処理
@MESSAGE_PRINT_OPERATION_CHECK
#DIM  LCOUNT,2		;ループ用
#DIM  FIND_ARRAY_COUNT,VARSIZE("MESSAGE_BOX")		;ストック別適合数
#DIM  CANDIDATE_COUNT		;ランダム選出用の箱の個数
#DIMS CANDIDATE_BOX,500	;ランダム選出用の箱
#DIM  TEMP

;MESSAGE_COUNTの分FORループを回して全部表示する
FOR LCOUNT,0,MESSAGE_COUNT
	CALL MESSAGE_PRINT_ESCAPE(MESSAGE_BOX:LCOUNT)
	RESETCOLOR
	PRINTL
NEXT

