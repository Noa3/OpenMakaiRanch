
;魔界の住民のセリフを口上色反映して表示
;ARGS→住民
;ARGS:1→セリフ
@RESIDENT_KOJO(ARGS,ARGS:1)

;発言者により表示色変更
CALL RESIDENT_KOJO_COLOR_REF(ARGS)
SIF !LINEISEMPTY()
	PRINTL

;前回発言者と異なる場合であなた以外は発言者名入れる
SIF RESIDENT_KOJO_BEFORE != ARGS && ARGS != "あなた"
	PRINTFORM %NAMES_ENG(ARGS)%
PRINTFORML 「%ARGS:1%」
RESETCOLOR

;前回発言者の記録
RESIDENT_KOJO_BEFORE = %ARGS%



;発言者により表示色変更
;ARGS→住民
@RESIDENT_KOJO_COLOR_REF(ARGS)

SELECTCASE ARGS
CASE "あなた"
	;あなたはあなた口上色で表示
	SETCOLOR CFLAG:0:カラーコード／口上

;たぶんFORMとかで参照できないっぽいので力技
CASE "ユジン"
	SETCOLOR RESIDENT_KOJO_ユジン
CASE "マノ"
	SETCOLOR RESIDENT_KOJO_マノ
CASE "フドウ"
	SETCOLOR RESIDENT_KOJO_フドウ
CASE "ケンチ"
	SETCOLOR RESIDENT_KOJO_ケンチ
CASE "タルト"
	SETCOLOR RESIDENT_KOJO_タルト
CASE "あらし"
	SETCOLOR RESIDENT_KOJO_あらし
CASE "シンミ"
	SETCOLOR RESIDENT_KOJO_シンミ
CASE "ノノミ"
	SETCOLOR RESIDENT_KOJO_ノノミ
CASE "テラ"
	SETCOLOR RESIDENT_KOJO_テラ
CASE "カグヤ"
	SETCOLOR RESIDENT_KOJO_カグヤ
CASE "ゴロー"
	SETCOLOR RESIDENT_KOJO_ゴロー
CASE "ショウ"
	SETCOLOR RESIDENT_KOJO_ショウ
CASE "シンシア"
	SETCOLOR RESIDENT_KOJO_シンシア
CASE "ぷにえ"
	SETCOLOR RESIDENT_KOJO_ぷにえ
CASE "ゴーズ"
	SETCOLOR RESIDENT_KOJO_ゴーズ
CASE "ウキョウ"
	SETCOLOR RESIDENT_KOJO_ウキョウ
CASE "ヒナ"
	SETCOLOR RESIDENT_KOJO_ヒナ
CASE "キュレタ"
	SETCOLOR RESIDENT_KOJO_キュレタ
CASE "マツダイラ"
	SETCOLOR RESIDENT_KOJO_マツダイラ
ENDSELECT

;0だと通常色へ
GETCOLOR
SIF !RESULT
	RESETCOLOR





