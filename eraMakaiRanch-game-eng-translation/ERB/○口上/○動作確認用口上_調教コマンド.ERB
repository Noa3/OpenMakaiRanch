CASE "正常位","後背位","対面座位","背面座位","騎乗位","対面立位","背面立位","強制騎乗位"
		;CALL MESSAGE_BOX,@"「test_↓を使い、Ｖセックスの共通口上を呼び出しています」"
		;CALL MESSAGE_BOX,@"「test_実際には↓のみ使用し、この3行は使用しないほうが処女喪失時の口上への対応などが楽です」"
		;CALL MESSAGE_BOX,@"「test_体位で別々の口上を用意したい場合はCASEを分割、↓を使わないまたは追加記述してください」"
		;分割すると処女喪失時の例外処理をするために逐一書く必要があるよ
		;↓を使うことで楽できるのと処女喪失時に実行口上を飛ばす処理ができるよ
	CALL KOJO_GENERAL_動作確認用口上_TRAIN_INSIDE("Ｖセックス",ARGS:2)

CASE "Ａ正常位","Ａ後背位","Ａ対面座位","Ａ背面座位","Ａ騎乗位","Ａ対面立位","Ａ背面立位","強制Ａ騎乗位"
		;CALL MESSAGE_BOX,@"「test_↓を使い、Ａセックスの共通口上を呼び出しています」"
	CALL KOJO_GENERAL_動作確認用口上_TRAIN_INSIDE("Ａセックス",ARGS:2)
	
CASE "素股"
	SELECTCASE ARGS:2
	CASE "実行"
		CALL MESSAGE_BOX,@"「test_調教コマンド【素股】実行直後の口上です」"
	CASE "継続"
