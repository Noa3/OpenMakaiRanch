;ARGS:0　シチュ指定　ARGS:1～　さらに細かく振り分けたい場合に使用
@KOJO_GENERAL_動作確認用口上_TRAIN(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

;ここに来てる場合ARGS:0は"調教コマンド"固定
;調教コマンドごとにシチュ指定で振り分けするよ　名称はTRAIN.csv参照
;現状の仕様は@COMに書かれた地の文→口上になる

SELECTCASE ARGS:1
CASE "実行後"
	IF SOURCE:処女喪失
		CALL MESSAGE_BOX,@"「test_今回のコマンドで処女喪失していると表示されます」"
		RETURN
	ELSEIF SOURCE:Ａ処女喪失
		CALL MESSAGE_BOX,@"「test_今回のコマンドでＡ処女喪失していると表示されます」"
		RETURN
	ELSEIF SOURCE:Ｍ処女喪失
		CALL MESSAGE_BOX,@"「test_今回のコマンドでＭ処女喪失していると表示されます」"
		RETURN
	ELSEIF SOURCE:初パイズリ
		CALL MESSAGE_BOX,@"「test_今回のコマンドで初めてパイズリしていると表示されます」"
		RETURN
	ELSEIF SOURCE:初キス
		CALL MESSAGE_BOX,@"「test_今回のコマンドで初めてキスしていると表示されます」"
		RETURN
	ENDIF
	CALL MESSAGE_BOX,@"「test_時間経過する調教コマンドを実行した時にコマンドに関わらず表示判定の入る口上です」"

CASE "乳揉み","育乳マッサージ","濃厚母乳マッサージ","ミルクタンクマッサージ"
	;ここからバリエーションでの振り分けをするよ　振り分けが多いほどたのしいけど大変だよ
	;振り分け方はそれぞれだけど好感度状態などから振り分けるのが楽かなあ
	
	;まず『初回処理』かどうかを見てみよう　EXP:(SELECTCOM +1000) ++　という命令を口上表示『後』にしてます
	;よってこの値が0なら『このキャラはこのコマンドを使ったことがない』ってことだね
	;細かいことはさておき下のIF文で初回処理ができます
	;隷属乳牛になるまで乳揉みしたことないことは…搾ってばかりならありそう
	;\nを書くとそこで改行されるよ　プログラムの仕様上Enter改行はNGよ
	;CALLを2回すると『どちらかしか表示されない』ので改行目的だとこれもNGよ
	
	;初回処理
	IF !EXP:(SELECTCOM+1000)
		CALL MESSAGE_BOX,@"「test_調教コマンド【乳揉み】を初めて行った時の口上です」"
	ELSE
		CALL MESSAGE_BOX,@"「test_調教コマンド【乳揉み】の2回目以降の口上です」"
		SIF ABL:バストサイズ >= BUSTSIZE_豊乳
			CALL MESSAGE_BOX,@"「test_バストサイズが【豊乳】以上の場合候補に入ります」"
		SIF ABL:バストサイズ < BUSTSIZE_並乳
			CALL MESSAGE_BOX,@"「test_バストサイズが【貧乳】以下の場合候補に入ります」"
		SIF EX:Ｂ絶頂 >= 100
			CALL MESSAGE_BOX,@"「test_この調教中にＢ絶頂を100回以上している場合候補に入ります」"
		SIF !TFLAG:Ｎ露出
			CALL MESSAGE_BOX,@"「test_【胸露出】ではない場合候補に入ります」"
		
		;調教中は汚れがあるか参照できる　GETBIT(STAIN:乳房,4)で「おっぱいにローションが付着してるか」を判定
		;詳しくはStain.csv見てもらえれば
		SIF GETBIT(STAIN:乳房,4)
			CALL MESSAGE_BOX,@"「test_ローションを乳房に塗っている場合候補に入ります」"
	ENDIF
	
CASE "乳搾り"
	IF MARK:母乳体質
		CALL MESSAGE_BOX,@"「test_調教コマンド【乳搾り】を【母乳体質】で行った場合の口上です」"
		SIF ABL:搾乳中毒 >= 10
			CALL MESSAGE_BOX,@"「test_調教コマンド【乳搾り】を【母乳体質】で行った場合、【搾乳中毒】がLv10以上の時候補に入ります」"
	ELSE
		CALL MESSAGE_BOX,@"「test_調教コマンド【乳搾り】を【母乳体質】ではない時に行った場合の口上です」"
	ENDIF

CASE "乳首つまみ"
	CALL MESSAGE_BOX,@"「test_調教コマンド【乳首つまみ】の口上です」"

CASE "Ｃ愛撫"
	CALL MESSAGE_BOX,@"「test_調教コマンド【Ｃ愛撫】の口上です」"
	SIF ABL:Ｃ感度 >= 200 || ABL:Ｃ感覚 >= 10
		CALL MESSAGE_BOX,@"「test_調教コマンド【Ｃ愛撫】実行時Ｃ感度200\%以上、またはＣ感覚がLv10以上で候補に入ります」"

CASE "Ｖ指挿れ"
	CALL MESSAGE_BOX,@"「test_調教コマンド【Ｖ指挿れ】の口上です」"

CASE "Ａ指挿れ"
	CALL MESSAGE_BOX,@"「test_調教コマンド【Ａ指挿れ】の口上です」"
	IF PALAM:Ａ潤滑 >= 5000
		CALL MESSAGE_BOX,@"「test_調教コマンド【Ａ指挿れ】実行時、Ａ潤滑が5000以上で候補に入ります」"
	ELSE
		CALL MESSAGE_BOX,@"「test_調教コマンド【Ａ指挿れ】実行時、Ａ潤滑が5000未満で候補に入ります」"
	ENDIF

CASE "尻撫で"
	CALL MESSAGE_BOX,@"「test_調教コマンド【尻撫で】の口上です」"
	
CASE "乳撫で"
	CALL MESSAGE_BOX,@"「test_調教コマンド【乳撫で】の口上です」"
	
CASE "くすぐり"
	CALL MESSAGE_BOX,@"「test_調教コマンド【くすぐり】の口上です」"
	
;似たコマンドで共通の口上でOKの場合コンマ区切りでいい　初回判定はそれぞれで出ちゃうけども
CASE "乳吸い","母乳吸い尽くし"
	CALL MESSAGE_BOX,@"「test_調教コマンド【乳吸い】【母乳吸い尽くし】の口上です」"
	
	;搾乳処理の前に調教口上表示が来るので現在母乳量を見ることが可能
	IF BASE:母乳容量
		CALL MESSAGE_BOX,@"「test_調教コマンド【乳吸い】【母乳吸い尽くし】実行時、母乳容量が0ではない場合候補に入ります」"
	ELSE
		CALL MESSAGE_BOX,@"「test_調教コマンド【乳吸い】【母乳吸い尽くし】実行時、母乳容量が0の場合候補に入ります」"
	ENDIF
	
CASE "乳首しゃぶり","乳揉み吸い","直飲み触手複合搾乳"
	CALL MESSAGE_BOX,@"「test_調教コマンド【乳首しゃぶり】【乳揉み吸い】【直飲み触手複合搾乳】の口上です」"
	CALL MESSAGE_BOX,@"「test_カンマで区切ると似たコマンドで同じ口上を使えますが、\n　1000番台EXPの記述を使うとそれぞれに対し初回判定が入るのでご了承ください」"
	
CASE "キス"
	SIF TALENT:キス未経験
		RETURN
	CALL MESSAGE_BOX,@"「test_調教コマンド【キス】の口上です」"
	CALL MESSAGE_BOX,@"「test_ファーストキスの口上は【イベント】で呼び出すため、【キス未経験】の場合何もせずRETURNしてください」"
	
CASE "Ｃ舐め"
