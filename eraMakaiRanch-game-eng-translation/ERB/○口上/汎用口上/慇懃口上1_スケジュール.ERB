				ELSEIF ＃陥落状態／屈服以上＃
					CALL MESSAGE_BOX,@"「はぅ… また搾乳されてしまいます…」"
				ELSE
					CALL MESSAGE_BOX,@"「っ……！ このような所業、許されるはずが……！」"
				ENDIF
			ENDIF
		ENDSELECT
	CASE "実行後"
		IF CFLAG:乳牛 || CFLAG:洗脳 || ＃陥落状態／恋慕以上＃
			IF EX:噴乳 >= 10000
				CALL MESSAGE_BOX,@"「はひぃぃ…♥ こんなに…でてしまいましたぁ…♥♥♥ あぅ……♥♥」"
