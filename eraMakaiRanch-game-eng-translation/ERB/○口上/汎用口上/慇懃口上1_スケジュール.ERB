@KOJO_GENERAL_慇懃口上1_SCHEDULE(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:1
CASE "酪農"
	SELECTCASE ARGS:2
	CASE "初回"
		IF CFLAG:総搾乳量
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「%SELF_CALL()%も乳牛ですし、家畜同士、通じ合える気がいたします♥♥」"
			ELSEIF ＃陥落状態／恋慕以上＃ || CFLAG:洗脳
				CALL MESSAGE_BOX,@"「必ず%MASTER_CALL()%のお役に立ってみせます…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「これもお役目、果たすのみでございます」"
			ENDIF
