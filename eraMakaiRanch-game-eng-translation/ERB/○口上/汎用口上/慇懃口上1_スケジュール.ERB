			IF ABL:酪農 >= 5
				CALL MESSAGE_BOX,@"「家畜のお世話にございますか…？ 多少経験はございますよ」"
			ELSE
				CALL MESSAGE_BOX,@"「家畜のお世話にございますか…？ とりあえず試みてはみますが…」"
			ENDIF
		ENDIF
	CASE "通常"
		IF TIME == 0 || TIME == 2
			IF CFLAG:乳牛 || CFLAG:洗脳 || ＃陥落状態／恋慕以上＃
				CALL MESSAGE_BOX,@"「さぁ沢山ミルクを搾って%MASTER_CALL()%に貢献いたしましょう…♥♥」"
