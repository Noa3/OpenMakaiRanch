;最初の振り分け　調教中もここから
;…の前に　口が塞がってる場合や崩壊の場合の振り分けをしてしまおう

;口が塞がっている場合は口塞ぎ汎用口上呼び出して終了　現状全部SHACKLE_1呼んでるけど必要に応じて2番以降作ってね
;崩壊中＋Ｍ装備処理はＭ装備のほうに入れてるよ
IF TFLAG:Ｍ装備
	CALL KOJO_GENERAL_MOUTH_SHACKLE_1(ARGS:0,ARGS:1,ARGS:2,ARGS:3)
	RETURN
ELSEIF CFLAG:崩壊 && !CFLAG:洗脳
	;例外処理したい場合とりあえずここに　洗脳コマンド使用時はそのまま通すよ
	;崩壊した場合の口上も通す
	;例文も通さなあかん
	;ここもあとで崩壊用汎用作る予定
	
	IF GROUPMATCH(ARGS:0,"例文")
	ELSEIF GROUPMATCH(ARGS:1,"洗脳触手","崩壊")
	
	ELSE
		IF NOWEX:総絶頂
			CALL MESSAGE_BOX,@"「あ゛ーっ♥ お゛っ♥♥」"
			CALL MESSAGE_BOX,@"「ぁっ♥ あああ♥」"
		ELSE
			CALL MESSAGE_BOX,@"「ぅぁ…ぁ…」"
			CALL MESSAGE_BOX,@"「んぁ…ぁっ…」"
		ENDIF
		RETURN
	ENDIF
