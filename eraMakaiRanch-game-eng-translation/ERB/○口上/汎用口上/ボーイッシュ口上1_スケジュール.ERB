		ELSE
			CALL MESSAGE_BOX,@"「事務作業…… %MASTER_CALL()%、頼む相手を間違えてるぞ」"
		ENDIF
	CASE "通常"
		IF ABL:事務 >= 8
			CALL MESSAGE_BOX,@"「事務処理だったら、この%SELF_CALL()%に任せときな！」"
		ELSEIF ABL:事務 >= 4
