@KOJO_GENERAL_ボーイッシュ口上1_SCHEDULE(ARGS:0,ARGS:1,ARGS:2,ARGS:3)

SELECTCASE ARGS:1
CASE "酪農"
	SELECTCASE ARGS:2
	CASE "初回"
		IF CFLAG:総搾乳量
			IF CFLAG:乳牛
				CALL MESSAGE_BOX,@"「%SELF_CALL()%も乳牛だし、家畜同士、通じ合える気がするぜ♥♥」"
			ELSEIF ＃陥落状態／恋慕以上＃ || CFLAG:洗脳
				CALL MESSAGE_BOX,@"「必ず%MASTER_CALL()%の役に立ってみせるから…♥」"
			ELSE
				CALL MESSAGE_BOX,@"「家畜の世話か……普通の方だよな…？」"
			ENDIF
		ELSE
			IF ABL:酪農 >= 5
				CALL MESSAGE_BOX,@"「家畜の世話…？ いくらか経験したことあるぜ」"
			ELSE
				CALL MESSAGE_BOX,@"「家畜の世話…？ とりあえずやってはみるけど…」"
			ENDIF
		ENDIF
	CASE "通常"
		IF TIME == 0 || TIME == 2
			IF CFLAG:乳牛 || CFLAG:洗脳 || ＃陥落状態／恋慕以上＃
				CALL MESSAGE_BOX,@"「いっぱいミルクを搾って%MASTER_CALL()%の役に立たないとな…♥♥」"
				CALL MESSAGE_BOX,@"「へへ♥ 上手に世話したら%MASTER_CALL()%に褒めてもらえっかな…♥」"
