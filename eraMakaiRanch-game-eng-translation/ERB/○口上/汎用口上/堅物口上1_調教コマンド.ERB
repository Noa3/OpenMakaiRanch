			CALL MESSAGE_BOX,@"「%MASTER_CALL()%の%PENIS_CALL()%…♥ %SELF_CALL()%の%VAGINA_CALL()%犯してるぅう…♥♥」"
		ELSEIF ＃陥落状態／屈服以上＃
			CALL MESSAGE_BOX,@"「あっ♥ くぅう…ッ♥ 気持ちよく、なんてぇ…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「いい加減に… んっ…♥ しろッ…！」"
		ENDIF
	
	CASEELSE
		
	ENDSELECT
	
