		IF CFLAG:乳牛 || CFLAG:洗脳 || ＃陥落状態／隷属＃
			CALL MESSAGE_BOX,@"「%MASTER_CALL()%♥♥ %MASTER_CALL()%の%PENIS_CALL()%♥♥ だいすきぃ♥♥♥」"
