	;例文も通さなあかん
	;ここもあとで崩壊用汎用作る予定
	
	IF GROUPMATCH(ARGS:0,"例文")
	ELSEIF GROUPMATCH(ARGS:1,"洗脳触手","崩壊")
	
	ELSE
		IF NOWEX:総絶頂
			CALL MESSAGE_BOX,@"「あ゛ーっ♥ お゛っ♥♥」"
			CALL MESSAGE_BOX,@"「ぁっ♥ あああ♥」"
		ELSE
			CALL MESSAGE_BOX,@"「ぅぁ…ぁ…」"
			CALL MESSAGE_BOX,@"「んぁ…ぁっ…」"
