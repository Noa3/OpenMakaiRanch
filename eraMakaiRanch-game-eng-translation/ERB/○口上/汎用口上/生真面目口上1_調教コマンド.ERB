				CALL MESSAGE_BOX,@"「%MASTER_CALL()%♥♥ %MASTER_CALL()%の%PENIS_CALL()%いいっ♥♥\n　%SELF_CALL()%、%ANAL_CALL()%で気持ちよくなる変態にされちゃいましたぁ♥♥♥」"
