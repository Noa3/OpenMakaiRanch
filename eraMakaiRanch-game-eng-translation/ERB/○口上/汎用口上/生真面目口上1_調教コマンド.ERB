CASE "乳首つまみ"
	IF !EXP:(SELECTCOM+1000)
		IF CFLAG:乳牛 || ＃陥落状態／恋慕以上＃ || CFLAG:洗脳
			CALL MESSAGE_BOX,@"「あっ♥ ちくびぃ♥ ちくびこりこり気持ちいいですぅ♥♥♥」"
		ELSEIF ＃陥落状態／屈服以上＃
			CALL MESSAGE_BOX,@"「ひゃぁっ！♥ ち、乳首いじめないでください…♥」"
		ELSE
			CALL MESSAGE_BOX,@"「ひゃぁっ！ ち、乳首はだめっ…♥」"
		ENDIF
		RETURN
	ENDIF
	IF ABL:Ｎ感度 >= 200 || ABL:Ｎ感覚 >= 10
		CALL MESSAGE_BOX,@"「あっ♥ らめぇ♥♥ ちくびよわいのぉ♥♥♥」"
		CALL MESSAGE_BOX,@"「ちくびぃ♥♥ ちくび感じすぎちゃうぅ♥♥♥」"
