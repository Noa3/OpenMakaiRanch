			CALL MESSAGE_BOX,@"「うぁぁっ！ ゴブリンなんかにっ……ぁぁあああああっ！」"
		ELSE
			CALL MESSAGE_BOX,@"「は、離せっ！ なに入れようとしてんだ…っ うぁぁっ！」"
		ENDIF
	
	CASE "処女喪失直後"
