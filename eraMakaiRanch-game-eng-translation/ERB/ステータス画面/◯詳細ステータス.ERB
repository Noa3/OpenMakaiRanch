
;詳細表示　ページ・TARGETを移動できるように変更
;ARGS→元ページ
	;牛舎・調教中
	;@SCHEDULE_PLANに遡ってメインメニュー・全奴隷
@SHOW_STATUS_DETAIL_PLUS(ARGS)
#DIM DYNAMIC PAGE

PAGE_MAX = 7
CLEARLINE LINECOUNT

;あなたはちょい表記違う
IF !TARGET
	PRINTL
	CALL PRINT_PORTRAIT
	CALL PRINT_POST_C
ELSE
	CALL PRINT_IMAGE("ステータス")
	CALL PRINT_PORTRAIT
	CALL PRINT_ALL_STATE
ENDIF
CALL PRINT_NAME_STATUS
PRINTL
CALL PRINT_AFFILIATION_DATA
PRINTL
CALL HALFLINE

;オーナーのみ表示変更
IF !TARGET
	TRYCALLFORM STATUS_DETAIL_MASTER_PAGE_{PAGE}
ELSEIF CSTR:状態／あなたの子 == "成長中"
	PRINTL
	PRINTFORMLC 【Child in the Process of Growing】
ELSE
	TRYCALLFORM STATUS_DETAIL_PAGE_{PAGE}
ENDIF
CALL PRINTL_ALIGN(3)
CALL PRINT_NOW_PAGE(PAGE,1,1)

;調教中の場合TARGET変更不可
IF ARGS != "調教中"
	PRINTLC [300] Prev Chara
	PRINTLC 　
	PRINTL [301] Next Chara
ENDIF
PRINTFORMLC [ 90] Show Original Status：\@ ORIGINAL_STATUS ? ON # OFF \@
PRINTLC 　
PRINTL [ 99] Return
BINPUT
SELECTCASE RESULT
CASE 1 TO PAGE_MAX
	PAGE = RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 89
	PAGE = 0
CASE 90
	INVERTBIT ORIGINAL_STATUS,0
CASE 300
	CALL CHANGE_TARGET_CHARA(0,ARGS)
CASE 301
	CALL CHANGE_TARGET_CHARA(1,ARGS)
CASE 99
	ORIGINAL_STATUS = 0
	RETURN
ENDSELECT
RESTART


