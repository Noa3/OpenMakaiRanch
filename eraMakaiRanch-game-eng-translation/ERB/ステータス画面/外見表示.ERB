
;外見表示
@PRINT_EXTERIOR

PRINTFORM Height：%PRINT_HEIGHT()%【%FIGURE_ENG(CSTR:体型)%】
SIF CSTR:肌の色 != "標準"
	PRINTFORM 【%SKIN_ENG(CSTR:肌の色)%】
IF GETBIT(＃ステータス隠蔽／陰毛＃) && !GETBIT(＃再シャッフル／身体特徴＃) && FLAG:キャラメイク隠蔽有効
	CALL PRINT_WORD_COLOR("【Pubic Hair: Not Yet Determined】","灰")
ELSE
	SELECTCASE CSTR:陰毛
	CASE "標準",""
	CASE "パイパン","剛毛"
		PRINTFORM <%PUBIC_HAIR_ENG(CSTR:陰毛)%> 
	CASEELSE
		PRINTFORM <Pubic Hair：%PUBIC_HAIR_ENG(CSTR:陰毛)%> 
	ENDSELECT
ENDIF
PRINTL

;元々の外見を表示するかを広域変数制御にした
IF !ORIGINAL_STATUS
	CALL PRINT_HAIR_STYLE
	CALL PRINT_EYE_COLOR
ELSE
	CALL PRINT_ORIGINAL_HAIR_STYLE
	CALL PRINT_ORIGINAL_EYE_COLOR
ENDIF
PRINTL



;あなた用
@PRINT_EXTERIOR_PLAYER

PRINTFORM Height：%PRINT_HEIGHT()%【%FIGURE_ENG(CSTR:体型)%】
SIF TALENT:二本角
	PRINT 【Horns】
SIF CSTR:肌の色 != "標準"
	PRINTFORM 【%SKIN_ENG(CSTR:肌の色)%】
SELECTCASE CSTR:陰毛
CASE "標準",""
CASE "パイパン","剛毛"
	PRINTFORM <%CSTR:陰毛%> 
CASEELSE
	PRINTFORM <Pubic Hair：%CSTR:陰毛%> 
ENDSELECT
PRINTL
CALL PRINT_HAIR_STYLE
CALL PRINT_EYE_COLOR
IF TALENT:オトコ
	CALL PRINT_NIPPLE_COLOR
ELSE
	PRINTL
ENDIF
PRINTL



;髪色を色付き表示
@PRINT_HAIR_STYLE

SIF CFLAG:カラーコード／髪
	SETCOLOR CFLAG:カラーコード／髪
PRINTFORM 【%ADD_SPACE(HAIR_CHAR_ENG(CSTR:髪特徴))%%HAIR_COLOR_ENG(CSTR:髪色)% (%HAIR_STYLE_ENG(CSTR:髪型)%)】
RESETCOLOR

@PRINT_HAIR_COLOR_SHORT

SIF CFLAG:カラーコード／髪
	SETCOLOR CFLAG:カラーコード／髪
PRINTFORM 【%ADD_SPACE(HAIR_CHAR_ENG(CSTR:髪特徴))%%HAIR_COLOR_ENG(CSTR:髪色)%】
RESETCOLOR


;目の色を色付き表示
;ARG→カラコン時の簡易版
@PRINT_EYE_COLOR(ARG)

SIF !ARG
	PRINT Eye Color：
SIF CFLAG:カラーコード／右目
	SETCOLOR CFLAG:カラーコード／右目
PRINTFORM %EYE_ENG(CSTR:右目の色)%

;左が黒の時に対応
SIF CSTR:左目の色 != ""
	RESETCOLOR
SIF CFLAG:カラーコード／左目
	SETCOLOR CFLAG:カラーコード／左目
SIF CSTR:左目の色 != ""
	PRINTFORM ／%EYE_ENG(CSTR:左目の色)%
RESETCOLOR

IF CSTR:瞳の形 != ""
	SIF CFLAG:カラーコード／右目
		SETCOLOR CFLAG:カラーコード／右目
	;左右にしようかと思ったけど見づらいだけなのでやめた
	PRINTFORM 【%EYE_ENG(CSTR:瞳の形)%】
ENDIF
;目の特徴を追加
SIF CSTR:目の特徴 != ""
	PRINTFORM 【%EYE_ENG(CSTR:目の特徴)%】
RESETCOLOR




