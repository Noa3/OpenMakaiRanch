;部位開発度の表示
@SHOW_SENSITIVE_LIST
#DIMS KANKAKU
#DIMS KANDO

;STR:Ｂ→3950
STR_REF = 3950
FOR LOCAL,STR_REF,STR_REF +10
	SIF STR:LOCAL == ""
		BREAK
	KANKAKU = %STR:LOCAL%感覚
	KANDO = %STR:LOCAL%感度
	
	;感覚Lv10か感度120%でピンク
	IF ABL:KANKAKU >= 10 || ABL:KANDO >= 120
		SETCOLOR 0xFF70FF
	
	;感度80%以下は水色
	ELSEIF ABL:KANDO <= 80
		SETCOLOR 0x50C0FF
	ENDIF
	
	;感度200%だとハート追加
	IF ABL:KANDO >= 200
		PRINTFORM %STR:LOCAL%Lv{ABL:KANKAKU,2}
		CALL HEARTCB(0xD02830)
		PRINTFORM <{ABL:KANDO,3}\%> 
	ELSE
		PRINTFORM %STR:LOCAL%Lv{ABL:KANKAKU,2} <{ABL:KANDO,3}\%> 
	ENDIF
	RESETCOLOR
NEXT
PRINTL



;EXPバー付き
@SHOW_SENSITIVE_LIST_PLUS

IF ORIGINAL_STATUS
	CALL PRINT_ORIGINAL_SENSITIVE_LIST
	RETURN
ENDIF
CALL SENSITIVE_NEXTEXP_BAR("Ｂ")
CALL SENSITIVE_NEXTEXP_BAR("Ｎ")
CALL SENSITIVE_NEXTEXP_BAR("Ｃ")
CALL SENSITIVE_NEXTEXP_BAR("Ｖ")
CALL SENSITIVE_NEXTEXP_BAR("Ａ")

;絶頂回数はTOSTR固定
PRINTFORML Total Orgasms：%TOSTR(EXP:総絶頂回数,"#,0")% 
PRINTL



;感覚増加までのバー付きで表示
@SENSITIVE_NEXTEXP_BAR(ARGS)
#DIM NEXTLV_EXP
#DIM NOWLV_EXP
#DIM NEXT_EXP
#DIM NOW_EXP
;次レベルまでに必要なEXPから現在EXPで割合を求めようとしたらえらいことになるんだ
#DIMS S_ORGASM
#DIMS S_EXP
#DIMS S_ABL
;もう足りん
#DIMS S_KANDO

S_ORGASM = %ARGS%絶頂回数
S_EXP = %ARGS%経験
S_ABL = %ARGS%感覚
S_KANDO = %ARGS%感度

;表示
CALL PRINT_WORD_COLOR,@"%ABL_ENG(S_ABL)%Lv{ABL:S_ABL,2} <{ABL:S_KANDO,3}\%> ","桃"
PRINTFORM Total Orgasms：{EXP:S_ORGASM,8} 

;LV99ならMAXと表示しておわり
IF ABL:S_ABL == 99
	CALL PRINTL_WORD_COLOR("MAX","桃")
	RETURN
ENDIF

;感覚上昇必要EXP
CALL NEXT_EXP(S_ABL)
NEXTLV_EXP = RESULT
CALL NEXT_EXP(S_ABL,1)
NOWLV_EXP = RESULT

;現在ABLから見てNOWLV_EXPが0、NEXTLV_EXPが100のバーを出す
NEXT_EXP = NEXTLV_EXP -NOWLV_EXP
NOW_EXP = EXP:S_ORGASM -NOWLV_EXP
CALL PRINT_COLORBAR(NOW_EXP,NEXT_EXP,10,BARCOLORSET("紫"),RESULT:1)
PRINTFORM  NEXT：{NEXTLV_EXP} 
;PRINTFORM ,{NOWLV_EXP},{NEXT_EXP},{NOW_EXP}
PRINTL

