;性格素質
@SHOW_TALENT_LIST_PERSONALITY

BR = 0
PRINT Personality ：
IF !MAXARRAY(TALENT,300,500)
	CALL PRINTL_WORD_COLOR("None","灰")
	RETURN
ENDIF
FOR LOCAL,300,500
	SIF !TALENT:LOCAL
		CONTINUE
	CALL BR_PLUS(6,1)
	PRINTFORM 【%TALENTS_ENG(TALENTNAME:LOCAL)%】
NEXT
PRINTL



;嗜好素質・好き
@SHOW_TALENT_LIST_LIKE

;STR:牛→8300
STR_REF = 8300 -500
BR = 0

;-1のとき苦手なので変化
PRINT Preferences ：
IF MAXARRAY(TALENT,500,600) < 1
	CALL PRINTL_WORD_COLOR("None","灰")
	RETURN
ENDIF
FOR LOCAL,500,600
	SIF TALENT:LOCAL < 1
		CONTINUE
	CALL BR_PLUS(6,1)
	SIF BR >= 2
		PRINT ・
	PRINTFORM %PREFERENCES_ENG(STR:(STR_REF +LOCAL))%
NEXT
PRINTL



;嗜好・苦手
@SHOW_TALENT_LIST_DISLIKE

BR = 0
PRINT Dislikes    ：
IF MINARRAY(TALENT,500,600) > -1
	CALL PRINTL_WORD_COLOR("None","灰")
	RETURN
ENDIF
FOR LOCAL,500,600
	SIF TALENT:LOCAL > -1
		CONTINUE
	CALL BR_PLUS(6,1)
	SIF BR >= 2
		PRINT ・
	PRINTFORM %PREFERENCES_ENG(STR:(STR_REF +LOCAL))%
NEXT
PRINTL



;特殊素質の表示
@SHOW_TALENT_LIST_SPECIAL

BR = 0

;ここはなければそもそも表示しない
SIF MAXARRAY(TALENT,600,700) < 1
	RETURN
PRINT Special     ：
FOR LOCAL,600,700
	SIF !TALENT:LOCAL
		CONTINUE
	CALL BR_PLUS(6,1)
	PRINTFORM 【%TALENTS_ENG(TALENTNAME:LOCAL)%】
NEXT
PRINTL



;性素質の表示
@SHOW_TALENT_NASTY

PRINT Sexual      ：
IF MAXARRAY(TALENT,30,50) < 1 && (CFLAG:妊娠日数 <= 9 || CFLAG:妊娠日数 >= 16) && CFLAG:妊娠日数 <= 92
	CALL PRINTL_WORD_COLOR("None","灰")
	RETURN
ENDIF
SETCOLOR 0xFF70FF

;性素質じゃないけどここで表示が一番よさそうなので
SIF (CFLAG:妊娠日数 > 9 && CFLAG:妊娠日数 < 16) || CFLAG:妊娠日数 > 92
	PRINTFORM ❤Pregnant❤ 
FOR LOCAL,30,50
	SIF TALENT:LOCAL
		PRINTFORM ❤%TALENTS_ENG(TALENTNAME:LOCAL)%❤ 
NEXT
RESETCOLOR
PRINTL



