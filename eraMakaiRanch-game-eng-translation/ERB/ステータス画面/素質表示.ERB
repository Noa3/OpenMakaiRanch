
;持っている素質の簡易表示
@SHOW_TALENT_LIST_SIMPLE

BR = 0

;どのカテゴリか特に表示せず並べる
FOR LOCAL,50,700
	SIF !TALENT:LOCAL
		CONTINUE
	
	;シンプル表示のときは好き嫌いは飛ばす
	SIF LOCAL >= 500 && LOCAL < 650
		CONTINUE
	CALL BR_PLUS(5,1)
	PRINTFORM 【%TALENTS_ENG(TALENTNAME:LOCAL)%】
NEXT
PRINTL

;先天素質があれば表示
SIF MAXARRAY(TALENT,30,50) || (CFLAG:妊娠日数 > 9 && CFLAG:妊娠日数 < 16) || CFLAG:妊娠日数 > 92
	CALL SHOW_TALENT_NASTY



;現在の素質を表示
@SHOW_TALENT_LIST

;ランダムキャラメイク中に来たとき隠蔽有効なら隠す
IF GETBIT(＃ステータス隠蔽／素質＃) && !GETBIT(＃再シャッフル／性格素質＃) && FLAG:キャラメイク隠蔽有効
	CALL PRINTL_WORD_COLOR("Qualities unknown","灰")
	RETURN
ENDIF

;6つずつ改行
PRINTL 　《 Qualities 》
CALL SHOW_TALENT_LIST_TRIBE
CALL SHOW_TALENT_LIST_CONSTITUTION
CALL SHOW_TALENT_LIST_PERSONALITY
CALL SHOW_TALENT_LIST_LIKE
CALL SHOW_TALENT_LIST_DISLIKE
CALL SHOW_TALENT_LIST_SPECIAL



;種族系素質の表示
@SHOW_TALENT_LIST_TRIBE

BR = 0
PRINT Racial      ：
IF !MAXARRAY(TALENT,50,100)
	CALL PRINTL_WORD_COLOR("None","灰")
	RETURN
ENDIF
FOR LOCAL,50,100
	SIF !TALENT:LOCAL
		CONTINUE
	CALL BR_PLUS(6,1)
	PRINTFORM 【%TALENTS_ENG(TALENTNAME:LOCAL)%】
NEXT
PRINTL



;体質系素質の表示
;技能もここで出す
@SHOW_TALENT_LIST_CONSTITUTION

BR = 0
PRINT Skills      ：
IF !MAXARRAY(TALENT,100,300)
	CALL PRINTL_WORD_COLOR("None","灰")
	RETURN
ENDIF
FOR LOCAL,100,300
	SIF !TALENT:LOCAL
		CONTINUE
	CALL BR_PLUS(6,1)
	PRINTFORM 【%TALENTS_ENG(TALENTNAME:LOCAL)%】
