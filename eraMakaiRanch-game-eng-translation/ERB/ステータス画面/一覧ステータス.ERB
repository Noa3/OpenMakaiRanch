;霊力残量
@PRINT_REMAINING_EP

SIF !TARGET
	RETURN
IF !BASE:吸収可能霊力
	IF !BASE:霊力
		CALL PRINT_WORD_COLOR(" Fully Drained","灰")
	ELSE
		CALL PRINT_WORD_COLOR(" Can't Extr","灰")
	ENDIF
ELSE
	PRINTFORM  Can Extr：%VALUE_DIGIT(BASE:吸収可能霊力),10%EP
ENDIF



;魔力残量
@PRINT_REMAINING_MP

SIF !TARGET
	RETURN
IF !BASE:吸収可能魔力
	IF !BASE:魔力
		CALL PRINT_WORD_COLOR(" Fully Drained","灰")
	ELSE
		CALL PRINT_WORD_COLOR(" Can't Extr","灰")
	ENDIF
ELSE
	PRINTFORM  Can Extr：%VALUE_DIGIT(BASE:吸収可能魔力),10%MP
ENDIF




