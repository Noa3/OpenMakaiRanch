
;ARGS→飛んできた場所
@TABLE_STATUS(ARGS)

IF CSTR:状態／あなたの子 == "成長中"
	PRINT 　【Infant】
	SIF !GROUPMATCH(FLAG:一覧ステータス切り替え,0,5,8)
		RETURN
ELSE
	CALL TABLE_STATUS_BUST
ENDIF
; EN Code to spread character status over 2 lines
;IF ARGS == "メイン"
PRINTL
PRINT 　     　
;ENDIF
SELECTCASE FLAG:一覧ステータス切り替え
CASE 0
	CALL TABLE_STATUS_BASE(ARGS)
CASE 1
	;PRINTFORM HP：{BASE:体力,4} 
	;CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青緑"),RESULT:1)
	;PRINT  
	CALL PRINT_MILKTANK(1,0,1)
	
CASE 2
	LOCALS = %VALUE_DIGIT(BASE:霊力)%
	LOCALS:1 = %VALUE_DIGIT(MAXBASE:霊力)%
	PRINTFORM EP：%LOCALS,10%／%LOCALS:1,10% 
	CALL PRINT_COLORBAR(BASE:霊力,MAXBASE:霊力,8,BARCOLORSET(""),RESULT:1)
	CALL PRINT_REMAINING_EP
	
CASE 3
	IF MARK:絶頂魔力回復淫紋
		CALL PRINT_MILKTANK(1,1,1)
		CALL PRINT_REMAINING_MP
	ELSEIF MAXBASE:魔力
		LOCALS = %VALUE_DIGIT(BASE:魔力)%
		LOCALS:1 = %VALUE_DIGIT(MAXBASE:魔力)%
		PRINTFORM MP：%LOCALS,10%／%LOCALS:1,10% 
		CALL PRINT_COLORBAR(BASE:魔力,MAXBASE:魔力,8,BARCOLORSET("濃紫"),RESULT:1)
		CALL PRINT_REMAINING_MP
	ELSE
		CALL PRINT_WORD_COLOR("Manaless","灰")
	ENDIF
	
CASE 4
	CALL PRINT_HEIGHT_SHORT
	CALL PRINT_TRIVE
	SIF !TALENT:オトコ
		CALL PRINT_HAIR_STYLE
	
CASE 5
	CALL PRINT_AFFILIATION_DATA
CASE 6
	CALL ABL_WORK_LIST(1)
CASE 7
	;CALL PRINT_MILKTANK(1,0,1)
	CALL PRINT_CAPITULATION_LIST

CASE 8
	SELECTCASE ARGS
	CASE "メイン"
		;メインの時だけスケジュール予定表示
		CALL TABLE_STATUS_AUTO_SCHEDULE
	CASEELSE
		PRINTFORM HP：{BASE:体力,4} 
		CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青緑"),RESULT:1)
		PRINT  
		CALL PRINT_MILKTANK(1,0,1)
	ENDSELECT

ENDSELECT


;メイン0番
@TABLE_STATUS_BASE(ARGS)

PRINTFORM HP：{BASE:体力,4} 
CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青緑"),RESULT:1)
PRINT  

;飛んできた場所で表示変更
SELECTCASE ARGS
CASE "メイン"
	CALL SCHEDULE_PLAN_PRINT(CSTR:スケジュール,1)
	
	;仕事の場合は出さない
	SIF !GROUPMATCH(CSTR:スケジュール,"酪農","調教","事務","調剤","訓練","大浴場掃除")
		CALL PRINT_MILKTANK(1,0,1)
	
CASE "牛舎","風呂","願い事"
	CALL PRINT_MILKTANK(1,0,1)
	
CASE "牛舎入れ","提携先送り"
	;居場所も出す
	CALL PRINT_MILKTANK(1,0,1)
	CALL PRINT_NOW_PLACE(0,1)
	
CASE "調教対象"
	CALL PRINT_MILKTANK(1,0,1)
	IF SAVE_TARGET >= 0
		SIF !TALENT:SAVE_TARGET:オトコ
			CALL ABL_WORK_PRINT(0,"レズっ気")
	ENDIF
	
CASE "料理当番"
	CALL PRINT_MILKTANK(1,0,1)
	PRINTFORM Cooking：Lv{ABL:料理,2}
	
CASE "掃除当番"
	CALL PRINT_MILKTANK(1,0,1)
	PRINTFORM Cleaning：Lv{ABL:掃除,2}
	
CASE "部屋割り変更"
	CALL PRINT_ROOM_NUM
ENDSELECT



;自動スケジュール表示
@TABLE_STATUS_AUTO_SCHEDULE
#DIMS AUTO_SCHEDULE

;自動スケジュール無視の場合はその他
IF CFLAG:牛舎番号
	AUTO_SCHEDULE = ＜牛舎＞
ELSEIF CSTR:居場所 == "体内"
	AUTO_SCHEDULE = ＜体内＞
ELSEIF CFLAG:追跡対象
	AUTO_SCHEDULE = ！未捕獲
ELSE
	;CSTR:自動スケジュール／月→350
	FLAG_REF = 350
	AUTO_SCHEDULE = %CSTR:(DAY:曜日 +FLAG_REF)%
ENDIF

IF GROUPMATCH(AUTO_SCHEDULE,"＜牛舎＞","＜体内＞","！未捕獲")
	CALL PRINT_WORD_COLOR,@"%SCHEDULE_PLAN_ENG(AUTO_SCHEDULE),35,LEFT%","灰"
ELSE
	PRINTFORM %SCHEDULE_PLAN_ENG(AUTO_SCHEDULE),35,LEFT%
ENDIF
CALL SCHEDULE_PLAN_PRINT(CSTR:スケジュール,1)
SIF !GROUPMATCH(CSTR:スケジュール,"酪農","調教","事務","調剤","訓練","大浴場掃除")
	CALL PRINT_MILKTANK(1,0,1)



