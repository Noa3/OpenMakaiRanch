
;ABLのうち仕事に使うとこの表示
;ARG→飛んできた場所　0：ステータス表示　1：一覧ステータス
@ABL_WORK_LIST(ARG)

CALL ABL_WORK_PRINT(ARG,"酪農")
CALL ABL_WORK_PRINT(ARG,"事務")
CALL ABL_WORK_PRINT(ARG,"掃除")
CALL ABL_WORK_PRINT(ARG,"料理")
CALL ABL_WORK_PRINT(ARG,"薬学")
CALL ABL_WORK_PRINT(ARG,"接客")
CALL ABL_WORK_PRINT(ARG,"技巧")
SIF !TALENT:オトコ
	CALL ABL_WORK_PRINT(ARG,"レズっ気")
PRINT 　
SIF !ARG
	PRINTL



;ARG→飛んできた場所　0：ステータス表示　1：一覧ステータス
@ABL_WORK_PRINT(ARG,ARGS)

IF ABL:ARGS >= 10
	SETCOLOR 0x70FFFF
ELSEIF ABL:ARGS >= 5
	SETCOLOR 0x70FF70
ELSEIF ABL:ARGS <= 1
	SETCOLOR 0x606060
ENDIF
IF !ARG
	IF ARGS == "レズっ気"
		PRINTFORM LesbLv{ABL:ARGS,2} 
	ELSE
		PRINTFORM %ABL_SHORT_ENG(ARGS)%{ABL:ARGS, 2, LEFT} 
	ENDIF

;一覧用の短縮表示
ELSE
	; Modified to use ABL_SHORT_ENG
	PRINTFORM %ABL_SHORT_ENG(ARGS)%{ABL:ARGS, 2, LEFT} 

	;SELECTCASE ARGS
	;CASE "酪農"
	;	PRINTFORM 農Lv{ABL:ARGS,2} 
	;CASE "事務"
	;	PRINTFORM 書Lv{ABL:ARGS,2} 
	;CASE "掃除"
	;	PRINTFORM 掃Lv{ABL:ARGS,2} 
	;CASE "料理"
	;	PRINTFORM 食Lv{ABL:ARGS,2} 
	;CASE "薬学"
	;	PRINTFORM 薬Lv{ABL:ARGS,2} 
	;CASE "接客"
	;	PRINTFORM 客Lv{ABL:ARGS,2} 
	;CASE "技巧"
	;	PRINTFORM 技Lv{ABL:ARGS,2} 
	;CASE "レズっ気"
	;	PRINTFORM ♀Lv{ABL:ARGS,2} 
	;ENDSELECT
ENDIF
RESETCOLOR



@ABL_WORK_LIST_PLUS

IF ORIGINAL_STATUS
	CALL ORIGINAL_ABL_WORK_LIST_PLUS
	RETURN
ENDIF
IF TALENT:オトコ
	CALL WORK_NEXTEXP_BAR("酪農",1)
	CALL WORK_NEXTEXP_BAR("事務",1)
	CALL WORK_NEXTEXP_BAR("掃除",1)
	CALL WORK_NEXTEXP_BAR("料理",1)
	CALL WORK_NEXTEXP_BAR("薬学",1)
	CALL WORK_NEXTEXP_BAR("接客",1)
	CALL WORK_NEXTEXP_BAR("技巧",1)
ELSE
	;段々になる
	CALL WORK_NEXTEXP_BAR("酪農")
	CALL WORK_NEXTEXP_BAR("技巧",1,1)
	CALL WORK_NEXTEXP_BAR("事務")
	CALL WORK_NEXTEXP_BAR("母性",1,1)
	CALL WORK_NEXTEXP_BAR("掃除")
	CALL WORK_NEXTEXP_BAR("奉仕精神",1,1)
	CALL WORK_NEXTEXP_BAR("料理")
	CALL WORK_NEXTEXP_BAR("マゾっ気",1,1)
	CALL WORK_NEXTEXP_BAR("薬学")
	CALL WORK_NEXTEXP_BAR("レズっ気",1,1)
	CALL WORK_NEXTEXP_BAR("接客")
ENDIF
CALL MANYL(2)



;ARG→1なら改行
;ARG:1→1なら性系
@WORK_NEXTEXP_BAR(ARGS,ARG:0,ARG:1)
#DIM NEXTLV_EXP
#DIM NOWLV_EXP
#DIM NEXT_EXP
#DIM NOW_EXP
;次レベルまでに必要なEXPから現在EXPで割合を求めようとしたらえらいことになるんだ
#DIMS WORK
#DIMS WORK_EXP

WORK = %ARGS%
WORK_EXP = %WORK%経験

;雑なエラー対策
SELECTCASE WORK
CASE "母性"
	WORK_EXP = 授乳愛情経験
CASE "技巧"
	WORK_EXP = 習得
CASE "奉仕精神"
	WORK_EXP = 奉仕経験
CASE "マゾっ気"
	WORK_EXP = 被虐快楽経験
CASE "レズっ気"
	WORK_EXP = レズ調教経験
ENDSELECT

;性系か違うかでちょっと変える
IF ARG:1
	PRINTFORM %ABL_ENG(WORK), 10%Lv{ABL:WORK, 2} <{EXP:WORK_EXP, 6}EXP> 
ELSE
	PRINTFORM %ABL_ENG(WORK), 10%Lv{ABL:WORK, 2} <{EXP:WORK_EXP, 6}EXP> 
ENDIF

;LV99ならMAXと表示しておわり
IF ABL:ARGS == 99
	SETCOLOR 0x70FF70
	SIF ARG:1
		SETCOLOR 0xFF70FF
	PRINT MAX 　　　　　　　　　
	RESETCOLOR
	SIF ARG:0
		PRINTL
	RETURN
ENDIF

;必要EXP
CALL NEXT_EXP(WORK)
NEXTLV_EXP = RESULT
CALL NEXT_EXP(WORK,1)
NOWLV_EXP = RESULT

;現在ABLから見てNOWLV_EXPが0、NEXTLV_EXPが100のバーを出す
NEXT_EXP = NEXTLV_EXP -NOWLV_EXP
NOW_EXP = EXP:WORK_EXP -NOWLV_EXP
IF ARG:1
	CALL PRINT_COLORBAR(NOW_EXP,NEXT_EXP,10,BARCOLORSET("桃"),RESULT:1)
ELSE
	CALL PRINT_COLORBAR(NOW_EXP,NEXT_EXP,10,BARCOLORSET("緑"),RESULT:1)
ENDIF
;PRINTFORM  NEXT：{NEXTLV_EXP,4,LEFT} 
SIF ARG:0
	PRINTL

