
;個人ステータス表示
@SHOW_STATUS_DETAIL

;画像・ドット絵があるキャラとないキャラで改行がずれるのを防ぐ措置→内部でやった
CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT

;あなたと成長途中の子は別関数→ここに合わせないと表示がずれる
IF !TARGET
	CALL PRINT_ALL_STATE
	CALL SHOW_STATUS_PLAYER
	RETURN
ELSEIF CSTR:状態／あなたの子 == "成長中"
	CALL SHOW_STATUS_CHILD
	RETURN
ELSE
	CALL PRINT_ALL_STATE
ENDIF
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
SIF !CFLAG:非戦闘職 || BASE:レベル > 1
	PRINTFORM Lv{BASE:レベル} 
PRINTL
PRINTFORM 【%HEIGHT_ENG(CSTR:身長)%】Bust Size：%PRINT_BUSTSIZE(ABL:バストサイズ)%
CALL PRINT_BUST_C(1,1,1)
CALL PRINT_VIRGIN_SIMPLE
CALL PRINT_NOW_PURPOSE
PRINTL
CALL ABL_WORK_LIST(0)
CALL SHOW_SENSITIVE_LIST
PRINTL
CALL SHOW_EQUIP

;フラグで変更
SELECTCASE FLAG:選択画面表示形式／素質
CASE 0
	CALL SHOW_TALENT_LIST_SIMPLE
CASE 1
	CALL SHOW_TALENT_LIST
	CALL SHOW_TALENT_NASTY
ENDSELECT

;スキップなら飛ばす
SIF FLAG:選択画面表示形式／刻印 != 2
	CALL SHOW_MARK_LIST(1)
CALL PRINT_CAPITULATION_SIMPLE
PRINTL
CALL PRINT_SOME_DRINK



;あなたのステータス
@SHOW_STATUS_PLAYER

;女あなたならおっぱいも
PRINTFORM %CALLNAME%
IF TALENT:オトコ
	PRINTFORM 【%HEIGHT_ENG(CSTR:身長)%】
ELSE
	PRINTFORM 【%HEIGHT_ENG(CSTR:身長)%】Breast Size：%PRINT_BUSTSIZE(ABL:バストサイズ)%
	CALL PRINT_BUST_C(1,1,1)
ENDIF

;行を合わせる
CALL MANYL(3)
CALL ABL_WORK_LIST(0)
CALL MANYL(2)
CALL SHOW_EQUIP
SELECTCASE FLAG:選択画面表示形式／素質
CASE 0
	CALL SHOW_TALENT_LIST_SIMPLE
CASE 1
	CALL SHOW_TALENT_LIST
	CALL SHOW_TALENT_NASTY
ENDSELECT
PRINTL
PRINTFORM  Spirit Energy：%VALUE_DIGIT(BASE:霊力)% 
CALL PRINT_COLORBAR(BASE:霊力,MAXBASE:霊力,8,BARCOLORSET(""),RESULT:1)
PRINTFORM  Mana：%VALUE_DIGIT(BASE:魔力)% 
CALL PRINT_COLORBAR(BASE:魔力,MAXBASE:魔力,8,BARCOLORSET("濃紫"),RESULT:1)
PRINTFORML  <{BASE:魔力回復割合,2}\%\/day>

IF ITEM:絶倫 && GETBIT(＃有効／絶倫＃)
	CALL PRINT_WORD_COLOR,@"【Peerless】","桃"
ELSE
	PRINTFORM  Vigor：%VALUE_DIGIT(BASE:精力)% 
	CALL PRINT_COLORBAR(BASE:精力,MAXBASE:精力,8,BARCOLORSET(""),RESULT:1)
ENDIF
PRINTL



;子供のステータス
@SHOW_STATUS_CHILD

PRINT 【Beloved Daughter】
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
SIF BASE:レベル > 1
	PRINTFORM Lv{BASE:レベル} 
PRINTL
CALL SHOW_EQUIP

CALL ABL_WORK_LIST(0)
PRINTL
PRINTFORM  Spirit Energy：%TOSTR(BASE:霊力,"#,0")% 
CALL PRINT_COLORBAR(BASE:霊力,MAXBASE:霊力,8,BARCOLORSET(""),RESULT:1)
PRINTFORM  Mana：%TOSTR(BASE:魔力,"#,0")% 
CALL PRINT_COLORBAR(BASE:魔力,MAXBASE:魔力,8,BARCOLORSET("濃紫"),RESULT:1)

PRINTL






