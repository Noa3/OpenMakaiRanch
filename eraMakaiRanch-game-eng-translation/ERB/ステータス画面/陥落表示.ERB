
;現在の陥落状態を表示
;ARG→改行
@PRINT_CAPITULATION(ARG)

IF !BASE:抵抗心
	CALL PRINT_WORD_COLOR,@"Resistance：%PRINT_PALAM_PERCENT(BASE:抵抗心)%　","黄"
ELSE
	CALL PRINT_WORD_COLOR,@"Resistance：%PRINT_PALAM_PERCENT(BASE:抵抗心)%　"
ENDIF

IF !BASE:尊厳
	CALL PRINT_WORD_COLOR,@"Dignity：%PRINT_PALAM_PERCENT(BASE:尊厳)%　","薄青"
ELSE
	CALL PRINT_WORD_COLOR,@"Dignity：%PRINT_PALAM_PERCENT(BASE:尊厳)%　"
ENDIF

IF CFLAG:家畜 || CFLAG:乳牛
	CALL PRINTL_WORD_COLOR,@"Will：%PRINT_PALAM_PERCENT(BASE:精神力)%　","水色"
ELSEIF BASE:精神力 < BASE_LIMITER_HEAL_MIND
	CALL PRINTL_WORD_COLOR,@"Will：%PRINT_PALAM_PERCENT(BASE:精神力)%　","赤"
ELSE
	CALL PRINTL_WORD_COLOR,@"Will：%PRINT_PALAM_PERCENT(BASE:精神力)%　"
ENDIF

IF !BASE:嫌悪感
	CALL PRINT_WORD_COLOR,@"Disgust：%PRINT_PALAM_PERCENT(BASE:嫌悪感)%　","薄青"
ELSE
	CALL PRINT_WORD_COLOR,@"Disgust：%PRINT_PALAM_PERCENT(BASE:嫌悪感)%　"
ENDIF

IF BASE:好感度 >= BASE_FIRST_MAX
	CALL PRINT_WORD_COLOR,@"Favorability：%PRINT_PALAM_PERCENT(BASE:好感度)%　","桃"
ELSE
	CALL PRINT_WORD_COLOR,@"Favorability：%PRINT_PALAM_PERCENT(BASE:好感度)%　"
ENDIF

IF !BASE:理性
	CALL PRINT_WORD_COLOR,@"Rationality：%PRINT_PALAM_PERCENT(BASE:理性)%　","桃"
ELSE
	CALL PRINT_WORD_COLOR,@"Rationality：%PRINT_PALAM_PERCENT(BASE:理性)%　"
ENDIF

IF BASE:乳牛堕ち >= BASE_FIRST_MAX
	CALL PRINTL_WORD_COLOR,@"Fall to Dairy Cow：%PRINT_PALAM_PERCENT(BASE:乳牛堕ち)%　","桃"
ELSE
	CALL PRINTL_WORD_COLOR,@"Fall to Dairy Cow：%PRINT_PALAM_PERCENT(BASE:乳牛堕ち)%　"
ENDIF
SIF ARG
	PRINTL



;簡易版
@PRINT_CAPITULATION_SIMPLE

SIF !TARGET
	RETURN
IF BASE:抵抗心 || BASE:尊厳
	PRINTFORM Resistance：%PRINT_PALAM_PERCENT(BASE:抵抗心)%　
	PRINTFORM Dignity：%PRINT_PALAM_PERCENT(BASE:尊厳)%　
	PRINTFORM Disgust：%PRINT_PALAM_PERCENT(BASE:嫌悪感)%　
	
ELSE
	IF !CFLAG:家畜 && !CFLAG:乳牛
		IF  BASE:精神力 < BASE_LIMITER_HEAL_MIND
			CALL PRINT_WORD_COLOR,@"Will：%PRINT_PALAM_PERCENT(BASE:精神力)%　","赤"
		ELSE
			CALL PRINT_WORD_COLOR,@"Will：%PRINT_PALAM_PERCENT(BASE:精神力)%　"
		ENDIF
	ENDIF
	IF BASE:嫌悪感
		PRINTFORM Disgust：%PRINT_PALAM_PERCENT(BASE:嫌悪感)%　
	ELSE
		IF BASE:好感度 >= BASE_FIRST_MAX
			CALL PRINT_WORD_COLOR,@"Favorability：%PRINT_PALAM_PERCENT(BASE:好感度)%　","桃"
		ELSE
			CALL PRINT_WORD_COLOR,@"Favorability：%PRINT_PALAM_PERCENT(BASE:好感度)%　"
		ENDIF
	ENDIF
	IF BASE:理性
		PRINTFORM Rationality：%PRINT_PALAM_PERCENT(BASE:理性)%　
	ELSE
		IF BASE:乳牛堕ち >= BASE_FIRST_MAX
			CALL PRINTL_WORD_COLOR,@"Fall to Dairy Cow：%PRINT_PALAM_PERCENT(BASE:乳牛堕ち)%　","桃"
		ELSE
			CALL PRINTL_WORD_COLOR,@"Fall to Dairy Cow：%PRINT_PALAM_PERCENT(BASE:乳牛堕ち)%　"
		ENDIF
	ENDIF
ENDIF



;キャラ一覧
@PRINT_CAPITULATION_LIST

SIF !TARGET
	RETURN
IF BASE:抵抗心 || BASE:尊厳
	PRINTFORM Resis%PRINT_PALAM_PERCENT(BASE:抵抗心)%　
	PRINTFORM Digni%PRINT_PALAM_PERCENT(BASE:尊厳)%　
	PRINTFORM Disgt%PRINT_PALAM_PERCENT(BASE:嫌悪感)%　
	
ELSE
	IF !CFLAG:家畜 && !CFLAG:乳牛
		IF  BASE:精神力 < BASE_LIMITER_HEAL_MIND
			CALL PRINT_WORD_COLOR,@"Will%PRINT_PALAM_PERCENT(BASE:精神力)%　","赤"
		ELSE
			CALL PRINT_WORD_COLOR,@"Will%PRINT_PALAM_PERCENT(BASE:精神力)%　"
		ENDIF
	ENDIF
	IF BASE:嫌悪感
		PRINTFORM Disgt%PRINT_PALAM_PERCENT(BASE:嫌悪感)%　
	ELSE
		IF BASE:好感度 >= BASE_FIRST_MAX
			CALL PRINT_WORD_COLOR,@"Favor%PRINT_PALAM_PERCENT(BASE:好感度)%　","桃"
		ELSE
			CALL PRINT_WORD_COLOR,@"Favor%PRINT_PALAM_PERCENT(BASE:好感度)%　"
		ENDIF
	ENDIF
	IF BASE:理性
		PRINTFORM Ratio%PRINT_PALAM_PERCENT(BASE:理性)%　
	ELSE
		IF BASE:乳牛堕ち >= BASE_FIRST_MAX
			CALL PRINT_WORD_COLOR,@"Dairy%PRINT_PALAM_PERCENT(BASE:乳牛堕ち)%　","桃"
		ELSE
			CALL PRINT_WORD_COLOR,@"Dairy%PRINT_PALAM_PERCENT(BASE:乳牛堕ち)%　"
		ENDIF
	ENDIF
ENDIF

