
;霊力・魔力・母乳のバー表示
@PRINT_SOME_DRINK

IF MARK:母乳体質
	IF MARK:絶頂魔力回復淫紋
		CALL PRINT_MILKTANK(1,1,0)
	ELSE
		PRINTFORM Breast Milk Capacity：%TOSTR(BASE:母乳容量,"#,0")%%MILK_COUNTING()% 
		CALL PRINT_MILKTANK(1,1,0,0,1)
		SIF MARK:魔力母乳体質
			PRINTFORM +%VALUE_DIGIT(BASE:魔力)%MP 
	ENDIF
	PRINTL
ELSE
	CALL PRINTL_WORD_COLOR("　Not【Lactating】","灰")
ENDIF

;常に表示
PRINTFORMLC Spirit Energy：%VALUE_DIGIT(BASE:霊力)%／%VALUE_DIGIT(MAXBASE:霊力)%EP 
CALL PRINT_COLORBAR(BASE:霊力,MAXBASE:霊力,8,BARCOLORSET(""),RESULT:1)
CALL PRINT_REMAINING_EP
PRINTL

;それぞれで表示して並びを揃える
IF MARK:絶頂魔力回復淫紋
	CALL PRINTLC_WORD_COLOR("【Mana Recovering Climax Crest】","桃")
	PRINT 　　　　
	CALL PRINT_REMAINING_MP
ELSEIF MAXBASE:魔力
	PRINTFORMLC Mana         ：%VALUE_DIGIT(BASE:魔力)%／%VALUE_DIGIT(MAXBASE:魔力)%MP 
	CALL PRINT_COLORBAR(BASE:魔力,MAXBASE:魔力,8,BARCOLORSET("濃紫"),RESULT:1)
	CALL PRINT_REMAINING_MP
	PRINTFORM  <{BASE:魔力回復割合,2}\%\/day>
ELSE
	CALL PRINT_WORD_COLOR("　Manaless","灰")
ENDIF
PRINTL


