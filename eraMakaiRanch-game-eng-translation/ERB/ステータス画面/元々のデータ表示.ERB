@PRINT_ORIGINAL_AFFILIATION_DATA
#DIMS AFFILIATION

CALL PRINT_TRIVE

;ここで帰る場合
SIF CSTR:初期値／ジョブ == "" && CSTR:初期値／身分 == "" && CSTR:初期値／所属 == ""
	RETURN

AFFILIATION = 【
EXIST = 0
IF CSTR:初期値／所属 != ""
	AFFILIATION += JOB_ENG(CSTR:初期値／所属)
	EXIST = 1
ENDIF
IF CSTR:初期値／身分 != ""
	AFFILIATION += JOB_ENG(CSTR:初期値／身分)
	EXIST = 1
ENDIF
IF CSTR:初期値／ジョブ != ""
	SIF EXIST
		AFFILIATION += "・"
	AFFILIATION += JOB_ENG(CSTR:初期値／ジョブ)
ENDIF
AFFILIATION += "】"
PRINTFORM %AFFILIATION%



