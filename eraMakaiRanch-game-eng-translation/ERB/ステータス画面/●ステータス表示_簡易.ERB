
;簡易ステータス表示
@SHOW_STATUS_SIMPLE

CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT
IF !TARGET
	CALL SHOW_STATUS_PLAYER_SIMPLE
	RETURN
ENDIF
CALL PRINT_ALL_STATE
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
SIF !CFLAG:非戦闘職 || BASE:レベル > 1
	PRINTFORM Lv{BASE:レベル} 
PRINTL
PRINTFORM 【%HEIGHT_ENG(CSTR:身長)%】Breast Size：%PRINT_BUSTSIZE(ABL:バストサイズ)%
CALL PRINT_BUST_C(1,1,1)
CALL PRINT_VIRGIN_SIMPLE
CALL ABL_WORK_LIST(0)
CALL PRINT_SOME_DRINK
PRINTL



;あなたのステータス
@SHOW_STATUS_PLAYER_SIMPLE

CALL PRINT_POST_C
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
SIF BASE:レベル > 1
	PRINTFORM Lv{BASE:レベル} 
PRINTL
CALL ABL_WORK_LIST(0)
PRINTFORM  霊力：%VALUE_DIGIT(BASE:霊力)% 
CALL PRINT_COLORBAR(BASE:霊力,MAXBASE:霊力,8,BARCOLORSET(""),RESULT:1)
PRINTFORM  魔力：%VALUE_DIGIT(BASE:魔力)% 
CALL PRINT_COLORBAR(BASE:魔力,MAXBASE:魔力,8,BARCOLORSET("濃紫"),RESULT:1)
PRINTFORML  <{BASE:魔力回復割合,2}\%\/day>

IF ITEM:絶倫 && GETBIT(＃有効／絶倫＃)
	CALL PRINT_WORD_COLOR,@"【Peerless】","桃"
ELSE
	PRINTFORM  精力：%VALUE_DIGIT(BASE:精力)% 
	CALL PRINT_COLORBAR(BASE:精力,MAXBASE:精力,8,BARCOLORSET(""),RESULT:1)
ENDIF
PRINTL



