
;習得アビリティ表示
@PRINT_LEARNED_ABILITY

;ITEM:汚れ無視→800
ITEM_ID_MIN = 800
ITEM_ID_MAX = 820
PRINTL 　《 General Abilities 》
CALL LEARNED_ABILITY_LIST_COMMON

ITEM_ID_MIN = 820
ITEM_ID_MAX = 840
PRINTL 　《 Breast Torture Abilities 》
CALL LEARNED_ABILITY_LIST_COMMON

ITEM_ID_MIN = 840
ITEM_ID_MAX = 860
PRINTL 　《 Penis Ablities 》
CALL LEARNED_ABILITY_LIST_COMMON



;一覧表示中身
@LEARNED_ABILITY_LIST_COMMON

BR = 0
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	;価格設定されていれば表示
	SIF !ITEMPRICE:LOCAL
		CONTINUE
	
	;最大Lvをチェック
	CALL ABILITY_GET_ONCE_CHECK(LOCAL)
	SIF !ITEM:LOCAL
		SETCOLOR 0x606060
	
	;あなた性別での制限→習得不可なので非表示でいい
	IF TALENT:0:オトコ
		SIF GROUPMATCH(ITEMNAME:LOCAL,"ふたなりちんぽ")
			CONTINUE
	ELSE
		SIF GROUPMATCH(ITEMNAME:LOCAL,"百合手折り")
			CONTINUE
	ENDIF
	IF !FLAG:１コ限定アイテム
		PRINTFORM 【%ITEMS_ENG(ITEMNAME:LOCAL)%Lv{ITEM:LOCAL}】
		
		;MAXのとき表示
		SIF ABILITY_LEVEL_MAX:LOCAL == ITEM:LOCAL && ITEM:LOCAL
			CALL PRINT_WORD_COLOR,@"MAX","黄"
	ELSE
		PRINTFORM 【%ITEMS_ENG(ITEMNAME:LOCAL)%】
	ENDIF
	RESETCOLOR
	CALL BR_PLUS(4)
NEXT
RESETCOLOR
SIF !LINEISEMPTY()
	PRINTL
PRINTL





