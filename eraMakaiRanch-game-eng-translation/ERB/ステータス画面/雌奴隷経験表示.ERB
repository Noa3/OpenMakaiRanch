;ARGS→ABL名
;ARGS:1→EXP名
@SEX_SLAVE_EXP_BAR(ARGS,ARGS:1)
#DIM NEXTLV_EXP
#DIM NOWLV_EXP
#DIM NEXT_EXP
#DIM NOW_EXP

;ここに表示もまとめる
;搾乳中毒・触手中毒は絶頂回数も
SELECTCASE ARGS
CASE "搾乳中毒"
	PRINTFORM %ABL_ENG(ARGS),18,LEFT%Lv{ABL:ARGS,2} 　 Milking Orgasms：{EXP:搾乳絶頂回数,6} <{EXP:(ARGS:1),6}EXP> 
CASE "触手中毒"
	PRINTFORM %ABL_ENG(ARGS),18,LEFT%Lv{ABL:ARGS,2} 　Tentacle Orgasms：{EXP:触手絶頂回数,6} <{EXP:(ARGS:1),6}EXP> 
CASEELSE
	IF !LINEISEMPTY()
		PRINTFORM 　%ABL_ENG(ARGS),18,LEFT%Lv{ABL:ARGS,2} <{EXP:(ARGS:1),6}EXP> 
	ELSE
		SIF ARGS == "母乳濃度"
			PRINT 　
		PRINTFORM %ABL_ENG(ARGS),18,LEFT%Lv{ABL:ARGS,2} <{EXP:(ARGS:1),6}EXP> 
	ENDIF
ENDSELECT

;LV99ならMAXと表示しておわり
IF ABL:ARGS == 99
	CALL PRINT_WORD_COLOR("MAX　　　 ","桃")
	RETURN
	
;母乳濃度は5がMAX
ELSEIF ABL:ARGS == 5 && ARGS == "母乳濃度"
	CALL PRINT_WORD_COLOR("MAX　","桃")
	RETURN
ENDIF

;必要EXP
CALL NEXT_EXP(ARGS)
NEXTLV_EXP = RESULT
CALL NEXT_EXP(ARGS,1)
NOWLV_EXP = RESULT
NEXT_EXP = NEXTLV_EXP -NOWLV_EXP
NOW_EXP = EXP:(ARGS:1) -NOWLV_EXP
CALL PRINT_COLORBAR(NOW_EXP,NEXT_EXP,10,BARCOLORSET("紫"),RESULT:1)

