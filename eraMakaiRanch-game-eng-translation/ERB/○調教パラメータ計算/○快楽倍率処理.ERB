
;快楽値まとめ　ちと多くしすぎたので増加分をほどほどに
;広域変数で処理
@SENSITIVE_FIX_CALC

;技巧補正計算
CALL SENSITIVE_FIX_CALC_TECHNIQUE

;レズっ気補正計算
CALL SENSITIVE_FIX_CALC_LESBIAN

;触手補正計算
CALL SENSITIVE_FIX_CALC_TENTACLE

;感覚と絶頂回数での補正
CALL SENSITIVE_FIX_CALC_EXPERIENCE

;感度に上乗せする補正
CALL SENSITIVE_FIX_CALC_KANDO

;刻印補正
CALL SENSITIVE_FIX_CALC_MARK




;技巧補正計算
@SENSITIVE_FIX_CALC_TECHNIQUE

;TECHNIQUE_FIX:0→合計　1→技巧補正　2→技巧10まで限定の補正
VARSET TECHNIQUE_FIX
IF PLAYER >= 0
	;10まで+3,それ以降+1
	TECHNIQUE_FIX:1 = ABL:PLAYER:技巧 *1
	TECHNIQUE_FIX:2 = LIMIT(ABL:PLAYER:技巧,0,10) *2
ELSE
	TECHNIQUE_FIX:1 = FLAG:補正技巧値 *1
	TECHNIQUE_FIX:2 = LIMIT(FLAG:補正技巧値,0,10) *2
ENDIF
TECHNIQUE_FIX:0 = SUMARRAY(TECHNIQUE_FIX) +100



;レズっ気補正計算
@SENSITIVE_FIX_CALC_LESBIAN

;LESBIAN_FIX:0→合計　1→調教者ABL補正　2→Lv10まで　3→調教者MARK補正
;4→調教対象ABL補正　5→Lv10まで
;6→調教対象MARK補正：まだなし
VARSET LESBIAN_FIX
IF PLAYER >= 0
	IF !TALENT:PLAYER:オトコ && !TALENT:オトコ
		LESBIAN_FIX:1 = ABL:PLAYER:レズっ気 *1
		LESBIAN_FIX:2 = LIMIT(ABL:PLAYER:レズっ気,0,10) *2
		LESBIAN_FIX:3 = MARK:PLAYER:レズ中毒 *10 +MARK:PLAYER:レズ依存 *10 +MARK:PLAYER:百合姫 *20
		LESBIAN_FIX:4 = ABL:レズっ気 *1
		LESBIAN_FIX:5 = LIMIT(ABL:レズっ気,0,10) *2
	ENDIF
ENDIF
LESBIAN_FIX:0 = SUMARRAY(LESBIAN_FIX) +100



;触手補正計算
@SENSITIVE_FIX_CALC_TENTACLE

;体内凌辱とかしてるとあっという間に上がるので5ずつ→3ずつ→1ずつの弱めにする
;TENTACLE_FIX：0→合計　1→触手中毒補正　2→触手中毒20まで限定の補正　3→触手中毒10まで限定の補正　4→刻印補正
VARSET TENTACLE_FIX
TENTACLE_FIX:1 = ABL:触手中毒 *1
TENTACLE_FIX:2 = LIMIT(ABL:触手中毒,0,20) *2
TENTACLE_FIX:3 = LIMIT(ABL:触手中毒,0,10) *2
TENTACLE_FIX:4 = MARK:触手中毒 *10 +MARK:触手の虜 *20 +MARK:触手の苗床 *30
TENTACLE_FIX:0 = SUMARRAY(TENTACLE_FIX) +100



;感覚と絶頂回数での補正
@SENSITIVE_FIX_CALC_EXPERIENCE

;EX:Ａ絶頂回数→0
;ABL:Ａ感覚→0
;EXPERIENCE_FIX:0→Ａ　以下ＢＣＶＮ
;FIX:0→感覚補正　1→感覚10まで限定の補正
;2→現調教の部位絶頂回数補正（100まで）　3→現調教の総絶頂回数補正（ルートして+100%まで）
VARSET EXPERIENCE_FIX
FOR LOCAL,0,5
	FIX = ABL:LOCAL *2
	FIX:1 = LIMIT(ABL:LOCAL,0,10) *3
	FIX:2 = LIMIT(EX:LOCAL,0,100)
	FIX:3 = LIMIT(SQRT (EX:総絶頂 +1),0,100)
	EXPERIENCE_FIX:LOCAL = 100 +FIX +FIX:1 +FIX:2 +FIX:3
NEXT

