
;SOURCE_UP後の処理
@SOURCE_UP_AFTER_COMMON

;搾乳メッセージ→抽出メッセージ→射精メッセージの順
;全部なければ絶頂メッセージ（した場合）
MESSAGE_EXIST = 0
CALL TRAIN_LACTATION_RESULT
CALL PRINT_EJACULATION_MESSAGE
CALL PRINT_T_EJACULATION_MESSAGE

;精液ボテメッセージ
SIF SOURCE:膣内射精経験 || SOURCE:尻穴射精経験 || SOURCE:精飲経験
	CALL PRINT_B_EJACULATION_MESSAGE
CALL SOURCE_UP_AFTER_BR_FIX
CALL PRINT_ECSTASY_MESSAGE

;絶頂したとき愛液追加→再度汚れ交換
IF NOWEX:総絶頂
	CALL SET_STAIN_TARGET("膣","愛液")

	;SOURCE:ペニス引き抜き　の付与自体ではTFLAG:Ｖ挿入　をリセットしない
	SIF GETBIT(＃Ｐ使用／Ｖ挿入＃)
		CALL SWAP_STAIN("膣","ペニス")

	;コマンド実行時の汚れ交換をもう1度行う
	CALL COMMAND_STAIN_PLUS
ENDIF
CALL SOURCE_UP_AFTER_HP_MESSAGE
CALL SOURCE_UP_AFTER_SP_MESSAGE
SIF !LINEISEMPTY()
	PRINTL



;噴乳時のメッセージ、ドレイン処理
@TRAIN_LACTATION_RESULT

SIF !NOWEX:噴乳
	RETURN
CALL TRAIN_LACTATION_MESSAGE
CALL TRAIN_ENERGY_DRAIN_MESSAGE
CALL PRINT_LACTATION_VOL

;霊力・魔力ドレイン整理
CALL SLAVE_ENERGY_DRAIN_CALC

;装備の整理
CALL NIPPLE_SUCKER_ADJUST
CALL HANDY_ENERGY_DRAIN_ADJUST
MESSAGE_EXIST ++



;コマンド実行後処理
@COMMAND_AFTER_COMMON

;あなた調教中以外はおわり
SIF !TFLAG:調教中
	RETURN
PRINTW
CALL PRINT_EXP_MESSAGE

;4部位以上で絶頂+中に射精されている場合快楽刻印追加
EXIST = 0
FOR LOCAL,0,5
	SIF NOWEX:LOCAL
		EXIST ++
NEXT
SIF EXIST >= 4 && !MARK:快楽刻印 && (SOURCE:膣内射精経験 || SOURCE:尻穴射精経験 || SOURCE:乳内射精経験)
	CALL MARK_GET_PLEASURE

;精力0でペニス引き抜きON
SIF !BASE:0:精力
	SOURCE:ペニス引き抜き = 1

;ペニス引き抜き判定でリセット
SIF SOURCE:ペニス引き抜き
	CALL PENIS_RESET

;コンドーム装備中に射精したら外す
SIF TEQUIP:0:コンドーム && SOURCE:射精回数
	CALL CONDOM_REMOVE
CALL TRAIN_STAIN_SETTING
CALL KOJO_PRINT("調教コマンド","実行後")



;おっぱい装備整理
;200cc出る場合乳首吸引器が外れる
@NIPPLE_SUCKER_ADJUST

SIF NOWEX:噴乳 < 200 || !TEQUIP:乳首吸引器
	RETURN
TFLAG:Ｎ装備 = 0
TEQUIP:乳首吸引器 = 0
CALL NIPPLE_SUCKER_ADJUST_MESSAGE



;搾れるものがないなら抽出装置は外す
@HANDY_ENERGY_DRAIN_ADJUST

SIF !TEQUIP:小型霊力抽出装置 || BASE:霊力 || BASE:魔力
	RETURN
TEQUIP:小型霊力抽出装置 = 0
CALL HANDY_ENERGY_DRAIN_ADJUST_MESSAGE
CALL KOJO_PRINT("調教コマンド","搾乳器取り外し")



;コンドーム外し
@CONDOM_REMOVE

CALL CONDOM_REMOVE_MESSAGE
TEQUIP:0:コンドーム = 0
STAIN:0:ペニス = STAIN:0:ゴム中ペニス
CALL SET_STAIN_PLAYER("ペニス","精液")


