	ELSE
		TFLAG:ペニスサイズ差補正 = LIMIT(FIX:2 * FIX:2 * (-1),-500,0)
	ENDIF
	IF DAMAGE > -16 && DAMAGE < 1 && FIX:3 > 0 && FIX:5
		DAMAGE += 15
		ABL:Ａ拡張 += (RAND:20 < DAMAGE / 2 + 1 ? 1 # 0)
	ENDIF
	SIF ABL:PLAYER:ペニスサイズ > ABL:PLAYER:初期値／ペニスサイズ
		SOURCE:Ａ快楽／あなた責め = SOURCE:Ａ快楽／あなた責め * ABL:PLAYER:ペニスサイズ / ABL:PLAYER:初期値／ペニスサイズ
	SOURCE:Ａ快楽／あなた責め = SOURCE:Ａ快楽／あなた責め * (1000 + TFLAG:ペニスサイズ差補正) / 1000
ELSEIF DAMAGE > 5
	LOCAL = MIN(ABL:初期値／Ａサイズ * 3 - ABL:Ａサイズ - ABL:Ａ拡張,DAMAGE - 5)
