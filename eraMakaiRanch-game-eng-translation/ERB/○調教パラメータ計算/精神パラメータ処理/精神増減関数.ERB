
;BASE減少処理
;ARGS→BASE名
;ARG→元ダメージ用数値
;ARG:1→補正のかかるしきい値
@MIND_BASE_MINUS(ARGS,ARG,ARG:1)

CALL MIND_BASE_CALC_FIX(ARGS,ARG /20,ARG:1)
DAMAGE = RESULT
SIF !BASE:ARGS || CFLAG:崩壊 || CFLAG:洗脳 || !DAMAGE
	RETURN

;BASEにより個別補正
SELECTCASE ARGS
CASE "嫌悪感"
	;あなた調教中でないなら嫌悪感を補正後に1/4
	SIF !TFLAG:調教中 && !TFLAG:スケジュール外Ｈ
		DAMAGE /= 4

CASE "精神力"
	;30%以下なら根性値
	SIF BASE:精神力 < BASE_ENDURE_MIND
		DAMAGE /= 2
	
	;調教外で体力元々ある／気力ある→リミッターかける
	IF (TFLAG:調教前体力 && !TFLAG:調教中) || BASE:気力
		IF BASE:精神力 -DAMAGE < BASE_LIMITER_HEAL_MIND
			CALL MIND_MINUS_LIMITER(ARGS)
			RETURN
		ENDIF
	ENDIF
ENDSELECT
;最初だけ<付け　閉じる側が色リセット後なのでこちらも合わせた
SIF !SOURCE:精神パラメータ増減済み
	PRINT < 
CALL MIND_BASE_PRINT_COLOR(ARGS)
BASE:ARGS = LIMIT(BASE:ARGS -DAMAGE,0,MAXBASE:ARGS)

IF !CFLAG:牛舎番号
	PRINTFORM %BASE_ENG(ARGS)%-{DAMAGE} → %PRINT_PALAM_PERCENT(BASE:ARGS)% 
ELSE
	PRINTFORM %BASE_ENG(ARGS)%-{DAMAGE} 
ENDIF

;0になったら表示
SIF !BASE:ARGS
	CALL PRINT_WORD_COLOR,@"%BASE_ENG(ARGS)%0\% ","黄"
RESETCOLOR
SOURCE:精神パラメータ増減済み = 1



;精神パラメータのしきい値含めた補正
;ARGS→BASE名
;ARG→DAMAGE／LOVE
;ARG:1→補正のかかるしきい値
@MIND_BASE_CALC_FIX(ARGS,ARG,ARG:1)
#DIM MIND_BASE

MIND_BASE = ARG

;コマンド前に気力がある+反抗心など→-300
;嫌悪感・好感度は除く
SIF SOURCE:コマンド前気力 && !GROUPMATCH(ARGS,"","嫌悪感","好感度")
	MIND_BASE -= MIND_SP_GUARD

;しきい値超えたら1/5,しきい値の10倍上限
SIF MIND_BASE > ARG:1
	MIND_BASE = ARG:1 +(MIND_BASE -ARG:1) /5
MIND_BASE = LIMIT(MIND_BASE,0,ARG:1 *10)
RETURN MIND_BASE



;色付け
;ARGS→BASE名
;ARG→1:増加
@MIND_BASE_PRINT_COLOR(ARGS,ARG)

;増加／減少で色変え
IF ARG
	SELECTCASE ARGS
	CASE "抵抗心","尊厳","嫌悪感","理性","精神力"
		SETCOLOR 0x70FF70
	CASE "好感度","乳牛堕ち"
		SETCOLOR 0xFF70FF
	ENDSELECT
ELSE
	SELECTCASE ARGS
	CASE "抵抗心","尊厳","嫌悪感","好感度","乳牛堕ち"
		SETCOLOR 0x70FF70
	CASE "精神力"
		;限界近いとき赤
		IF BASE:ARGS < BASE_LIMITER_HEAL_MIND
			SETCOLOR 0xE02020
		ELSE
			SETCOLOR 0x70FF70
		ENDIF
	CASE "理性"
		SETCOLOR 0xFF70FF
	ENDSELECT
ENDIF



;リミッターかけた精神力減少
@MIND_MINUS_LIMITER(ARGS)

SIF !SOURCE:精神パラメータ増減済み
	PRINT < 
SIF BASE:精神力 > BASE_LIMITER_HEAL_MIND
	BASE:精神力 = BASE_LIMITER_HEAL_MIND
SIF BASE:精神力 < BASE_LIMITER_HEAL_MIND
	SETCOLOR 0xE02020
IF !CFLAG:牛舎番号
	PRINTFORM %BASE_ENG(ARGS)%-{DAMAGE} → %PRINT_PALAM_PERCENT(BASE:ARGS)% 
ELSE
	PRINTFORM %BASE_ENG(ARGS)%-{DAMAGE} 
ENDIF
CALL PRINT_WORD_COLOR("Decrease Prevented ","水色")
SOURCE:精神パラメータ増減済み = 1





;BASE増加処理
;ARGS→BASE名
;ARG→元ダメージ
;ARG:1→補正のかかるしきい値
@MIND_BASE_PLUS(ARGS,ARG,ARG:1)
#DIM DISP_LIMIT

CALL MIND_BASE_CALC_FIX(ARGS,ARG /30,ARG:1)
LOVE = RESULT
SIF CFLAG:崩壊 || CFLAG:洗脳 || !LOVE
	RETURN

;BASEにより個別補正
SELECTCASE ARGS
CASE "乳牛堕ち"
	;乳牛堕ちが80%以上は根性値
	SIF BASE:乳牛堕ち > BASE_ENDURE_COW
		LOVE /= 2
		
	;100%以上なら1/4　計1/8
	SIF BASE:乳牛堕ち >= BASE_FIRST_MAX
		LOVE /= 4
ENDSELECT

;上限後表示
DISP_LIMIT = 0
SELECTCASE ARGS
CASE "好感度"
	SIF !GETBIT(＃上限到達後表示／好感度＃) && BASE:好感度 >= BASE_FALLINLOVE_FAV
		DISP_LIMIT = 1
CASE "乳牛堕ち"
	SIF !GETBIT(＃上限到達後表示／乳牛堕ち＃) && BASE:乳牛堕ち >= BASE_FIRST_MAX
		DISP_LIMIT = 1
ENDSELECT
BASE:ARGS = LIMIT(BASE:ARGS +LOVE,0,MAXBASE:ARGS)
SIF DISP_LIMIT
	RETURN

SIF !SOURCE:精神パラメータ増減済み
	PRINT < 
CALL MIND_BASE_PRINT_COLOR(ARGS,1)
IF !CFLAG:牛舎番号
	PRINTFORM %BASE_ENG(ARGS)%+{LOVE} → %PRINT_PALAM_PERCENT(BASE:ARGS)% 
ELSE
	PRINTFORM %BASE_ENG(ARGS)%+{LOVE} 
ENDIF
SELECTCASE ARGS
CASE "好感度"
	SIF BASE:好感度 == MAXBASE:好感度 && !＃陥落状態／隷属＃
		CALL PRINT_WORD_COLOR,@"%BASE_ENG(ARGS)% MAX ","黄"
CASE "乳牛堕ち"
	SIF BASE:乳牛堕ち == MAXBASE:乳牛堕ち && !CFLAG:乳牛
		CALL PRINT_WORD_COLOR,@"%BASE_ENG(ARGS)% MAX ","黄"
ENDSELECT
RESETCOLOR
SOURCE:精神パラメータ増減済み = 1



;BASE直接減少処理
;ARGS→BASE名
;ARG→ダメージ
@MIND_BASE_DIRECT_MINUS(ARGS,ARG)

SIF !BASE:ARGS || CFLAG:崩壊 || CFLAG:洗脳 || ARG <= 0
	RETURN
DAMAGE = ARG
SIF !SOURCE:精神パラメータ増減済み
	PRINT < 
CALL MIND_BASE_PRINT_COLOR(ARGS)
BASE:ARGS = LIMIT(BASE:ARGS -DAMAGE,0,MAXBASE:ARGS)
IF !CFLAG:牛舎番号
	PRINTFORM %BASE_ENG(ARGS)%-{DAMAGE} → %PRINT_PALAM_PERCENT(BASE:ARGS)% 
ELSE
	PRINTFORM %BASE_ENG(ARGS)%-{DAMAGE} 
ENDIF
SIF !BASE:ARGS
	CALL PRINT_WORD_COLOR,@"%BASE_ENG(ARGS)% 0\% ","黄"
RESETCOLOR
SOURCE:精神パラメータ増減済み = 1



;BASE直接増加処理
;ARGS→BASE名
;ARG→元ダメージ
@MIND_BASE_DIRECT_PLUS(ARGS,ARG)

SIF BASE:ARGS == MAXBASE:ARGS || CFLAG:崩壊 || CFLAG:洗脳
	RETURN
LOVE = ARG
SIF !SOURCE:精神パラメータ増減済み
	PRINT < 
CALL MIND_BASE_PRINT_COLOR(ARGS,1)
BASE:ARGS = LIMIT(BASE:ARGS +LOVE,0,MAXBASE:ARGS)
IF !CFLAG:牛舎番号
	PRINTFORM %BASE_ENG(ARGS)%+{LOVE} → %PRINT_PALAM_PERCENT(BASE:ARGS)% 
ELSE
	PRINTFORM %BASE_ENG(ARGS)%+{LOVE} 
ENDIF
SELECTCASE ARGS
CASE "好感度"
	SIF BASE:好感度 == MAXBASE:好感度 && !＃陥落状態／隷属＃
		CALL PRINT_WORD_COLOR,@"%BASE_ENG(ARGS)% MAX ","黄"
CASE "乳牛堕ち"
	SIF BASE:乳牛堕ち == MAXBASE:乳牛堕ち && !CFLAG:乳牛
		CALL PRINT_WORD_COLOR,@"%BASE_ENG(ARGS)% MAX ","黄"
ENDSELECT
RESETCOLOR
SOURCE:精神パラメータ増減済み = 1



