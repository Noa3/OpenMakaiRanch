
;⑤TALENTなどで倍率計算して乗算
@MIND_EXP_MULTIPLY

CALL MIND_EXP_MULTIPLY_CATTLE
CALL MIND_EXP_MULTIPLY_NASTY
CALL MIND_EXP_MULTIPLY_OBEDIENCE
CALL MIND_EXP_MULTIPLY_SURRENDER
CALL MIND_EXP_MULTIPLY_PAIN
CALL MIND_EXP_MULTIPLY_FEAR
CALL MIND_EXP_MULTIPLY_UNPLEASANT
CALL MIND_EXP_MULTIPLY_HATE
CALL MIND_EXP_MULTIPLY_DESPAIR

;崩壊なら失意以外の感情全て0
SIF !CFLAG:崩壊
	RETURN
FOR LOCAL,30,40
	SIF SOURCENAME:LOCAL != "失意"
		CONTINUE
	SOURCE:LOCAL = 0
NEXT
SOURCE:被虐快楽経験 = 0
SOURCE:レズ調教経験 = 0
SOURCE:習得 = 0
SOURCE:授乳愛情経験 = 0



;乳牛
@MIND_EXP_MULTIPLY_CATTLE

SIF CFLAG:乳牛
	TIMES SOURCE:乳牛,1.30
SIF MARK:淫乳
	TIMES SOURCE:乳牛,1.30

;搾乳器なら*1.5
SIF TFLAG:搾乳器
	TIMES SOURCE:乳牛,1.50



;淫欲
@MIND_EXP_MULTIPLY_NASTY

;0にしてから共通通し
FIX = 0
CALL MIND_CALC_MULTIPLY_COMMONFIX

;+-入れ替え
FIX *= -1

;+の場合は半減
SIF FIX > 0
	FIX /= 2

;なんか少ないので+感情は+50
FIX += 150
SIF TALENT:幼稚
	FIX += 20
SIF TALENT:解放
	FIX += 10
SIF TALENT:快感に素直
	FIX += 20
SIF MARK:快楽刻印
	FIX += 30
SIF MARK:淫紋
	FIX += 50
	
SIF TALENT:快感の否定
	FIX -= 20
IF !BASE:好感度
	SIF TALENT:気丈
		FIX -= 20
	SIF TALENT:自制心
		FIX -= 10
	SIF TALENT:無関心
		FIX -= 10
	SIF TALENT:清楚
		FIX -= 10
	SIF TALENT:気品
		FIX -= 10
ENDIF
SIF MARK:淫核 && SOURCE:Ｃ快楽
	FIX += 30
FIX = LIMIT(FIX,10,300)
SOURCE:淫欲 = SOURCE:淫欲 *FIX /100



;恭順
@MIND_EXP_MULTIPLY_OBEDIENCE

FIX = 0
CALL MIND_CALC_MULTIPLY_COMMONFIX
FIX *= -1
SIF FIX > 0
	FIX /= 2
FIX += 150

;気力0%→-30
SIF !BASE:気力
	FIX -= 30
SIF TALENT:清楚
	FIX += 10
SIF TALENT:チョロイン && !PLAYER
	FIX += 100
SIF MARK:快楽刻印
	FIX += 10
SIF MARK:淫紋
	FIX += 20

IF !BASE:好感度
	SIF BASE:理性
		FIX -= 30
	SIF TALENT:快感の否定
		FIX -= 20
	SIF TALENT:気丈
		FIX -= 20
	SIF TALENT:プライド高い
		FIX -= 10
	SIF TALENT:高慢
		FIX -= 20
	SIF TALENT:反抗的
		FIX -= 20
ENDIF
SIF TALENT:自制心
	FIX -= 10
SIF TALENT:無関心
	FIX -= 10
SIF TALENT:生意気
	FIX -= 10
SIF BASE:抵抗心
	FIX -= 20
SIF BASE:嫌悪感
	FIX -= 20
FIX = LIMIT(FIX,10,300)
SOURCE:恭順 = SOURCE:恭順 *FIX /100

;苦痛・恐怖刻印があると恭順1/5
SIF MARK:苦痛刻印
	SOURCE:恭順 /= 5
SIF MARK:恐怖刻印
	SOURCE:恭順 /= 5

;あなた調教以外なら恭順0
SIF PLAYER
	SOURCE:恭順 = 0



;屈服
@MIND_EXP_MULTIPLY_SURRENDER

FIX = 0
CALL MIND_CALC_MULTIPLY_COMMONFIX
FIX *= -1
SIF FIX > 0
	FIX /= 2
FIX += 150

;TALENT:処女結界破壊→150
FOR LOCAL,150,200
	SIF TALENT:LOCAL
		FIX += 20
NEXT

;体力0→+50
SIF !BASE:体力
	FIX += 50

;気力0→+50
SIF !BASE:気力
	FIX += 50

SIF MARK:屈服刻印
	FIX += 30
SIF MARK:苦痛刻印
	FIX += 20
SIF MARK:恐怖刻印
	FIX += 20
SIF MARK:絶望刻印
	FIX += 10
SIF MARK:淫紋
	FIX += 20

IF !BASE:好感度
	SIF TALENT:快感の否定
		FIX -= 20
	SIF TALENT:気丈
		FIX -= 20
ENDIF
SIF TALENT:自制心
	FIX -= 10
SIF TALENT:無関心
	FIX -= 10
FIX = LIMIT(FIX,10,300)
SOURCE:屈服 = SOURCE:屈服 *FIX /100



;苦痛
@MIND_EXP_MULTIPLY_PAIN

FIX = 100
CALL MIND_CALC_MULTIPLY_COMMONFIX

;気力0%→+30
SIF !BASE:気力
	FIX += 30
SIF TALENT:幼稚
	FIX += 50
SIF TALENT:痛みに弱い
	FIX += 30
SIF TALENT:臆病
	FIX += 20
	
SIF TALENT:痛みに強い
	FIX -= 30
SIF TALENT:感情乏しい
	FIX -= 20
SIF TALENT:気丈
	FIX -= 20
SIF CFLAG:上位種族
	FIX -= 20
FIX = LIMIT(FIX,10,300)
SOURCE:苦痛 = SOURCE:苦痛 *FIX /100



;恐怖
@MIND_EXP_MULTIPLY_FEAR

FIX = 100
CALL MIND_CALC_MULTIPLY_COMMONFIX
SIF TALENT:幼稚
	FIX += 20
SIF TALENT:臆病
	FIX += 50
SIF TALENT:弱気
	FIX += 20
SIF TALENT:悲観的
	FIX += 30
	
SIF TALENT:感情乏しい
	FIX -= 30
SIF TALENT:楽観的
	FIX -= 30
SIF TALENT:気丈
	FIX -= 20
SIF TALENT:粗野
	FIX -= 20
SIF TALENT:気品
	FIX -= 10
SIF TALENT:正義感
	FIX -= 30
FIX = LIMIT(FIX,10,300)
SOURCE:恐怖 = SOURCE:恐怖 *FIX /100

;乳牛→恐怖1/5
SIF CFLAG:乳牛
	SOURCE:恐怖 /= 5



;不快
@MIND_EXP_MULTIPLY_UNPLEASANT

FIX = 100
CALL MIND_CALC_MULTIPLY_COMMONFIX

SIF TALENT:感情乏しい
	FIX -= 30
FIX = LIMIT(FIX,10,300)
SOURCE:不快 = SOURCE:不快 *FIX /100



;反感
@MIND_EXP_MULTIPLY_HATE

SIF TFLAG:媚薬使用中
	TIMES SOURCE:反感,2.00
FIX = 100
CALL MIND_CALC_MULTIPLY_COMMONFIX

;恋慕でHP0でない→-50
SIF ＃陥落状態／恋慕以上＃ && BASE:体力
	FIX -= 50
FIX -= EX:総絶頂
SIF TALENT:生意気
	FIX += 20
SIF TALENT:反抗的
	FIX += 30
SIF TALENT:気丈
	FIX += 30
SIF TALENT:プライド高い
	FIX += 30
SIF TALENT:高慢
	FIX += 50
	
SIF TALENT:臆病
	FIX -= 10
SIF TALENT:大人しい
	FIX -= 10
SIF TALENT:素直
	FIX -= 20
SIF TALENT:幼稚
	FIX -= 10
SIF MARK:奉仕中毒
	FIX -= 30
FIX = LIMIT(FIX,10,300)
SOURCE:反感 = SOURCE:反感 *FIX /100

;隷属or乳牛→反感・失意を0
SIF ＃陥落状態／隷属＃ || CFLAG:乳牛
	SOURCE:反感 = 0



;失意
@MIND_EXP_MULTIPLY_DESPAIR

FIX = 100
CALL MIND_CALC_MULTIPLY_COMMONFIX

;尊厳50%以上→-30
SIF BASE:尊厳 >= 5000
	FIX -= 30
	
;霊力0で戦闘職→+50
SIF !BASE:霊力 && !CFLAG:非戦闘職
	FIX += 50
	
;体力0なら+50
SIF !BASE:体力
	FIX += 50
SIF TFLAG:搾乳責め
	FIX -= (ABL:搾乳中毒 *2)
SIF TALENT:弱気
	FIX += 10
SIF TALENT:臆病
	FIX += 30
SIF TALENT:悲観的
	FIX += 20
SIF TALENT:卑屈
	FIX += 50
SIF TALENT:貞操観念 && !TALENT:処女
	FIX += 100
SIF MARK:処女結界破壊 && !CFLAG:上位種族
	FIX += 100
	
SIF TALENT:幼稚
	FIX -= 30
SIF TALENT:気品
	FIX -= 20
SIF TALENT:楽観的
	FIX -= 20
SIF TALENT:気丈
	FIX -= 30
	
;魔力枷かつ霊力があれば半減
SIF EQUIP:魔力枷 && BASE:霊力
	FIX /= 2
FIX = LIMIT(FIX,10,300)
SOURCE:失意 = SOURCE:失意 *FIX /100

;恋慕で半減
SIF ＃陥落状態／恋慕以上＃ && BASE:体力
	SOURCE:失意 /= 2

;隷属・乳牛・気力ありなら0
SIF ＃陥落状態／隷属＃ || CFLAG:乳牛 || BASE:気力
	SOURCE:失意 = 0




