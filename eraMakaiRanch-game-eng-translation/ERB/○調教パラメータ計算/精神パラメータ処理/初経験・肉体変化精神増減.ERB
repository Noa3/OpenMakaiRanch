
;処女喪失などでの増減　あなた調教以外からも来たいので関数化
@LOST_VARGIN_MIND_DAMAGE

SIF CFLAG:崩壊 || CFLAG:洗脳
	RETURN
SIF SOURCE:処女喪失 && !TALENT:貞操無頓着
	CALL V_LOST_VARGIN_MIND_DAMAGE
SIF SOURCE:初キス && !TALENT:貞操無頓着
	CALL FIRST_KISS_MIND_DAMAGE
SIF SOURCE:母乳体質化
	CALL LACTATION_MIND_DAMAGE
SIF SOURCE:膨乳段階
	CALL BUSTUP_MIND_DAMAGE
SIF SOURCE:処女結界破壊 && !CFLAG:上位種族
	CALL BREAK_VIRGIN_BARRIER_MIND_DAMAGE

;SOURCE:処女喪失→300
VARSET SOURCE,0,300,310



;処女喪失時のパラメータ増減
@V_LOST_VARGIN_MIND_DAMAGE

;地の文から
CALL V_LOST_VARGIN_MIND_DAMAGE_MESSAGE
IF V_PENIS == CALLNAME:0
	IF TALENT:性知識乏しい
		;痛みが強いかで変更
		IF SOURCE:Ｖ痛み >= 5000
			CALL MIND_BASE_DIRECT_MINUS("好感度",1000)
		ELSE
			CALL MIND_BASE_DIRECT_PLUS("好感度",1000)
		ENDIF
	ELSEIF ＃陥落状態／恋慕以上＃ || CFLAG:乳牛
		LOVE = 1000
		SIF TALENT:乙女心
			TIMES LOVE,2.00
		CALL MIND_BASE_DIRECT_PLUS("好感度",LOVE)
	ELSEIF (＃陥落状態／陥落以上＃ || TALENT:チョロイン) && !TALENT:貞操観念
		LOVE = 1000
		SIF TALENT:乙女心
			TIMES LOVE,2.00
		CALL MIND_BASE_DIRECT_PLUS("好感度",LOVE)
	ELSE
		GOTO MIND_DAMAGE_COMMON
	ENDIF
ELSE
	$MIND_DAMAGE_COMMON
	IF TALENT:貞操観念
		DAMAGE = 2000
	ELSE
		DAMAGE = 1000
	ENDIF
	SIF TALENT:乙女心
		TIMES DAMAGE,1.50
	SIF ＃陥落状態／陥落以上＃
		TIMES DAMAGE,0.50
	CALL MIND_BASE_DIRECT_MINUS("尊厳",DAMAGE)
	CALL MIND_BASE_DIRECT_MINUS("精神力",DAMAGE)
	
	;あなた以外だとここは通らない
	IF !PLAYER
		;表示する分があれば
		SIF BASE:嫌悪感 < MAXBASE:嫌悪感 || BASE:好感度
			PRINTL
		CALL MIND_BASE_DIRECT_PLUS("嫌悪感",DAMAGE)
		CALL MIND_BASE_DIRECT_MINUS("好感度",DAMAGE)
	ENDIF
ENDIF
CALL MIND_PALAM_AFTER_PRINT(1)



;初キス時
@FIRST_KISS_MIND_DAMAGE

CALL FIRST_KISS_MIND_DAMAGE_MESSAGE
IF KISS_PLAYER == CALLNAME:0
	IF ＃陥落状態／恋慕以上＃ || CFLAG:乳牛
		LOVE = 1000
		SIF TALENT:乙女心
			TIMES LOVE,2.00
		CALL MIND_BASE_DIRECT_PLUS("好感度",LOVE)
	ELSEIF (＃陥落状態／陥落以上＃ || TALENT:チョロイン) && !TALENT:貞操観念
		LOVE = 300
		SIF TALENT:乙女心
			TIMES LOVE,2.00
		CALL MIND_BASE_DIRECT_PLUS("好感度",LOVE)
	ELSE
		GOTO MIND_DAMAGE_COMMON
	ENDIF
ELSE
	$MIND_DAMAGE_COMMON
	IF TALENT:乙女心
		DAMAGE = 2000
	ELSE
		DAMAGE = 1000
	ENDIF
	SIF TALENT:貞操観念
		TIMES DAMAGE,1.50
	SIF ＃陥落状態／陥落以上＃
		TIMES DAMAGE,0.50
	CALL MIND_BASE_DIRECT_MINUS("尊厳",DAMAGE)
	CALL MIND_BASE_DIRECT_MINUS("精神力",DAMAGE)
	SIF !PLAYER
		CALL MIND_BASE_DIRECT_PLUS("嫌悪感",DAMAGE)
ENDIF
CALL MIND_PALAM_AFTER_PRINT(1)



;母乳体質化
@LACTATION_MIND_DAMAGE

CALL LACTATION_MIND_DAMAGE_MESSAGE
SIF !TALENT:性知識乏しい && !＃陥落状態／恋慕以上＃
	CALL MIND_BASE_DIRECT_MINUS("尊厳",1000)
CALL MIND_PALAM_AFTER_PRINT(1)



;膨乳
@BUSTUP_MIND_DAMAGE

CALL BUSTUP_MIND_DAMAGE_MESSAGE
IF CFLAG:乳牛
	LOVE = SOURCE:膨乳段階 *800
	CALL MIND_BASE_DIRECT_PLUS("乳牛堕ち",LOVE)
ELSEIF ＃陥落状態／隷属＃
	LOVE = SOURCE:膨乳段階 *500
	CALL MIND_BASE_DIRECT_PLUS("乳牛堕ち",LOVE)
ELSEIF MARK:搾乳中毒
	LOVE = SOURCE:膨乳段階 *300
	CALL MIND_BASE_DIRECT_PLUS("乳牛堕ち",LOVE)
ELSEIF ＃陥落状態／恋慕以上＃
	IF ABL:バストサイズ > 26
		DAMAGE = 500
		CALL MIND_BASE_DIRECT_MINUS("精神力",DAMAGE)
		CALL MIND_BASE_DIRECT_MINUS("好感度",DAMAGE)
	ENDIF
ELSE
	IF ABL:バストサイズ > 26
		DAMAGE = 3000
		CALL MIND_BASE_DIRECT_MINUS("抵抗心",DAMAGE)
		CALL MIND_BASE_DIRECT_MINUS("尊厳",DAMAGE)
		DAMAGE = 1000
		CALL MIND_BASE_DIRECT_MINUS("精神力",DAMAGE)
		
	ELSEIF ABL:バストサイズ < BUSTSIZE_爆乳 && TALENT:乳劣等感
		DAMAGE = SOURCE:膨乳段階 *300
		CALL MIND_BASE_DIRECT_MINUS("抵抗心",DAMAGE)
		CALL MIND_BASE_DIRECT_MINUS("尊厳",DAMAGE)
		SIF !PLAYER
			CALL MIND_BASE_DIRECT_MINUS("嫌悪感",DAMAGE)
	ELSE
		DAMAGE = SOURCE:膨乳段階 *500
		CALL MIND_BASE_DIRECT_MINUS("抵抗心",DAMAGE)
		CALL MIND_BASE_DIRECT_MINUS("尊厳",DAMAGE)
	ENDIF
ENDIF
CALL MIND_PALAM_AFTER_PRINT(1)



;処女結界破壊
@BREAK_VIRGIN_BARRIER_MIND_DAMAGE

CALL BREAK_VIRGIN_BARRIER_MIND_DAMAGE_MESSAGE
IF CFLAG:乳牛 || ＃陥落状態／恋慕以上＃ || CFLAG:無抵抗
ELSE
	DAMAGE = 5000
	CALL MIND_BASE_DIRECT_MINUS("抵抗心",DAMAGE)
	CALL MIND_BASE_DIRECT_MINUS("尊厳",DAMAGE)
	DAMAGE = 3000
	CALL MIND_BASE_DIRECT_MINUS("精神力",DAMAGE)
ENDIF
CALL MIND_PALAM_AFTER_PRINT(1)

