
;④感情SOURCEから振り分け
;もろもろを30～39に変換
@MIND_EXP_PLUS
#DIM MIND_FIX

	;乳牛堕ち→振り分け済み
	;淫欲→マゾっ気で追加
;マゾっ気による変換
IF ABL:マゾっ気 >= 5
	MIND_FIX = LIMIT(ABL:マゾっ気 -5,0,15)
	SOURCE:淫欲 += ((SOURCE:屈辱 +SOURCE:支配 +SOURCE:恥辱) *MIND_FIX /10)
	SOURCE:淫欲 += (SOURCE:被虐快楽経験 *MIND_FIX /10)
ENDIF


	;恭順→振り分け済み
	;屈服
;恥じらい／大人しい・無関心でない→恥辱で増加
SIF (TALENT:恥じらい || TALENT:大人しい) && !TALENT:無関心
	SOURCE:屈服 += SOURCE:恥辱

;臆病／弱気／悲観的→苦痛・恐怖で増加
SIF TALENT:臆病 || TALENT:弱気 || TALENT:悲観的
	SOURCE:屈服 += (SOURCE:苦痛 +SOURCE:恐怖)

;臆病→支配で増加
SIF TALENT:臆病
	SOURCE:屈服 += SOURCE:支配

;マゾっ気により恥辱・屈辱・支配で増加
IF ABL:マゾっ気 >= 5
	MIND_FIX = LIMIT(ABL:マゾっ気 -4,0,20)
	DAMAGE = (SOURCE:恥辱 +SOURCE:屈辱 +SOURCE:支配) *MIND_FIX /10
	SOURCE:屈服 += DAMAGE
ENDIF


	;苦痛→振り分け済み
	;恐怖
;臆病→マゾっ気なければ恥辱・屈辱・支配で増加
IF TALENT:臆病 && ABL:マゾっ気 < 10
	DAMAGE = (SOURCE:恥辱 +SOURCE:屈辱 +SOURCE:支配) /2
	SOURCE:恐怖 += DAMAGE
ENDIF

	;不快
;不潔で基礎増加
SOURCE:不快 += SOURCE:不潔

;プライド高い／高慢→屈辱で増加
SIF TALENT:プライド高い || TALENT:高慢
	SOURCE:不快 += SOURCE:屈辱


	;反感
;理性があれば3つで増加
IF BASE:理性
	DAMAGE = (SOURCE:恥辱 +SOURCE:屈辱 +SOURCE:支配) /2
	SOURCE:反感 += DAMAGE
ENDIF

;快感の否定→理性があれば淫欲で増加
SIF TALENT:快感の否定 && BASE:理性
	SOURCE:反感 += (SOURCE:淫欲 /2)


	;失意
;気力0→苦痛・恐怖で増加
SIF !BASE:気力
	SOURCE:失意 += (SOURCE:苦痛 +SOURCE:恐怖)









