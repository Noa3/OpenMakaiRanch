
;奉仕共通SOURCE
@SERVICE_CONTINUE_SOURCE_COMMON

LOSEBASE:体力 += 30
LOSEBASE:気力 += 50
SOURCE:習得 += 1500
SOURCE:恥辱 += 1000
SOURCE:情愛 += 2000
SOURCE:情愛 += (ABL:奉仕精神 *300)
SOURCE:屈辱 += 1000
SOURCE:不潔 += 500
SOURCE:支配 += 500



;強制系共通SOURCE
@FORCIBLY_CONTINUE_SOURCE_COMMON

SOURCE:調教者体力消費 += 30
LOSEBASE:体力 += 50
LOSEBASE:気力 += 50
SOURCE:恥辱 += 1500
SOURCE:情愛 += 500
SOURCE:マゾヒズム += 1000
SOURCE:屈辱 += 2500
SOURCE:不潔 += 1000
SOURCE:支配 += 1500





@EQUIP_50_CONTINUE
;素股継続

CALL SEX_MESSAGE("素股")
IF TFLAG:奉仕可能
	CALL SERVICE_CONTINUE_SOURCE_COMMON
ELSE
	CALL FORCIBLY_CONTINUE_SOURCE_COMMON
ENDIF
SOURCE:Ｖ快楽／あなた責め += 1000



