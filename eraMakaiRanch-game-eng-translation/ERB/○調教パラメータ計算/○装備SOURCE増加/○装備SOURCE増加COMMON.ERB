
;装備の責めSOURCEを追加、メッセージ表示
@TRAIN_EQUIP_SOURCE_COMMON

;拘束TFLAGでの追加処理
FOR LOCAL,0,20
	SIF !GETBIT(TFLAG:拘束BIT,LOCAL)
		CONTINUE
	TRYCCALLFORM BIND_{LOCAL}_CONTINUE
		SIF TFLAG:調教中 || TFLAG:スケジュール外Ｈ || SOURCE:体内凌辱中継続メッセージ表示
			TRYCALLFORM BIND_{LOCAL}_CONTINUE_MESSAGE
	CATCH
	ENDCATCH
	BREAK
NEXT

;TEQUIPに応じてSOURCE追加処理
FOR LOCAL,0,300
	;FORM使えば済んだ
	SIF !TEQUIP:LOCAL
		CONTINUE
	TRYCCALLFORM EQUIP_{LOCAL}_CONTINUE
		;あったらメッセージ呼び→口上呼び
		;1行で済むやつはSOURCEのついでに入ってたりするのでTRY
		IF TFLAG:調教中 || TFLAG:スケジュール外Ｈ || SOURCE:体内凌辱中継続メッセージ表示
			TRYCALLFORM EQUIP_{LOCAL}_CONTINUE_MESSAGE
			CALL KOJO_PRINT("調教コマンド",TEQUIPNAME:LOCAL,"継続")
		ENDIF
	CATCH
	ENDCATCH
NEXT

;触手服でのSOURCE追加処理
CALL TRAIN_T_CLOTHE


