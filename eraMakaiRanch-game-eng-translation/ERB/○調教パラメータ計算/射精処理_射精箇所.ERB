	SIF DEFAULT_SET
		CFLAG:PARTS = RESULT
	RETURN RESULT

;+→選ばず返す
ELSEIF CFLAG:PARTS > 0
	RETURN CFLAG:PARTS
ENDIF

;全体コンフィグを見る→+なら選ばず返す
PARTS = 射精箇所／%ARGS%
SIF FLAG:PARTS
	RETURN FLAG:PARTS

;ここまで来たら選択
CALL SELECT_EJACULATION_PART(ARGS)
PARTS = 個別設定／射精箇所／%ARGS%
SIF DEFAULT_SET
	CFLAG:PARTS = RESULT
RETURN RESULT



