
;快楽値の合計計算
@SENSITIVE_SUM_CALC

;計算した補正を使って部位ごとに計算
;ABL:Ａ感度→10
;SOURCE:Ａ快楽→0
;SOURCE:Ａ快楽／あなた責め→100
;SOURCE:Ａ快楽／レズ調教→110
;SOURCE:Ａ快楽／器具→120
;SOURCE:Ａ快楽／触手→130
;SOURCE:Ａ快楽／魔族→140
;SOURCE:Ａ痛み→190

ABL_REF = 10
SOURCE_REF:0 = 100
SOURCE_REF:1 = 110
SOURCE_REF:2 = 120
SOURCE_REF:3 = 130
SOURCE_REF:4 = 140
SOURCE_REF:5 = 190

FOR LOCAL,0,5
	;あなた責め・レズ調教→技巧補正・レズ補正かける
	SOURCE:(SOURCE_REF:0 +LOCAL) *= (TECHNIQUE_FIX *LESBIAN_FIX)
	SOURCE:(SOURCE_REF:0 +LOCAL) /= 10000
	SOURCE:(SOURCE_REF:1 +LOCAL) *= (TECHNIQUE_FIX *LESBIAN_FIX)
	SOURCE:(SOURCE_REF:1 +LOCAL) /= 10000
	
	;触手→触手補正
	SOURCE:(SOURCE_REF:3 +LOCAL) *= TENTACLE_FIX
	SOURCE:(SOURCE_REF:3 +LOCAL) /= 100
	
	;器具・魔族→補正なし
	
	;個別補正した値を合計値へ
	FOR LOCAL:1,0,5
		SOURCE:LOCAL += SOURCE:(SOURCE_REF:(LOCAL:1) +LOCAL)
	NEXT
	
	;合計したあと感覚・感度・刻印で補正
	;感度は感度+補正値
	SOURCE:LOCAL *= EXPERIENCE_FIX:LOCAL
	SOURCE:LOCAL /= 100
	SOURCE:LOCAL *= (SENSITIVE_FIX:LOCAL +ABL:(ABL_REF +LOCAL))
	SOURCE:LOCAL /= 100
	SOURCE:LOCAL *= MARK_FIX:LOCAL
	SOURCE:LOCAL /= 100
	
	;痛み分を減少→0だとバグに見えるので最低保証1%
	SOURCE:LOCAL = LIMIT(SOURCE:LOCAL -SOURCE:(SOURCE_REF:5 +LOCAL),SOURCE:LOCAL /100,SOURCE:LOCAL)
NEXT

;快楽値倍率コンフィグ
CALL DIFFICULTY_CONFIG_APPLY("快楽値")

;快楽値に5%のランダム補正
FOR LOCAL,0,5
	CALL RANDOM_FIX(SOURCE:LOCAL,5,SOURCENAME:LOCAL)
	SOURCE:LOCAL += FIX
NEXT



;絶頂判定
@TRAIN_ECSTASY

;PALAM+SOURCEが10000以上で絶頂
FOR LOCAL,0,5
	SIF PALAM:LOCAL +SOURCE:LOCAL < 10000
		CONTINUE
	PLEASURE = PALAM:LOCAL +SOURCE:LOCAL
	NOWEX:LOCAL = PLEASURE /10000
	
	;触手責めしていれば触手絶頂経験増加
	;SOURCE:Ａ快楽／触手→130
	SIF NOWEX:LOCAL
		SOURCE:触手絶頂経験 += (SOURCE:(LOCAL +130) /2)
NEXT
NOWEX:総絶頂 = SUMARRAY(NOWEX,0,5)

;絶頂すると気力追加減少→√絶頂回数 *10000 /2
SIF !NOWEX:総絶頂
	RETURN
DAMAGE = SQRT(NOWEX:総絶頂 *10000) /2
LOSEBASE:気力 += DAMAGE

;回復淫紋あれば体力と気力回復
;射精処理でも使ってるけどそこの後の部分なので大丈夫なはず
IF MARK:絶頂体力回復淫紋
	HEAL = NOWEX:総絶頂 *100
	SOURCE:調教対象体力回復 += HEAL
	SOURCE:調教対象気力回復 += HEAL
ENDIF

