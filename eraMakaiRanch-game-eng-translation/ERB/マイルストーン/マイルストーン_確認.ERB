
;マイルストーン確認目次
@MILESTONE_TABLE
#DIM DYNAMIC PAGE
#DIM DYNAMIC REWORD

PAGE_MAX = 4
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT

;FLAG:ニンゲンのミルクを出荷→800
;FLAG_REFあとで
;マイルストーン達成時の報酬STR→7800
STR_REF = 7000
PRINTL Milestone conditions and rewards.

;水色→達成済み　白→未達成
CALL PRINT_WORD_COLOR,@"【Achieved】","水色"
PRINTL 【Not achived】
CALL PRINTL_WORD_COLOR,@"・Achivements are mostly unlocked during payment, with some exceptions.","黄"
DRAWLINE

;ページ1→800～819,2→820～850,3→850～899,4→900～
SELECTCASE PAGE
CASE 1
	FLAG_REF = 800
	FLAG_REF:1 = 820
CASE 2
	FLAG_REF = 820
	FLAG_REF:1 = 850
CASE 3
	FLAG_REF = 850
	FLAG_REF:1 = 900
CASE 4
	FLAG_REF = 900
	FLAG_REF:1 = 1000
ENDSELECT
FOR LOCAL,FLAG_REF,FLAG_REF:1
	SIF FLAGNAME:LOCAL == ""
		CONTINUE
	
	;10ごと改行
	SIF LOCAL != FLAG_REF && !(LOCAL %10)
		PRINTL
	
	;達成済みなら水色
	SIF FLAG:LOCAL
		SETCOLOR BARCOLORSET("水色")
	
	;条件表示か報酬表示か
	IF REWORD
		PRINTFORML <{LOCAL -800,3}> %MILESTONES_REWARD(STR:(LOCAL +STR_REF))%
	ELSE
		PRINTFORML <{LOCAL -800,3}> %MILESTONES(FLAGNAME:LOCAL)%
	ENDIF
	RESETCOLOR
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [ 90] Change display（Currently：Milestone \@ REWORD ? rewards # conditions \@）
PRINTLC 　
PRINTL [ 99] Done
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 90
	INVERTBIT REWORD,0
CASE 99
	RETURN
ENDSELECT
RESTART



