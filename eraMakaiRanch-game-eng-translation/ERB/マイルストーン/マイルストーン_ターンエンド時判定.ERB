
;ターンエンド時マイルストーン判定
@MILESTONE_CHECK_ALL

;FLAG:ニンゲンのミルクを出荷→800
FLAG_REF = 800
FOR LOCAL,FLAG_REF,FLAG_REF +200
	SIF FLAG:LOCAL
		CONTINUE
	CALL MILESTONE_CHECK(LOCAL)
NEXT



;不動産部分のみまとめて判定
@MILESTONE_CHECK_ESTATE

;FLAG:＜奴隷寮＞の購入→850
FLAG_REF = 850
FOR LOCAL,FLAG_REF,FLAG_REF +10
	SIF FLAG:LOCAL
		CONTINUE
	CALL MILESTONE_CHECK(LOCAL)
NEXT



;個別→なんか購入時とかに直接呼べると便利
;ARG→FLAG
@MILESTONE_CHECK(ARG)

TRYCCALLFORM MILESTONE_CHECK_{ARG}
	SIF !RESULT
		RETURN
	CALL MILESTONE_COMPLETE_COMMON(ARG)
	TRYCALLFORM MILESTONE_REWARD_{ARG}
	PRINTLC [ 0] OK
	INPUT
	CALL HALFLINE
CATCH
ENDCATCH



;マイルストーン達成時共通処理
;ARG→FLAG
@MILESTONE_COMPLETE_COMMON(ARG)

;貢献ptを+1000するのを共通処理にした
;DAY入れると達成日参照できるか　まだ見られないんだけども
FLAG:ARG = DAY
MONEY:貢献PT += 1000
PRINTFORM No.{ARG -800} 
CALL PRINTW_WORD_COLOR,@"[%MILESTONES(FLAGNAME:ARG)%] Achieved！＜Contribution Points+1,000＞","水色"
PRINTL








