
;あなたデータの変更
@NEWGAME_PLAYER_DATA
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL PRINT_PORTRAIT
PRINTFORM Name：%CALLNAME%　Full Name：
IF NAME == ""
	CALL PRINTL_WORD_COLOR,@"(None)","灰"
ELSE
	PRINTFORML %NAME%
ENDIF
CALL PRINT_AFFILIATION_DATA
CALL PRINT_VISUAL_AGE
SIF !TALENT:オトコ
	CALL PRINT_BUST_DETAIL
CALL PRINT_EXTERIOR_PLAYER
CALL PRINT_VIRGIN_PLAYER
CALL SHOW_EQUIP
DRAWLINE
TRYCALLFORM NEWGAME_PLAYER_DATA_INDEX{PAGE}
CALL PRINTL_ALIGN(2)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORML [89] Switch Selection Method: \@ SELF_CHARA_MAKE_RANDOM ? Shuffle # Manual Input \@
PRINTLC [90] Default / EX Mode
PRINTLC [98] Hint
PRINTL [99] Complete
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 89
	INVERTBIT SELF_CHARA_MAKE_RANDOM,0
CASE 90
	CALL NEWGAME_PLAYER_DATA_EXMODE
CASE 98
	CALL BROWSE_HINT("あなた設定")
CASE 99
	RETURN
CASEELSE
	CALL PLAYER_DATA_CONFIG_INPUT(PAGE,RESULT)
ENDSELECT
RESTART




