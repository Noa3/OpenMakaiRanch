
;スレイちゃんデータ変更
@CHARA_MAKE_FIXED_SLAVE_FIRST
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL CHARA_MAKE_SLAVE_DATA(PAGE,"初期設定")
CALL FIXED_SLAVE_CHANGE_LIST
CALL PRINTL_ALIGN(2)
PRINTFORMLC [80] Display Item Change <PAGE{PAGE,2}／{PAGE_MAX}>
PRINTFORML [89] Switch Selection Method: \@ SELF_CHARA_MAKE_RANDOM ? Shuffle # Manual Input \@
DRAWLINE

;スレイちゃんは固定
PRINTLC [90] Restore to Defaults
PRINTLC [98] Hint
PRINTL [99] Complete
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 89
	INVERTBIT SELF_CHARA_MAKE_RANDOM,0
CASE 90
	;キャラリセット関数を呼ぶ
	CALL NEWGAME_CHARA_RESET(1)
	SIF !FLAG:候補割合／一般種族／人間
		CALL CHARA_MAKE_FIXED_SLAVE_TRIBE_QUESTION
CASE 98
	CALL BROWSE_HINT("スレイ設定")
CASE 99
	IF !CFLAG:口上表示 && FLAG:口上表示
		CALL PRINTL_WORD_COLOR,@"The dialogue has not been set. Is that okay?","黄"
		CALL ASK_YN
		SIF RESULT
			RESTART
	ENDIF
	RETURN
CASEELSE
	CALL FIXED_SLAVE_CHANGE_INPUT(RESULT)
ENDSELECT
RESTART


