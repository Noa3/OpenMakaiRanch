
;楽々スタートキットのチェック
@GIFTSET_CONFIG_CHECK

SIF !FLAG:楽々スタートキットBIT
	RETURN

PRINTL 【楽々スタートキット】
IF GETBIT(＃スタートキット／衣服＃)
	;ITEM:作業着セット→1000
	;アイテム名が設定されているものを取得
	FOR LOCAL,1000,2000
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 100000
	NEXT
	CALL PRINTL_WORD_COLOR,@"All clothes cost 100,000G","黄"
ENDIF

IF GETBIT(＃スタートキット／消耗品＃)
	;ITEM:栄養ドリンク→200
	FOR LOCAL,200,350
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 100000
	NEXT
	CALL PRINTL_WORD_COLOR,@"All consumables cost 100,000G","黄"
ENDIF

IF GETBIT(＃スタートキット／薬品＃)
	;ITEM:母乳分泌促進薬→350
	FOR LOCAL,350,400
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 100000
	NEXT
	CALL PRINTL_WORD_COLOR,@"All drugs costs 100,000G","黄"
ENDIF

IF GETBIT(＃スタートキット／搾乳器＃)
	;ITEM:搾乳カップ→900
	FOR LOCAL,900,920
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 100000
	NEXT
	CALL PRINTL_WORD_COLOR,@"搾乳器全部10万コ入手","黄"
ENDIF

IF GETBIT(＃スタートキット／龍タマ＃)
	ITEM:龍のタマ = 7
	CALL PRINTL_WORD_COLOR,@"＜龍のタマ＞7コ入手","黄"
ENDIF

IF GETBIT(＃スタートキット／魔力貯蔵器＃)
	;ITEM:家庭用魔力貯蔵器→50
	FOR LOCAL,50,60
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 1
	NEXT
	CALL MAGIC_STORAGE
	MONEY:貯蔵魔力 = FLAG:貯蔵魔力上限値
ENDIF

IF GETBIT(＃スタートキット／不動産＃)
	;ITEM:家族風呂→120
	FOR LOCAL,120,150
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 1
	NEXT
	ITEM:事務所増築 = ESTATE_OFFICE_LIMIT
	ITEM:ペット小屋 = ESTATE_PETHOUSE_LIMIT
	ITEM:奴隷寮増築 = ESTATE_DORMITORY_LIMIT
	ITEM:牛舎 = ESTATE_COWSHED_LIMIT
	
	;FLAG:第1牛舎増築段階→500
	FLAG_REF = 490
	FOR LOCAL,1,11
		FLAG:(FLAG_REF +LOCAL *10) = 10
	NEXT
	CALL PET_HOUSE_BLANC_CHECK
	CALL PRINTL_WORD_COLOR,@"不動産設備最大拡張","黄"
ENDIF

IF GETBIT(＃スタートキット／調教・拘束＃)
	;ITEM:バイブ→500
	FOR LOCAL,500,600
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 1
	NEXT
	CALL PRINTL_WORD_COLOR,@"調教グッズ+拘束具全て入手","黄"
ENDIF

IF GETBIT(＃スタートキット／魔術＃)
	;ITEM:個人用転移門→600
	FOR LOCAL,600,800
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 99
	NEXT
	CALL PRINTL_WORD_COLOR,@"魔術全て習得+Lvあるものは99","黄"
ENDIF

IF GETBIT(＃スタートキット／アビリティ＃)
	;ITEM:汚れ無視→800
	FOR LOCAL,800,900
		SIF ITEMNAME:LOCAL == ""
			CONTINUE
		ITEM:LOCAL = 99
	NEXT
	CALL PRINTL_WORD_COLOR,@"アビリティ全て習得+Lvあるものは99","黄"
ENDIF
PRINTW

