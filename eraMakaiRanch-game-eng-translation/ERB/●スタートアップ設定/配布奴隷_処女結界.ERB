
;処女結界奴隷の初期設定
@CHARA_MAKE_FIXED_SLAVE_VIRGIN_BARRIER
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL CHARA_MAKE_SLAVE_DATA(PAGE,"初期設定")
CALL FIXED_SLAVE_CHANGE_LIST
CALL PRINTL_ALIGN(2)
PRINTFORMLC [80] Display Item Change <PAGE{PAGE,2}／{PAGE_MAX}>
PRINTFORML [89] Switch Selection Method: \@ SELF_CHARA_MAKE_RANDOM ? Shuffle # Manual Input \@
DRAWLINE

;別なほうも見たいなら
IF CSTR:ジョブ == "退魔巫女"
	PRINTLC [90] Switch to 【Sister】
ELSE
	PRINTLC [90] Switch to 【Miko】
ENDIF
PRINTLC [98] Tip
PRINTL [99] Done
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 89
	INVERTBIT SELF_CHARA_MAKE_RANDOM,0
CASE 90
	;逆側のキャラリセット関数を呼ぶ
	IF CSTR:ジョブ == "退魔巫女"
		CALL NEWGAME_CHARA_RESET(4)
	ELSE
		CALL NEWGAME_CHARA_RESET(3)
	ENDIF
	SIF !FLAG:候補割合／一般種族／人間
		CALL CHARA_MAKE_FIXED_SLAVE_TRIBE_QUESTION
CASE 98
	CALL BROWSE_HINT("処女結界奴隷設定")
CASE 99
	IF !CFLAG:口上表示 && FLAG:口上表示
		CALL PRINTL_WORD_COLOR("No dialogue selected, confirm?","黄")
		CALL ASK_YN
		SIF RESULT
			RESTART
	ENDIF
	RETURN
CASEELSE
	CALL FIXED_SLAVE_CHANGE_INPUT(RESULT)
ENDSELECT
RESTART



