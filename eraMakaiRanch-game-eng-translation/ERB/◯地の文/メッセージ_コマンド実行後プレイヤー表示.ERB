
;PLAYERの表示
@PRINT_PLAYER_COMMAND_AFTER_MESSAGE

;あなた以外、スケジュールならおわり
SIF PLAYER < 0 || (!TFLAG:調教中 && !TFLAG:スケジュール外Ｈ)
	RETURN
EXIST = 0
PRINTFORM %CALLNAME:PLAYER%：
CALL PRINT_PLAYER_HP_MESSAGE
CALL PRINT_PLAYER_VIGOR_MESSAGE
CALL PRINT_PLAYER_EXP_MESSAGE
CALL PRINT_MASTER_POWERUP_VOL
PRINTL

;何も表示ない場合1行消す
SIF !EXIST
	CLEARLINE 1



;PLAYERのHP
@PRINT_PLAYER_HP_MESSAGE

;回復表示かダメージ表示か
IF SOURCE:調教者体力消費 > SOURCE:調教者体力回復
	PRINTFORM HP-{SOURCE:調教者体力消費 -SOURCE:調教者体力回復} 
	EXIST ++
ELSEIF SOURCE:調教者体力消費 < SOURCE:調教者体力回復
	PRINTFORM HP+{SOURCE:調教者体力回復 -SOURCE:調教者体力消費} 
	EXIST ++
ENDIF



;PLAYERの精力消費表示
@PRINT_PLAYER_VIGOR_MESSAGE

SIF !SOURCE:調教者精力消費量
	RETURN
PRINTFORM Vigor -{SOURCE:調教者精力消費量} 
SIF !BASE:0:精力
	CALL PRINT_WORD_COLOR,@"【0 Vigor】","黄"
EXIST ++



;PLAYERの経験値表示
@PRINT_PLAYER_EXP_MESSAGE

SAVE_TARGET = TARGET
TARGET = PLAYER
FOR LOCAL,30,100
	SIF SOURCE:LOCAL <= 0
		CONTINUE
	SIF !GETBIT(＃上限到達後表示／性経験値＃) && EXP:LOCAL >= EXP_MAX
		CONTINUE
	EXIST ++
	PRINTFORM %PALAM_ENG(SOURCENAME:LOCAL)%+{SOURCE:LOCAL} 
	SIF LOCAL >= 40
		PRINTFORM <EXP+{PALAM:LOCAL}> 
	
	;あんまり多くないのでPRINTLしない
NEXT
TARGET = SAVE_TARGET



;最大値増加メッセージ　調教中以外は飛ばす
@PRINT_MASTER_POWERUP_VOL

SIF !SOURCE:プレイヤー増加霊力量 && !SOURCE:プレイヤー増加魔力量
	RETURN
IF SOURCE:プレイヤー増加霊力量
	PRINTFORM Maximum Spirit Energy +{SOURCE:プレイヤー増加霊力量} 
	EXIST ++
ENDIF
IF SOURCE:プレイヤー増加魔力量
	PRINTFORM Maximum Mana +{SOURCE:プレイヤー増加魔力量} 
	EXIST ++
ENDIF








