;ARG→NO_BUSTUP
;ARG:1→SENSITIVE_PLUS
@COM547_BUST_SENSITIVE_UP_MESSAGE(ARG,ARG:1)

;膨乳したなら「さらに」表示
SIF ARG
	PRINT さらに
PRINTFORM Due to the essence, %CALLNAME%'s %SLANG_B()% are becoming warm...
CALL HEARTCB(0xD02830)
PRINTL
CALL KOJO_PRINT("肉体改造","Ｂ感度上昇")
