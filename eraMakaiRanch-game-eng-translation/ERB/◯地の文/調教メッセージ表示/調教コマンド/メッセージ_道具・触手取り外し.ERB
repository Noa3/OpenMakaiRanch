;触手フェラチオ、触手イラマチオ共通部分
@MOUSE_TENTACLE_REMOVE_MESSAGE

SIF !TFLAG:口内精液
	RETURN
IF CFLAG:崩壊
	PRINTFORML %CALLNAME%'s mouth overflowed with tentacle %SLANG_SEMEN()%...
ELSEIF (ABL:精液中毒 +ABL:触手中毒 >= 10) || ＃陥落状態／隷属＃
	CALL PRINT_WORD_COLOR,@"　%CALLNAME% swallowed the remaining tentacle %SLANG_SEMEN()% in her mouth...","桃"
	CALL HEARTCB(0xD02830)
	PRINTL
ELSEIF MARK:恐怖刻印
	PRINTFORML %CALLNAME% swallowed the remaining tentacle %SLANG_SEMEN()% with teary eyes...
ELSE
	PRINTFORML %CALLNAME% spat out the remaining tentacle %SLANG_SEMEN()%...
ENDIF


