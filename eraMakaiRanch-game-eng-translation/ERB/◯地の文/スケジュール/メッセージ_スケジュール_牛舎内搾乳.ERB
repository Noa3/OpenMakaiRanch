;搾乳開始の1キャラ目の地の文表示
@COWSHED_LACTATION_START_MESSAGE

;1匹でもたちにならないよう調整
PRINTFORM In %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)%, 
CALL PRINT_COWSHED_SLAVE_CALL

;乳牛の呼び方ランダム
@PRINT_COWSHED_SLAVE_CALL
#DIM WORD_PLUS
#DIMS COWSHED_SLAVE_CALL_TERM
#DIMS COWSHED_SLAVE_CALL_TERM1 = "female", "milk", "milking", "boob", "breast milk", "dairy", "milk tank", "holstein", "livestock"
#DIMS COWSHED_SLAVE_CALL_TERM2 = " slave", " cow"
#DIMS COWSHED_SLAVE_BUST
#DIMS LACT_SHED_MCHN
#DIMS LACT_SHED_DRN
#DIMS LACT_SHED_DRN_1 = "", "repeatedly ", "continuously ", "relentlessly "
#DIMS LACT_SHED_DRN_2 = "extract", "drain"


WORD_PLUS = RAND:9
COWSHED_SLAVE_CALL_TERM = %COWSHED_SLAVE_CALL_TERM1:WORD_PLUS%

SIF WORD_PLUS < 6
	COWSHED_SLAVE_CALL_TERM += @"%COWSHED_SLAVE_CALL_TERM2:(RAND:2)%"
SIF BOX_COUNT >= 2 && WORD_PLUS != 8
	COWSHED_SLAVE_CALL_TERM += "s"

IF WORD_PLUS == 8 || BOX_COUNT < 2
	COWSHED_SLAVE_BUST = %COWSHED_SLAVE_CALL_TERM%'s %TOLOWER(SLANG_B())%
ELSE
	COWSHED_SLAVE_BUST = %COWSHED_SLAVE_CALL_TERM%' %TOLOWER(SLANG_B())%
ENDIF


IF BOX_COUNT >= 2
	LACT_SHED_MCHN = milking machines
ELSE
	LACT_SHED_MCHN = a milking machine
ENDIF

LACT_SHED_DRN = %LACT_SHED_DRN_1:(RAND:4)%%LACT_SHED_DRN_2:(RAND:2)%


;TARGET指定されてるのでSLANG使用可能
SELECTCASE RAND:4
CASE 0
	IF BOX_COUNT >= 2
		PRINTFORM %LACT_SHED_MCHN% are attached to the %COWSHED_SLAVE_BUST% and %LACT_SHED_DRN% their %TOLOWER(SAVESTR:表記／母乳)%
	ELSE
		PRINTFORM %LACT_SHED_MCHN% is attached to the %COWSHED_SLAVE_BUST% and %LACT_SHED_DRN% their %TOLOWER(SAVESTR:表記／母乳)%
	ENDIF
CASE 1
	PRINTFORM %TOLOWER(SAVESTR:表記／母乳)% is %LACT_SHED_DRN%ed from the %COWSHED_SLAVE_BUST%
CASE 2
	IF BOX_COUNT >= 2
		PRINTFORM %LACT_SHED_MCHN% %LACT_SHED_DRN% %TOLOWER(SAVESTR:表記／母乳)% from the %COWSHED_SLAVE_BUST%
	ELSE
		PRINTFORM %LACT_SHED_MCHN% %LACT_SHED_DRN%s %TOLOWER(SAVESTR:表記／母乳)% from the %COWSHED_SLAVE_BUST%
	ENDIF
CASE 3
	IF BOX_COUNT >= 2
		PRINTFORM %LACT_SHED_MCHN% %LACT_SHED_DRN% the %COWSHED_SLAVE_BUST% of their %TOLOWER(SAVESTR:表記／母乳)%
	ELSE
		PRINTFORM %LACT_SHED_MCHN% %LACT_SHED_DRN%s the %COWSHED_SLAVE_BUST% of their %TOLOWER(SAVESTR:表記／母乳)%
	ENDIF
ENDSELECT
PRINT ...
CALL HEARTCB(0xD02830)
PRINTL


