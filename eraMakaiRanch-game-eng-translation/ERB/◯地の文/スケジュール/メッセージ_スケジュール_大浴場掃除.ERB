
;大浴場掃除開始の地の文
@WORK_LARGE_BATHLOOM_CLEANING_BEGIN_MESSAGE

SIF !EXP:実行回数／大浴場掃除 && TARGET
	PRINTFORML You ordered %CALLNAME% to clean the large bath...
PRINTFORM %CALLNAME%%PRINT_WORK_GROUP()% 
SIF CSTR:0:スケジュール == "大浴場掃除" && TARGET
	PRINTFORM and you 
PRINTL cleaned the large bath.
CALL KOJO_PRINT("スケジュール","大浴場掃除",KOJO_TYPE)



;掃除上手さ表示
@WORK_LARGE_BATHLOOM_CLEANING_ABL_MESSAGE

SIF !TARGET
	RETURN
IF !EXP:実行回数／大浴場掃除
	IF ABL:掃除 >= 8
		PRINTL It seems the experience from the outside world is coming into play, and the task is being done very efficiently.
	ELSEIF ABL:掃除 >= 4
		PRINTL They seem to have quite a knack for it.
	ELSE
		PRINTL ...It looks like progress is slow.
	ENDIF
ELSE
	IF ABL:掃除 >= 8
		PRINTL The bathtub is quickly becoming clean. 
	ELSEIF ABL:掃除 >= 4
		PRINTL They've improved quite a bit.
	ELSE
		PRINTL ...It looks like progress is slow.
	ENDIF
ENDIF




