
;ペットをブラッシング：地の文
;TARGET,ANIMAL,PET_NAME指定済み
@PET_COMMU_MESSAGE_BRUSHING

FLAG_NAME = なつき度／%ANIMAL%
IF TALENT:動物に好かれる || BASE:FLAG_NAME >= 8000
	CALL PET_COMMU_MESSAGE_BRUSHING_LOVE
	DAMAGE = 100
ELSEIF !TALENT:動物に嫌われる || BASE:FLAG_NAME >= 5000
	CALL PET_COMMU_MESSAGE_BRUSHING_LOW
	DAMAGE = 100
ELSE
	CALL PET_COMMU_MESSAGE_BRUSHING_HATE
	DAMAGE = 150
ENDIF



;【動物に好かれる】orなつき時
@PET_COMMU_MESSAGE_BRUSHING_LOVE

PRINTFORML %CALLNAME%は%PET_NAME%をブラッシングすることにした。
SELECTCASE ANIMAL
CASE "堕天馬","魔界ハムスター"
	PRINTFORML %PET_NAME%は体を伏せてブラッシングしやすいように大人しくしている。
CASEELSE
	PRINTFORML %PET_NAME%は体を伸ばしてブラッシングしやすいように大人しくしている。
ENDSELECT
PRINTL ………
PRINTFORML %PET_NAME%の体毛が整った！%PET_NAME%も満足げだ！



;【動物に嫌われる】ではないor嫌われるけどなつき程々
@PET_COMMU_MESSAGE_BRUSHING_LOW

;上と同じ
CALL PET_COMMU_MESSAGE_BRUSHING_LOVE



;【動物に嫌われる】
@PET_COMMU_MESSAGE_BRUSHING_HATE

PRINTFORML %CALLNAME%は%PET_NAME%をブラッシングしようと試みた…
PRINTL ………
PRINTL 何度もブラシを跳ね除けられたが、どうにかブラッシングを完了した。
PRINTL 多少は信頼を得られた気がしないでもない。




