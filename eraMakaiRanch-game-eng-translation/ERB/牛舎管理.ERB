
;牛舎管理
;ARG　牛舎番号
@COWSHED_MANAGE_ENTRANCE(ARG)

;FLAG:第1牛舎増築段階→500
;FLAG:第1牛舎スケジュール→501
;FLAG:第1牛舎家畜頭数→502
;FLAG:第1牛舎スケジュール表示→503
FLAG_REF = 490
FLAG_REF:1 = 491
FLAG_REF:2 = 492
FLAG_REF:3 = 493

;牛舎が立ってないときおわり
SIF ARG > ITEM:牛舎
	RETURN
COWSHED_NUM = ARG
COWSHED_CAPACITY = FLAG:(FLAG_REF +COWSHED_NUM *10)*10
CALL COWSHED_MANAGE
CALL SCHEDULE_ADJUST



;牛舎画面
@COWSHED_MANAGE

;牛舎内の現在の乳牛頭数を計算
FLAG:(FLAG_REF:2 +COWSHED_NUM *10) = CMATCH(CFLAG:牛舎番号,COWSHED_NUM)
COWSHED_SLAVE = FLAG:(FLAG_REF:2 +COWSHED_NUM *10)
CLEARLINE LINECOUNT
PRINTFORML %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM),24%：{COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3}匹 
DRAWLINE
IF COWSHED_SLAVE < COWSHED_CAPACITY
	PRINTL [ 0] Move Livestock In 
ELSE
	CALL PRINTL_WORD_COLOR("　Cowshed is full","灰")
ENDIF
IF COWSHED_SLAVE
	PRINTLC [ 1] Move Livestock Out 
	PRINTLC [ 2] Batch Move 
	PRINTLC [ 3] Display Livestock Status
ELSE
	CALL PRINTLC_WORD_COLOR("　No Livestock in Cowshed","灰")
ENDIF
PRINTL
DRAWLINE
PRINTFORML [10] Livestock Treatment：\@ FLAG:(FLAG_REF:1 +COWSHED_NUM *10) ? Industrial Milking # Milk Cow \@
PRINT [11] Milking Display：
SELECTCASE FLAG:(FLAG_REF:3 +COWSHED_NUM *10)
CASE 0
	PRINTL Individual Display
CASE 1
	PRINTL Aggregate Display＋Show LvUP
CASE 2
	PRINTL Aggregate Display＋Ignore LvUP
ENDSELECT
PRINTL [12] Change Cowshed Name

CALL PRINTL_ALIGN(-5)
	;PRINTL [ 6] 牛舎で使用する責め具を変更 
DRAWLINE
PRINTLC [30] Prev Cowshed
PRINTLC [31] Next Cowshed
PRINTL [99] Done
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL COWSHED_MANAGE_PUTIN
CASE 1
	CALL COWSHED_MANAGE_PUTOUT
CASE 2
	CALL COWSHED_MANAGE_MOVE
CASE 3
	CALL COWSHED_MANAGE_STATUS
CASE 10
	PRINTFORML Select treatment for livestock in %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)%
	PRINTL [ 0] Milk Cow          ：Midday Break
	PRINTL [ 1] Industrial Milking：No Breaks
	BINPUT
	FLAG:(FLAG_REF:1 +COWSHED_NUM *10) = RESULT
		
CASE 11
	PRINTFORML Select status display during schedule execution for livestock in %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)%
	PRINTL [ 0] Individual Display
	PRINTL [ 1] Aggregate Display＋Show LvUP
	PRINTL [ 2] Aggregate Display＋Ignore LvUP
	PRINTL
	PRINTL [99] Cancel
	INPUT
	SIF RESULT >= 0 && RESULT <= 2
		FLAG:(FLAG_REF:3 +COWSHED_NUM *10) = RESULT

CASE 12
	PRINTFORML Change the name of %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)%?
	PRINTLC [ 0] Input
	PRINTLC [ 1] Restore to Default
	PRINTL [99] Cancel
	INPUT
	IF RESULT == 0
		PRINTL Enter a name for this Cowshed
		INPUTS
		SIF RESULTS != ""
			COWSHED_NAME:COWSHED_NUM = %RESULTS%
	ELSEIF RESULT == 1
		LOCALS = Cowshed %TOSTR(COWSHED_NUM)%
		COWSHED_NAME:COWSHED_NUM =%LOCALS%
	ENDIF

CASE 30
	COWSHED_NUM --
	SIF COWSHED_NUM < 1
		COWSHED_NUM = ITEM:牛舎

CASE 31
	COWSHED_NUM ++
	SIF COWSHED_NUM > ITEM:牛舎
		COWSHED_NUM = 1
	
CASE 99
	RETURN
ENDSELECT
RESTART



;牛舎に入れる
@COWSHED_MANAGE_PUTIN
#DIM DYNAMIC PAGE
#DIM DYNAMIC HIDE_CATTLE = 1

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML Select dairy cows to move into %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)%. Capacity：{COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3} 
PRINTL （Livestock in other Cowsheds are highlighted in blue）
DRAWLINE

;あんまり多くてもなので20匹ずつ表示
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	IF CFLAG:追跡対象
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(6)%：Not Captured","灰"
		CONTINUE
	ELSEIF CSTR:居場所 == "体内"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(6)%：In body","灰"
		CONTINUE
	ELSEIF !MARK:母乳体質
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(6)%：Not 【Lactating】","灰"
		CONTINUE
	ELSEIF CFLAG:牛舎番号 == COWSHED_NUM
		PRINTFORML %CALLNAME_DIGIT(6)%：%ITEMS_ENG(COWSHED_NAME:(CFLAG:牛舎番号))%
		CONTINUE
	ELSEIF HIDE_CATTLE && CFLAG:牛舎番号
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(6)%：%ITEMS_ENG(COWSHED_NAME:(CFLAG:牛舎番号))%","灰"
		CONTINUE
	ENDIF
	SIF CFLAG:牛舎番号
		SETCOLOR 0x50C0FF
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	RESETCOLOR
	CALL PRINT_POST_C
	CALL TABLE_STATUS("牛舎入れ")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  7] Other Cowsheds：\@ HIDE_CATTLE ? HIDE # SHOW \@
PRINTFORMLC [  8] Change Display Settings
PRINTL [ 99] Done
BINPUT
SELECTCASE RESULT
CASE 7
	INVERTBIT HIDE_CATTLE,0
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	SIF !CFLAG:調教可能 || !MARK:母乳体質
		RESTART
	CFLAG:牛舎番号 = COWSHED_NUM
	
	;自室があれば解除
	CALL RESET_SLAVE_ROOM("牛舎")
	
	;牛舎での搾乳専用スケジュール
	CSTR:スケジュール = 牛舎
	
	;居場所を牛舎にする
	CALL CHARA_WHEREABOUTS_TARGET
	FLAG:(FLAG_REF:2 +COWSHED_NUM *10) ++
	COWSHED_SLAVE ++
	IF COWSHED_SLAVE >= COWSHED_CAPACITY
		PRINTW This cowshed is now full
		RETURN
	ENDIF
ENDSELECT
RESTART



;牛舎から出す
@COWSHED_MANAGE_PUTOUT

;上手い方法が思いつかないので全員まとめて表示するよ
;30匹超えたあたりからそれはそれは大変になるけど一括とかでどうにか

CLEARLINE LINECOUNT
PRINTFORML Select livestock to move out of %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)%. Capacity：{COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3} 
DRAWLINE
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CFLAG:牛舎番号 != COWSHED_NUM
		CONTINUE
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("牛舎")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTFORMLC [  8] Change Display Settings
PRINTLC 　
PRINTL [ 99] Done
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	SIF CFLAG:牛舎番号 != COWSHED_NUM
		RESTART
	CFLAG:牛舎番号 = 0
	CALL CHARA_WHEREABOUTS_TARGET
	CALL SCHEDULE_RESET_TARGET
	FLAG:(FLAG_REF:2 +COWSHED_NUM *10) --
	COWSHED_SLAVE --
	IF !COWSHED_SLAVE
		PRINTW This cowshed is now empty
		RETURN
	ENDIF
ENDSELECT
RESTART



;まとめて移動
@COWSHED_MANAGE_MOVE
#DIM MOVE_COWSHED_NUM
#DIM MOVE_COWSHED_SLAVE
#DIM MOVE_COWSHED_CAPACITY
#DIM MOVE_COWSHED_DIFF

PRINTFORML Select the destination for livestock in %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)%. Capacity：{COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3} 
FOR LOCAL,1,11
	SIF LOCAL == COWSHED_NUM || LOCAL > ITEM:牛舎
		CONTINUE
	
	;移動先の乳牛頭数（現在・最大）を計算
	MOVE_COWSHED_SLAVE = CMATCH(CFLAG:牛舎番号,LOCAL)
	MOVE_COWSHED_CAPACITY = FLAG:(FLAG_REF +LOCAL *10) *10
	PRINTFORM [{LOCAL,2}] %ITEMS_ENG(COWSHED_NAME:LOCAL),20%：{MOVE_COWSHED_SLAVE,3}／{MOVE_COWSHED_CAPACITY,3} 
	
	;移動するスペースあるか計算
	MOVE_COWSHED_DIFF =  COWSHED_SLAVE +MOVE_COWSHED_SLAVE -MOVE_COWSHED_CAPACITY
	IF MOVE_COWSHED_DIFF <= 0
		CALL PRINTL_WORD_COLOR("Move Possible","水色")
	ELSE
		CALL PRINTL_WORD_COLOR,@"Move Impossible：Can't hold {MOVE_COWSHED_DIFF} cows","黄"
	ENDIF
NEXT
PRINTL [90] All Out of Cowshed
PRINTL
PRINTL [99] Cancel
BINPUT
PRINTL
IF RESULT == 90
	PRINTFORML Move all dairy cows out of %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)%?
	CALL ASK_YN
	SIF RESULT
		RETURN
	FOR TARGET_COUNT,1,CHARANUM
		TARGET = TARGET_COUNT
		SIF CFLAG:牛舎番号 != COWSHED_NUM
			CONTINUE
		CFLAG:牛舎番号 = 0
		CALL CHARA_WHEREABOUTS_TARGET
		CALL SCHEDULE_RESET_TARGET
	NEXT
ELSEIF RESULT > 0 && RESULT <= 11 && RESULT != COWSHED_NUM
	MOVE_COWSHED_NUM = RESULT
	SIF COWSHED_SLAVE +FLAG:(FLAG_REF:2 +MOVE_COWSHED_NUM *10) > (FLAG:(FLAG_REF +MOVE_COWSHED_NUM *10))*10
		RETURN
	PRINTFORML Move all of %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)%'s cows into %ITEMS_ENG(COWSHED_NAME:MOVE_COWSHED_NUM)%?
	CALL ASK_YN
	SIF RESULT
		RETURN
	FOR TARGET_COUNT,1,CHARANUM
		TARGET = TARGET_COUNT
		SIF CFLAG:牛舎番号 != COWSHED_NUM
			CONTINUE
		CFLAG:牛舎番号 = MOVE_COWSHED_NUM
		CALL CHARA_WHEREABOUTS_TARGET
	NEXT
ENDIF



;牛舎内家畜のステータス
@COWSHED_MANAGE_STATUS

CLEARLINE LINECOUNT
PRINTL View the detailed information of a selected dairy cow
DRAWLINE
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CFLAG:牛舎番号 != COWSHED_NUM
		CONTINUE
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("牛舎")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTFORMLC [  8] Change Display Settings
PRINTLC 　
PRINTL [ 99] Done
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	SIF CFLAG:牛舎番号 != COWSHED_NUM
		RESTART
	CALL SCHEDULE_PLAN("牛舎")
ENDSELECT
RESTART





