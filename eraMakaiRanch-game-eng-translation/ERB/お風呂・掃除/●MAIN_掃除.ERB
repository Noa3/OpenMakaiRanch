
;掃除
@MAIN_CLEANING
#DIM DUTY

;掃除当番指定
CALL CLEANING_DUTY_SELECT
DUTY = RESULT

;指定しない場合適当に済ませておわり
IF DUTY < 0
	PRINTL 　　　《 Cleaning 》
	PRINTW You decide to skip cleaning today.
	RETURN
ENDIF
TARGET = DUTY

;EXP入れするときのバグ防止
FLAG:作業ABL最大値 = ABL:掃除
PRINTL 　　　《 Cleaning 》

IF !EXP:実行回数／掃除
	KOJO_TYPE = 初回
ELSE
	KOJO_TYPE = 通常
ENDIF
CALL WORK_CLEANING_BEGIN_MESSAGE
CALL WORK_CLEANING_ABL_MESSAGE

;掃除したキャラの体力減少+経験値増加
CALL CLEANING_WORK
PRINTW
DRAWLINE



;掃除したキャラの体力減少+経験値増加
@CLEANING_WORK
#DIM CLEANING_ROOM

;消費体力：50 +調教可能なキャラの数*5 -掃除Lv *10(30～300)
;0になってもできることにしとく
CLEANING_ROOM = 0
SAVE_TARGET = TARGET
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:スケジュール設定可能／調教
		CONTINUE
	CLEANING_ROOM ++
NEXT
TARGET = SAVE_TARGET
COST = LIMIT(50 +CLEANING_ROOM *5 -ABL:掃除 *10,30,300)
PRINTFORM %CALLNAME%：
CALL HP_COST(COST)
CALL EXP_UP("掃除")
CALL SCHEDULE_AFTER_CATTLE_MIND_MINUS
CALL MIND_PALAM_AFTER_PRINT(1)
CALL ABL_UP
PRINTL
EXP:実行回数／掃除 ++
EXP:区間実行回数／掃除 ++
FLAG:あなた用風呂掃除完了 = 1
CALL WORK_CLEANING_COMPLETE_MESSAGE






