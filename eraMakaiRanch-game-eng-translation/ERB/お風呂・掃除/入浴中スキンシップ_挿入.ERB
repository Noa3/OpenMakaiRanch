
;風呂場Ｖ挿入
@BATHLOOM_V_INSERT

;ここで処女結界破壊はできないことにする
SIF TALENT:処女結界
	RETURN

;対面座位
V_PENIS = %CALLNAME:0%
SELECTCOM = 32
CALL COM32
IF !RESULT
	PRINTW 挿入するのはやめにした…
	RETURN
ENDIF
TFLAG:Ｖ装備 = 1
SETBIT ＃Ｐ使用／Ｖ挿入＃
LOSEBASE:体力 += 20
LOSEBASE:気力 += 30
CALL PRINT_IMAGE("調教実行")
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("調教コマンド",TRAINNAME:SELECTCOM,"実行")
EXP:(SELECTCOM +1000) ++
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++
TFLAG:コマンド中射精回数 = 0
IF !BASE:0:精力
	RESULT = 3
ELSE
	;継続コマンド選択
	PRINTL
	PRINTFORML [ 0] %SAVESTR:表記／乳房%を揉む
	PRINTFORML [ 1] %SAVESTR:表記／母乳%を吸う
	PRINTFORML [ 2] %SAVESTR:表記／精液%を注ぎ込む
	PRINTFORML [ 3] %SAVESTR:表記／ペニス%を引き抜く
	INPUT
	PRINTL
ENDIF
SELECTCASE RESULT
CASE 0
	CALL BATHLOOM_BUST_MASSAGE(1)
CASE 1
	CALL BATHLOOM_BUST_SUCK(1)
;CASE 2
CASE 3
	WAIT_SKIP = 1
	CALL COM890
	WAIT_SKIP = 0
	PRINTW
	RETURN
ENDSELECT
CALL EJACULATION_PISTON
PRINTW



