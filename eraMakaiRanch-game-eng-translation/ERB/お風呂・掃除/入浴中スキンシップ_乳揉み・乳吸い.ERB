
;風呂場で乳揉み
;ARG→1なら止めない（挿入中呼び出し）
@BATHLOOM_BUST_MASSAGE(ARG)

SELECTCOM = 10
LOSEBASE:体力 += 20
LOSEBASE:気力 += 20
SOURCE:Ｂ快楽／あなた責め = 2000
SOURCE:恥辱 = 1000
SOURCE:屈辱 = 300
SOURCE:情愛 = 2000
SOURCE:調教者習得 = 400
SOURCE:乳揉み = 1
CALL PRINT_IMAGE("調教実行")
CALL TRAIN_INSERT_MESSAGE
CALL BATHLOOM_BUST_MASSAGE_MESSAGE
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++
SIF !ARG
	PRINTW



;風呂場で乳吸い
;ARG→1なら止めない（挿入中呼び出し）
@BATHLOOM_BUST_SUCK(ARG)

SELECTCOM = 20
LOSEBASE:体力 += 20
LOSEBASE:気力 += 30
SOURCE:Ｂ快楽／あなた責め = 500
SOURCE:Ｎ快楽／あなた責め = 2000
SOURCE:恥辱 = 2000
SOURCE:情愛 = 5000
SOURCE:屈辱 = 2000
SOURCE:不潔 = 500
SOURCE:支配 = 2000
SOURCE:授乳 = 2000
SOURCE:調教者習得 = 400
TFLAG:搾乳責め = 1
TFLAG:乳吸い = 1
SIF ITEM:搾乳エナジードレイン && GETBIT(＃個人有効／搾乳エナジードレイン＃) && GETBIT(＃有効／搾乳エナジードレイン＃)
	TFLAG:エナジードレイン = 1
CALL PRINT_IMAGE("調教実行")
CALL TRAIN_INSERT_MESSAGE
CALL BATHLOOM_BUST_SUCK_MESSAGE
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++
SIF !ARG
	PRINTW


