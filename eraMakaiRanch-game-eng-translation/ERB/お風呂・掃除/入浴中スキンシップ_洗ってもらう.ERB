
;洗ってもらうコマンド
@BATHLOOM_PLAYER_WASHING

CALL MANYL(5)
IF TFLAG:浴槽内
	PRINTFORML %CALLNAME:0% and %CALLNAME% get out of the tub
	TFLAG:浴槽内 = 0
ENDIF

;娘が成長中なら普通に洗う一択
IF CSTR:状態／あなたの子 == "成長中"
	CALL BATHLOOM_PLAYER_WASHING_BODY
	PRINTW
	RETURN
ENDIF
PRINTL Select area to get washed
PRINTL
PRINTL [ 0] Whole Body Washed
PRINTFORML [ 1] Use %SAVESTR:表記／乳房% To Wash Body
IF !BASE:PLAYER:精力
	CALL PRINTL_WORD_COLOR,@"　%CALLNAME:PLAYER% vigor too low","灰"
	PRINTL
	PRINTL
ELSE
	PRINTFORML [ 2] Get %SAVESTR:表記／ペニス% Washed
	PRINTL [ 3] Get Paizuri
	PRINTFORML [ 4] Use %SAVESTR:表記／膣% To Wash %SAVESTR:表記／ペニス%
ENDIF
PRINTL
PRINTL [99] Cancel
BINPUT
PRINTL
IF CSTR:状態／あなたの子 == "成長後"
	SELECTCASE RESULT
	CASE IS != 0
		CHILD_COM = RESULT
		CALL CHILD_REBELLION
		SIF RESULT
			RETURN
		RESULT = CHILD_COM
	ENDSELECT
ENDIF
SELECTCASE RESULT
CASE 0
	CALL BATHLOOM_PLAYER_WASHING_BODY
CASE 1
	CALL BATHLOOM_PLAYER_WASHING_USE_BUST
CASE 2
	CALL BATHLOOM_PLAYER_WASHING_PENIS
	
	;RETURN 99してきてたらキャンセル
	SIF RESULT == 99
		RETURN
CASE 3
	CALL BATHLOOM_PLAYER_WASHING_PAIZURI
	SIF RESULT == 99
		RETURN
CASE 4
	CALL BATHLOOM_PLAYER_WASHING_USE_VAGINA
	SIF RESULT == 99
		RETURN
CASEELSE
	RETURN
ENDSELECT
PRINTW



;普通に洗ってもらう
@BATHLOOM_PLAYER_WASHING_BODY

CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_BODY_MESSAGE
SOURCE:情愛 += 1000
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++



;おっぱい洗い
@BATHLOOM_PLAYER_WASHING_USE_BUST

CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_USE_BUST_MESSAGE
LOSEBASE:体力 += 50
LOSEBASE:気力 += 30
SOURCE:Ｂ快楽 = 2000
SOURCE:Ｎ快楽 = 1000
SOURCE:習得 = 2000
SOURCE:恥辱 = 1000
SOURCE:情愛 = 3000
SOURCE:屈辱 = 500
SOURCE:支配 = 500
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++



;ちんぽ洗ってもらう
@BATHLOOM_PLAYER_WASHING_PENIS

;手コキを呼ぶ→奉仕不可なら帰る
CALL COM57
SIF !RESULT
	RETURN 99
LOSEBASE:体力 += 20
LOSEBASE:気力 += 20
SOURCE:不潔 = 0
CALL PRINT_IMAGE("奉仕")
CALL BATHLOOM_PLAYER_WASHING_PENIS_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("調教コマンド",TRAINNAME:SELECTCOM,"実行")
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++
PRINTL
CALL EJACULATION_PISTON



;パイズリ洗い
@BATHLOOM_PLAYER_WASHING_PAIZURI

SELECTCOM = 53
CALL COM53
SIF !RESULT
	RETURN 99
SETBIT ＃Ｐ使用／パイズリ＃
LOSEBASE:体力 += 20
LOSEBASE:気力 += 20
SOURCE:不潔 = 0
CALL PRINT_IMAGE("パイズリ")
CALL BATHLOOM_PLAYER_WASHING_PAIZURI_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("調教コマンド",TRAINNAME:SELECTCOM,"実行")
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++
PRINTL
CALL EJACULATION_PISTON



;騎乗位ちんぽ洗い
@BATHLOOM_PLAYER_WASHING_USE_VAGINA

;騎乗位かどうかで奉仕判定変化するので先にSELECTCOM設定
SELECTCOM = 34
CALL COM34
SIF !RESULT
	RETURN 99
TFLAG:Ｖ装備 = 1
SETBIT ＃Ｐ使用／Ｖ挿入＃
LOSEBASE:体力 += 20
LOSEBASE:気力 += 20
SOURCE:不潔 = 0
PALAM:Ｖ潤滑 += 3000
CALL PRINT_IMAGE("調教実行")
CALL BATHLOOM_PLAYER_WASHING_USE_VAGINA_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("調教コマンド",TRAINNAME:SELECTCOM,"実行")
EXP:(SELECTCOM +1000) ++
SELECTCOM = 0
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++
PRINTL
CALL EJACULATION_PISTON



