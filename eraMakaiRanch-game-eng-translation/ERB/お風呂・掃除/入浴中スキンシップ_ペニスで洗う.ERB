
;おまんこをペニスで洗う？
@BATHLOOM_SLAVE_WASHING_V_IN_PENIS

;洗うと言えるか？なので共通を使わない
;ここで処女結界破壊はできないことにする
;RETURN99でキャンセルする
SIF TALENT:処女結界
	RETURN 99

;正常位
V_PENIS = %CALLNAME:0%
SELECTCOM = 30
CALL COM30
IF !RESULT
	PRINTW 挿入するのはやめにした…
	RETURN 99
ENDIF
TFLAG:Ｖ装備 = 1
SETBIT ＃Ｐ使用／Ｖ挿入＃

;洗うので不潔ではないのと潤滑増加
SOURCE:不潔 = 0
PALAM:Ｖ潤滑 += 3000
LOSEBASE:体力 += 20
LOSEBASE:気力 += 40

;地の文をキャンセルしてくるのでここで書く
CALL PRINT_IMAGE("調教実行")
CALL BATHLOOM_SLAVE_WASHING_V_IN_PENIS_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("調教コマンド",TRAINNAME:SELECTCOM,"実行")
EXP:(SELECTCOM +1000) ++
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++

;1回リセット
TFLAG:コマンド中射精回数 = 0
IF !BASE:0:精力
	RESULT = 3
ELSE
	PRINTL
	;継続コマンド選択
	PRINTFORML [ 0] %SAVESTR:表記／乳房%を揉む
	PRINTFORML [ 1] %SAVESTR:表記／母乳%を吸う
	PRINTFORML [ 2] %SAVESTR:表記／精液%を注ぎ込む
	PRINTFORML [ 3] %SAVESTR:表記／ペニス%を引き抜く
	INPUT
	PRINTL
ENDIF
SELECTCASE RESULT
CASE 0
	;挿入状態からの乳揉み呼び出し
	CALL BATHLOOM_BUST_MASSAGE(1)
CASE 1
	CALL BATHLOOM_BUST_SUCK(1)
;CASE 2
	;一度射精してても再度射精まで行動
CASE 3
	;基本的にWAIT入れるとこを飛ばす
	WAIT_SKIP = 1
	CALL COM890
	WAIT_SKIP = 0
	PRINTW
	RETURN
ENDSELECT

;あとは射精までピストンする
CALL EJACULATION_PISTON



;アナルをペニスで洗う　ほんとか？
@BATHLOOM_SLAVE_WASHING_A_IN_PENIS

;Ａ後背位
A_PENIS = %CALLNAME:0%
SELECTCOM = 41
CALL COM41
IF !RESULT
	PRINTW 挿入するのはやめにした…
	RETURN 99
ENDIF
TFLAG:Ａ装備 = 1
SETBIT ＃Ｐ使用／Ａ挿入＃

;洗うので若干不潔ではないのと潤滑増加
SOURCE:不潔 /= 2
LOSEBASE:体力 += 30
LOSEBASE:気力 += 60
PALAM:Ａ潤滑 += 3000
CALL PRINT_IMAGE("調教実行")
CALL BATHLOOM_SLAVE_WASHING_A_IN_PENIS_MESSAGE
CALL LOST_VARGIN
CALL LOST_VARGIN_PLAYER
CALL KOJO_PRINT("調教コマンド",TRAINNAME:SELECTCOM,"実行")
EXP:(SELECTCOM +1000) ++
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++
TFLAG:コマンド中射精回数 = 0
IF !BASE:0:精力
	RESULT = 3
ELSE
	PRINTL
	;継続コマンド選択　後背位から吸えない
	PRINTFORML [ 0] %SAVESTR:表記／乳房%を揉む
	PRINTFORML [ 2] %SAVESTR:表記／精液%を注ぎ込む
	PRINTFORML [ 3] %SAVESTR:表記／ペニス%を引き抜く
	INPUT
	PRINTL
ENDIF
SELECTCASE RESULT
CASE 0
	CALL BATHLOOM_BUST_MASSAGE(1)
CASE 3
	WAIT_SKIP = 1
	CALL COM890
	WAIT_SKIP = 0
	PRINTW
	RETURN
ENDSELECT
CALL EJACULATION_PISTON


