
;体を洗うコマンド
@BATHLOOM_SLAVE_WASHING

CALL MANYL(5)
IF TFLAG:浴槽内
	PRINTFORML %CALLNAME:0% and %CALLNAME% get out of the tub
	TFLAG:浴槽内 = 0
ENDIF

;成長中の娘は普通洗い一択
IF CSTR:状態／あなたの子 == "成長中"
	CALL BATHLOOM_SLAVE_WASHING_BODY
	CALL SOURCE_CHECK
	TFLAG:スキンシップ回数 ++
	PRINTW
	RETURN
ENDIF
PRINTL Select area to wash
PRINTL
PRINTL [ 0] Wash Whole Body
PRINTFORMLC [ 1] Carefully Wash %SAVESTR:表記／乳房%
PRINTLC [ 2] Carefully Wash Nipples
PRINTFORML [ 3] Carefully Wash %SAVESTR:表記／陰核%
PRINTL
IF !TALENT:処女結界
	PRINTFORMLC [ 4] Carefully Wash %SAVESTR:表記／膣%
	IF !BASE:PLAYER:精力
		CALL PRINTL_WORD_COLOR,@"　Insertion not possible, %CALLNAME:PLAYER%'s vigor is too low","灰"
		PRINTL
	ELSEIF PLAYER_PENIS
		PRINTFORML [ 5] Wash %SAVESTR:表記／膣% Using %SAVESTR:表記／ペニス%
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR("　Blocked by【Virginity Barrier】","灰")
ENDIF
PRINTFORMLC [ 6] Carefully Wash %SAVESTR:表記／アナル%
IF !BASE:PLAYER:精力
	CALL PRINTL_WORD_COLOR,@"　Insertion not possible, %CALLNAME:PLAYER%'s vigor is too low","灰"
	PRINTL
ELSEIF PLAYER_PENIS
	PRINTFORML [ 7] Wash %SAVESTR:表記／アナル% Using %SAVESTR:表記／ペニス%
ENDIF
PRINTL
PRINTL [99] Cancel
BINPUT
PRINTL
IF CSTR:状態／あなたの子 == "成長後"
	SELECTCASE RESULT
	CASE IS != 0
		CHILD_COM = RESULT
		CALL CHILD_REBELLION
		SIF RESULT
			RETURN
		RESULT = CHILD_COM
	ENDSELECT
ENDIF
SELECTCASE RESULT
CASE 0
	CALL BATHLOOM_SLAVE_WASHING_BODY
CASE 1
	CALL BATHLOOM_SLAVE_WASHING_BUST
CASE 2
	CALL BATHLOOM_SLAVE_WASHING_NIPPLE
CASE 3
	CALL BATHLOOM_SLAVE_WASHING_CLITORIS
CASE 4
	CALL BATHLOOM_SLAVE_WASHING_VAGINA
CASE 5
	CALL BATHLOOM_SLAVE_WASHING_V_IN_PENIS
	
	;RETURN 99してきてたらキャンセル
	SIF RESULT == 99
		RETURN
CASE 6
	CALL BATHLOOM_SLAVE_WASHING_ANAL
CASE 7
	CALL BATHLOOM_SLAVE_WASHING_A_IN_PENIS
	SIF RESULT == 99
		RETURN
CASEELSE
	RETURN
ENDSELECT
CALL SOURCE_CHECK
TFLAG:スキンシップ回数 ++
PRINTW



;全部位共通
@BATHLOOM_SLAVE_WASHING_COMMON_SOURCE

;部位洗いには快楽値含めないことにした　変なタイミングで絶頂するので
SOURCE:恥辱 = 300
SOURCE:情愛 = 300
SOURCE:屈辱 = 100
SOURCE:支配 = 200
SOURCE:調教者習得 = 100
CALL PRINT_IMAGE("調教実行")



;全身洗い
@BATHLOOM_SLAVE_WASHING_BODY

;全部位共通の感情SOURCE呼び
CALL BATHLOOM_SLAVE_WASHING_COMMON_SOURCE
CALL BATHLOOM_SLAVE_WASHING_BODY_MESSAGE

IF GROUPMATCH(CSTR:状態／あなたの子,"成長中","成長後")
	SOURCE:Ａ快楽／あなた責め = 300
	SOURCE:Ｂ快楽／あなた責め = 300
	SOURCE:Ｃ快楽／あなた責め = 300
	SOURCE:Ｎ快楽／あなた責め = 300
	SIF !TALENT:処女結界
		SOURCE:Ｖ快楽／あなた責め = 300
	SOURCE:情愛 += 1000
ELSE
	CALL MIND_BASE_DIRECT_PLUS("好感度",50)
ENDIF



