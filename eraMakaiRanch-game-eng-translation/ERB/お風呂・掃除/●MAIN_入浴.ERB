
;入浴
@MAIN_BATHING

;あなた用風呂
CALL MANYL(3)
PRINTL 　　　《 Bathing 》
CALL MAIN_BATHING_PLAYER
SIF WAIT_ON
	PRINTW
WAIT_ON = 0
DRAWLINE

;大浴場があれば大浴場、なければシャワー
CALL MAIN_BATHING_LARGE

;RETURN 99してきてたら止めない
SIF RESULT == 99
	RETURN
PRINTW
DRAWLINE



;あなた用風呂
@MAIN_BATHING_PLAYER

;掃除してない場合適当にシャワー
IF !FLAG:あなた用風呂掃除完了
	PRINTFORML %CALLNAME:0% takes a shower.
	WAIT_ON ++
	RETURN
ENDIF

;でかい浴槽作ってる場合二人で入れる
TARGET = -1
IF ITEM:家族風呂
	PRINTFORML %CALLNAME:0% decides to take a bath.
	PRINTL Invite a slave to bathe with you?
	CALL ASK_YN
	PRINTL
	SIF !RESULT
		CALL SELECT_TOGETHER_BATHING_SLAVE
ENDIF

;呼ばない、家族風呂がない場合あなただけ
IF TARGET <= 0
	TARGET = 0
	CALL MAIN_BATHING_PLAYER_SOLO_MESSAGE
	HEAL_PRINT_DONE = 0
	CALL BATHING_HEAL
	CALL SORO_BATHLOOM_AFTER
	RETURN
ENDIF
CALL MAIN_BATHING_PLAYER_DUO_BEFORE_MESSAGE
CALL BEFORE_TRAIN_AJUST_STRIP_FLAG

;フラグ立て→一時的脱衣の判定を全てON→脱衣処理
CALL TRAIN_CLOTHE_STRIP_SENTENCE_FLAG
VARSET TFLAG,1,120,145
CALL AJUST_STRIP_FLAG
CALL MAIN_BATHING_PLAYER_DUO_MESSAGE
HEAL_PRINT_DONE = 0
CALL DUO_BATHING_HEAL
PRINTW

;スキンシップ（セクハラ）
CALL PLAY_BATHLOOM_BEFORE



;大浴場またはシャワー
@MAIN_BATHING_LARGE

;大浴場がないか掃除完了してないならシャワー
IF !ITEM:大浴場 || FLAG:大浴場掃除完了度 < 100
	;表示する奴隷検索
	CALL BATHING_LARGE_PRINT_SLAVE_SEARCH
	
	;RETURN 99ならこちらも99で終了
	SIF RESULT == 99
		RETURN 99
	
	;保存したTARGETでメッセージ
	TARGET = SAVE_TARGET
	CALL MAIN_BATHING_SLAVE_SHOWER_MESSAGE
	
	;こっちは回復処理が入らないのでおわり
	RETURN
ENDIF

CALL BATHING_LARGE_PRINT_SLAVE_SEARCH
SIF RESULT == 99
	RETURN 99
TARGET = SAVE_TARGET
CALL MAIN_BATHING_SLAVE_LARGE_BATH_MESSAGE
HEAL_PRINT_DONE = 0
CALL BATHING_HEAL

;次のまとめて処理部分で飛ばすため
CFLAG:行動済み = 1

;他のキャラの回復処理
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:調教可能 || CFLAG:行動済み || CFLAG:崩壊 || (!＃陥落状態／屈服以上＃ && !CFLAG:入浴許可)
		CONTINUE
	CALL BATHING_HEAL
NEXT

;大浴場を使用した場合フラグリセット
FLAG:大浴場掃除完了度 = 0



;表示する奴隷検索
@BATHING_LARGE_PRINT_SLAVE_SEARCH

SAVE_TARGET = 0
EXIST = 0
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	
	;あなた風呂に呼んでない、崩壊してない
	;屈服or陥落で風呂の許可降りることにしてる
	;または個別に入浴許可
	SIF !CFLAG:調教可能 || CFLAG:行動済み || CFLAG:崩壊 || (!＃陥落状態／屈服以上＃ && !CFLAG:入浴許可)
		CONTINUE
	EXIST ++
	
	;EXIST分の1でSAVE_TARGET上書き
	;後になるほど上書き＝メッセージ表示の確率下がる
	SIF !RAND:EXIST
		SAVE_TARGET = TARGET
NEXT

;最後まで該当者不在の場合RETURN 99
SIF !EXIST
	RETURN 99





