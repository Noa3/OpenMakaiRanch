
;スキンシップ前のフラグ処理
@PLAY_BATHLOOM_BEFORE

CALL RESET_TRAIN_PALAM
VARSET TFLAG,1,120,145
CALL AJUST_STRIP_FLAG
TFLAG:スケジュール外Ｈ = 1
PLAYER = MASTER

;ちんぽチェック
CALL PLAYER_PENIS_CHECK

;浴槽内かどうか判定するのでまず入る
TFLAG:浴槽内 = 1
TFLAG:浴室 = 1
;お湯で潤滑増える
PALAM:Ｖ潤滑 += 5000
PALAM:Ａ潤滑 += 5000

;TARGETの保存が必要
SAVE_TARGET = TARGET
CALL PLAY_BATHLOOM

;リセット前にTARGET戻しが必要
TARGET = SAVE_TARGET
CALL RESET_TRAIN_PALAM
CALL RESET_TIME_FLAG

;行動済みにして大浴場をキャンセルさせる
CFLAG:SAVE_TARGET:行動済み = 1



;お風呂でスキンシップ
@PLAY_BATHLOOM

;行動でHP増減するので毎回個人の業務可能チェックを入れる
CALL TARGET_SCHEDULE_POSSIBLE

;毎回汚れをリセット
RESET_STAIN 0
RESET_STAIN TARGET
TFLAG:スケジュール外Ｈ = 1

;スケジュール外でのリセット
VARSET TFLAG,0,30,100
VARSET TEQUIP

;全部WAITスキップでOK
TFLAG:Ｐ引き抜き後WAITスキップ = 1
CALL MANYL(5)
CALL SHOW_SLAVE_STATE(2)
	;CALL KOJO_PRINT("訪問","入口")
PRINTL

;浴槽に入ってるかどうか判定
IF TFLAG:浴槽内
	PRINTL 　＜Inside Bathtub＞
ELSE
	PRINTL 　＜Bathroom＞
ENDIF
CALL BATHLOOM_COMMAND_CHECK
CALL MANYL(3)
DRAWLINE
PRINTFORML [99] End Bathing Session（Elapsed Time：{TFLAG:スキンシップ回数}）
BINPUT
IF CSTR:状態／あなたの子 == "成長後"
	SELECTCASE RESULT
	CASE 2,4,11
		CHILD_COM = RESULT
		CALL CHILD_REBELLION
		SIF RESULT
			RESTART
		RESULT = CHILD_COM
	ENDSELECT
ENDIF
SELECTCASE RESULT
CASE 0
	;[会いに行く]内と共通
	CALL VISIT_STROKING_HEAD
CASE 1
	CALL VISIT_KISS
CASE 2
	CALL BATHLOOM_BUST_MASSAGE
CASE 3
	CALL BATHLOOM_SLAVE_WASHING
CASE 4
	CALL BATHLOOM_V_INSERT
CASE 10
	CALL BATHLOOM_PLAYER_WASHING
CASE 11
	CALL VISIT_BREAST_FEEDING
CASE 99
	CALL PLAY_BATHLOOM_AFTER
	RETURN
ENDSELECT

;回数制限撤廃ならここで回数を0
SIF GETBIT(＃制限撤廃／家族風呂＃)
	TFLAG:スキンシップ回数 = 0

;6回スキンシップするとのぼせておわり　HP-100
IF TFLAG:スキンシップ回数 > 5
	COST = 100
	PRINTFORML %CALLNAME:0% and %CALLNAME% got too heated...　HP-{COST}
	CALL PLAYER_HP_COST(COST,1)
	CALL HP_COST(COST,1)
	WAIT_ON ++
	RETURN
ENDIF

;風呂は体力なくなったらおわり
IF !BASE:体力
	PRINTFORML %CALLNAME% seems to be exhausted...
	PRINTFORML Let's get her out of here before she gets cooked.
	WAIT_ON ++
	RETURN
ENDIF
RESTART



