
;風呂に呼ぶ奴隷選択
@SELECT_TOGETHER_BATHING_SLAVE
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML %CALLNAME:0% takes a bath with a slave
PRINTL
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	
	;牛舎→OK　未捕獲→NG　体内→NG
	IF CFLAG:追跡対象
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：Not captured","灰"
		CONTINUE
	ELSEIF CSTR:居場所 == "体内"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：In body","灰"
		CONTINUE
	ELSEIF !CFLAG:調教可能
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：Can't be trained","灰"
		CONTINUE
	ELSEIF EQUIP:魔力枷
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：Restrained with Mana Shackles","灰"
		CONTINUE
	ENDIF
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	IF CFLAG:牛舎番号
		CALL PRINT_WORD_COLOR("[Cowshed] ","黄")
	ELSE
		PRINT 　　　 
	ENDIF
	CALL TABLE_STATUS("風呂")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] Change display items
PRINTLC   
PRINTL [ 99] Enter alone
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	TARGET = -1
	RETURN

CASEELSE
	TARGET = RESULT -100
	SIF !CFLAG:調教可能
		RESTART
	RETURN
ENDSELECT
RESTART


