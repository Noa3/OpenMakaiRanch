
;名前による毛並みと性別補正
@NAMING_PET_NAME_FIX

SELECTCASE ANIMAL
CASE "堕天馬"
	CALL NAMING_PET_NAME_FIX_HORSE
CASE "オルトロス"
	CALL NAMING_PET_NAME_FIX_DOG
CASE "魔界ハムスター"
	CALL NAMING_PET_NAME_FIX_HAMSTER
ENDSELECT



;ｳﾏﾁｬﾝ
;候補に上がってるやつ以外はキリがないのでやめ
@NAMING_PET_NAME_FIX_HORSE

SELECTCASE PET_NAME
CASE "シュナイダー","健太"
	PET_GENDER = 1
CASE "赤兎馬"
	PET_COAT = 赤毛
CASE "松風"
	PET_COAT = 鹿毛
CASE "グルファクシ"
	PET_COAT = 金色
CASE "牧場王"
	PET_COAT = 白馬
	PET_GENDER = 1
CASE "マカマカ"
	PET_COAT = 黒鹿毛
	PET_GENDER = 0
CASE "オダシ"
	PET_COAT = 白馬
	PET_GENDER = 0
CASE "黒王号","カスタード"
	PET_COAT = 黒毛
	PET_GENDER = 1
CASE "スイーツコウジョウ"
	PET_COAT = 鹿毛
	PET_GENDER = 0
CASE "エポナ"
	PET_COAT = 尾花栗毛
	PET_GENDER = 0
ENDSELECT



