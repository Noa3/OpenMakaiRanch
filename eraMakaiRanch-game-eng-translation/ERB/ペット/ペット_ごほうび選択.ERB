
;ごほうび選択
;TARGET,ANIMAL,PET_NAME指定済み
@MASTER_REWORD_ANIMAL_SELECT

;撫でバリエーション　結果はどれも同じ
CALL PET_STROKE_SENTENCE

;ペット対応のおやつチェック
CALL SELECT_PET_SNACK
INPUT
PRINTL

;1かつおやつを持ってると使用
IF RESULT && ITEM:ITEM_NUM
	CALL PET_COMMU_SNACK(ITEM_NUM)
ELSE
	CALL PET_COMMU_STROKE
ENDIF
PRINTW



;バリエーションに意味はない撫で選択肢
@PET_STROKE_SENTENCE

STR_REF = 8100
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)
PRINTFORMLC [ 0] %RESULTS%
PRINTL



;ペット対応のおやつチェック
@SELECT_PET_SNACK

SELECTCASE ANIMAL
CASE "堕天馬"
	ITEM_NUM = GETNUM(ITEM,"ガッツニンジン")
CASE "オルトロス"
	ITEM_NUM = GETNUM(ITEM,"謎肉ジャーキー")
CASE "魔界ハムスター"
	ITEM_NUM = GETNUM(ITEM,"煎り魔界ひまわりの種")
ENDSELECT

;持っているなら表示+個数+今の体型
IF ITEM:ITEM_NUM
	PRINTFORM [ 1] Give ＜%ITEMS_ENG(ITEMNAME:ITEM_NUM)%＞：{ITEM:ITEM_NUM} Owned　
	CALL PRINT_PET_SHAPE(ANIMAL,0,1)
ELSE
	CALL PRINTL_WORD_COLOR,@"　　 %ITEMS_ENG(ITEMNAME:ITEM_NUM)%：0","灰"
ENDIF



;ペットなでなで
;TARGET,ANIMAL,PET_NAME指定済み
@PET_COMMU_STROKE

;地の文呼び出し
CALL PET_COMMU_MESSAGE_STROKE

;なつき度増加倍率算出→増加
PRINT [
CALL PET_FRIENDRY_TIMES_CALC("撫で")
CALL PET_FRIENDRY_PLUS(RESULT,50)
PRINTL ]



;ペットにおやつ
;TARGET,ANIMAL,PET_NAME指定済み
;ARG→アイテムNO
@PET_COMMU_SNACK(ARG)

CALL PET_COMMU_MESSAGE_SNACK(ARG)
PRINT [
CALL PET_FRIENDRY_TIMES_CALC("おやつ")
CALL PET_FRIENDRY_PLUS(RESULT,300)

;体型増加
CALL PET_WEIGHT_PLUS(ARG)
PRINTL ]
ITEM:ARG --






