
;オルトロスの名前特殊処理
;ARG→FUNNY_NAME（ネタ名表示）
@NAMING_PET_ORTHROS_NAME_METHOD(ARG)

SIF ANIMAL != "オルトロス"
	RETURN
PRINTL 名付け方式を選択してください。
PRINTLC [ 0] 1つの名前をつける（1つ目の名前以降リセット）
PRINTLC [ 1] 左右の頭にそれぞれ名付ける
PRINTL [99] Cancel
INPUT
SELECTCASE RESULT
CASE 0
	PET_NAME:1 =
	PET_NAME:2 =
CASE 1
	PRINTL 兄／姉の頭の名前を入力してください。
	CALL ORTHROS_NAME_INPUT(ARG)
	SIF RESULTS == ""
		RETURN
	PET_NAME = %RESULTS%
	CALL ORTHROS_NAME_JOINT_INPUT
	SIF RESULTS == ""
		RETURN
	PET_NAME:1 = %RESULTS%
	PRINTL
	PRINTL 弟／妹の頭の名前を入力してください。
	CALL ORTHROS_NAME_INPUT(ARG)
	PET_NAME:2 = %RESULTS%
	
	;空欄になったら接続詞も消す
	SIF PET_NAME:2 == ""
		PET_NAME:1 =
ENDSELECT



;オルトロスの名前候補
@ORTHROS_NAME_INPUT(ARG)
#DIM LOOP_REF

STR_REF = 20200
LOOP_REF = 20210
SIF ARG
	LOOP_REF = 20300
BR = 0
FOR LOCAL,STR_REF,LOOP_REF
	SIF STR:LOCAL == ""
		CONTINUE
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
NEXT
CALL INPUTBUTTON
INPUT
SELECTCASE RESULT
CASE 0 TO 99
	RESULTS = %STR:(STR_REF +RESULT)%
CASE 901
	PRINTL Enter a name
	INPUTS
	RETURN
CASEELSE
	RESULTS =
ENDSELECT



;接続詞入力
@ORTHROS_NAME_JOINT_INPUT

STR_REF = 8120
PRINTL
PRINTL 地の文・表記上での接続詞を選択してください。
CALL PRINTL_WORD_COLOR("半角の「&」はバグを引き起こす気がするので避けるといいと思われます。","黄")
BR = 0
FOR LOCAL,STR_REF,STR_REF +10
	SIF STR:LOCAL == ""
		CONTINUE
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL -STR_REF,3}] %STR:LOCAL%
NEXT
CALL INPUTBUTTON
INPUT
SELECTCASE RESULT
CASE 0 TO 9
	RESULTS = %STR:(STR_REF +RESULT)%
CASE 901
	PRINTL 接続詞を入力してください。
	INPUTS
	RETURN
CASEELSE
	RESULTS =
ENDSELECT




