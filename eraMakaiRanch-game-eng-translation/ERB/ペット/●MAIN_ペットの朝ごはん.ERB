
;ペットの朝ごはん
@PET_BREAKFAST
#DIM FOOD_TYPE
#DIM HEALTH_LIMIT

;とりあえずあなたが毎日あげる
;魔界乳牛は健康度以外作ってないので各ごはんで健康度増加
;元々90以下か上かで上限値変更
IF FLAG:乳牛健康度 > 90
	HEALTH_LIMIT = 100
ELSE
	HEALTH_LIMIT = 90
ENDIF
SELECTCASE FLAG:ごはん種類／魔界乳牛
CASE 1,2
	HEAL = 1
CASE 3
	HEAL = 3
CASEELSE
	HEAL = 0
ENDSELECT
FLAG:乳牛健康度 = LIMIT(FLAG:乳牛健康度 +HEAL,0,HEALTH_LIMIT)
PRINTFORML       Dairy Cows→%PRINT_PET_FOOD("魔界乳牛")%　【Health】+{HEAL} → {FLAG:乳牛健康度} 

CALL GET_PET_FLAG_REF
FOR LOCAL,0,20
	ANIMAL = %ITEMNAME:(ITEM_REF +LOCAL)%
	SIF ANIMAL == "" || !ITEM:ANIMAL
		CONTINUE
	PET_NAME = %PET_NAME_REF(ANIMAL)%
	PRINTFORM %PET_NAME,16%→%PRINT_PET_FOOD(ANIMAL)%　
	
	;ごはん種類による体型補正・なつき度増加
	FOOD_TYPE = FLAG:(FLAG_REF:2 +LOCAL)
	PRINT 【
	CALL PET_BREAKFAST_WEIGHT_FIX(FOOD_TYPE)
	CALL PET_BREAKFAST_FRIENDRY(FOOD_TYPE)
	PRINTL 】
NEXT
CALL MANYL(2)



;ごはん種類による体型補正
;ARG→FOOD_TYPE
@PET_BREAKFAST_WEIGHT_FIX(ARG)
#DIM WEIGHT_PLUS

FLAG_NAME = 体型／%ANIMAL%
WEIGHT_PLUS = PET_FOOD_WEIGHT_FIX:ARG
CALL RANDOM_FIX(WEIGHT_PLUS,10,"栄養")
WEIGHT_PLUS += FIX

;ごはんごとのベース体型値より下→上げる、上→下げる
;+-500だと半減・+-100は増減なし
SIF ABS(PET_FOOD_WEIGHT_BASE:ARG -FLAG:FLAG_NAME) <= BREAKFAST_WEIGHT_FIX_HALF
	WEIGHT_PLUS /= 2
SIF ABS(PET_FOOD_WEIGHT_BASE:ARG -FLAG:FLAG_NAME) <= BREAKFAST_WEIGHT_FIX_ZERO
	WEIGHT_PLUS = 0

IF PET_FOOD_WEIGHT_BASE:ARG >= FLAG:FLAG_NAME
	FLAG:FLAG_NAME = LIMIT(FLAG:FLAG_NAME +WEIGHT_PLUS,0,ANIMAL_WEIGHT_MAX)
	PRINTFORM Body Shape+{WEIGHT_PLUS} → {FLAG:FLAG_NAME /100}\% 
ELSE
	FLAG:FLAG_NAME = LIMIT(FLAG:FLAG_NAME -WEIGHT_PLUS,0,ANIMAL_WEIGHT_MAX)
	PRINTFORM Body Shape-{WEIGHT_PLUS} → {FLAG:FLAG_NAME /100}\% 
ENDIF



;なつき度増加
@PET_BREAKFAST_FRIENDRY(ARG)
#DIM FRIENDRY_PLUS

FRIENDRY_PLUS = PET_FOOD_FRIENDRY:ARG
CALL PET_FRIENDRY_TIMES_CALC("朝ごはん")
CALL PET_FRIENDRY_PLUS(RESULT,FRIENDRY_PLUS)


