
;なつき度増加倍率算出
;TARGET,ANIMAL,PET_NAME指定済み
;ARGS→シチュ
@PET_FRIENDRY_TIMES_CALC(ARGS)
#DIM MAG

;100%から
MAG = 100
IF TALENT:動物に好かれる
	MAG += 50
ELSEIF TALENT:動物に嫌われる
	MAG -= 50
ENDIF
SIF ANIMAL == "堕天馬" && TALENT:天界種族
	MAG -= 30

;30～200%
MAG = LIMIT(MAG,30,200)

;おやつをあげる場合は最低倍率50%まで上げる
SIF ARGS == "おやつ"
	MAG = LIMIT(MAG,50,200)
RETURN MAG



;なつき度増加
;TARGET,ANIMAL,PET_NAME指定済み
;ARG→計算した倍率
;ARG:1→基礎値
@PET_FRIENDRY_PLUS(ARG,ARG:1)

FLAG_NAME = なつき度／%ANIMAL%
LOVE = ARG:1 *ARG /100
CALL RANDOM_FIX(LOVE,10,"なつき度")
LOVE += FIX
BASE:FLAG_NAME = LIMIT(BASE:FLAG_NAME +LOVE,0,MAXBASE:FLAG_NAME)
PRINTFORM Affection +{LOVE} → {BASE:FLAG_NAME/100,3}\% 
CALL PRINT_FRIENDRY_PLUS_EFFECT



;なつき度増加の影響表示
;TARGET,ANIMAL,PET_NAME指定済み
@PRINT_FRIENDRY_PLUS_EFFECT

SIF !GETBIT(＃影響要素表示／なつき度＃)
	RETURN
SIF TALENT:動物に好かれる
	PRINT 【Loved by Animals】
SIF TALENT:動物に嫌われる
	PRINT 【Hated By Animals】
SIF ANIMAL == "堕天馬" && TALENT:天界種族
	PRINT 【天界種族】



;体型増加
;ARG→アイテムNO
@PET_WEIGHT_PLUS(ARG)
#DIM CAL

;増加量参照
SELECTCASE ITEMNAME:ARG
CASE "ガッツニンジン","謎肉ジャーキー"
	CAL = 400
CASE "煎り魔界ひまわりの種"
	CAL = 800
ENDSELECT
FLAG_NAME = 体型／%ANIMAL%
CALL RANDOM_FIX(CAL,10,"栄養")
CAL += FIX
FLAG:FLAG_NAME = LIMIT(FLAG:FLAG_NAME +CAL,0,ANIMAL_WEIGHT_MAX)
PRINTFORM 体型+{CAL} → {FLAG:FLAG_NAME /100}\% 



;体形減少
;ARG→減少基礎値
@PET_WEIGHT_MINUS(ARG)

;ARG=0ならおわり
SIF !ARG
	RETURN
FLAG_NAME = 体型／%ANIMAL%
COST = ARG
CALL RANDOM_FIX(COST,10,"運動量")
COST += FIX

;体形半分以下の時は半減する
SIF FLAG:FLAG_NAME < ANIMAL_WEIGHT_MAX /2
	COST /= 2
FLAG:FLAG_NAME = LIMIT(FLAG:FLAG_NAME -COST,0,ANIMAL_WEIGHT_MAX)
PRINTFORM Body Shape -{COST} → {FLAG:FLAG_NAME /100}\% 





