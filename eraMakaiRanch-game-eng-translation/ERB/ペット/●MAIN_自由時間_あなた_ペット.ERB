
;ペットと過ごす選択後
;ARG→RESULT-1
@MASTER_PLAY_ANIMAL_SELECT(ARG)

;ITEM:堕天馬→100
ANIMAL = %ITEMNAME:(100 +ARG)%
PET_NAME = %PET_NAME_REF(ANIMAL)%
CALL MANYL(3)
PRINTFORML What do you want to do with %PET_NAME%?　Today's weather：【%WEATHER_ENG(SAVESTR:天気／今日)%】
CALL MASTER_PLAY_ANIMAL_LIST
BINPUT
IF RESULT == 98
	CALL BROWSE_HINT("ペットと遊ぶ")
	RESTART
ENDIF
CALL FREE_TIME_PLAY_ANIMAL(RESULT)
CALL MASTER_REWORD_ANIMAL_SELECT

;回復入れる
PRINTFORM %CALLNAME% spent time with %PET_NAME% and recovered health…　
CALL PLAY_ANIMAL_AFTER_HEAL
PRINTW



;選択肢
;TARGET,ANIMAL,PET_NAME指定済み
@MASTER_PLAY_ANIMAL_LIST

;天気悪いなら外出るのはやめとく
IF !GROUPMATCH(SAVESTR:天気／今日,＃悪天候＃)
	PRINTLC [ 0] Walk
ELSE
	CALL PRINTL_WORD_COLOR("Can't go out due to bad weather.","灰")
ENDIF
PRINTLC [ 1] Wash
PRINTL [ 2] Brush
IF !GROUPMATCH(SAVESTR:天気／今日,＃悪天候＃)
	CALL MASTER_PLAY_ANIMAL_TOY(3,"フリスビー")
	SELECTCASE ANIMAL
	CASE "堕天馬"
	CASE "オルトロス"
		CALL MASTER_PLAY_ANIMAL_TOY(4,"いい感じの棒")
	CASE "魔界ハムスター"
	ENDSELECT
ENDIF
PRINTL
PRINTL [98] Hint



;遊び道具選択肢
;ARG→出す選択肢番号
;ARGS→遊び道具
@MASTER_PLAY_ANIMAL_TOY(ARG,ARGS)

IF ITEM:ARGS
	PRINTFORML [{ARG,2}] Play with ＜%ITEMS_ENG(ARGS)%＞：{ITEM:ARGS} Owned
ELSE
	CALL PRINTL_WORD_COLOR,@"　　 %ITEMS_ENG(ARGS)%","灰"
ENDIF


