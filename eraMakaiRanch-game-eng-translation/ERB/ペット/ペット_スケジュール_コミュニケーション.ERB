
;スケジュールで遊ぶなり洗うなり実行
;TARGET,ANIMAL,PET_NAME指定済み
;ARG→INPUT
@FREE_TIME_PLAY_ANIMAL(ARG)

;今とりあえずほぼ共通
SELECTCASE ARG
CASE 0
	;散歩
	;地の文呼び+消費体力呼び出し
	CALL PET_COMMU_MESSAGE_WALKING
	
	;パラメータ増減
	CALL PLAY_ANIMAL_PALAM_PLUS("散歩")
	
	;龍のタマ発見処理
	CALL PET_COMMU_WALKING_DRAGON_BALL
CASE 1
	;洗う
	CALL PET_COMMU_MESSAGE_WASH
	CALL PLAY_ANIMAL_PALAM_PLUS("洗う")
CASE 2
	;ブラッシング
	CALL PET_COMMU_MESSAGE_BRUSHING
	CALL PLAY_ANIMAL_PALAM_PLUS("ブラッシング")
CASE 3
	;フリスビー
	CALL PET_COMMU_MESSAGE_PLAY_FRISBEE
	
	;ANIMAL_GOODS_BREAK%で壊れる
	CALL PLAY_ANIMAL_GOODS_BREAK("フリスビー")
	CALL PLAY_ANIMAL_PALAM_PLUS("フリスビー")
CASE 4
	;いい感じの棒：ｲﾇﾁｬﾝだけ
	CALL PET_COMMU_MESSAGE_PLAY_NICE_STICK
	
	;確定で壊れる
	CALL PLAY_ANIMAL_GOODS_BREAK_MUST("いい感じの棒")
	CALL PLAY_ANIMAL_PALAM_PLUS("いい感じの棒")
ENDSELECT
PRINTW



;パラメータ増減
;ARGS→実行行動
@PLAY_ANIMAL_PALAM_PLUS(ARGS)
#DIM FRIENDRY
#DIM CAL

;行動により基礎なつき度・体型値算出
SELECTCASE ARGS
CASE "散歩"
	FRIENDRY = 150
	CAL = 200
CASE "洗う"
	FRIENDRY = 150
	CAL = 100
CASE "ブラッシング"
	FRIENDRY = 120
	CAL = 0
CASE "フリスビー"
	FRIENDRY = 200
	
	;DAMAGE量の倍が消費カロリーにする
	CAL = DAMAGE *2
CASE "いい感じの棒"
	FRIENDRY = 200
	CAL = DAMAGE *2
ENDSELECT

;なつき度増加倍率算出→増加
PRINT [
CALL PET_FRIENDRY_TIMES_CALC(ARGS)
CALL PET_FRIENDRY_PLUS(RESULT,FRIENDRY)

;体型少し減少
CALL PET_WEIGHT_MINUS(CAL)
PRINTL ]

;TARGETの体力少し消費
PRINTFORM %CALLNAME%：
CALL HP_COST(DAMAGE,0,1)



;たまに遊び道具が壊れる
;ARGS→アイテム名
@PLAY_ANIMAL_GOODS_BREAK(ARGS)

;ANIMAL_GOODS_BREAK%
SIF RAND:100 >= ANIMAL_GOODS_BREAK
	RETURN
ITEM:ARGS --
CALL PRINTL_WORD_COLOR,@"%ARGS%が壊れてしまった。","黄"



;確定で壊れる
;ARGS→アイテム名
@PLAY_ANIMAL_GOODS_BREAK_MUST(ARGS)

ITEM:ARGS --
CALL PRINTL_WORD_COLOR,@"%ARGS%が壊れてしまった。","黄"




