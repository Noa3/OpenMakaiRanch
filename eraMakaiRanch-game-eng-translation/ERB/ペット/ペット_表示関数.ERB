
;ペット性別表示
;ARG→性別
;ARG:1→改行
@PRINT_PET_GENDER(ARG,ARG:1)

IF ARG
	CALL PRINT_WORD_COLOR("♂ ","水色")
ELSE
	CALL PRINT_WORD_COLOR("♀ ","桃")
ENDIF
SIF ARG:1
	PRINTL



;ペット体型表示
;ARGS→種族名
;ARG→バー表示
;ARG:1→改行
@PRINT_PET_SHAPE(ARGS,ARG,ARG:1)

FLAG_NAME = 体型／%ARGS%
SELECTCASE FLAG:FLAG_NAME
CASE 0 TO 499
	CALL PRINT_WORD_COLOR("【ExUndwerweight】 ","黄")
CASE 500 TO 1999
	CALL PRINT_WORD_COLOR("【Undwerweight】 ","黄")
CASE 2000 TO 2999
	PRINT 【Slim】
CASE 3000 TO 3999
	PRINT 【Thin】
CASE 4000 TO 5999
	CALL PRINT_WORD_COLOR("【Normal Weight】 ","水色")
CASE 6000 TO 6999
	PRINT 【Heavy】
CASE 7000 TO 7999
	PRINT 【Plump】
CASE 8000 TO 9499
	CALL PRINT_WORD_COLOR("【Overweight】 ","黄")
CASE 9500 TO 10000
	CALL PRINT_WORD_COLOR("【ExOverweight】 ","黄")
ENDSELECT
SIF ARG
	CALL PRINT_COLORBAR(FLAG:FLAG_NAME,ANIMAL_WEIGHT_MAX,8,BARCOLORSET("青緑"),RESULT:1)
SIF ARG:1
	PRINTL





