
;毛並みシャッフル
@NAMING_PET_SHUFFLE_COAT

LAST_SHUFFLE_S = %PET_COAT%
STR_MAX = 49
CALL STR_REF_SHUFFLE(STR_REF +100)
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
PET_COAT = %RESULTS%



;毛並み候補表示
@NAMING_PET_SELECT_COAT
#DIM LOOP_REF

LOOP_REF = 100
PRINTL Select fur color.
BR = 0
FOR LOCAL,STR_REF +LOOP_REF,STR_REF +LOOP_REF +50
	SIF STR:LOCAL == ""
		CONTINUE
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL-STR_REF -LOOP_REF,3}] %STR:LOCAL%
NEXT
PRINTL
PRINTL [900] Cancel
INPUT
SIF RESULT >= 0 && RESULT < 50 && STR:(STR_REF +LOOP_REF +RESULT) != ""
	PET_COAT = %STR:(STR_REF +LOOP_REF +RESULT)%



