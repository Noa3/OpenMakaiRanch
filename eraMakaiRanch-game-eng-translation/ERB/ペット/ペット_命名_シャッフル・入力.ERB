;いろいろ手動入力
;ARGS→入力項目
@NAMING_PET_MANUAL(ARGS)

SELECTCASE ARGS
CASE "名前"
	PRINTL Enter name.
	INPUTS
	IF RESULTS != ""
		PET_NAME = %RESULTS%
		CALL NAMING_PET_NAME_FIX
	ENDIF
	
CASE "毛並み"
	PRINTL Enter fur color.
	INPUTS
	SIF RESULTS != ""
		PET_COAT = %RESULTS%
	
CASE "模様"
	PRINTL Enter appearance.
	INPUTS
	PET_PATTERN = %RESULTS%
ENDSELECT






