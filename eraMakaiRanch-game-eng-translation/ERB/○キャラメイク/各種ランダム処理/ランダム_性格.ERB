
;性格
@RANDOM_SLAVE_PERSONALITY

LAST_SHUFFLE_S = %CSTR:性格%
STR_REF = 3000
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)

;手柄目当ての面々はたいがい好戦的では
SIF CFLAG:魔界入りの目的 == 2 && GROUPMATCH(RESULTS,"弱気","大人しい","温厚")
	RESTART

;好色が選ばれて性経験ない側ならやり直し
SIF RESULTS == "好色" && GROUPMATCH(CSTR:性経験,"無垢","生娘","処女")
	RESTART
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:性格 = %RESULTS%
CALL CATEGORY_PERSONALITY



