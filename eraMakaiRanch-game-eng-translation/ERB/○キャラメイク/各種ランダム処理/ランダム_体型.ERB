
;奴隷候補の体型　リストで上げる→詳細時に抽選にした
@RANDOM_SLAVE_SHAPE

IF CHILD_HEIGHT_CHECK(CSTR:身長)
	;FLAG:子供候補割合／体型／スレンダー→3210
	FLAG_REF = 3210
ELSE
	;FLAG:候補割合／体型／スレンダー→3120
	FLAG_REF = 3120
ENDIF
STR_REF = 6560
LAST_SHUFFLE_S = %CSTR:体型%
CALL RANDOM_BOX_LOTTERY(9)

;種族補正
CALL RANDOM_SLAVE_SHAPE_TRIBE_REVISION
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:体型 = %RESULTS%



;種族補正
@RANDOM_SLAVE_SHAPE_TRIBE_REVISION

FLAG_NAME = 種族設定／%CSTR:種族%
TRIBE_FLAG_A = 外見反映率／%CSTR:種族%
SELECTCASE CSTR:種族
CASE "エルフ","ダークエルフ","ハーフエルフ"
	IF !GROUPMATCH(RESULTS,"スレンダー","痩せ型") && GETBIT(FLAG:FLAG_NAME,2) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		IF RAND:2
			RESULTS = スレンダー
		ELSE
			RESULTS = 痩せ型
		ENDIF
	ELSEIF !GROUPMATCH(RESULTS,"豊満","ムチムチ") && GETBIT(FLAG:FLAG_NAME,3) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		IF RAND:2
			RESULTS = 豊満
		ELSE
			RESULTS = ムチムチ
		ENDIF
	ENDIF
CASE "翼人"
	IF !GROUPMATCH(RESULTS,"スレンダー","痩せ型") && GETBIT(FLAG:FLAG_NAME,1) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		IF RAND:2
			RESULTS = スレンダー
		ELSE
			RESULTS = 痩せ型
		ENDIF
	ENDIF
CASE "仙人"
	IF !GROUPMATCH(RESULTS,"スレンダー","痩せ型") && GETBIT(FLAG:FLAG_NAME,2) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		IF RAND:2
			RESULTS = スレンダー
		ELSE
			RESULTS = 痩せ型
		ENDIF
	ENDIF
ENDSELECT



