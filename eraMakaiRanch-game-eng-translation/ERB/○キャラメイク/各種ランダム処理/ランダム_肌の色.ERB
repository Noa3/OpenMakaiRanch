
;奴隷候補の肌の色
@RANDOM_SLAVE_SKIN_COLOR
#DIMS SKIN_COLOR

;FLAG:候補割合／肌の色／アルビノ→3160
FLAG_REF = 3160
STR_REF = 6580
LAST_SHUFFLE_S = %CSTR:肌の色%
CALL RANDOM_BOX_LOTTERY(9)

;再シャッフルのカウントがなければ種族補正
SIF !SHUFFLE_COUNT
	CALL RANDOM_SLAVE_SKIN_COLOR_TRIBE_REVISION
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:肌の色 = %RESULTS%
CALL CATEGORY_SKIN_COLOR



;種族による補正　種族設定に合わせる
@RANDOM_SLAVE_SKIN_COLOR_TRIBE_REVISION

FLAG_NAME = 種族設定／%CSTR:種族%
TRIBE_FLAG_A = 外見反映率／%CSTR:種族%
SELECTCASE CSTR:種族
CASE "ダークエルフ"
	SIF GROUPMATCH(RESULTS,"標準","色白","美白","アルビノ") && GETBIT(FLAG:FLAG_NAME,1) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		RESULTS = 褐色
CASE "エルフ","ハーフエルフ","仙人","妖狐"
	SIF GROUPMATCH(RESULTS,"標準","褐色","小麦色") && GETBIT(FLAG:FLAG_NAME,1) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		RESULTS = 色白
CASE "翼人","ヴァンパイア","ダンピール","天使","天人","女神"
	SIF GROUPMATCH(RESULTS,"標準","褐色","小麦色") && GETBIT(FLAG:FLAG_NAME,0) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		RESULTS = 色白
ENDSELECT

