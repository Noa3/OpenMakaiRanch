
;奴隷候補の目全般
@RANDOM_SLAVE_EYE

CALL RANDOM_SLAVE_EYE_COLOR
CALL RANDOM_SLAVE_PUPIL
CALL RANDOM_SLAVE_EYE_FEATURE



;奴隷候補の目の色　オッドアイ設定もできるよ
;ARG→オッドアイ確定でシャッフル
@RANDOM_SLAVE_EYE_COLOR(ARG)

LAST_SHUFFLE_S = %CSTR:右目の色%
STR_REF = 150
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)

;10%で黒にしておく
SIF !RAND:10
	RESULTS = 黒
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:右目の色 = %RESULTS%

;左目シャッフル
CALL RANDOM_SLAVE_LEFT_EYE_COLOR(ARG)
CALL CATEGORY_EYE_COLOR
CALL AUTOSET_EYE_COLOR_CODE



;左目の色シャッフル
;ARG→オッドアイ確定でシャッフル
@RANDOM_SLAVE_LEFT_EYE_COLOR(ARG)

;一旦左目の色リセット
CSTR:左目の色 =

;確定か10%でオッドアイ
SIF !ARG && RAND:100 < 90
	RETURN
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)

;右と同じはやり直し
SIF CSTR:右目の色 == RESULTS
	RESTART
CSTR:左目の色 = %RESULTS%



;奴隷候補の瞳の形
@RANDOM_SLAVE_PUPIL

LAST_SHUFFLE_S = %CSTR:瞳の形%
STR_REF = 800
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)

;50%で空欄・霊力入ってない場合はもう1度80%
SIF RAND:100 < 50
	RESULTS =
SIF RAND:100 < 80 && !MAXBASE:霊力
	RESULTS =

;霊力入ってない＝最初のシャッフルでは空欄でもそのまま通す
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS && MAXBASE:霊力
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:瞳の形 = %RESULTS%




;奴隷候補の目の特徴
@RANDOM_SLAVE_EYE_FEATURE

LAST_SHUFFLE_S = %CSTR:目の特徴%
STR_REF = 2000
STR_MAX = 15
CALL STR_REF_SHUFFLE(STR_REF)

;50%で空欄・霊力入ってない場合はもう1度80%
SIF RAND:100 < 50
	RESULTS =
SIF RAND:100 < 80 && !MAXBASE:霊力
	RESULTS =

;霊力入ってない＝最初のシャッフルでは空欄でもそのまま通す
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS && MAXBASE:霊力
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:目の特徴 = %RESULTS%




