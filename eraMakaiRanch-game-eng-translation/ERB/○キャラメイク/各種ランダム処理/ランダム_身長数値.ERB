
;奴隷候補の身長数値
@RANDOM_SLAVE_HEIGHT

;オトコの場合オトコ用へ
IF TALENT:オトコ
	CALL RANDOM_CHARA_HEIGHT_MALE
	RETURN
ENDIF
SELECTCASE CSTR:身長

;一応なんも入ってないと標準にしてもっかい処理
CASE ""
	CSTR:身長 = 標準
	RESTART

;1つ下の数値+1+上限範囲までのRAND
CASE "幼児体型"
	CFLAG:身長 = HEIGHT_MAX_妖精体型 +1 +RAND:(HEIGHT_MAX_幼児体型 -HEIGHT_MAX_妖精体型)
CASE "子供体型"
	CFLAG:身長 = HEIGHT_MAX_幼児体型 +1 +RAND:(HEIGHT_MAX_子供体型 -HEIGHT_MAX_幼児体型)
CASE "小柄"
	CFLAG:身長 = HEIGHT_MAX_子供体型 +1 +RAND:(HEIGHT_MAX_小柄 -HEIGHT_MAX_子供体型)
CASE "低身長"
	CFLAG:身長 = HEIGHT_MAX_小柄 +1 +RAND:(HEIGHT_MAX_低身長 -HEIGHT_MAX_小柄)
CASE "標準"
	CFLAG:身長 = HEIGHT_MAX_低身長 +1 +RAND:(HEIGHT_MAX_標準 -HEIGHT_MAX_低身長)
CASE "高身長"
	CFLAG:身長 = HEIGHT_MAX_標準 +1 +RAND:(HEIGHT_MAX_高身長 -HEIGHT_MAX_標準)
CASE "大柄"
	CFLAG:身長 = HEIGHT_MAX_高身長 +1 +RAND:(HEIGHT_MAX_大柄 -HEIGHT_MAX_高身長)
ENDSELECT



;オトコ用
@RANDOM_CHARA_HEIGHT_MALE

SELECTCASE CSTR:身長
CASE ""
	CSTR:身長 = 標準
	RESTART
CASE "幼児体型"
	CFLAG:身長 = HEIGHT_MAX_妖精体型 +1 +RAND:(HEIGHT_MAX_幼児体型 -HEIGHT_MAX_妖精体型)
CASE "子供体型"
	CFLAG:身長 = HEIGHT_MAX_幼児体型 +1 +RAND:(HEIGHT_MAX_子供体型 -HEIGHT_MAX_幼児体型)
CASE "小柄"
	CFLAG:身長 = HEIGHT_MAX_子供体型 +1 +RAND:(HEIGHT_MAX_小柄 -HEIGHT_MAX_子供体型)
CASE "低身長"
	CFLAG:身長 = HEIGHT_MAX_小柄 +1 +RAND:(MALE_HEIGHT_MAX_低身長 -HEIGHT_MAX_小柄)
CASE "標準"
	CFLAG:身長 = MALE_HEIGHT_MAX_低身長 +1 +RAND:(MALE_HEIGHT_MAX_標準 -MALE_HEIGHT_MAX_低身長)
CASE "高身長"
	CFLAG:身長 = MALE_HEIGHT_MAX_標準 +1 +RAND:(MALE_HEIGHT_MAX_高身長 -MALE_HEIGHT_MAX_標準)
CASE "大柄"
	CFLAG:身長 = MALE_HEIGHT_MAX_高身長 +1 +RAND:(MALE_HEIGHT_MAX_大柄 -MALE_HEIGHT_MAX_高身長)
ENDSELECT



