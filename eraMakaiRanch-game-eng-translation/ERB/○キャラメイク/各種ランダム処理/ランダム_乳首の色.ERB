
;乳首の色決定
@RANDOM_SLAVE_NIPPLE_COLOR

;BOX詰め+ループ付きランダム
;FLAG:候補割合／乳首の色／ピンク→3150
;FLAG:候補割合／乳首の色／褐色肌／ピンク→3170
LAST_SHUFFLE_S = %CSTR:乳首の色%

;褐色・小麦色なら褐色系用割合
FLAG_REF = 3150
SIF GROUPMATCH(CSTR:肌の色,"褐色","小麦色")
	FLAG_REF = 3170
STR_REF = 6570
CALL RANDOM_BOX_LOTTERY(9)
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:乳首の色 = %RESULTS%
CALL AUTOSET_NIPPLE_COLOR_CODE



;カラーコード適応
@AUTOSET_NIPPLE_COLOR_CODE

SELECTCASE CSTR:乳首の色
CASE "ピンク"
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_PINK
CASE "ディープピンク"
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_DEEPPINK
CASE "ホットピンク"
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_HOTPINK
CASE "チェリーピンク"
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_CHERRYPINK
CASE "ライトピンク"
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_LIGHTPINK
CASE "ルビーレッド"
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_RUBYRED
CASE "ラセットブラウン"
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_RUSSETBROWN
CASE "ブラウン"
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_BROWN
ENDSELECT

