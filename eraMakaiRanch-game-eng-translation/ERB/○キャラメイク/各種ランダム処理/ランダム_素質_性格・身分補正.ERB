		TALENT:プライド高い = 1
	ELSEIF RAND:100 < 50
		TALENT:高慢 = 1
	ENDIF
CASE "王族"
	IF RAND:100 < 80
		TALENT:プライド高い = 1
	ELSEIF RAND:100 < 80
		TALENT:高慢 = 1
	ENDIF
ENDSELECT

