
;奴隷候補のBASEパラメータ
@RANDOM_SLAVE_BASE_STATUS

;ランダムから来たかで通る関数変える
;SLAVE_HP_FIXで補正をかけてたけど廃止
CALL SLAVE_LEVEL_CALC
CALL SLAVE_HP_CALC
CALL SLAVE_EP_CALC
CALL SLAVE_MP_CALC
CALL SLAVE_SP_CALC
CALL SLAVE_BATTLE_POWER_CALC
CALL SLAVE_BATTLE_SPECIAL_CALC



;レベル計算（EP計算と分割）
@SLAVE_LEVEL_CALC

;ランク*10+乱数Lv
MAXBASE:レベル = CFLAG:ランク*10 +RAND:10
MAXBASE:レベル = LIMIT(MAXBASE:レベル,1,MAXBASE:レベル)
BASE:レベル = MAXBASE:レベル

;非戦闘職なら1
SIF !CFLAG:非戦闘職
	RETURN
MAXBASE:レベル = 1
BASE:レベル = MAXBASE:レベル
CFLAG:ランク = 0



;霊力計算
@SLAVE_EP_CALC

IF CFLAG:非戦闘職
	STATUS = 100
ELSE
	;レベル→霊力計算
	;STATUS = RESULT　になってる
	CALL LEVEL_EP_CALC
ENDIF
MAXBASE:霊力 = STATUS
BASE:霊力 = MAXBASE:霊力

