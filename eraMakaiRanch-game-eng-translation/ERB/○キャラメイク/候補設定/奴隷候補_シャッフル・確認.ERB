
;奴隷候補のシャッフル
@TRAVELLER_SHUFFLE

;シャッフルしたら変更チケットをリセット
FLAG:奴隷候補設定変更チケット使用中 = 0
VARSET LIST_TRIBE
VARSET LIST_JOB
VARSET LIST_BUST
VARSET LIST_HEIGHT
VARSET LIST_POSITION
VARSET LIST_RANK
VARSET LIST_GROUP_RANK
VARSET LIST_GROUP
VARSET LIST_PURPOSE
VARSET LIST_MAGIC_POWER
VARSET LIST_DIVINITY
FOR LOCAL,0,10
	CALL RANDOM_LIST(LOCAL)
NEXT



;奴隷候補確認
@PRINT_SLAVE_CANDIDATE

;まず共通関数
CALL PRINT_TRAVELLER_LIST("候補確認")

;フリーならここでシャッフルできる
IF FLAG:開発者モード
	PRINTLC [ 0] OK
	PRINTLC [ 1] Reshuffle（Developer Mode Only）
	INPUT
	IF RESULT
		CALL TRAVELLER_SHUFFLE
		RESTART
	ENDIF
ELSE
	PRINTW
ENDIF

