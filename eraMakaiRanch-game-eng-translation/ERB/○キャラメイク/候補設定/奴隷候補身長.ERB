
;身長おおよそ決定
@RANDOM_LIST_HEIGHT(ARG)

;FLAG:候補割合／身長／幼児体型→3100
FLAG_REF = 3100
STR_REF = 6500
CALL RANDOM_BOX_LOTTERY(9)
LIST_HEIGHT:ARG = %RESULTS%

;種族補正
FLAG_NAME = 種族設定／%LIST_TRIBE:ARG%
TRIBE_FLAG_A = 外見反映率／%LIST_TRIBE:ARG%
SELECTCASE LIST_TRIBE:ARG
CASE "エルフ","ダークエルフ","仙人","竜人","妖狐"
	SIF GROUPMATCH(LIST_HEIGHT:ARG,"標準","小柄","低身長") && GETBIT(FLAG:FLAG_NAME,0) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		LIST_HEIGHT:ARG = 高身長
CASE "ハーフリング"
	SIF !GROUPMATCH(LIST_HEIGHT:ARG,"幼児体型") && GETBIT(FLAG:FLAG_NAME,0) && (RAND:100 < FLAG:TRIBE_FLAG_A)
		LIST_HEIGHT:ARG = 子供体型
ENDSELECT



