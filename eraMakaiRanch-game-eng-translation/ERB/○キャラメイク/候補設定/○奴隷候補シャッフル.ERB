
;ランダムでニンゲンの大まかな特徴を出す
;ARG→奴隷候補の目的
@RANDOM_LIST(ARG)

;目的別の確率に当たったor目的別の最低保障日数になったらリスト入り
;FLAG:奴隷候補空振り日数／魔界水晶→150
;ただし渋滞フラグがONなら問答無用で来る
IF RAND:100 < RANDOM_LIST_PROBABILITY:ARG || FLAG:(150 +ARG) >= RANDOM_LIST_GUARANTEE:ARG || FLAG:魔界入りニンゲンで渋滞
	FLAG:(150 +ARG) = 0
ELSE
	;空振りしたら空振り日数+1して終了
	FLAG:(150 +ARG) ++
	RETURN
ENDIF

;CHARA_NOで来たのがARG、それがそのまま目的に入る
LIST_PURPOSE:ARG = ARG

;目的別に呼ぶリストが変わる
SELECTCASE LIST_PURPOSE:ARG

;一般種族
;水晶・植物・名声・奪還・事故・侵略・結界付き・競売所
CASE 0 TO 7
	;目的番号とリンクできるのは共通関数でいい
	CALL RANDOM_LIST_TRIBE_NORMAL(ARG)
	CALL RANDOM_LIST_JOB(ARG)
	CALL RANDOM_LIST_RANK(ARG)
	CALL RANDOM_LIST_GROUP(ARG)
	
	;仲間ランクは計算済み
	CALL RANDOM_LIST_POSITION(ARG)

;上位種族
CASE 8
	CALL RANDOM_LIST_TRIBE_SPECIAL(ARG)
	CALL RANDOM_LIST_JOB(ARG)
	CALL RANDOM_LIST_RANK(ARG)
	CALL RANDOM_LIST_POSITION(ARG)

;天界種族
CASE 9
	CALL RANDOM_LIST_TRIBE_HEAVEN(ARG)
	CALL RANDOM_LIST_JOB(ARG)
	CALL RANDOM_LIST_RANK(ARG)
	CALL RANDOM_LIST_POSITION(ARG)
ENDSELECT

;身長、乳は目的とかしらへん　魔力量も追加
CALL RANDOM_LIST_HEIGHT(ARG)
CALL RANDOM_LIST_BUST(ARG)
CALL RANDOM_LIST_MAGIC_POWER(ARG)

;表示の半角化
CALL FONT_HARF(ARG)

