	SIF CFLAG:一人称が名前
		PRINTW The character refers to herself by name, so if you change the name, please make sure to update the first-person pronoun as well.
	CALL CHARA_CHILD_NAME
CASE 1
	CALL KOJO_SETTING

CASE 2
	STR_REF = 1000
	PRINTL Select a race.
	FOR LOCAL,STR_REF,STR_REF+300
		SIF STR:LOCAL == ""
			CONTINUE
		PRINTFORMLC [{LOCAL-STR_REF,3}] %RACE_ENG(STR:LOCAL)%
	NEXT
