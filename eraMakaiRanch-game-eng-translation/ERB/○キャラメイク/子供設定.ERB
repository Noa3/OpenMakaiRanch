	PRINTFORMLC [ 0] dad
	PRINTFORMLC [ 1] father
	PRINTFORMLC [ 2] otōsama
	PRINTFORMLC [ 3] chichisama
	PRINTFORMLC [ 4] daddy
	PRINTFORMLC [ 5] papa
	PRINTFORMLC [ 6] old man
	PRINTFORMLC [ 7] patriarch
	CALL INPUTBUTTON
	BINPUT
ELSE
	RESULT = RAND:8
ENDIF
SELECTCASE RESULT
CASE 0
	CSTR:あなた呼び方／陥落後 = dad
