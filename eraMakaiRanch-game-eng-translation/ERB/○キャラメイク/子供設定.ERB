	CALL CHANGE_PERSONAL_C_CALL("あなた呼び方／陥落後")
CASE 99
	IF CALLNAME != ""
		PRINTL
		PRINTFORMW You've decided to turn an available room into %CALLNAME%'s nursery and raise them.
		RETURN
	ELSE
		PRINTFORMW Please name the newborn.
	ENDIF
ENDSELECT
