
;服装再シャッフル
@CHARA_MAKE_SLAVE_SHUFFLE_CLOTHE

CLEARLINE LINECOUNT
CALL PRINT_PORTRAIT(1)
PRINTL 奴隷候補の服装・下着・アクセサリーを再シャッフルします。
PRINTL （柄はキャラメイク中は抽選されません）
PRINTL
CALL SHOW_EQUIP
CALL PRINTL_ALIGN(-15)
CALL HALFLINE
SIF GETBIT(＃再シャッフル／服装＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:10)%pt】
PRINTL ＜服装の再シャッフル＞
PRINTLC [ 0] 服装全て
PRINTLC [ 1] 下着のみ
PRINTLC [ 2] 装飾のみ
CALL MANYL(2)
PRINTL ＜装備の色・形シャッフル＞
FOR LOCAL,1,20
	SIF !EQUIP:LOCAL || LOCAL == 5
		CONTINUE
	PRINTFORML [{LOCAL +10}] %EQUIPNAME:(EQUIP:LOCAL)%
NEXT
RESETCOLOR
CALL PRINTL_ALIGN
DRAWLINE
PRINTL [99] Done
BINPUT
SELECTCASE RESULT
CASE 0
	CALL RANDOM_SLAVE_CLOTHE
CASE 1
	;下着をリセット→下着のみ再シャッフル
	FOR LOCAL,3,5
		SIF !EQUIP:LOCAL
			CONTINUE
		CSTR:(EQUIP:LOCAL) =
		EQUIP:(EQUIP:LOCAL) = 0
		EQUIP:LOCAL = 0
	NEXT
	CALL RANDOM_SLAVE_CLOTHE_LINGERIE
	CALL CHARA_MAKE_SLAVE_SHUFFLE_EQUIP_REGISTER
	CALL RANDOM_SLAVE_LINGERIE_COLOR
CASE 2
	;アクセサリーのみ
	FOR LOCAL,10,20
		SIF !EQUIP:LOCAL
			CONTINUE
		CSTR:(EQUIP:LOCAL) =
		EQUIP:(EQUIP:LOCAL) = 0
		EQUIP:LOCAL = 0
	NEXT
	CALL RANDOM_SLAVE_CLOTHE_ACCESSORY
	CALL CHARA_MAKE_SLAVE_SHUFFLE_EQUIP_REGISTER
	CALL RANDOM_SLAVE_ACCESSORY_COLOR
CASE 10 TO 29
	CALL CHARA_MAKE_SLAVE_SHUFFLE_CLOTHE_PART(RESULT -10)
CASE 99
	RETURN
ENDSELECT

;99以外ならここなので一括フラグONでOK
SETBIT ＃再シャッフル／服装＃
RESTART



;個別色シャッフル
;ARG→変更するEQUIP位置
@CHARA_MAKE_SLAVE_SHUFFLE_CLOTHE_PART(ARG)

;アイテム番号
ITEM_NUM = EQUIP:ARG
LAST_SHUFFLE_S = %CSTR:ITEM_NUM%

;参照STR変更
SELECTCASE ITEMNAME:ITEM_NUM
CASE "ドレス","バトルドレス","淫乱ドレス","ゴスロリ衣装","軍服","マント"
	STR_REF = 6720
CASE "メガネ","伊達メガネ"
	;メガネの場合はメガネ用に移動しておわり
	CALL RANDOM_SLAVE_ACCESSORY_GLASSES(ITEM_NUM)
	RETURN
CASEELSE
	STR_REF = 6700
ENDSELECT
STR_MAX = 19
CALL STR_REF_SHUFFLE(STR_REF)
IF SHUFFLE_COUNT < 10 && LAST_SHUFFLE_S == RESULTS
	SHUFFLE_COUNT ++
	RESTART
ENDIF
SHUFFLE_COUNT = 0
CSTR:ITEM_NUM = %RESULTS%





;再シャッフル用ID入れ
;説明は@CHARA_EQUIP_REGISTERで
@CHARA_MAKE_SLAVE_SHUFFLE_EQUIP_REGISTER
#DIMS CLOTHE_CATEGORY

FOR LOCAL,1000,2000
	SIF !EQUIP:LOCAL
		CONTINUE
	CALL CLOTHE_CATEGORY_CHECK(ITEMNAME:LOCAL)
	SELECTCASE RESULTS
	CASE "衣服"
		EQUIP:装備中ID／衣服 = LOCAL
		
		;こっちでは色柄を無視
	CASE "下着上下","下着上下／極小"
		EQUIP:装備中ID／下着上 = LOCAL
		EQUIP:装備中ID／下着下 = LOCAL
		
	{
	CASE "鎧","下着上","下着上／極小","下着上／シール","下着下","下着下／極小","下着下／シール",
	"眼","頭","腕","脚","首","上着"
	}
		;極小とシールは上書き必要
		IF GROUPMATCH(RESULTS,"下着上／極小","下着上／シール")
			RESULTS = 下着上
		ELSEIF GROUPMATCH(RESULTS,"下着下／極小","下着下／シール")
			RESULTS = 下着下
		ENDIF
		CLOTHE_CATEGORY = 装備中ID／%RESULTS%
		EQUIP:CLOTHE_CATEGORY = LOCAL
	ENDSELECT
NEXT



