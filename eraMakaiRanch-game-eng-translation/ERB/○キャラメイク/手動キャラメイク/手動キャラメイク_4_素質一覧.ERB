
;素質一覧
@SELF_CHARA_MAKE_TALENT
#DIM DYNAMIC PAGE

PAGE_MAX = 6
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL PRINT_SELF_CHARA_MAKE_STATUS
TRYCALLFORM SELF_CHARA_MAKE_TALENT_{PAGE}
RESETCOLOR
CALL PRINTL_ALIGN(2)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTL [99] 戻る
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN

;素質一覧からはTALENT番号を直接入力しよう
CASEELSE
	CALL SELF_CHARA_MAKE_TALENT_INPUT(RESULT)
ENDSELECT
RESTART

