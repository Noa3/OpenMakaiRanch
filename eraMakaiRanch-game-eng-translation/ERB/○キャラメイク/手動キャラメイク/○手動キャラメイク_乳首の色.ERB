
;乳首の色ちょっと長いのでここ
@SELECT_NIPPLE_COLOR

CALL MANYL(3)
PRINTL Select a nipple color
SETCOLOR NIPPLE_COLOR_CODE_PINK
PRINTLC [ 0] Pink
SETCOLOR NIPPLE_COLOR_CODE_DEEPPINK
PRINTLC [ 1] Deep Pink
SETCOLOR NIPPLE_COLOR_CODE_HOTPINK
PRINTLC [ 2] Hot Pink
SETCOLOR NIPPLE_COLOR_CODE_CHERRYPINK
PRINTLC [ 3] Cherry Pink
SETCOLOR NIPPLE_COLOR_CODE_LIGHTPINK
PRINTLC [ 4] Light Pink
SETCOLOR NIPPLE_COLOR_CODE_RUBYRED
PRINTLC [ 5] Ruby Red
SETCOLOR NIPPLE_COLOR_CODE_RUSSETBROWN
PRINTLC [ 6] Dark Brown
SETCOLOR NIPPLE_COLOR_CODE_BROWN
PRINTLC [ 7] Brown
RESETCOLOR
CALL INPUTBUTTON
INPUT
SELECTCASE RESULT
CASE 0
	CSTR:乳首の色 = ピンク
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_PINK
	
CASE 1
	CSTR:乳首の色 = ディープピンク
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_DEEPPINK
	
CASE 2
	CSTR:乳首の色 = ホットピンク
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_HOTPINK
	
CASE 3
	CSTR:乳首の色 = チェリーピンク
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_CHERRYPINK
	
CASE 4
	CSTR:乳首の色 = ライトピンク
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_LIGHTPINK
	
CASE 5
	CSTR:乳首の色 = ルビーレッド
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_RUBYRED
	
CASE 6
	CSTR:乳首の色 = ラセットブラウン
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_RUSSETBROWN
	
CASE 7
	CSTR:乳首の色 = ブラウン
	CFLAG:カラーコード／乳首 = NIPPLE_COLOR_CODE_BROWN
	
CASE 901
	CALL MANYL(3)
	PRINTL Enter a nipple color
	PRINTL （カラーコードは別途入力してください）
	INPUTS
	SIF RESULTS != ""
		CSTR:乳首の色 = %RESULTS%
ENDSELECT



