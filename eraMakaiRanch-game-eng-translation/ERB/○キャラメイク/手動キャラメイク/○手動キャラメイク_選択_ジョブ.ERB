
;手動キャラメイクのジョブ
@SELF_CHARA_MAKE_JOB

PRINTL Select a job category
;PRINTL （ランダム抽選では出ないものも含まれたり、言い換えの水増しがあったりします）
PRINTLC [ 0] Close Physical
PRINTLC [ 1] Ranged Physical
PRINTLC [ 2] Magic
PRINTLC [ 3] Magic Warriors
PRINTLC [ 4] Assorted
PRINTLC [ 5] Tools・Support Combatant
PRINTLC [ 6] Non-Combatant
PRINTLC [ 7] Royalty
CALL INPUTBUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 900
	CSTR:ジョブ =
CASE 901
	PRINTL Enter the name of a job
	INPUTS
	CSTR:ジョブ = %RESULTS%
CASE 0 TO 7
	CALL SELF_CHARA_MAKE_JOB_CATEGORY(RESULT)
ENDSELECT



;カテゴリ選択後
;ARG→カテゴリ
@SELF_CHARA_MAKE_JOB_CATEGORY(ARG)

;STR:手動入力ジョブ→7000
STR_REF = 7000 +ARG *50
PRINTL Select a job
FOR LOCAL,STR_REF,STR_REF +50
	SIF STR:LOCAL == ""
		CONTINUE
	PRINTFORMLC [{LOCAL -STR_REF,2}] %JOB_ENG(STR:LOCAL)%
NEXT
PRINTL
PRINTL [99] （Cancel）
BINPUT
SIF RESULT == 99
	RETURN
CSTR:ジョブ = %STR:(RESULT +STR_REF)%
CALL SELF_CHARA_MAKE_JOB_FEATURE(ARG)



;ジョブ決定後の特徴反映設定
;ARG→カテゴリ
@SELF_CHARA_MAKE_JOB_FEATURE(ARG)

CALL MANYL(3)
SELECTCASE ARG
CASE 0,1
	SIF !CFLAG:魔力量
		RETURN
	PRINTL Physical job selected. Set [Mana Capacity] to 0?
	CALL ASK_YN
	IF !RESULT
		CFLAG:魔力量 = 0
		CALL SLAVE_MP_CALC
		CALL SLAVE_BATTLE_POWER_CALC(1)
	ENDIF
	
CASE 2,3
	SIF CFLAG:魔力量
		RETURN
	PRINTL Magic job selected. Increase [Mana Capacity]?
	CALL ASK_YN
	SIF RESULT
		RETURN
	PRINTL Enter their Mana Capacity 
	INPUT
	IF RESULT >= 0
		CFLAG:魔力量 = RESULT
		CALL SLAVE_MP_CALC
		CALL SLAVE_BATTLE_POWER_CALC(1)
	ENDIF

CASE 6
	SIF CFLAG:非戦闘職
		RETURN
	PRINTL Non-combatant job selected. Set to [Non-combatant] and set level to 1?
	CALL ASK_YN
	SIF RESULT
		RETURN
	CFLAG:非戦闘職 = 1
	MAXBASE:レベル = 1
	BASE:レベル = MAXBASE:レベル
	CFLAG:ランク = 0
	BASE:回復回数 = 0
	BASE:大技回数 = 0
	CALL SLAVE_EP_CALC
	CALL SLAVE_BATTLE_POWER_CALC(1)

CASE 7
	SIF CSTR:身分 == "王族"
		RETURN
	PRINTL Royalty job selected. Change status to [Royalty] as well?
	CALL ASK_YN
	SIF RESULT
		RETURN
	CSTR:身分 = 王族
	
	;身分からの母乳価格補正確認
	CALL SELF_CHARA_MAKE_MILK_PRICE
ENDSELECT

