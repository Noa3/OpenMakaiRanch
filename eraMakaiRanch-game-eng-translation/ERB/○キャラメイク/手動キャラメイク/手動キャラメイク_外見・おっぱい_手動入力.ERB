
;外見・おっぱいの変更手動入力
;ARGS→CHANGE_STATE
@SELF_CHARA_MAKE_APPEARAINCE_INPUT_MANUAL(ARGS)

SELECTCASE ARGS
CASE "身長"
	PRINTL Enter a numerical value for height.（Units：mm）
	INPUT
	IF RESULT >= 0
		CFLAG:身長 = RESULT
		CALL HEIGHT_CSTR_CALC(1)
	ENDIF
	
CASE "体型"
	STR_REF = 50
	STR_MAX = 50
	
	;共通化
	CALL CHANGE_STR_LINEUP("体型")
	
	;RESULTSが空欄以外で入力
	SIF RESULTS != ""
		CSTR:体型 = %RESULTS%
	
CASE "肌の色"
	STR_REF = 100
	STR_MAX = 50
	CALL CHANGE_STR_LINEUP("肌の色")
	SIF RESULTS != ""
		CSTR:肌の色 = %RESULTS%
	CALL CATEGORY_SKIN_COLOR
	
CASE "髪色"
	STR_REF = 200
	STR_MAX = 50
	CALL CHANGE_STR_LINEUP("髪色")
	SIF RESULTS != ""
		CSTR:髪色 = %RESULTS%
	
	;共通でやってしまって大丈夫そう
	CALL AUTOSET_HAIR_COLOR_CODE
	CALL CATEGORY_HAIR_COLOR

CASE "カラーコード／髪"
	CALL EDIT_COLOR_CODE(CFLAG:カラーコード／髪,1)
	SIF RESULT
		CFLAG:カラーコード／髪 = RESULT

CASE "髪特徴"
	STR_REF = 300
	STR_MAX = 50
	CALL CHANGE_STR_LINEUP("髪特徴",1)
	
	;空欄有効→キャンセルならそのまま
	SIF !RESULT
		CSTR:髪特徴 = %RESULTS%
	CALL CATEGORY_HAIR_FEATURE
	
CASE "髪型"
	STR_REF = 500
	STR_MAX = 100
	CALL CHANGE_STR_LINEUP("髪型")
	SIF RESULTS != ""
		CSTR:髪型 = %RESULTS%
	CALL CATEGORY_HAIR_STYLE

CASE "外見年齢"
	PRINTL Enter apparent age 。（0 or older）
	INPUT
	SIF RESULT >= 0
		CFLAG:外見年齢 = RESULT
	
CASE "陰毛"
	STR_REF = 6850
	STR_MAX = 10
	CALL CHANGE_STR_LINEUP("陰毛の濃さ")
	SIF RESULTS != ""
		CSTR:陰毛 = %RESULTS%
	
CASE "右目の色"
	STR_REF = 150
	STR_MAX = 50
	CALL CHANGE_STR_LINEUP("右目の色")
	SIF RESULTS != ""
		CSTR:右目の色 = %RESULTS%
	CALL CATEGORY_EYE_COLOR
	CALL AUTOSET_EYE_COLOR_CODE_RIGHT

CASE "カラーコード／右目"
	CALL EDIT_COLOR_CODE(CFLAG:カラーコード／右目,1)
	SIF RESULT
		CFLAG:カラーコード／右目 = RESULT
	
CASE "左目の色"
	STR_REF = 150
	STR_MAX = 50
	CALL CHANGE_STR_LINEUP("左目の色",1)
	SIF !RESULT
		CSTR:左目の色 = %RESULTS%
	CALL CATEGORY_EYE_COLOR
	CALL AUTOSET_EYE_COLOR_CODE_LEFT

CASE "カラーコード／左目"
	;左目の色が空欄だとキャンセル
	SIF CSTR:左目の色 == ""
		RETURN
	CALL EDIT_COLOR_CODE(CFLAG:カラーコード／左目,1)
	SIF RESULT
		CFLAG:カラーコード／左目 = RESULT

CASE "瞳の形"
	STR_REF = 800
	STR_MAX = 50
	CALL CHANGE_STR_LINEUP("瞳の形",1)
	SIF !RESULT
		CSTR:瞳の形 = %RESULTS%

CASE "目の特徴"
	STR_REF = 2000
	STR_MAX = 50
	CALL CHANGE_STR_LINEUP("目の特徴",1)
	SIF !RESULT
		CSTR:目の特徴 = %RESULTS%


;2ページ目
CASE "バストサイズ"
	CALL INPUT_BUST
	IF RESULT >= 0
		ABL:バストサイズ = RESULT
		CALL BUSTSIZE_TALENT_SET
		SIF ABL:バストサイズ < BUSTSIZE_巨乳
			TALENT:極上乳圧 = 0
	ENDIF

CASE "乳弾力"
	STR_REF = 1350
	STR_MAX = 50
	CALL CHANGE_STR_LINEUP,@"%SAVESTR:表記／乳房%の弾力"
	SIF RESULTS != ""
		CSTR:乳弾力 = %RESULTS%

CASE "乳首の色"
	;別関数
	CALL SELECT_NIPPLE_COLOR

CASE "カラーコード／乳首"
	CALL EDIT_COLOR_CODE(CFLAG:カラーコード／乳首,1)
	SIF RESULT
		CFLAG:カラーコード／乳首 = RESULT
	
CASE "Ｂ感度"
	PRINTFORML Enter Ｂ（%SAVESTR:表記／乳房%）Sensitivity.（10～{SENSITIVE_MAX}, rounded to 10）
	PRINTL If Ｎ Sensitivity is below Ｂ Sensitivity, it is increased to Ｂ Sensitivity.
	INPUT
	IF RESULT >= 10 && RESULT < 1000
		ABL:Ｂ感度 = RESULT
		ABL:Ｂ感度 -= (ABL:Ｂ感度 %10)
		CALL NIPPLE_SENSITIVE_FIX
	ENDIF
	
CASE "Ｎ感度"
	PRINTFORML Enter Ｎ（Nipple）Sensitivity.（10～{SENSITIVE_MAX}, rounded to 10）
	PRINTL If Ｎ Sensitivity is below Ｂ Sensitivity, it is increased to Ｂ Sensitivity.
	INPUT
	IF RESULT >= 10 && RESULT < 1000
		ABL:Ｎ感度 = RESULT
		ABL:Ｎ感度 -= (ABL:Ｎ感度 %10)
		CALL NIPPLE_SENSITIVE_FIX
	ENDIF

CASE "陥没乳首"
	INVERTBIT TALENT:陥没乳首,0

CASE "母乳体質"
	INVERTBIT MARK:母乳体質,0
	IF MARK:母乳体質
		IF TALENT:処女
			EXP:出産 = 0
			TALENT:先天的母乳体質 = 1
		ELSE
			PRINTL Select if it comes from [Childbirht] or [Innate Lactation].
			PRINTLC [ 0] Childbirht
			PRINTLC [ 1] Innate Lactation
			INPUT
			IF !RESULT
				EXP:出産 = 1
				TALENT:先天的母乳体質 = 0
			ELSE
				EXP:出産 = 0
				TALENT:先天的母乳体質 = 1
			ENDIF
		ENDIF
	ELSE
		EXP:出産 = 0
		TALENT:先天的母乳体質 = 0
	ENDIF

CASE "母乳容量補正値"
	PRINTL Enter breast milk capacity adjustment.（1～999、default 100%）
	INPUT
	SIF RESULT > 0 && RESULT < 1000
		CFLAG:母乳容量補正値 = RESULT

CASE "母乳価格ボーナス"
	PRINTL Enter bonus to milk value.（0～999）
	INPUT
	SIF RESULT >= 0 && RESULT < 1000
		CFLAG:母乳価格ボーナス = RESULT

CASE "極上乳圧"
	INVERTBIT TALENT:極上乳圧,0

CASE "バストサイズ+1"
	SIF ABL:バストサイズ >= BUSTSIZE_超乳 -1
		RETURN
	ABL:バストサイズ ++
	CALL BUSTSIZE_TALENT_SET
	SIF ABL:バストサイズ < BUSTSIZE_巨乳
		TALENT:極上乳圧 = 0

CASE "バストサイズ-1"
	SIF !ABL:バストサイズ
		RETURN
	ABL:バストサイズ --
	CALL BUSTSIZE_TALENT_SET
	SIF ABL:バストサイズ < BUSTSIZE_巨乳
		TALENT:極上乳圧 = 0
ENDSELECT


