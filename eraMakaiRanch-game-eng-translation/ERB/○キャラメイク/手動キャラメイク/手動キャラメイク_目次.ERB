
;手動でキャラメイク入り口
@SELF_CHARA_MAKE_ENTRANCE

IF MONEY:貢献PT < CHARA_MAKE_COST && !FLAG:貢献pt消費ゼロ
	PRINTL Insufficient Contribution Points
	PRINTFORMW （Requires %VALUE_DIGIT(CHARA_MAKE_COST)% Contribution Points to make）
	RETURN
ENDIF
CALL MANYL(5)
PRINTL Manually customize a slave candidate.
PRINTL Note that while fine-tuning is possible, it is time consuming.
PRINTL (If you can make a CSV file, it may be faster.)
PRINTL Start the character maker?
IF FLAG:貢献pt消費ゼロ
	CALL PRINTL_WORD_COLOR,@"0 Contribution Points＞ Option Enabled","黄"
ELSE
	CALL PRINTL_WORD_COLOR,@"（%VALUE_DIGIT(CHARA_MAKE_COST)% Contribution Points will be used. Current：%VALUE_DIGIT(MONEY:貢献PT)%pt）","黄"
ENDIF
CALL ASK_YN
IF !RESULT
	;ランダムするか聞くのを追加
	CALL MANYL(3)
	PRINTL Randomize base presets?
	CALL ASK_YN
	IF !RESULT
		CALL SELF_CHARA_MAKE_SET_RANDOM
	ELSE
		CALL SELF_CHARA_MAKE_BEFORE
	ENDIF
	CALL SELF_CHARA_MAKE
ELSE
	RETURN
ENDIF



;手動キャラメイク前のデフォルトステータス入れ
@SELF_CHARA_MAKE_BEFORE

FLAG:再シャッフルBIT = 0
FLAG:キャラメイク中 = 1
ADDCHARA 2
TARGET = CHARANUM -1
CFLAG:追跡対象 = 1
TALENT:並乳 = 1
CALL RANDOM_SLAVE_BUST
CALL HEIGHT_CSTR_CALC
CALL SLAVE_EP_CALC
CALL SLAVE_BATTLE_POWER_CALC(1)
CALL CHOICE_CATEGORY
CALL SWEET_PERSON_CALL_ALL
CALL SWEET_GENITAL_CALL_ALL



;本体
@SELF_CHARA_MAKE

CLEARLINE LINECOUNT

;手動時の共通表示まとめ
CALL PRINT_SELF_CHARA_MAKE_STATUS

;目次
PRINTL 　《 Index 》
CALL HALFLINE
PRINTL [ 0] Basic・Profile
PRINTFORML [ 1] Appearance and %SAVESTR:表記／乳房%
PRINTL [ 2] Status・Work Experience
PRINTL [ 3] Sex Experience
PRINTL [ 4] Traits
PRINTL [ 5] Dedicated Settings
CALL PRINTL_ALIGN(3)
DRAWLINE
PRINTLC [90] Discard
PRINTLC [91] datデータ出力

;決定ボタン出すか無効か
CALL SLAVE_AUCTION_PRICE_CALC
IF CFLAG:競売価格 > MONEY
	CALL PRINTL_WORD_COLOR,@"　資金不足","黄"
ELSEIF CALLNAME == ""
	CALL PRINTL_WORD_COLOR,@"　名前を設定してください","黄"
ELSE
	PRINTL [99] Confirm
ENDIF
SIF CFLAG:競売価格
	PRINTFORML 競売価格：%VALUE_DIGIT(CFLAG:競売価格)%G　資金：%VALUE_DIGIT(MONEY)%G
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL SELF_CHARA_MAKE_PROFILE
CASE 1
	CALL SELF_CHARA_MAKE_APPEARAINCE
CASE 2
	CALL SELF_CHARA_MAKE_STATUS
CASE 3
	CALL SELF_CHARA_MAKE_SENSITIVE
CASE 4
	CALL SELF_CHARA_MAKE_TALENT
CASE 5
	CALL SELF_CHARA_MAKE_EXCLUSIVE
CASE 90
	PRINTL Discard and return?
	CALL ASK_YN
	IF !RESULT
		DELCHARA TARGET
		FLAG:キャラメイク中 = 0
		RETURN
	ENDIF
CASE 91
	;キャラメイク中のdat出力
	CALL CHARA_MAKE_OUTPUT_DATA
	
CASE 99
	CALL SELF_CHARA_MAKE_COMPLETE
	
	;RETURN 1してきたら完了
	SIF RESULT
		RETURN
ENDSELECT
RESTART



;手動時の共通表示
@PRINT_SELF_CHARA_MAKE_STATUS

CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT
CALL PRINT_NAME_STATUS
CALL PRINT_AFFILIATION_DATA
CALL PRINT_VISUAL_AGE
PRINTFORM Breast Size：%PRINT_BUSTSIZE(ABL:バストサイズ)%
CALL PRINT_BUST_C(1,1,1)
PRINTFORML Sexual Experience：【%SEXP_ENG(CSTR:性経験)%】
CALL PRINT_EXTERIOR
PRINTFORM Personality：【%PERSONALITY_ENG(CSTR:性格)%】
SIF !(CFLAG:魔界入りの目的 == 8 || CFLAG:魔界入りの目的 == 9)
	CALL PRINT_PURPOSE(CFLAG:魔界入りの目的)
PRINTFORM  Lv{BASE:レベル}　★{CFLAG:ランク}
IF CFLAG:仲間規模
	PRINTFORML ／{CFLAG:仲間ランク}%GROUP_SCALE()%
ELSE
	CALL PRINTL_WORD_COLOR,@"【No Companions】","灰"
ENDIF
PRINTL



;キャラメイク完了判定
@SELF_CHARA_MAKE_COMPLETE

CLEARLINE LINECOUNT
CALL CHARA_MAKE_SLAVE_DATA(9)

;各種確認
SIF CALLNAME == "Default-Chan"
	CALL PRINTL_WORD_COLOR,@"！Name is still「Default-Chan」","黄"
SIF !CFLAG:口上表示 && FLAG:口上表示
	CALL PRINTL_WORD_COLOR,@"No dialogue selected","黄"
PRINTL Confirm character?
CALL ASK_YN
SIF RESULT
	RETURN
SIF !FLAG:貢献pt消費ゼロ
	MONEY:貢献PT -= CHARA_MAKE_COST
SIF CFLAG:魔界入りの目的 == 7
	MONEY -= CFLAG:競売価格

;終了前に排他素質消去
CALL EXCLUSIVE_TALENT

;整理してこれでOKになったはず
CALL CHARA_MAKE_END_CALC
CALL CHARA_MAKE_END_FLAGSET

;最後までOKならRETURN 1
RETURN 1


