
;外見・おっぱいの変更
;ARG→PAGE
;ARG:1→INPUT_NUM
@SELF_CHARA_MAKE_APPEARAINCE_INPUT(ARG,ARG:1)

;ページ+INPUT_NUMでINPUT_NUMを上書き
;INPUT_NUMで変更箇所を指定する
;イベント入手キャラの呼び出しにも使うのでこんな感じ
INPUT_NUM = (ARG -1) *100 +ARG:1
SELECTCASE INPUT_NUM
CASE 0
	CHANGE_STATE = 身長
CASE 1
	CHANGE_STATE = 体型
CASE 2
	CHANGE_STATE = 肌の色
CASE 3
	CHANGE_STATE = 髪色
CASE 4
	CHANGE_STATE = 髪特徴
CASE 5
	CHANGE_STATE = 髪型
CASE 6
	CHANGE_STATE = ヘアスタイル一括
CASE 7
	CHANGE_STATE = カラーコード／髪
CASE 8
	CHANGE_STATE = 外見年齢
CASE 9
	CHANGE_STATE = 陰毛
CASE 10
	CHANGE_STATE = 右目の色
CASE 11
	CHANGE_STATE = カラーコード／右目
CASE 12
	CHANGE_STATE = 左目の色
CASE 13
	CHANGE_STATE = カラーコード／左目
CASE 14
	CHANGE_STATE = 瞳の形
CASE 15
	CHANGE_STATE = 目の特徴

;2ページ目
CASE 100
	CHANGE_STATE = バストサイズ
CASE 101
	CHANGE_STATE = 乳弾力
CASE 102
	CHANGE_STATE = 乳首の色
CASE 103
	CHANGE_STATE = カラーコード／乳首
CASE 104
	CHANGE_STATE = Ｂ感度
CASE 105
	CHANGE_STATE = Ｎ感度
CASE 106
	CHANGE_STATE = 陥没乳首
CASE 110
	CHANGE_STATE = 母乳体質
CASE 111
	CHANGE_STATE = 母乳容量補正値
CASE 112
	CHANGE_STATE = 母乳価格ボーナス
CASE 113
	CHANGE_STATE = 極上乳圧
CASE 120
	CHANGE_STATE = バストサイズ+1
CASE 121
	CHANGE_STATE = バストサイズ-1
ENDSELECT

;SELF_CHARA_MAKE_RANDOMが有効かどうかで呼ぶ関数変更
IF SELF_CHARA_MAKE_RANDOM
	CALL SELF_CHARA_MAKE_APPEARAINCE_INPUT_SHUFFLE(CHANGE_STATE)
ELSE
	CALL SELF_CHARA_MAKE_APPEARAINCE_INPUT_MANUAL(CHANGE_STATE)
ENDIF






