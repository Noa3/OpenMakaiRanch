
;ステータス・仕事能力の変更
;ARG→PAGE
;ARG:1→INPUT_NUM
@SELF_CHARA_MAKE_STATUS_INPUT(ARG,ARG:1)

INPUT_NUM = (ARG -1) *100 +ARG:1
SELECTCASE INPUT_NUM
CASE 0
	CHANGE_STATE = レベル
CASE 1
	CHANGE_STATE = 非戦闘職
CASE 2
	CHANGE_STATE = 体力
CASE 3
	CHANGE_STATE = 気力
CASE 4
	CHANGE_STATE = 霊力再計算
CASE 5
	CHANGE_STATE = 霊力固定
CASE 6
	CHANGE_STATE = 魔力量
CASE 7
	CHANGE_STATE = 魔力再計算
CASE 8
	CHANGE_STATE = 魔力固定
CASE 9
	CHANGE_STATE = 魔力回復割合
CASE 10
	CHANGE_STATE = 戦闘力再計算


;2ページ目
CASE 100
	CHANGE_STATE = 回復回数
CASE 101
	CHANGE_STATE = 大技回数
CASE 102
	CHANGE_STATE = 同行仲間
CASE 103
	CHANGE_STATE = 仲間ランク
CASE 104
	CHANGE_STATE = 仲間戦闘力再計算


;3ページ目
CASE 200
	CHANGE_STATE = 酪農ABL
CASE 201
	CHANGE_STATE = 事務ABL
CASE 202
	CHANGE_STATE = 掃除ABL
CASE 203
	CHANGE_STATE = 料理ABL
CASE 204
	CHANGE_STATE = 薬学ABL
CASE 205
	CHANGE_STATE = 接客ABL
CASE 210
	CHANGE_STATE = 掃除下手
CASE 211
	CHANGE_STATE = 料理下手
CASE 212
	CHANGE_STATE = 接客下手
CASE 213
	CHANGE_STATE = 調合知識
ENDSELECT

;SELF_CHARA_MAKE_RANDOMが有効かどうかで呼ぶ関数変更
IF SELF_CHARA_MAKE_RANDOM
	CALL SELF_CHARA_MAKE_STATUS_INPUT_SHUFFLE(CHANGE_STATE)
ELSE
	CALL SELF_CHARA_MAKE_STATUS_INPUT_MANUAL(CHANGE_STATE)
ENDIF



