
;素質の変更
;ARG→INPUT
@SELF_CHARA_MAKE_TALENT_INPUT(ARG)

;一応弾き処理
SIF TALENTNAME:ARG == ""
	RETURN
SELECTCASE ARG
CASE 100 TO 149,200 TO 209,300 TO 349
	;逆側はOFFする
	INVERTBIT TALENT:ARG,0
	TALENT:(ARG +50) = 0
	
CASE 150 TO 199,250 TO 259,350 TO 399
	;逆側OFFは-50
	INVERTBIT TALENT:ARG,0
	TALENT:(ARG -50) = 0

CASE 210 TO 249,260 TO 299,400 TO 499,600 TO 699
	;素直にONOFF
	INVERTBIT TALENT:ARG,0

CASE 500 TO 599
	;+1→-1→0→+1で切り替え
	SELECTCASE TALENT:ARG
	CASE 1
		TALENT:ARG = -1
	CASE 0
		TALENT:ARG = 1
	CASEELSE
		TALENT:ARG = 0
	ENDSELECT
ENDSELECT

;プライド高い・低い・高慢・卑屈はどれかだけ
IF TALENT:高慢 || TALENT:卑屈
	TALENT:プライド高い = 0
	TALENT:プライド低い = 0
ENDIF



