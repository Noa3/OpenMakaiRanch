
;基礎・プロフィールの変更
;ARG→PAGE
;ARG:1→INPUT_NUM
@SELF_CHARA_MAKE_PROFILE_INPUT(ARG,ARG:1)

;ページ+INPUT_NUMでINPUT_NUMを上書き
;INPUT_NUMで変更箇所を指定する
INPUT_NUM = (ARG -1) *100 +ARG:1
SELECTCASE INPUT_NUM
CASE 0
	CHANGE_STATE = 名前
CASE 1
	CHANGE_STATE = 種族
CASE 2
	CHANGE_STATE = 上位種族
CASE 3
	CHANGE_STATE = ジョブ
CASE 4
	CHANGE_STATE = 身分
CASE 5
	CHANGE_STATE = 所属
CASE 6
	CHANGE_STATE = 服装
CASE 7
	CHANGE_STATE = 魔界入りの目的
CASE 10
	CHANGE_STATE = 身長
CASE 11
	CHANGE_STATE = 体型
CASE 12
	CHANGE_STATE = 肌の色
CASE 13
	CHANGE_STATE = バストサイズ
CASE 14
	CHANGE_STATE = 性経験


;2ページ目
CASE 100 TO 120
	;ARG:1が元々のINPUT_NUM
	SIF TALENTNAME:(ARG:1 +TALENT_REF) == ""
		RETURN
	INVERTBIT TALENT:(ARG:1 +TALENT_REF),0
	
	;エルフ耳／ハーフリング耳は片方だけ
	SIF TALENTNAME:(ARG:1 +TALENT_REF) == "エルフ耳"
		TALENT:ハーフリング耳 = 0
	SIF TALENTNAME:(ARG:1 +TALENT_REF) == "ハーフリング耳"
		TALENT:エルフ耳 = 0
	RETURN


;3ページ目
CASE 200
	CHANGE_STATE = 性格
CASE 201
	CHANGE_STATE = 口上
	
;変更用関数に飛ばすようにした
CASE 210
	CHANGE_STATE = 一人称
CASE 211
	CHANGE_STATE = 陥落前のあなた呼び方
CASE 212
	CHANGE_STATE = 陥落後のあなた呼び方
CASE 213
	CHANGE_STATE = ペニス呼び方
CASE 214
	CHANGE_STATE = 膣呼び方
CASE 215
	CHANGE_STATE = アナル呼び方
ENDSELECT

;SELF_CHARA_MAKE_RANDOMが有効かどうかで呼ぶ関数変更
IF SELF_CHARA_MAKE_RANDOM
	CALL SELF_CHARA_MAKE_PROFILE_INPUT_SHUFFLE(CHANGE_STATE)
ELSE
	CALL SELF_CHARA_MAKE_PROFILE_INPUT_MANUAL(CHANGE_STATE)
ENDIF




