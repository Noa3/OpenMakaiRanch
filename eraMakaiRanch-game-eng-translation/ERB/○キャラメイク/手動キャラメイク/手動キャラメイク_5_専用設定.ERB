
;専用設定
@SELF_CHARA_MAKE_EXCLUSIVE

CLEARLINE LINECOUNT
CALL PRINT_SELF_CHARA_MAKE_STATUS
PRINTL 　《Dedicated Settings》
CALL HALFLINE
PRINTL ・Use this when making exclusive graphics or dialogues for characters.
PRINTL
PRINTLC [ 0] Identifier
PRINTFORML ：%CSTR:識別名%
PRINTLC [ 1] Source Title
PRINTFORML ：%CSTR:出典作品名%
PRINTLC [ 2] Character Introduction
PRINTFORML ：%CSTR:キャラクター紹介%
CALL PRINTL_ALIGN(3)
DRAWLINE
PRINTL [99] Return
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	PRINTL Enter a identifier
	INPUTS
	CSTR:識別名 = %RESULTS%
	
CASE 1
	PRINTL Enter the source work
	INPUTS
	CSTR:出典作品名 = %RESULTS%
	
CASE 2
	PRINTL Enter a character introduction
	INPUTS
	CSTR:キャラクター紹介 = %RESULTS%
	
CASE 99
	RETURN
ENDSELECT
RESTART



