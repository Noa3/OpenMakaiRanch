;嗜好
@SELF_CHARA_MAKE_TALENT_5

PRINTL 　《 嗜好 》
PRINTL （好き→青　苦手→赤　どちらでもない→グレー）
PRINTL ※選択のたび＜好き→苦手→なし→好き＞と入れ替わります
CALL HALFLINE
BR = 0

;TALENT:牛好き→500
;STR:牛→8300
STR_REF = 8300 -500
FOR LOCAL,500,600
	SIF TALENTNAME:LOCAL == ""
		CONTINUE
	
	;嗜好だけ+-で色変更
	IF TALENT:LOCAL > 0
		SETCOLOR 0x80FFFF
	ELSEIF TALENT:LOCAL < 0
		SETCOLOR 0xEF857D
	ELSE
		SETCOLOR 0x606060
	ENDIF
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL,3}] %TALENTS_ENG(STR:(LOCAL +STR_REF))%
NEXT



