
;基礎・プロフィール
@SELF_CHARA_MAKE_PROFILE
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL PRINT_SELF_CHARA_MAKE_STATUS
TRYCALLFORM SELF_CHARA_MAKE_PROFILE_{PAGE}
CALL PRINTL_ALIGN(2)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTLC [99] 戻る
PRINTFORML [90] 選択方式切り替え：\@ SELF_CHARA_MAKE_RANDOM ? シャッフル # 手動入力 \@
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 90
	INVERTBIT SELF_CHARA_MAKE_RANDOM,0
CASE 99
	RETURN
CASEELSE
	CALL SELF_CHARA_MAKE_PROFILE_INPUT(PAGE,RESULT)
ENDSELECT
RESTART

