
;外見再シャッフル
@CHARA_MAKE_SLAVE_SHUFFLE_APPEARAINCE

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT
PRINTL Reshuffle the appearance attributes for slave candidates.
PRINTL
CALL PRINT_EXTERIOR
CALL HALFLINE
SIF GETBIT(＃再シャッフル／身体特徴＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:2)%pt】
PRINTL [ 0] Height value
PRINTFORML ※This will shuffle within the range of 【%CSTR:身長%】.
PRINTL
PRINTL [ 1] Body type
PRINTL [ 2] Skin color
PRINTL [ 3] Pubic hair
RESETCOLOR
PRINTL
SIF GETBIT(＃再シャッフル／ヘアスタイル＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:3)%pt】
PRINTL ヘアスタイルシャッフル
PRINTLC [10] Hair Color
PRINTLC [11] Hair Characteristic
PRINTLC [12] Hair Style
PRINTL
PRINTL [13] Shuffle All Hair
RESETCOLOR
PRINTL
SIF GETBIT(＃再シャッフル／目特徴＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:4)%pt】
PRINTL Eye-related shuffle
PRINTLC [20] Eye Color
PRINTL [21] Shuffle with odd eyes confirmed
PRINTLC [22] Eye Shape
PRINTL [23] Eye Features
RESETCOLOR
CALL PRINTL_ALIGN
DRAWLINE
PRINTL [99] Done
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL RANDOM_SLAVE_HEIGHT
	SETBIT ＃再シャッフル／身体特徴＃
CASE 1
	CALL RANDOM_SLAVE_SHAPE
	SETBIT ＃再シャッフル／身体特徴＃
CASE 2
	CALL RANDOM_SLAVE_SKIN_COLOR
	SETBIT ＃再シャッフル／身体特徴＃
CASE 3
	CALL RANDOM_SLAVE_UNDERHAIR
	SETBIT ＃再シャッフル／身体特徴＃
CASE 10
	CALL RANDOM_SLAVE_HAIR_COLOR
	SETBIT ＃再シャッフル／ヘアスタイル＃
CASE 11
	CALL RANDOM_SLAVE_HAIR_FEATURE
	SETBIT ＃再シャッフル／ヘアスタイル＃
CASE 12
	CALL RANDOM_SLAVE_HAIR_STYLE
	SETBIT ＃再シャッフル／ヘアスタイル＃
CASE 13
	CALL RANDOM_SLAVE_HAIR
	SETBIT ＃再シャッフル／ヘアスタイル＃
CASE 20
	CALL RANDOM_SLAVE_EYE_COLOR
	SETBIT ＃再シャッフル／目特徴＃
CASE 21
	CALL RANDOM_SLAVE_EYE_COLOR(1)
	SETBIT ＃再シャッフル／目特徴＃
CASE 22
	CALL RANDOM_SLAVE_PUPIL
	SETBIT ＃再シャッフル／目特徴＃
CASE 23
	CALL RANDOM_SLAVE_EYE_FEATURE
	SETBIT ＃再シャッフル／目特徴＃
CASE 99
	RETURN
ENDSELECT
RESTART

