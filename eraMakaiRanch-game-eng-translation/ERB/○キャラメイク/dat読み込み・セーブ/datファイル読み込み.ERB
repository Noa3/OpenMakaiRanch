
;datから読み込み
@CHARA_DATA_LOAD

IF MONEY:貢献PT < CHARA_MAKE_COST && !FLAG:貢献pt消費ゼロ
	PRINTL Insufficient Contribution Points
	PRINTFORMW （%VALUE_DIGIT(CHARA_MAKE_COST)% Contribution Points required to read .dat）
	RETURN
ENDIF
PRINTL Load character data?
IF FLAG:貢献pt消費ゼロ
	CALL PRINTL_WORD_COLOR,@"＜0 Contribution Points＞ Option Enabled","黄"
ELSE
	CALL PRINTL_WORD_COLOR,@"%VALUE_DIGIT(CHARA_MAKE_COST)% Contribution Points will be used. Current：%VALUE_DIGIT(MONEY:貢献PT)%pt）","黄"
ENDIF
CALL ASK_YN
SIF !RESULT
	CALL CHARA_DATA_LOAD_LIST



;読み込みdat選択
@CHARA_DATA_LOAD_LIST
#DIM DYNAMIC PAGE

PAGE_MAX = 5
CLEARLINE LINECOUNT
SIF PAGE < 1
	PAGE = 1
PRINTL 読み込むキャラクターを選択してください
DRAWLINE
FOR LOCAL,20 *(PAGE -1) +100,20 *PAGE +100
	IF FIND_CHARADATA(TOSTR(LOCAL))
		CHKCHARADATA RESULTS
		PRINTFORML [{LOCAL}] %RESULTS%
	ELSE
		CALL PRINTL_WORD_COLOR,@"<{LOCAL}> NO DATA","灰"
	ENDIF
NEXT
DRAWLINE
CALL PRINT_NOW_PAGE(PAGE)
CALL RIGHT_RETURN_BUTTON(0,"キャンセル")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	;CSV読み込み時と同じ画面へ
	LOADCHARA TOSTR(RESULT)
	TARGET = CHARANUM -1
	FLAG:キャラメイク中 = 1
	
	;datが対応前のとき確認メッセージ
	SIF CFLAG:dat作成バージョン < CAVEAT_DAT_VERSION
		CALL PRINTW_WORD_COLOR,@"※datファイルのバージョンがデータ番号に変更が加わる前のものです。読み込み後の素質等の確認を推奨します","黄"
	CALL CSV_CHARA_ADD_FIX
	CALL SELF_CHARA_MAKE
	RETURN
ENDSELECT
RESTART










