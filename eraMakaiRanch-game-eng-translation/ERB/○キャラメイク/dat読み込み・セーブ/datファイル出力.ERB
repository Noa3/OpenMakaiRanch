
;簡易版奴隷出力
@OUTPUT_CHARA_DATA_SELECT
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL ・奴隷のデータを出力し、セーブデータの変更やニューゲーム時に呼び出せるように保存します。
PRINTL （datファイルとして保存されます）
PRINTL バージョンアップにより以前のデータが読み込めなくなる場合があります。ご了承ください。
DRAWLINE
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("牛舎")
	PRINTL
NEXT
CALL PRINTL_ALIGN
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] 表示項目変更
PRINTLC 　
PRINTL [ 99] キャンセル
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN

CASEELSE
	TARGET = RESULT -100
	
	;出典[era魔界牧場]の奴隷は複製不可にしとくよ
	IF CSTR:出典作品名 == "era魔界牧場"
		PRINTW 出典作品名[era魔界牧場]の奴隷は出力できない設定になっています。
		RESTART
	ENDIF
	CALL OUTPUT_CHARA_DATA_CLEATE
	RETURN
ENDSELECT
RESTART



;キャラメイク中に来るとき
@CHARA_MAKE_OUTPUT_DATA
#DIM NOW_CHARA_MAKE

IF CALLNAME == ""
	CALL PRINTW_WORD_COLOR,@"　名前を設定してください","黄"
	RETURN
ENDIF
PRINTW キャラメイク中のデータをdatファイルに出力します。

;コピー
ADDCOPYCHARA TARGET
NOW_CHARA_MAKE = TARGET
TARGET = CHARANUM -1

;コピーの初期値を出す
CALL CHARA_MAKE_END_CALC

;下へ
CALL OUTPUT_CHARA_DATA_CLEATE

;コピーを消す
DELCHARA TARGET
TARGET = NOW_CHARA_MAKE



;キャラ選択後
@OUTPUT_CHARA_DATA_CLEATE

;キャラメイク中フラグON
FLAG:キャラメイク中 = 1

;キャラのコピーを作成
ADDCOPYCHARA TARGET
SAVE_TARGET = TARGET
TARGET = CHARANUM -1

;初期値が用意されているデータを初期値にリセット
FOR LOCAL,0,100
	CFLAG:LOCAL = CFLAG:(LOCAL +100)
	ABL:LOCAL = ABL:(LOCAL +100)
	MAXBASE:LOCAL = MAXBASE:(LOCAL +100)
	BASE:LOCAL = MAXBASE:LOCAL
	CSTR:LOCAL = %CSTR:(LOCAL +100)%
	EQUIP:LOCAL = EQUIP:(LOCAL +100)
NEXT

;初期値はどうせキャラ読み込み後に上書きされる　けど消しといたほうがバグ起こさなそう
VARSET CFLAG,0,100,200
VARSET EQUIP,0,100,200
VARSET CSTR,"",100,200

;一般使用部分はリセット
VARSET CFLAG,0,300,1000
VARSET EQUIP,0,300,2000
VARSET ABL,0,100,300
VARSET MAXBASE,0,100,300
VARSET BASE,0,100,300
VARSET CSTR,"",300,3000

;EXPの100～199は使う
VARSET EXP,0,0,100
VARSET EXP,0,200,2000
VARSET JUEL

;固定フラグON
CFLAG:霊力固定 = 1
CFLAG:魔力固定 = 1

;消去された素質あれば付ける
SIF MARK:乳房劣等感解消
	TALENT:乳劣等感 = 1
SIF MARK:乳責め嫌悪解消
	TALENT:乳責め嫌悪 = 1
SIF MARK:処女結界解除 || MARK:処女結界破壊
	TALENT:処女結界 = 1
SIF MARK:プライド崩壊
	TALENT:プライド高い = 1
SIF MARK:高慢消滅
	TALENT:高慢 = 1
SIF MARK:気丈崩壊
	TALENT:気丈 = 1
SIF MARK:反抗的消滅
	TALENT:反抗的 = 1
SIF MARK:生意気消滅
	TALENT:生意気 = 1
SIF MARK:楽観的消滅
	TALENT:楽観的 = 1
SIF MARK:カリスマ崩壊
	TALENT:カリスマ = 1
SIF MARK:正義の敗北
	TALENT:正義感 = 1
SIF MARK:乙女心凌辱
	TALENT:乙女心 = 1
SIF MARK:自制心崩壊
	TALENT:自制心 = 1
VARSET MARK

;バストサイズ素質調整
CALL BUSTSIZE_TALENT_SET

;ランク再計算
CFLAG:ランク = MAXBASE:レベル /10

;一旦追跡対象に
CFLAG:追跡対象 = 1

;隠蔽は無効に→ランダムならどうせまたONになる
FLAG:キャラメイク隠蔽有効 = 0

;バージョン突っ込む
CFLAG:dat作成バージョン = GAMEBASE_VERSION

;CSV読み込みと同じ処理
;装備がある部分のIDを入れる
CALL CHARA_EQUIP_REGISTER

;このへん確実なのでいちいち書かなくてもいいように
SIF TALENT:処女結界
	CALL VARGIN_BARRIER
SIF TALENT:先天的母乳体質
	MARK:母乳体質 = 1
SIF EXP:出産
	MARK:母乳体質 = 1

;確認とセーブ位置選択へ
CALL OUTPUT_CHARA_DATA_CONFIRM

;セーブしてもキャンセルしてもTARGETは消す
DELCHARA TARGET
TARGET = SAVE_TARGET



;確認
@OUTPUT_CHARA_DATA_CONFIRM

CLEARLINE LINECOUNT

;ステータス部分使う
;CALL SHOW_STATUS_DETAIL
CALL CHARA_MAKE_SLAVE_DATA(9)

CALL PRINTL_ALIGN
;DRAWLINE
PRINTL こちらのデータで保存します。よろしいですか？
CALL ASK_YN
SIF RESULT
	RETURN
CFLAG:追跡対象 = 0
CALL OUTPUT_CHARA_DATA_LIST



;セーブするデータ位置選択
@OUTPUT_CHARA_DATA_LIST
#DIM DYNAMIC PAGE
#DIM SAVE_NUM
#DIMS SAVE_PROFILE,2

PAGE_MAX = 5
CLEARLINE LINECOUNT
SIF PAGE < 1
	PAGE = 1
PRINTL セーブする番号を選択してください
DRAWLINE
FOR LOCAL,20 *(PAGE -1) +100,20 *PAGE +100
	IF FIND_CHARADATA(TOSTR(LOCAL))
		CHKCHARADATA RESULTS
		PRINTFORML [{LOCAL}] %RESULTS%
	ELSE
		PRINTFORM [{LOCAL}]
		CALL PRINTL_WORD_COLOR,@" NO DATA","灰"
	ENDIF
NEXT
DRAWLINE
CALL PRINT_NOW_PAGE(PAGE)
CALL RIGHT_RETURN_BUTTON(0,"キャンセル")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	;データが既にある場合は確認
	SAVE_NUM = RESULT
	IF FIND_CHARADATA(TOSTR(SAVE_NUM))
		CALL PRINTL_WORD_COLOR,@"！<{SAVE_NUM}>番には既にキャラデータが存在します。上書きしていいですか？","黄"
		CALL ASK_YN
		SIF RESULT
			RESTART
	ENDIF
	
	;表示するデータに名前・種族・おっぱい
	SAVE_PROFILE:1 = %PRINT_BUSTSIZE(ABL:バストサイズ)%【%PRINT_BUSTSIZE_TALENT()%】
	SAVE_PROFILE = 【%CALLNAME%】【%CSTR:種族%】%SAVE_PROFILE:1%
	SAVECHARA TOSTR(SAVE_NUM),SAVE_PROFILE,TARGET
	PRINTFORMW %CALLNAME%のデータを<{SAVE_NUM}>番に出力しました。
	RETURN
ENDSELECT
RESTART




