
;髪色から口上色セット
@KOJO_COLOR_SET_HAIR_COLOR_AUTO
#DIM COLOR,4

;口上が指定されていたら無効
SIF CSTR:使用口上 != ""
	RETURN

;髪色を基準にRGBそれぞれランダムに30まで増加
;黒だったら無効
SIF !CFLAG:カラーコード／髪
	RETURN
COLOR = CFLAG:カラーコード／髪
COLOR:1 = LIMIT(GETRED(COLOR) +RAND:30,0,255)
COLOR:2 = LIMIT(GETGREEN(COLOR) +RAND:30,0,255)
COLOR:3 = LIMIT(GETBLUE(COLOR) +RAND:30,0,255)
CFLAG:カラーコード／口上 = RGBCOLOR(COLOR:1,COLOR:2,COLOR:3)

