
;人称が空だったら直すとこ
@PERSON_CALL_FIX

;NEWGAMEするとあなたも来てなんか入力させられるので帰す
SIF !TARGET
	RETURN
CALL PERSON_CALL_FIX_SELF
CALL PERSON_CALL_FIX_YOU
CALL PERSON_CALL_FIX_MASTER
CALL PERSON_CALL_FIX_PENIS
CALL PERSON_CALL_FIX_VAGINA
CALL PERSON_CALL_FIX_ANAL



;一人称
@PERSON_CALL_FIX_SELF

SIF CSTR:一人称 != "" && CSTR:一人称／蕩け != ""
	RETURN
PRINTFORML %CALLNAME%の一人称が空欄のため補正を行います。
PRINTL
CALL CHANGE_PERSONAL_CALL("一人称")
SIF CSTR:一人称 == "" || CSTR:一人称／蕩け == ""
	RESTART



