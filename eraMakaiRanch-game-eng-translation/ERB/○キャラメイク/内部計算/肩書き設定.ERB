
;肩書き設定
@CHARA_SECOND_NAME_SETTING
#DIMS AFFILIATION

AFFILIATION += "【"
EXIST = 0
IF CSTR:所属 != ""
	AFFILIATION += CSTR:所属
	EXIST ++
ENDIF
IF CSTR:身分 != ""
	AFFILIATION += CSTR:身分
	EXIST ++
ENDIF
IF CSTR:ジョブ != ""
	SIF EXIST
		AFFILIATION += "・"
	AFFILIATION += CSTR:ジョブ
	EXIST ++
ENDIF
AFFILIATION += "】"
IF EXIST
	CSTR:肩書き = %AFFILIATION%
ELSEIF TALENT:天界種族 || CFLAG:上位種族
	CSTR:肩書き = %CSTR:種族%
ELSE
	CSTR:肩書き = 普通の%CSTR:種族%
ENDIF


