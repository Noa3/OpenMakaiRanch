;感度表示
@SENSITIVE_LIST_CHARA_MAKE
#DIMS KANDO

IF GETBIT(＃ステータス隠蔽／感度＃) && !GETBIT(＃再シャッフル／感度＃) && FLAG:キャラメイク隠蔽有効
	CALL PRINTL_WORD_COLOR("Sensitivity still unknown","灰")
	RETURN
ENDIF

;STR:Ｂ→3950
STR_REF = 3950
FOR LOCAL,STR_REF,STR_REF +10
	RESETCOLOR
	SIF STR:LOCAL == ""
		BREAK
	KANDO = %STR:LOCAL%感度
	
	;感度120%でピンク
	IF ABL:KANDO >= 120
		SETCOLOR 0xFF70FF
	
	;感度80%以下は水色
	ELSEIF ABL:KANDO <= 80
		SETCOLOR 0x50C0FF
	ENDIF
	
	;感度200%だとハート追加
	SIF ABL:KANDO >= 200
		CALL HEARTCB(0xD02830)
	PRINTFORM %ABL_ENG(KANDO)%<{ABL:KANDO,3}\%> 
	RESETCOLOR
NEXT
PRINTL



;性体質表示
@TALENT_NASTY_CHARA_MAKE

IF GETBIT(＃ステータス隠蔽／性体質＃) && !GETBIT(＃再シャッフル／性体質＃) && FLAG:キャラメイク隠蔽有効
	CALL PRINTL_WORD_COLOR("Sexual Traits unknown","灰")
