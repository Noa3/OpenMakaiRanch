
;再シャッフルの目次
;飛ばした先でリストにして決めさせようかなと思ったけど厳選したいなら頑張って感出したくてやめた
@CHARA_MAKE_SLAVE_SHUFFLE_INDEX
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1

;使用貢献ptを計算
;FLAG:再シャッフルBITのBITがONなら対応する疑似定数を加算
FLAG:使用貢献PT = 0
FOR LOCAL,0,20
	SIF GETBIT(FLAG:再シャッフルBIT,LOCAL)
		FLAG:使用貢献PT += SHUFFLE_AGAIN_PT:LOCAL
NEXT
CLEARLINE LINECOUNT
CALL CHARA_MAKE_SLAVE_DATA(PAGE)
PRINTL Select a category to randomize
PRINTFORML ＜Contribution Points：%VALUE_DIGIT(FLAG:使用貢献PT)%／%VALUE_DIGIT(MONEY:貢献PT)%（決定時に使用するpt／所持中pt）＞
PRINTL

;シャッフル可能項目を絞った
PRINTLC [ 0] Name
PRINTFORMLC [ 1] %SAVESTR:表記／乳房%
PRINTLC [ 2] Outward Appearance
PRINTLC [ 3] Personality・Traits
PRINTLC [ 4] Sexual Experience・Constitution
PRINTL [ 5] Clothing
CALL PRINTL_ALIGN(2)
PRINTFORML [80] Change Display <PAGE{PAGE,2}／{PAGE_MAX}>
DRAWLINE
PRINTLC [90] Restore To Initial State
PRINTLC 　
PRINTL [99] Go To Confirmation Screen
BINPUT
SELECTCASE RESULT
CASE 0
	CALL CHARA_MAKE_SLAVE_SHUFFLE_NAME
CASE 1
	CALL CHARA_MAKE_SLAVE_SHUFFLE_BUST
CASE 2
	CALL CHARA_MAKE_SLAVE_SHUFFLE_APPEARAINCE
CASE 3
	CALL CHARA_MAKE_SLAVE_SHUFFLE_PERSONALITY
CASE 4
	CALL CHARA_MAKE_SLAVE_SHUFFLE_SENSITIVE
CASE 5
	CALL CHARA_MAKE_SLAVE_SHUFFLE_CLOTHE
CASE 80
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 90
	PRINTL Undo changes?
	CALL ASK_YN
	IF !RESULT
		;-1されてるのでTARGETはバックアップになってる
		DELCHARA TARGET
		ADDCOPYCHARA TARGET
		FLAG:再シャッフルBIT = 0
	ENDIF
CASE 99
	RETURN
ENDSELECT
RESTART

