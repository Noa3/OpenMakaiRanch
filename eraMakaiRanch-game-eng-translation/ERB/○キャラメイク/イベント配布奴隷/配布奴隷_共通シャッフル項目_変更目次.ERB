
;配布奴隷のシャッフル項目一覧
;ARG→INPUT
@FIXED_SLAVE_CHANGE_INPUT(ARG)

SELECTCASE ARG
CASE 0
	CHANGE_STATE = 名前
CASE 1
	CHANGE_STATE = 乳弾力
CASE 2
	CHANGE_STATE = 乳首の色
CASE 3
	CHANGE_STATE = カラーコード／乳首
CASE 4
	CHANGE_STATE = 髪色
CASE 5
	CHANGE_STATE = 髪特徴
CASE 6
	CHANGE_STATE = 髪型
CASE 7
	CHANGE_STATE = ヘアスタイル一括
CASE 8
	CHANGE_STATE = カラーコード／髪
CASE 9
	CHANGE_STATE = 陰毛
	
CASE 10
	CHANGE_STATE = 右目の色
CASE 11
	CHANGE_STATE = カラーコード／右目
CASE 12
	CHANGE_STATE = 左目の色
CASE 13
	CHANGE_STATE = カラーコード／左目

CASE 20
	CHANGE_STATE = 陥落後のあなた呼び方

CASE 30
	CHANGE_STATE = 口上
ENDSELECT

;SELF_CHARA_MAKE_RANDOMが有効かどうかで呼ぶ関数変更
IF SELF_CHARA_MAKE_RANDOM
	CALL FIXED_SLAVE_CHANGE_INPUT_SHUFFLE(CHANGE_STATE)
ELSE
	CALL FIXED_SLAVE_CHANGE_INPUT_MANUAL(CHANGE_STATE)
ENDIF


