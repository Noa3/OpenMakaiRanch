
;魔術士奴隷候補の追加処理
@CHARA_MAKE_FIXED_SLAVE_SORCEROUS

CALL MANYL(5)
PRINTL A [Timid Peach Haired Busty White Mage] or
PRINTL A [Confident But Naive Silver Haired Busty Black Mage]
PRINTL Which way demon man?
PRINTL (If you want both, you can also load the CSV afterwards)
PRINTL （Breast size may not be【Huge】if thresholds were altered）
PRINTL
PRINTLC [ 0] White Mage
PRINTL [ 1] Black Mage
INPUT
IF !RESULT
	ADDCHARA 5
ELSE
	ADDCHARA 6
ENDIF
TARGET = CHARANUM -1
CALL CSV_CHARA_ADD_FIX
SIF !FLAG:候補割合／一般種族／人間
	CALL CHARA_MAKE_FIXED_SLAVE_TRIBE_QUESTION
CALL CHARA_MAKE_FIXED_SLAVE_SORCEROUS_SHUFFLE_INDEX



;シャッフル
@CHARA_MAKE_FIXED_SLAVE_SORCEROUS_SHUFFLE_INDEX
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL CHARA_MAKE_SLAVE_DATA(PAGE)
PRINTL 　《 Randomize 》
PRINTLC [ 0] Name Change Screen
PRINTLC [ 1] Breast Firmness
PRINTLC [ 2] Nipple Color
PRINTLC [ 3] Hair Style
PRINTLC [ 4] Eye Color
PRINTFORML [ 5] Dialogue Settings　Current：%DIALOGUE_ENG(CSTR:使用口上)%
CALL PRINTL_ALIGN
PRINTFORML [80] Change Display <PAGE{PAGE,2}／{PAGE_MAX}>
DRAWLINE

;別なほうも見たいなら
IF CSTR:ジョブ == "白魔術士"
	PRINTLC [90] Choose the Black Mage
ELSE
	PRINTLC [90] Choose the White Mage
ENDIF
PRINTLC [98] Tip
PRINTL [99] Done
BINPUT
SELECTCASE RESULT
CASE 0
	CALL CHARA_MAKE_SLAVE_SHUFFLE_NAME
CASE 1
	CALL RANDOM_SLAVE_BUST_FEELING
CASE 2
	CALL RANDOM_SLAVE_NIPPLE_COLOR
CASE 3
	CALL RANDOM_SLAVE_HAIR_STYLE
CASE 4
	CALL RANDOM_SLAVE_EYE_COLOR
CASE 5
	CALL KOJO_SETTING
CASE 80
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 90
	IF CSTR:ジョブ == "白魔術士"
		DELCHARA TARGET
		ADDCHARA 6
	ELSE
		DELCHARA TARGET
		ADDCHARA 5
	ENDIF
	TARGET = CHARANUM -1
	CALL CSV_CHARA_ADD_FIX(1)
	SIF !FLAG:候補割合／一般種族／人間
		CALL CHARA_MAKE_FIXED_SLAVE_TRIBE_QUESTION
CASE 98
	CALL BROWSE_HINT("魔術師奴隷設定")
CASE 99
	IF !CFLAG:口上表示 && FLAG:口上表示
		CALL PRINTL_WORD_COLOR("No dialogue selected, confirm?","黄")
		CALL ASK_YN
		SIF RESULT
			RESTART
	ENDIF
	CALL CHARA_MAKE_END_CALC
	CALL CHARA_MAKE_END_FLAGSET
	RETURN
ENDSELECT
RESTART



