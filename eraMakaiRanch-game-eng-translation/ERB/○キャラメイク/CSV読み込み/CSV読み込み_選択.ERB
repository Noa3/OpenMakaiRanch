	;	DISPNAME = %CSVCALLNAME(ARG)%
	;	CALL PRINTL_WORD_COLOR,@"<{ARG+100,3}>：%DISPNAME% can be summoned after completing the slave with mana event ","灰"
	;	EXIST = 1
	;ENDIF
ENDSELECT

