
;奴隷候補を作成する
@ORDER_CHARACTER

IF MONEY:貢献PT < CHARA_MAKE_COST && !FLAG:貢献pt消費ゼロ
	PRINTL Insufficient Contribution Points.
	PRINTFORMW （Requires %VALUE_DIGIT(CHARA_MAKE_COST)% Contribution Points to read from CSV）
	RETURN
ENDIF
CALL MANYL(5)
ALIGNMENT CENTER
PRINTL --- ！Warning！ ---
ALIGNMENT LEFT
DRAWLINE
PRINTL [Special Gate Release] allows loading in a CSV preset character
PRINTL This allows freely editing attributes such as [Race] and [Job].
;PRINTL 版権・オリジナル問わずキャラの再現度が高まります。個人で楽しむ領域であればご自由にどうぞ。
;PRINTL 注意点として、ほぼ全て自由記述形式で行うためわりと面倒です。
PRINTL Note that making a OP character may dramatically decrease the difficulty.
PRINTL 
;PRINTL ただし、セーブデータのアップロードやバグ報告などにおいて
;PRINTL ・eraというアングラ界隈だとしても倫理的にまずいものは上げないようにしてください。
;PRINTL ・公式が二次創作に制限をかけている版権作品のデータは上げないようにしてください。
;PRINTL （バグ報告をテキストで行う場合、適当に名前を置換してください）
DRAWLINE
PRINTL Load Character Data？
IF FLAG:貢献pt消費ゼロ
	CALL PRINTL_WORD_COLOR,@"＜0 Contribution Points＞ Option Enabled","黄"
ELSE
	CALL PRINTL_WORD_COLOR,@"（%VALUE_DIGIT(CHARA_MAKE_COST)% Contribution Points will be used. Current：%VALUE_DIGIT(MONEY:貢献PT)%pt）","黄"
ENDIF
CALL ASK_YN
SIF !RESULT
	CALL CSV_CHARA_LIST_TABLE



;読み込むキャラのカテゴリ
@CSV_CHARA_LIST_TABLE
#DIM SAVE_CHARANUM
#DIM CHARA_NUMBER
#DIM CHARA_COUNT
#DIM TABLE

CLEARLINE LINECOUNT
PRINTFORML Please select a source category.

FOR TABLE,0,100
	SIF STR:(6400+TABLE) == ""
		BREAK
	;枠に何人いるか
	CHARA_COUNT = 0
	FOR LOCAL,0,100
		CHARA_NUMBER = LOCAL+TABLE*100
		EXISTCSV CHARA_NUMBER
		SIF RESULT
			CHARA_COUNT ++
	NEXT
	PRINTFORMLC [{TABLE,2}] %CHARA_SOURCE_ENG(STR:(6400+TABLE))%　：{CHARA_COUNT}x 
NEXT
CALL MANYL(3)
PRINTL [99] Cancel
BINPUT
IF RESULT == 99
	RETURN
	
ELSEIF RESULT < 100
	SAVE_CHARANUM = CHARANUM
	CALL CSV_CHARA_LIST(RESULT)
	
	;キャラを呼び出していたらSAVE_CHARANUMとCHARANUMが異なるのでRETURNする
	SIF SAVE_CHARANUM != CHARANUM
		RETURN
ENDIF

;キャンセルで戻ってきたらRESTART
RESTART




;読み込むキャラを選択する
@CSV_CHARA_LIST(ARG)
#DIM CHARA_NUMBER
#DIM DYNAMIC PAGE
#DIM DYNAMIC STATUS_TOGGLE
#DIMS SOURCE_PRODUCTS
#DIMS DISPNAME

PAGE_MAX = 5
CLEARLINE LINECOUNT
SIF PAGE < 1
	PAGE = 1
VARSET CSVLOAD_OK

PRINTL Select a character preset
PRINTL ・Those with dedicated dialogue will be highlighted in blue
DRAWLINE

FOR LOCAL,20 *(PAGE -1),20 *PAGE
	;選択カテゴリ番号*100 +LOCALが存在するか見る
	CHARA_NUMBER = LOCAL +ARG *100
	EXISTCSV CHARA_NUMBER
	IF RESULT
		EXIST = 0
		;era魔界牧場枠はマイルストーン進行具合で不可能にする（予定がある）ので別関数を呼ぶ
		SIF !ARG
			CALL CHARA_LIST_MAKAIBOKUJO(CHARA_NUMBER)
		SIF EXIST
			CONTINUE
		
		;被りの場合はカスタム前に出典・名前を消す形式にした
		CSVLOAD_OK:CHARA_NUMBER = 1
		
		;専用口上がある場合水色表示
		SIF CSVCFLAG(CHARA_NUMBER,GETNUM(CFLAG,"専用設定／口上"))
			SETCOLOR 0x70FFFF
		IF CSVNAME(CHARA_NUMBER) != ""
			PRINTFORM [{CHARA_NUMBER+100,3}] %CSVNAME(CHARA_NUMBER),16,LEFT%：
		ELSE
			PRINTFORM [{CHARA_NUMBER+100,3}] %CSVCALLNAME(CHARA_NUMBER),16,LEFT%：
		ENDIF
		RESETCOLOR
		SELECTCASE STATUS_TOGGLE
		CASE 0
			PRINTFORML %JOB_ENG(CSVCSTR(CHARA_NUMBER, GETNUM(CSTR,"キャラクター紹介")))% 
		CASE 1
			CALL CSV_HEIGHT_BUST(CHARA_NUMBER)
		CASE 2
			CALL CSV_AFFILIATION_DATA(CHARA_NUMBER)
			PRINTL
		ENDSELECT
	ELSE
		CALL PRINTL_WORD_COLOR,@"<{CHARA_NUMBER+100,3}>：NODATA ","灰"
	ENDIF
NEXT
DRAWLINE
CALL PRINT_NOW_PAGE(PAGE)
PRINTFORMLC [  8] Switch Status Display（{STATUS_TOGGLE +1}／3）
PRINTLC 　
PRINTL [ 99] Cancel
BINPUT
PRINTL
SELECTCASE RESULT
CASE 8
	STATUS_TOGGLE ++
	SIF STATUS_TOGGLE > 2
		STATUS_TOGGLE = 0
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	CHARA_NUMBER = RESULT-100
	ADDCHARA CHARA_NUMBER
	TARGET = CHARANUM -1
	CALL CSV_CHARA_ADD_FIX
	CALL SELF_CHARA_MAKE
	RETURN
ENDSELECT
RESTART



;身長とおっぱい
;ARG：CHARA_NUMBER
@CSV_HEIGHT_BUST(ARG)
#DIM CSV_HEIGHT
#DIM CSV_BUSTSIZE

CSV_HEIGHT = CSVCFLAG(ARG,GETNUM(CFLAG,"身長"))

;グローバルフラグによる
IF FLAG:身長小数点表示
	PRINTFORM {CSV_HEIGHT/10}.{CSV_HEIGHT%10}cm 
ELSE
	PRINTFORM {CSV_HEIGHT/10}cm 
ENDIF
CSV_BUSTSIZE = CSVABL(ARG,GETNUM(ABL,"バストサイズ"))
PRINTFORM %PRINT_BUSTSIZE(CSV_BUSTSIZE)%
CALL PRINT_BUSTSIZE_SPECIFY(1,1,CSV_BUSTSIZE)
PRINTL



;種族とか
@CSV_AFFILIATION_DATA(ARG)
#DIMS CSV_DATA,5
#DIM CSV_HIGH_TRIBE

CSV_DATA:0 = %CSVCSTR(ARG,GETNUM(CSTR,"種族"))%
PRINTFORM 【%CSV_DATA:0%】

CSV_HIGH_TRIBE = CSVCFLAG(ARG,GETNUM(CFLAG,"上位種族"))
SIF CSV_HIGH_TRIBE
	PRINT [Higher Race]

CSV_DATA:1 = %CSVCSTR(ARG,GETNUM(CSTR,"所属"))%
CSV_DATA:2 = %CSVCSTR(ARG,GETNUM(CSTR,"身分"))%
CSV_DATA:3 = %CSVCSTR(ARG,GETNUM(CSTR,"ジョブ"))%

SIF CSV_DATA:1 == "" && CSV_DATA:2 == "" && CSV_DATA:3 == ""
	RETURN
PRINTFORM 【%CSV_DATA:1%%CSV_DATA:2%
SIF CSV_DATA:1 != "" || CSV_DATA:2 != ""
	PRINT ・
PRINTFORM %CSV_DATA:3%】 



;魔界牧場枠用読み込みリスト
@CHARA_LIST_MAKAIBOKUJO(ARG)
#DIMS DISPNAME

SELECTCASE ARG
CASE 0
	;あなたは読み込み不可
	CALL PRINTL_WORD_COLOR,@"<{ARG+100,3}>：%CALLNAME:0% can't be loaded ","灰"
	EXIST = 1
CASE 1
	;スレイちゃんも読み込み不可
	DISPNAME = %CSVCALLNAME(ARG)%
	CALL PRINTL_WORD_COLOR,@"<{ARG+100,3}>：%DISPNAME% can't be loaded ","灰"
	EXIST = 1
CASE 2
	;ベースちゃんもダメ
	DISPNAME = %CSVCALLNAME(ARG)%
	CALL PRINTL_WORD_COLOR,@"<{ARG+100,3}>：%DISPNAME% is the template character ","灰"
	EXIST = 1

;処女結界の2人は最初に片方なのでいなければOK
;魔術士奴隷2人は魔力持ち入手のマイルストーンが終わってればOK
;今とりあえずそのまま通す
CASE 5,6
