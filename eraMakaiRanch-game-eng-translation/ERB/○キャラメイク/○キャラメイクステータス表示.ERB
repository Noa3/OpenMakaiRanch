
;キャラメイク中ステータス表示
;ARG→PAGE
;ARGS→基本以外の場面
@CHARA_MAKE_SLAVE_DATA(ARG,ARGS)

CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT
CALL PRINT_NAME_STATUS
CALL PRINT_AFFILIATION_DATA
CALL PRINT_VISUAL_AGE
CALL PRINT_BUST_DETAIL
CALL PRINT_EXTERIOR

;最初は無視
IF ARGS == "初期設定"
ELSE
	SIF !(CFLAG:魔界入りの目的 == 8 || CFLAG:魔界入りの目的 == 9)
		CALL PRINT_PURPOSE(CFLAG:魔界入りの目的)
	PRINTFORM  Lv{BASE:レベル}　★{CFLAG:ランク}
	IF CFLAG:仲間規模
		PRINTFORML ／{CFLAG:仲間ランク}%GROUP_SCALE()%
	ELSE
		CALL PRINTL_WORD_COLOR,@"【Solo】","灰"
	ENDIF
ENDIF
PRINTL

;ドバっときてて見づらいのでページを分けた
SELECTCASE ARG
CASE 1
	PRINTFORML 　Personality：【%PERSONALITY_ENG(CSTR:性格)%】　1st Person Pronoun：%CSTR:一人称%　Calling You：%CSTR:あなた呼び方／陥落前%
	CALL PRINT_VIRGIN_DETAIL(1)
	CALL SHOW_TALENT_LIST
CASE 2
	CALL ABL_WORK_LIST_CHARA_MAKE
	CALL SHOW_EQUIP(1)
	CALL ABL_NASTY_LIST_CHARA_MAKE
	CALL SENSITIVE_LIST_CHARA_MAKE
	CALL TALENT_NASTY_CHARA_MAKE
	CALL PRINT_TARGET_BATTLE_STATUS

;9なら全部表示
CASE 9
	PRINTFORML 　Personality：【%PERSONALITY_ENG(CSTR:性格)%】　1st Person Pronoun：%CSTR:一人称%　Calling You：%CSTR:あなた呼び方／陥落前%
	CALL PRINT_VIRGIN_DETAIL(1)
	CALL SHOW_TALENT_LIST
	PRINTL
	CALL ABL_WORK_LIST_CHARA_MAKE
	CALL SHOW_EQUIP(1)
	CALL ABL_NASTY_LIST_CHARA_MAKE
	CALL SENSITIVE_LIST_CHARA_MAKE
	CALL TALENT_NASTY_CHARA_MAKE
	CALL PRINT_TARGET_BATTLE_STATUS
	DRAWLINE
	RETURN
ENDSELECT
CALL PRINTL_ALIGN(-10)
DRAWLINE



;部隊の規模
@GROUP_SCALE
#FUNCTIONS

SELECTCASE CFLAG:仲間規模
CASE 1
	RETURNF "【Party】"
CASE 2
	RETURNF "【Elite Force】"
CASE 3
	RETURNF "【Army】"
ENDSELECT



;標的の戦闘力
;ARG→1ならHPとか表示しない
@PRINT_TARGET_BATTLE_STATUS(ARG)

IF ARG
	PRINTL
ELSE
	PRINTFORM 　HP：%VALUE_DIGIT(MAXBASE:体力)%　Spirit Energy：%VALUE_DIGIT(MAXBASE:霊力)%EP
	IF MAXBASE:魔力
		PRINTFORML 　Mana：%VALUE_DIGIT(MAXBASE:魔力)%MP<{BASE:魔力回復割合,2}\%\/day>
	ELSE
		CALL PRINTL_WORD_COLOR,@"　No Mana","灰"
	ENDIF
ENDIF

;戦闘なしで貰える奴隷はこの下表示しない
SIF GROUPMATCH(CFLAG:魔界入りの目的,4,6,7)
	RETURN
PRINTFORM 　Combat Strength：%VALUE_DIGIT(BASE:戦闘力)%
IF !FLAG:キャラメイク中
	PRINTFORM ／%VALUE_DIGIT(MAXBASE:戦闘力)% 
	CALL PRINT_COLORBAR(BASE:戦闘力,MAXBASE:戦闘力,8,BARCOLORSET("青緑"),RESULT:1)
	PRINTFORM  Fatigue：{BASE:疲労度,3} 
	CALL PRINT_COLORBAR(BASE:疲労度,MAXBASE:疲労度,8,BARCOLORSET("黄"),RESULT:1)
ENDIF
PRINTL
IF BASE:回復回数
	PRINTFORM 　Recover：{BASE:回復回数}x remaining
ELSE
	CALL PRINT_WORD_COLOR,@"　No recovery action","灰"
ENDIF
IF BASE:大技回数
	PRINTFORM 　Signature Move：{BASE:大技回数}x remaining
ELSE
	CALL PRINT_WORD_COLOR,@"　No signature move","灰"
ENDIF
PRINTL
SIF !MAXBASE:仲間戦闘力1
	RETURN
IF BASE:仲間戦闘力1
	PRINTFORM 　Team Strength：%VALUE_DIGIT(BASE:仲間戦闘力1)%
	IF !FLAG:キャラメイク中
		PRINTFORM ／%VALUE_DIGIT(MAXBASE:仲間戦闘力1)% 
		CALL PRINT_COLORBAR(BASE:仲間戦闘力1,MAXBASE:仲間戦闘力1,8,BARCOLORSET("青緑"),RESULT:1)
	ENDIF
	PRINTFORM %GROUP_SCALE()%
ELSE
	CALL PRINT_WORD_COLOR,@"　Companions Wiped","灰"
ENDIF
PRINTL

