
;性格・素質・性ABL・1／2人称再シャッフル
@CHARA_MAKE_SLAVE_SHUFFLE_PERSONALITY

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT
PRINTL Randomize the Personality・Traits of a slave candidate
PRINTL
PRINTFORML 　Personality：【%PERSONALITY_ENG(CSTR:性格)%】　1st Person Pronoun：%CSTR:一人称%　Calling You：%CSTR:あなた呼び方／陥落前%
CALL ABL_WORK_LIST_CHARA_MAKE
CALL SHOW_TALENT_LIST
PRINTL
CALL ABL_NASTY_LIST_CHARA_MAKE
CALL TALENT_NASTY_CHARA_MAKE
CALL PRINTL_ALIGN(-15)
CALL HALFLINE
SIF GETBIT(＃再シャッフル／性格素質＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:5)%pt】
PRINTL 　[ 0] Randomize Personality
PRINTL 　（When randomizing personality, traits will be randomized as well）
PRINTL 　[ 1] Randomize Traits
RESETCOLOR
SIF GETBIT(＃再シャッフル／性ABL＃)
	SETCOLOR 0x80FFFF
PRINTFORML 【%VALUE_DIGIT(SHUFFLE_AGAIN_PT:6)%pt】
PRINTL 　[ 2] Randomize SexABL
RESETCOLOR
CALL PRINTL_ALIGN
DRAWLINE
PRINTL [99] Done
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL RANDOM_SLAVE_PERSONALITY
	CALL RANDOM_SLAVE_TALENT
	CALL RANDOM_SLAVE_CALLPERSON
	SETBIT ＃再シャッフル／性格素質＃
CASE 1
	CALL RANDOM_SLAVE_TALENT
	CALL RANDOM_SLAVE_CALLPERSON
	SETBIT ＃再シャッフル／性格素質＃
CASE 2
	CALL RANDOM_SLAVE_NASTY_ABL
	SETBIT ＃再シャッフル／性ABL＃
CASE 99
	RETURN
ENDSELECT
RESTART

