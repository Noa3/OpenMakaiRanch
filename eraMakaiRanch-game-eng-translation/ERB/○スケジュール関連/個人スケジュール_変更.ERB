
;キャラ選択INPUT後
;ARG→INPUT
;ARGS→元ページ　　メインメニュー・全奴隷・牛舎
@SCHEDULE_PLAN_CHANGE(ARG,ARGS)

SELECTCASE ARG
CASE 0
	CSTR:スケジュール = 自由
	SIF CSTR:SAVE_TARGET:状態／あなたの子 == "成長中"
		VARSET CSTR:SAVE_TARGET,"休日",350,357
CASE 1
	CSTR:スケジュール = 酪農
CASE 2
	SAVE_TARGET = TARGET
	CALL TRAIN_SLAVE_SELECT
CASE 3
	CSTR:スケジュール = 事務
CASE 4
	CSTR:スケジュール = 調剤
CASE 5
	CSTR:スケジュール = 大浴場掃除
CASE 6
	CSTR:スケジュール = 訓練
CASE 7
	CSTR:スケジュール = 図書館
CASE 100
	CSTR:スケジュール = 待機
CASE 101
	CSTR:0:スケジュール = 調教
	CFLAG:0:調教対象ID = CFLAG:ID
	CSTR:スケジュール = 調教対象
CASE 102
	CSTR:スケジュール = 搾乳
CASE 103
	CSTR:スケジュール = 抽出
CASE 104
	CSTR:スケジュール = 体内凌辱準備
CASE 105
	CSTR:スケジュール = 解放準備
CASE 106
	CSTR:スケジュール = 体内凌辱
CASE 107
	CSTR:スケジュール = 触手責め搾乳

CASE 200
	CALL VISIT_SLAVE_BEFORE
	RETURN 1
	
CASE 201
	IF CSTR:状態／あなたの子 == "成長後"
		CALL CHILD_REBELLION
		SIF RESULT
			RETURN
	ENDIF
	CALL MANYL(2)
	CALL SCHEDULE_MOVE_COWSHED
CASE 202
	PRINTFORML Move %CALLNAME% out of %ITEMS_ENG(COWSHED_NAME:(CFLAG:牛舎番号))%?
	CALL ASK_YN
	SIF RESULT
		RETURN
	
	;FLAG:第1牛舎家畜頭数→502
	FLAG_REF = 492
	FLAG:(FLAG_REF +CFLAG:牛舎番号 *10) --
	CFLAG:牛舎番号 = 0
	CALL SCHEDULE_RESET_TARGET
	CALL CHARA_WHEREABOUTS_TARGET

CASE 208
	CALL USE_ITEM_PLAYER
CASE 209
	CALL DRINK_COLD_MILK_AUTO(1)
	SIF WAIT_ON
		PRINTW
	WAIT_ON = 0
CASE 210
	;あなたと奴隷で別の関数
	IF !TARGET
		CALL PLAYER_CONFIG
	ELSE
		CALL SLAVE_CONFIG
	ENDIF
	RETURN 1

CASE 211
	CALL SHOW_STATUS_DETAIL_PLUS(ARGS)
	RETURN 1
	
CASE 212
	CALL AUTO_SCHEDULE
	RETURN 1
	
CASE 300
	CALL CHANGE_TARGET_CHARA(0,ARGS)
	
	;上の関数でTARGETを変更してRESTARTする形式にする（大量に関数呼び出しされると不具合あるかなと）
	RETURN 1
CASE 301
	CALL CHANGE_TARGET_CHARA(1,ARGS)
	RETURN 1
ENDSELECT



;牛舎に入れる
@SCHEDULE_MOVE_COWSHED

;FLAG:第1牛舎増築段階→500
;FLAG:第1牛舎スケジュール→501
;FLAG:第1牛舎家畜頭数→502
FLAG_REF = 490
FLAG_REF:1 = 491
FLAG_REF:2 = 492
PRINTFORML Choose where %CALLNAME% will stay.
FOR COWSHED_NUM,1,11
	SIF COWSHED_NUM > ITEM:牛舎
		BREAK
	
	;現在の乳牛頭数
	COWSHED_SLAVE = FLAG:(FLAG_REF:2 +COWSHED_NUM *10)
	
	;最大乳牛頭数
	COWSHED_CAPACITY = FLAG:(FLAG_REF +COWSHED_NUM *10)*10
	
	IF COWSHED_SLAVE >= COWSHED_CAPACITY
		SETCOLOR 64,64,64
		PRINTFORM 　<{COWSHED_NUM,2}> 
	ELSE
		PRINTFORM 　[{COWSHED_NUM,2}] 
	ENDIF
	{
	PRINTFORM %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM),20%： {COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3}　
	\@ FLAG:(FLAG_REF:1 +COWSHED_NUM *10) ? ミルク製造機 # 搾乳家畜 \@用 
	}
	RESETCOLOR
	SIF COWSHED_SLAVE >= COWSHED_CAPACITY
		PRINT ≪Full≫
	PRINTL
NEXT
DRAWLINE
PRINTFORML [99] Cancel
BINPUT
SIF RESULT == 99
	RETURN
CFLAG:牛舎番号 = RESULT
CSTR:スケジュール = 牛舎
CALL CHARA_WHEREABOUTS_TARGET

;乳牛頭数+1
FLAG:(FLAG_REF:2 +CFLAG:牛舎番号 *10) ++
SIF FLAG:(FLAG_REF:2 +CFLAG:牛舎番号 *10) == FLAG:(FLAG_REF +CFLAG:牛舎番号 *10) *10
	PRINTW This cowshed is now full

