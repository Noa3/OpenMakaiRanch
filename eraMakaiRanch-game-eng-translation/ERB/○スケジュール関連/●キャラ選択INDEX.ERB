
;スケジュール
;TARGET指定状態でここに来るよ
;ARGS→元ページ　　メインメニュー・全奴隷・牛舎
@SCHEDULE_PLAN(ARGS)
#DIM TRAIN_SLAVE_NUM
#DIM SAVE_TRAIN_TARGET

CLEARLINE LINECOUNT
CALL CALC_PEOPLE_FLAG
CALL SHOW_STATUS_DETAIL

;牛舎にいる場合専用メッセージと専用選択肢　管理コマンドはできてもいいか
IF CFLAG:牛舎番号
	CALL PRINTL_ALIGN(-10)
	PRINTFORM HP：{BASE:体力,4} 
	CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青緑"),RESULT:1)
	PRINTFORM 　SP：{BASE:気力,4} 
	CALL PRINT_COLORBAR(BASE:気力,MAXBASE:気力,8,BARCOLORSET("青緑"),RESULT:1)
	CALL PRINT_NOW_PLACE(1)
	DRAWLINE
	CALL PRINTL_WORD_COLOR("Schedule changes are not allowed while inside the cowshed","灰")
	GOTO LIST_END
	
;追跡中のキャラ用情報
ELSEIF CFLAG:追跡対象
	CALL PRINT_CHASE_STATUS(1)
	GOTO LIST_END
ELSEIF CSTR:状態／あなたの子 == "成長中"
	PRINTL
	PRINTFORML  During the Growth Period.(after {14 + CFLAG:捕獲日 - DAY} days)
	CALL PRINTL_ALIGN(-10)
	PRINTFORM HP：{BASE:体力,4} 
	CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青緑"),RESULT:1)
	CALL PRINT_NOW_PLACE_PLAN
	DRAWLINE
	PRINTL 　《 Schedule Change 》
	PRINTLC [  0] Free Time
	PRINTLC [  2] Let Child Be Breastfed
	PRINTL
	PRINTL
	PRINTL 　《 Management 》
	PRINTLC [200] Go Visit
	GOTO LIST_END_CHILD
ENDIF

;ある程度下げる
CALL PRINTL_ALIGN(-10)

;HPこっちで表示するようにした,SP足した
PRINTFORM HP：{BASE:体力,4} 
CALL PRINT_COLORBAR(BASE:体力,MAXBASE:体力,8,BARCOLORSET("青緑"),RESULT:1)
PRINTFORM 　SP：{BASE:気力,4} 
CALL PRINT_COLORBAR(BASE:気力,MAXBASE:気力,8,BARCOLORSET("青緑"),RESULT:1)

;居場所とスケジュールを表示する関数作る
CALL PRINT_NOW_PLACE_PLAN
DRAWLINE

;外出済みなら変更できない
IF CSTR:スケジュール == "行動済み"
	PRINTL Already acted, cannot be changed.
	GOTO LIST_END
ENDIF
PRINTL 　《 Change Schedule 》
CALL PRINT_SCHEDULE_PLAN_STATE
CALL PRINT_SCHEDULE_PLAN_WORK
CALL PRINT_SCHEDULE_PLAN_TRAIN

$LIST_END

;顔グラ・ドット絵で2下がる分を増やしていいかも
CALL PRINTL_ALIGN(2)
CALL PRINT_SCHEDULE_PLAN_MANAGEMENT

;このへんは常にOK　どの状況でも設定には行けるようにする
PRINTLC [210] Customization
PRINTLC [211] Detailed Status

;追跡中は自動スケジュール不可
IF CFLAG:追跡対象
	CALL PRINTLC_WORD_COLOR("Not captured","灰")
ELSE
	PRINTLC [212] Automatic Scheduling
ENDIF

;子供はここまで
$LIST_END_CHILD

PRINTL
DRAWLINE
PRINTLC [300] Prev Chara
PRINTLC [301] Next Chara
PRINTL [ 99] Done
BINPUT
PRINTL

;別関数へ
CALL SCHEDULE_PLAN_CHANGE(RESULT,ARGS)

;RETURN1してきたらRESTART
SIF RESULT
	RESTART

;ここで調整かけるようにする
CALL SCHEDULE_ADJUST



