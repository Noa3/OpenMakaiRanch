
;カスタムスケジュール管理
@AUTO_SCHEDULE_CUSTOM

CLEARLINE LINECOUNT
CALL SHOW_STATUS_SIMPLE
CALL HALFLINE
PRINTFORML Please set %CALLNAME%'s custom schedule.

;CSTR:自動スケジュール／カスタムＡ／朝→360
CSTR_REF = 360
FOR LOCAL,0,9
	SELECTCASE LOCAL
    CASE 0
        PRINTL 【Custom A】
    CASE 3
        PRINTL
        PRINTL 【Custom B】
    CASE 6
        PRINTL
        PRINTL 【Custom C】
	ENDSELECT
	PRINTFORM [{LOCAL,2}] 
	SELECTCASE LOCAL %3
    CASE 0
        PRINT Morning:
    CASE 1
        PRINT Noon:
    CASE 2
        PRINT Evening:
	ENDSELECT
	PRINTFORM %CUSTOM_SCHEDULE_ENG(CSTR:(CSTR_REF +LOCAL)),15,LEFT%　
NEXT
CALL MANYL(2)
IF !TARGET
	CALL PRINTL_WORD_COLOR,@"%CALLNAME% cannot automatically schedule training","灰"
ELSE
	CALL AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(0)
	CALL AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(1)
	CALL AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(2)
ENDIF
CALL PRINTL_ALIGN
DRAWLINE
PRINTLC [90] Restore to Defaults
PRINTLC 　
PRINTLC [99] Done
BINPUT
SELECTCASE RESULT
CASE 0 TO 9
	CALL AUTO_SCHEDULE_CUSTOM_SELECT(RESULT)
CASE 10 TO 12
	SAVE_TARGET = TARGET
	CALL AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_SELECT(RESULT -10)
	TARGET = SAVE_TARGET
CASE 90
	;CSTR_REF = 360
	PRINTL Would you like to reset all custom schedules to 【Free】?
	CALL ASK_YN
	SIF !RESULT
		VARSET CSTR,"自由",CSTR_REF,CSTR_REF +9
CASE 99
	RETURN
ENDSELECT
RESTART



;調教対象IDから名前表示
@AUTO_SCHEDULE_CUSTOM_TRAIN_CHARA_ID(ARG)
#DIMS PATTERN

SELECTCASE ARG
CASE 0
	PATTERN = Ａ
CASE 1
	PATTERN = Ｂ
CASE 2
	PATTERN = Ｃ
ENDSELECT

;CFLAG:自動スケジュール／調教対象ID／Ａ→520
;IDのキャラを探す
FINDCHARA CFLAG:ID,CFLAG:(520 +ARG)
IF RESULT <= 0
PRINTFORMLC [{10 +ARG}] Training target %PATTERN%: Not set
ELSE
PRINTFORMLC [{10 +ARG}] Training target %PATTERN%: %CALLNAME:RESULT%
ENDIF



;カスタム中身の選択
;ARG→INPUT
@AUTO_SCHEDULE_CUSTOM_SELECT(ARG)

;STR:スケジュール→3960
STR_REF = 3960
CALL MANYL(3)
PRINTL Please select a schedule.
FOR LOCAL,0,20
	STR_NAME = %STR:(STR_REF +LOCAL)%
	SIF STR_NAME == ""
		CONTINUE
	
	;可能か判定　恋慕以上かあなた前提になってる
	SELECTCASE STR_NAME
	
	;あなたのみ+マイルストーン
	CASE "訓練"
		CALL MILESTONE_UNLOCK_CHECK("自分で戦う","")
		SIF !RESULT || TARGET
			CONTINUE
	
	;上+朝はダメ
	CASE "図書館"
		CALL MILESTONE_UNLOCK_CHECK("禁断魔術","")
		SIF !RESULT || TARGET || ARG %3 == 0
			CONTINUE
	CASE "調教／対象Ａ","調教／対象Ｂ","調教／対象Ｃ"
		SIF !TARGET
			CONTINUE
	CASE "搾乳"
		SIF !MARK:母乳体質
			CONTINUE
	CASE "抽出"
		SIF !MARK:母乳体質 || (!BASE:霊力 && !MARK:魔力母乳体質) || !ITEM:霊力抽出装置
			CONTINUE
	CASE "調剤"
		CALL MILESTONE_UNLOCK_CHECK("調合","")
		SIF !RESULT
			CONTINUE
	ENDSELECT
	PRINTFORMLC [{LOCAL,2}] %CUSTOM_SCHEDULE_ENG(STR_NAME)%
NEXT
PRINTL
PRINTL [99] Cancel
BINPUT
SIF RESULT != 99
	CSTR:(CSTR_REF +ARG) = %STR:(STR_REF +RESULT)%


