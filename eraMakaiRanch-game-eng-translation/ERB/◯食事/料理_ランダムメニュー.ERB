
;メニュー候補生成+決定
@DINNER_MENU_CANDIDATE
#DIM MENU_NUM

;作る料理ランダム決定→1+料理Lv/3コの候補から選ぶ（MAX5）
VARSET DINNER_NAME

;完全お任せなら1回ランダムしてそれに決定
IF FLAG:夕食メニューおまかせ
	CALL DINNER_RANDOM_DISH
	RETURN
ENDIF
MENU_NUM = LIMIT(1 +ABL:料理 /3,1,5)
PRINTL
PRINTL ＜Please select a menu option＞
FOR LOCAL,0,MENU_NUM
	CALL DINNER_RANDOM_DISH
	DINNER_NAME:(LOCAL +1) = %DINNER_NAME:0%
	PRINTFORML [{LOCAL,2}] %DINNER_NAME:(LOCAL +1)%
NEXT
BINPUT

;0番に改めて決定した料理を入れる
DINNER_NAME:0 = %DINNER_NAME:(RESULT +1)%



;作る料理ランダム決定
@DINNER_RANDOM_DISH
#DIMS FOOD,2
#DIM FOOD_VALUE

;メイン食材+サブ食材で料理を作る
;選択確率は[広域定数.ERH]で弄れるよ
;デフォ：メインのみ30%　サブのみ10%　メイン+メイン20%　サブ+サブ5%
;あとはメイン+サブ
SELECTCASE RAND:100
CASE 0 TO DINNER_MAIN_ONLY -1
	;メイン食材からランダムで選ぶ
	CALL RANDOM_FOOD_SELECT_MAIN
	FOOD = %DINNER_NAME_ENG(RANDOM_FOOD)%
	
	;食材1つ
	FOOD_VALUE = 1

CASE DINNER_MAIN_ONLY TO DINNER_SUB_ONLY -1
	;サブのみ
	CALL RANDOM_FOOD_SELECT_SUB
	FOOD = %DINNER_NAME_ENG(RANDOM_FOOD)%
	FOOD_VALUE = 1

CASE DINNER_SUB_ONLY TO DINNER_MAIN_MAIN -1
	;メイン+メイン
	CALL RANDOM_FOOD_SELECT_MAIN
	FOOD = %DINNER_NAME_ENG(RANDOM_FOOD)%
	
	;2回目
	CALL RANDOM_FOOD_SELECT_MAIN
	FOOD:1 = %DINNER_NAME_ENG(RANDOM_FOOD)%
	
	;ごく稀に同じの選ばれた場合はRESTART
	SIF FOOD == FOOD:1
		RESTART
	FOOD = %DINNER_NAME_ENG(FOOD)% and %DINNER_NAME_ENG(FOOD:1)%
	
	;食材2つ
	FOOD_VALUE = 2

CASE DINNER_MAIN_MAIN TO DINNER_SUB_SUB -1
	;サブ+サブ
	CALL RANDOM_FOOD_SELECT_SUB
	FOOD = %DINNER_NAME_ENG(RANDOM_FOOD)%
	CALL RANDOM_FOOD_SELECT_SUB
	FOOD:1 = %DINNER_NAME_ENG(RANDOM_FOOD)%
	SIF FOOD == FOOD:1
		RESTART
	FOOD = %DINNER_NAME_ENG(FOOD)% and %DINNER_NAME_ENG(FOOD:1)%
	FOOD_VALUE = 2

CASEELSE
	;メイン+サブ
	CALL RANDOM_FOOD_SELECT_MAIN
	FOOD = %DINNER_NAME_ENG(RANDOM_FOOD)%
	CALL RANDOM_FOOD_SELECT_SUB
	FOOD:1 = %DINNER_NAME_ENG(RANDOM_FOOD)%
	SIF FOOD == FOOD:1
		RESTART
	FOOD = %DINNER_NAME_ENG(FOOD)% and %DINNER_NAME_ENG(FOOD:1)%
	FOOD_VALUE = 2

ENDSELECT

;料理方法ランダム
CALL RANDOM_COOKING_SELECT

;くっつけて料理名完成
CALL DINNER_NAME_COMPLETE(FOOD_VALUE,FOOD)



;メイン食材からランダムで選ぶ
@RANDOM_FOOD_SELECT_MAIN

STR_REF = 3300
STR_MAX = 100
CALL STR_REF_SHUFFLE(STR_REF)
RANDOM_FOOD = %RESULTS%



;サブ食材からランダム
@RANDOM_FOOD_SELECT_SUB

STR_REF = 3400
STR_MAX = 50
CALL STR_REF_SHUFFLE(STR_REF)
RANDOM_FOOD = %RESULTS%



;料理方法ランダム選択
@RANDOM_COOKING_SELECT

;母乳料理か違うかで番号変更
IF MILK_DINNER
	STR_REF = 3550
ELSE
	STR_REF = 3500
	
	;母乳料理じゃない場合も5%でミルク使用料理にする
	;おまけ機能中は飛ばす
	SIF RAND:100 < 5 && !EXTRA_SHUFFLE
		STR_REF = 3550
ENDIF
STR_MAX = 50
CALL STR_REF_SHUFFLE(STR_REF)
RANDOM_COOKING = %RESULTS%

;季節など条件による上書き・キャンセル
CALL RANDOM_COOKING_OVERWRITE



;上書き・キャンセル
@RANDOM_COOKING_OVERWRITE

;母乳料理のとき・おまけ機能中はそのまま
SIF MILK_DINNER || EXTRA_SHUFFLE
	RETURN

;夏に鍋だとやめとく
SIF DAY:季節 == 1 && RANDOM_COOKING == "鍋"
	CALL RANDOM_COOKING_SELECT

;冬は5%で鍋に上書き
SIF DAY:季節 == 3 && RAND:100 < 5
	RANDOM_COOKING = 鍋

;辛いの苦手だとカレーのとき甘口にする
SIF TALENT:辛味好き < 0 && RANDOM_COOKING == "カレー"
	RANDOM_COOKING = 甘口カレー

;逆だと辛口
SIF TALENT:辛味好き > 0 && RANDOM_COOKING == "カレー"
	RANDOM_COOKING = 辛口カレー



;料理名完成
;ARG→FOOD_VALUE　ARGS→FOOD
@DINNER_NAME_COMPLETE(ARG,ARGS)

;食材1つで特定料理なら「の」なし
IF ARG == 1 && GROUPMATCH(RANDOM_COOKING,"カレー","チャーハン","鍋","丼","フライ","グラタン","ドリア")
	DINNER_NAME = %ARGS% with %DINNER_NAME_ENG(RANDOM_COOKING)%
ELSE
	DINNER_NAME = %ARGS% and %DINNER_NAME_ENG(RANDOM_COOKING)%
ENDIF

