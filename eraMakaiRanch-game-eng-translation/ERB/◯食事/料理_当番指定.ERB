
;食事当番指定
@DINNER_DUTY_SELECT
#DIM COOK_JUDGE,2

;業務可能判定更新
CALL SCHEDULE_POSSIBLE

;曜日予定を見る
;FLAG:食事当番基準／月→300
;FLAG:食事当番ID・ABL／月→310
COOK_JUDGE = FLAG:(300 +DAY:曜日)
COOK_JUDGE:1 = FLAG:(310 +DAY:曜日)
SELECTCASE COOK_JUDGE
CASE 0
	;適当に済ます
	RETURN -1

CASE 1
	;選択
	CALL DINNER_DUTY_SELECT_TODAY
	RETURN RESULT

CASE 2
	;料理Lvが指定以上のキャラからランダム
	CALL DINNER_CHEF_RANDOM(COOK_JUDGE:1)
	RETURN RESULT
	
CASEELSE
	;指定IDのキャラ
	;見つからないなら-1、業務不可状態か牛舎にいるならダメ→その後に選ばせる
	FINDCHARA CFLAG:ID,COOK_JUDGE:1
	IF RESULT >= 0
		TARGET = RESULT
		IF CFLAG:牛舎番号
			CALL PRINT_WORD_COLOR,@"%CALLNAME% can't cook because she is in the cowshed.","黄"
		ELSEIF !CFLAG:業務可能
			CALL PRINT_WORD_COLOR,@"%CALLNAME% is in an inactive state for work.","黄"
		
		;料理可能ならここ
		ELSE
			RETURN RESULT
		ENDIF
		FORCEWAIT
	ENDIF
	CALL DINNER_DUTY_SELECT_TODAY
	RETURN RESULT
ENDSELECT



;料理Lvが指定以上のキャラからランダム
;ARG→FLAG:食事当番ID・ABL／曜日
@DINNER_CHEF_RANDOM(ARG)
#DIM NEED_ABL
#DIM COOK_ABL

;要求値を入れる（書き換えたりするので）
NEED_ABL = ARG

;業務可能なキャラのMAX料理Lv取得
COOK_ABL = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:業務可能 || CFLAG:牛舎番号 || COOK_ABL >= ABL:料理
		CONTINUE
	COOK_ABL = ABL:料理
NEXT

;MAXが足りない場合は必要値を引き下げ
SIF NEED_ABL > COOK_ABL
	NEED_ABL = COOK_ABL

;必要値を満たす業務可能キャラをBOX入れ
VARSET RANDOM_NO_BOX
VARSET BOX_COUNT
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:業務可能 || NEED_ABL > ABL:料理
		CONTINUE
	RANDOM_NO_BOX:BOX_COUNT = TARGET
	BOX_COUNT ++
NEXT

;一応バグ対策
IF !BOX_COUNT
	PRINTW ！A bug has occurred in obtaining the cooking ABL
	RETURN -1
ENDIF
RETURN RANDOM_NO_BOX:RAND(BOX_COUNT)



;手動選択
@DINNER_DUTY_SELECT_TODAY
#DIM DYNAMIC PAGE

;スキップ状態ならFORCEWAIT
SIF MESSKIP()
	FORCEWAIT

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL Please select the character for dinner duty.
PRINTFORML Serving: {DISH_QUANTITY} people　Necessary amount of %SAVESTR:表記／母乳%：%TOSTR(DISH_NEED_MILK,"#,0")%%MILK_COUNTING()% 
DRAWLINE
FOR TARGET_COUNT,0,20
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	
	;牛舎→NG　未捕獲→NG　体内→NG　業務不可→NG
	{
	IF CFLAG:追跡対象 || CSTR:居場所 == "体内" || !CFLAG:業務可能 
	|| CFLAG:牛舎番号 || (!CFLAG:調教可能 && !TALENT:オーナー)
	}
		CALL DINNER_DUTY_SELECT_IMPOSSIBLE
		CONTINUE
	ENDIF
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("料理当番")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] Change Display Settings
PRINTLC [ 98] Tip
PRINTL [ 99] Simple meal
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 98
	CALL BROWSE_HINT("料理")
CASE 99
	RETURN -1
CASEELSE
	TARGET = RESULT -100
	RETURN TARGET
ENDSELECT
RESTART



;ダメな理由
@DINNER_DUTY_SELECT_IMPOSSIBLE

SETCOLOR 0x606060
PRINTFORM %CALLNAME_DIGIT(4)%：
IF CFLAG:追跡対象
	PRINT Not Captured
ELSEIF CSTR:居場所 == "体内"
	PRINT In Body
ELSEIF CFLAG:牛舎番号
	PRINT Cowshed
ELSEIF !BASE:体力
	PRINT 0 HP
ELSEIF !CFLAG:業務可能
	PRINT Not available for work
ELSEIF !CFLAG:調教可能
	PRINT Not available for training
ENDIF
PRINTL
RESETCOLOR



