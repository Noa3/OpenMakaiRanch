
;ペット名など変更
@DEBUG_PET_NAME_EDIT

;ペット関係のフラグ番号一斉取得
CALL GET_PET_FLAG_REF
CLEARLINE LINECOUNT
CALL RANCH_STATUS_PET
PRINTL
FOR LOCAL,0,10
	SIF !ITEM:ITEM_REF
		CONTINUE
	PRINTFORML [{LOCAL,2}] %ITEMNAME:(LOCAL +ITEM_REF)%
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTL [99] Done
INPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 9
	CALL DEBUG_PET_NAME_EDIT_MENU(RESULT)
CASE 99
	RETURN
ENDSELECT
RESTART



;ペット選択後
;ARG→INPUT
@DEBUG_PET_NAME_EDIT_MENU(ARG)

ANIMAL = %ITEMNAME:(ARG +ITEM_REF)%
PET_NAME = %PET_NAME_REF(ANIMAL)%
SIF PET_NAME == ""
	RETURN
PRINTFORML %PET_NAME%に関して変更する箇所を選択してください。
PRINTFORML [ 0] 　名前：%SAVESTR:(ARG +STR_REF)%
PRINTFORML [ 1] 毛並み：%SAVESTR:(ARG +STR_REF:1)%
PRINTFORML [ 2] 　模様：%SAVESTR:(ARG +STR_REF:2)%
PRINT [ 3] 　性別：
CALL PRINT_PET_GENDER(FLAG:(FLAG_REF +ARG),1)
PRINT [ 4] 　体型：
CALL PRINT_PET_SHAPE(ANIMAL,1,1)
PRINTL [ 5] 各キャラへのなつき度
SIF ANIMAL == "オルトロス"
	PRINTL [ 6] ＜オルトロス＞限定：名付け方式変更／接続詞・名前変更
PRINTL
PRINTL [99] Done
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	PRINTL Enter a name
	INPUTS
	SIF RESULTS != ""
		SAVESTR:(ARG +STR_REF) = %RESULTS%
CASE 1
	PRINTL 毛並みを入力してください。
	INPUTS
	SIF RESULTS != ""
		SAVESTR:(ARG +STR_REF:1) = %RESULTS%
CASE 2
	PRINTL 模様を入力してください。
	INPUTS
	SIF RESULTS != ""
		SAVESTR:(ARG +STR_REF:2) = %RESULTS%
CASE 3
	INVERTBIT FLAG:(FLAG_REF +ARG),0
	PRINTW 性別を反転しました。
CASE 4
	FLAG_NAME = 体型／%ANIMAL%
	PRINTFORML 体型数値を0～{ANIMAL_WEIGHT_MAX}で入力してください。（現在値：{FLAG:FLAG_NAME}）
	INPUT
	SIF RESULT >= 0 && RESULT <= ANIMAL_WEIGHT_MAX
		FLAG:FLAG_NAME = RESULT
CASE 5
	CALL DEBUG_PET_NAME_EDIT_FRIENDRY(ARG)
CASE 6
	SIF ANIMAL != "オルトロス"
		RETURN
	PRINTL 名付け方式を選択してください。
	PRINTLC [ 0] 1つの名前をつける
	PRINTLC [ 1] 左右の頭にそれぞれ名付ける
	PRINTL [99] Cancel
	INPUT
	SELECTCASE RESULT
	CASE 0
		PRINTL Enter a name
		INPUTS
		IF RESULTS != ""
			SAVESTR:名前／オルトロス = %RESULTS%
			SAVESTR:名前／オルトロス／弟妹 =
			SAVESTR:名前／オルトロス／接続詞 =
		ENDIF
	CASE 1
		PRINTL 兄／姉の頭の名前を入力してください。
		INPUTS
		SIF RESULTS == ""
			RETURN
		SAVESTR:名前／オルトロス = %RESULTS%
		PRINTL
		PRINTL 地の文・表記上での接続詞を入力してください。
		CALL PRINTL_WORD_COLOR("半角の「&」はバグを引き起こす気がするので避けるといいかと思われます。","黄")
		INPUTS
		SIF RESULTS == ""
			RETURN
		SAVESTR:名前／オルトロス／接続詞 = %RESULTS%
		PRINTL
		PRINTL 弟／妹の頭の名前を入力してください。
		INPUTS
		SAVESTR:名前／オルトロス／弟妹 = %RESULTS%
	ENDSELECT
ENDSELECT



;なつき度デバッグ
;PET_NAME指定済み
;ARG→INPUT
@DEBUG_PET_NAME_EDIT_FRIENDRY(ARG)
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML %PET_NAME%のなつき度を変更するキャラを選択してください。
FOR TARGET_COUNT,0,20
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	PRINTFORML [{TARGET +100}] %CALLNAME_DIGIT()%：{BASE:(BASE_REF +ARG) /100,3}\%
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTL [ 99] Cancel
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	{
	PRINTFORML %CALLNAME%への%PET_NAME%のなつき度を0～{MAXBASE:(BASE_REF +ARG)}で入力してください。
	（現在値：{BASE:(BASE_REF +ARG)}）
	}
	INPUT
	SIF RESULT >= 0 && RESULT <= MAXBASE:(BASE_REF +ARG)
		BASE:(BASE_REF +ARG) = RESULT
ENDSELECT
RESTART




