
;セーブデータ表示項目の編集
@PRINT_SAVEDATA_ITEM_CONFIG

;STR:セーブデータメモ→6650
STR_REF = 6650
CLEARLINE LINECOUNT
PRINTL セーブデータに表示する項目を編集します。
DRAWLINE
PRINTL セーブ時刻：表示
FOR LOCAL,0,10
	SIF STR:(STR_REF +LOCAL) == ""
		BREAK
	PRINTFORM [{LOCAL,2}] %STR:(STR_REF +LOCAL),20%
	CALL PRINT_ONOFF(GETBIT(FLAG:セーブデータ表示情報BIT,LOCAL),1)
NEXT
PRINTL
PRINTFORML [20] セーブデータメモの編集：%SAVESTR:セーブデータメモ%
CALL PRINTL_ALIGN(-10)
CALL SAVEDATA_DISPLAY_CALC
PRINTFORML 表示項目：%RESULTS%
DRAWLINE
PRINTLC [98] Restore to Defaults
PRINTLC 　
PRINTL [99] Done
BINPUT
SELECTCASE RESULT
CASE 0 TO 19
	INVERTBIT FLAG:セーブデータ表示情報BIT,RESULT
CASE 20
	PRINTL メモの内容を入力してください。
	INPUTS
	SAVESTR:セーブデータメモ = %RESULTS%
CASE 98
	FLAG:セーブデータ表示情報BIT = 0b111010111
CASE 99
	RETURN
ENDSELECT
RESTART



;セーブデータ表示項目を返す
@SAVEDATA_DISPLAY_CALC
#DIMS DISPLAY

;プレイ時間用計算
TIME:1 += GETMILLISECOND() /1000 -TIME:2
TIME:2 = GETMILLISECOND() /1000

;セーブ時刻は必ず表示
GETTIME
DISPLAY = %RESULTS%

IF GETBIT(＃セーブデータ／メモ＃) && SAVESTR:セーブデータメモ != ""
	LOCALS = %SAVESTR:セーブデータメモ%
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃セーブデータ／牧場名＃)
	LOCALS = [%SAVESTR:牧場名%]
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃セーブデータ／難易度＃)
	LOCALS = %SAVESTR:難易度%
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃セーブデータ／レベル＃)
	LOCALS = [Lv{MAXBASE:0:レベル}]
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃セーブデータ／奴隷人数＃)
	;追跡対象だと捕まえてない＋あなたは入らない
	LOCAL = CMATCH(CFLAG:追跡対象,0) -1
	LOCALS = ＜Slaves：{LOCAL,3}＞
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃セーブデータ／経過日数＃)
	LOCALS = [Day {DAY}／%PRINT_TIME_NOW(TIME)%]
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃セーブデータ／日付＃)
	LOCALS =  [{DAY:年数}Yr：%SHOW_DATE_SEASON()%{DAY:日付,2}／%SHOW_DATE_WEEK()% %PRINT_TIME_NOW(TIME)%]
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃セーブデータ／プレイ時間＃)
	LOCALS = Played %PRINT_TIME(TIME:1)%
	DISPLAY += LOCALS
ENDIF

IF GETBIT(＃セーブデータ／バージョン＃)
	LOCALS = [ver{FLAG:セーブデータのバージョン /1000}.%TOSTR(FLAG:セーブデータのバージョン %1000,"000")%]
	DISPLAY += LOCALS
ENDIF
RESULTS = %DISPLAY%

