
;奴隷を検索する
;MAIN→1ならメイン画面から来てるのでスケジュール変更など可能
@SLAVE_SEARCH(MAIN)
#DIM DYNAMIC MAIN

CLEARLINE LINECOUNT

;条件文算出
CALL SLAVE_SEARCH_TERM_CALC

;条件の表示
CALL SLAVE_SEARCH_TERM_PRINT

;条件に合う奴隷表示
CALL SLAVE_SEARCH_PRINT(MAIN)

CALL PRINTL_ALIGN
DRAWLINE
PRINTLC [  0] Refine Criteria
PRINTLC [  1] Clear Criteria
PRINTFORMLC [  2] Change Display Settings
PRINTLC [ 90] Save／Load Search Criteria
PRINTLC [ 91] Show All Applicable Slaves
PRINTLC [ 99] Done
INPUT
INPUT_NUM = RESULT
PRINTL
IF INPUT_NUM >= 100 && INPUT_NUM < 100 +CHARANUM && MAIN
	TARGET = INPUT_NUM -100
	CALL SCHEDULE_PLAN("全奴隷")
	TARGET = -1
ENDIF
SELECTCASE INPUT_NUM
CASE 0
	CALL SLAVE_SEARCH_TERM_SELECT
CASE 1
	CALL SLAVE_SEARCH_TERM_RESET
CASE 2
	CALL CHANGE_TABLE_STATUS
CASE 90
	CALL SLAVE_SEARCH_TERM_SAVE
CASE 91
	CALL SLAVE_SEARCH_PRINT_ALL(MAIN)
CASE 99
	RETURN
ENDSELECT
RESTART



;条件文算出
@SLAVE_SEARCH_TERM_CALC
PRINTL Filter slaves by search criteria
SLAVE_SEARCH_TERM =
SIF SEARCH_SLAVE_TRIBE != ""
	SLAVE_SEARCH_TERM += @"【%RACE_ENG(SEARCH_SLAVE_TRIBE)%】"
SIF SEARCH_SLAVE_JOB != ""
	SLAVE_SEARCH_TERM += @"【%JOB_ENG(SEARCH_SLAVE_JOB)%】"
SIF SEARCH_SLAVE_POSITION != ""
	SLAVE_SEARCH_TERM += @"【%JOB_ENG(SEARCH_SLAVE_POSITION)%】"
SIF SEARCH_SLAVE_HEIGHT != ""
	SLAVE_SEARCH_TERM += @"【%HEIGHT_ENG(SEARCH_SLAVE_HEIGHT)%】"
SIF SEARCH_SLAVE_LOCATION != ""
	SLAVE_SEARCH_TERM += @"%LOCATIONS_ENG(SEARCH_SLAVE_LOCATION)%　"
SIF SEARCH_SLAVE_PRODUCT != ""
	SLAVE_SEARCH_TERM += @"出典作品【%SEARCH_SLAVE_PRODUCT%】"
IF SEARCH_SLAVE_COWSHED
	IF SEARCH_SLAVE_COWSHED == 1
		SLAVE_SEARCH_TERM += "Not In Cowshed　"
	ELSE
		;第1牛舎は2で来てる
		SLAVE_SEARCH_TERM += @"%ITEMS_ENG(COWSHED_NAME:(SEARCH_SLAVE_COWSHED -1))%　"
	ENDIF
ENDIF
SIF SEARCH_SLAVE_BUST
	SLAVE_SEARCH_TERM += @"【%TALENTS_ENG(TALENTNAME:SEARCH_SLAVE_BUST)%】"
IF SEARCH_SLAVE_VARGIN
	SELECTCASE SEARCH_SLAVE_VARGIN
	CASE 1
		SLAVE_SEARCH_TERM += "【Virginity Barrier】"
	CASE 2
		SLAVE_SEARCH_TERM += "【Virgin】"
	CASE 3
		SLAVE_SEARCH_TERM += "【Experienced】"
	ENDSELECT
ENDIF
SIF SEARCH_SLAVE_STATE != ""
	SLAVE_SEARCH_TERM += @"【%SEARCH_SLAVE_STATE%】"
IF SEARCH_SLAVE_MILK
	SELECTCASE SEARCH_SLAVE_MILK
	CASE 1
		SLAVE_SEARCH_TERM += "Not【Lactating】"
	CASE 2
		SLAVE_SEARCH_TERM += "【Lactating】"
	CASE 3
		SLAVE_SEARCH_TERM += "【Mana-Infused Milk】"
	CASE 4
		SLAVE_SEARCH_TERM += "【Mana Recovering Climax Crest】"
	ENDSELECT
ENDIF
IF SEARCH_SLAVE_MILK_DENCE
	IF SEARCH_SLAVE_MILK_DENCE == 1
		SLAVE_SEARCH_TERM += "Normal　"
	ELSE
		SLAVE_SEARCH_TERM += @"【%MARKNAME:SEARCH_SLAVE_MILK_DENCE%】"
	ENDIF
ENDIF
IF SEARCH_SLAVE_DRAIN_EP
	IF SEARCH_SLAVE_DRAIN_EP == 1
		SLAVE_SEARCH_TERM += "Ep Drained　"
	ELSE
		SLAVE_SEARCH_TERM += "Can Absorb EP　"
	ENDIF
ENDIF
IF SEARCH_SLAVE_DRAIN_MP
	IF SEARCH_SLAVE_DRAIN_MP == 1
		SLAVE_SEARCH_TERM += "MP Drained　"
	ELSE
		SLAVE_SEARCH_TERM += "Can Absorb MP　"
	ENDIF
ENDIF
IF SEARCH_SLAVE_CATTLE_MIND
	SELECTCASE SEARCH_SLAVE_CATTLE_MIND
	CASE 1
		SLAVE_SEARCH_TERM += "乳牛堕ち0\%"
	CASE 2
		SLAVE_SEARCH_TERM += "乳牛堕ち～49\%"
	CASE 3
		SLAVE_SEARCH_TERM += "乳牛堕ち～99\%"
	CASE 4
		SLAVE_SEARCH_TERM += "【乳牛堕ち】"
	ENDSELECT
ENDIF
IF SEARCH_SLAVE_MIND
	SELECTCASE SEARCH_SLAVE_MIND
	CASE 1
		SLAVE_SEARCH_TERM += "【崩壊】"
	CASE 2
		SLAVE_SEARCH_TERM += "精神力～49\%"
	CASE 3
		SLAVE_SEARCH_TERM += "精神力～99\%"
	CASE 4
		SLAVE_SEARCH_TERM += "精神力100\%"
	ENDSELECT
ENDIF



;条件の表示
@SLAVE_SEARCH_TERM_PRINT

PRINTL Displaying slaves that meet the search conditions.
IF SLAVE_SEARCH_TERM == ""
	PRINTL 《 Search criteria：No conditions 》
ELSE
	PRINTFORML 《 Search criteria：%SLAVE_SEARCH_TERM% 》
ENDIF
DRAWLINE





;条件に合う奴隷表示
;ARG→1ならメイン画面から来てるのでスケジュール変更など可能
@SLAVE_SEARCH_PRINT(ARG)
#DIM CHARA_NUM,2

VARSET CHARA_NUM
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	
	;条件に合うか別関数で使いまわす
	CALL SLAVE_SEARCH_TERM_JUDGE
	
	;RETURN 1以外なら次へ
	SIF !RESULT
		CONTINUE
	
	CHARA_NUM ++
	
	;あんまり多すぎる場合「ほか」
	IF CHARA_NUM >= 20
		CHARA_NUM:1 ++
		CONTINUE
	ENDIF
	IF ARG
		PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	ELSE
		PRINTFORM <{TARGET +100}> %CALLNAME_DIGIT()%
	ENDIF
	CALL PRINT_POST_C

	;牛舎管理を流用
	CALL TABLE_STATUS("牛舎")
	PRINTL
NEXT
SIF CHARA_NUM:1
	PRINTFORML 　　　Others {CHARA_NUM:1}x



;条件に合う奴隷を全員表示
;ARG→1ならメイン画面から来てるのでスケジュール変更など可能
@SLAVE_SEARCH_PRINT_ALL(ARG)

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	IF ARG
		PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	ELSE
		PRINTFORM <{TARGET +100}> %CALLNAME_DIGIT()%
	ENDIF
	CALL PRINT_POST_C
	CALL TABLE_STATUS("牛舎")
	PRINTL
NEXT
PRINTL [ 99] Done
INPUT
INPUT_NUM = RESULT
PRINTL
IF INPUT_NUM >= 100 && INPUT_NUM < 100 +CHARANUM && ARG
	TARGET = INPUT_NUM -100
	CALL SCHEDULE_PLAN("全奴隷")
	TARGET = -1
ENDIF



;TARGETが条件に合うか返す
@SLAVE_SEARCH_TERM_JUDGE

SIF SEARCH_SLAVE_TRIBE != "" && SEARCH_SLAVE_TRIBE != CSTR:種族
	RETURN
SIF SEARCH_SLAVE_JOB != "" && SEARCH_SLAVE_JOB != CSTR:ジョブ
	RETURN
SIF SEARCH_SLAVE_POSITION != "" && SEARCH_SLAVE_POSITION != CSTR:初期値／身分
	RETURN
SIF SEARCH_SLAVE_HEIGHT != "" && SEARCH_SLAVE_HEIGHT != CSTR:身長
	RETURN
SIF SEARCH_SLAVE_LOCATION != "" && SEARCH_SLAVE_LOCATION != CSTR:居場所
	RETURN
SIF SEARCH_SLAVE_PRODUCT != "" && SEARCH_SLAVE_PRODUCT != CSTR:出典作品名
	RETURN
SIF SEARCH_SLAVE_STATE != "" && SEARCH_SLAVE_STATE != CSTR:陥落状態
	RETURN
SIF SEARCH_SLAVE_BUST && !TALENT:SEARCH_SLAVE_BUST
	RETURN
IF SEARCH_SLAVE_COWSHED
	IF SEARCH_SLAVE_COWSHED == 1 && CFLAG:牛舎番号
		RETURN
	ELSEIF SEARCH_SLAVE_COWSHED -1 != CFLAG:牛舎番号
		RETURN
	ENDIF
ENDIF
IF SEARCH_SLAVE_VARGIN
	SELECTCASE SEARCH_SLAVE_VARGIN
	CASE 1
		SIF !TALENT:処女結界
			RETURN
	CASE 2
		SIF !TALENT:処女 || TALENT:処女結界
			RETURN
	CASE 3
		SIF TALENT:処女
			RETURN
	ENDSELECT
ENDIF
IF SEARCH_SLAVE_MILK
	SELECTCASE SEARCH_SLAVE_MILK
	CASE 1
		SIF MARK:母乳体質
			RETURN
	CASE 2
		SIF !MARK:母乳体質 || MARK:魔力母乳体質
			RETURN
	CASE 3
		SIF !MARK:魔力母乳体質 || MARK:絶頂魔力回復淫紋
			RETURN
	CASE 4
		SIF !MARK:絶頂魔力回復淫紋
			RETURN
	ENDSELECT
ENDIF
IF SEARCH_SLAVE_MILK_DENCE
	SELECTCASE SEARCH_SLAVE_MILK_DENCE
	CASE 1
		SIF !MARK:母乳体質 || MARK:濃厚母乳 || MARK:上質母乳 || MARK:豊潤母乳 || MARK:特濃母乳 || MARK:極上母乳
			RETURN
	CASE 20
		SIF !MARK:濃厚母乳
			RETURN
	CASE 21
		SIF !MARK:上質母乳
			RETURN
	CASE 22
		SIF !MARK:豊潤母乳
			RETURN
	CASE 23
		SIF !MARK:特濃母乳
			RETURN
	CASE 24
		SIF !MARK:極上母乳
			RETURN
	ENDSELECT
ENDIF
IF SEARCH_SLAVE_DRAIN_EP
	IF SEARCH_SLAVE_DRAIN_EP == 1
		SIF BASE:吸収可能霊力
			RETURN
	ELSEIF !BASE:吸収可能霊力
		RETURN
	ENDIF
ENDIF
IF SEARCH_SLAVE_DRAIN_MP
	IF SEARCH_SLAVE_DRAIN_MP == 1
		SIF BASE:吸収可能魔力 || !MAXBASE:魔力
			RETURN
	ELSEIF !BASE:吸収可能魔力
		RETURN
	ENDIF
ENDIF
IF SEARCH_SLAVE_CATTLE_MIND
	SELECTCASE SEARCH_SLAVE_CATTLE_MIND
	CASE 1
		SIF BASE:乳牛堕ち
			RETURN
	CASE 2
		SIF !BASE:乳牛堕ち || BASE:乳牛堕ち >= 5000
			RETURN
	CASE 3
		SIF BASE:乳牛堕ち < 5000 || CFLAG:乳牛
			RETURN
	CASE 4
		SIF !CFLAG:乳牛
			RETURN
	ENDSELECT
ENDIF
IF SEARCH_SLAVE_MIND
	SELECTCASE SEARCH_SLAVE_MIND
	CASE 1
		SIF !CFLAG:崩壊
			RETURN
	CASE 2
		SIF !BASE:精神力 || BASE:精神力 >= 5000
			RETURN
	CASE 3
		SIF BASE:精神力 < 5000 || BASE:精神力 == MAXBASE:精神力
			RETURN
	CASE 4
		SIF BASE:精神力 < MAXBASE:精神力
			RETURN
	ENDSELECT
ENDIF

;RETURN条件でないならRETURN 1
RETURN 1



;絞り込み条件リセット
@SLAVE_SEARCH_TERM_RESET

SEARCH_SLAVE_TRIBE:0 =
SEARCH_SLAVE_JOB:0 =
SEARCH_SLAVE_POSITION:0 =
SEARCH_SLAVE_HEIGHT:0 =
SEARCH_SLAVE_LOCATION:0 =
SEARCH_SLAVE_PRODUCT:0 =
SEARCH_SLAVE_STATE:0 =
SEARCH_SLAVE_COWSHED:0 = 0
SEARCH_SLAVE_BUST:0 = 0
SEARCH_SLAVE_VARGIN:0 = 0
SEARCH_SLAVE_MILK:0 = 0
SEARCH_SLAVE_MILK_DENCE:0 = 0
SEARCH_SLAVE_DRAIN_EP:0 = 0
SEARCH_SLAVE_DRAIN_MP:0 = 0
SEARCH_SLAVE_CATTLE_MIND:0 = 0
SEARCH_SLAVE_MIND:0 = 0



;検索条件のセーブロード
@SLAVE_SEARCH_TERM_SAVE

PRINTL Save or load the current search criteria
FOR LOCAL,1,11
	PRINTFORM Slot {LOCAL,2}　
	PRINTFORM [{LOCAL,2}] SAVE
	PRINTPLAIN 　
	PRINTFORM [{LOCAL +10,2}] LOAD
	PRINTPLAIN 　
	IF SEARCH_SLAVE_LABEL:LOCAL == ""
		CALL PRINTL_WORD_COLOR("No Label","灰")
	ELSE
		PRINTFORML %SEARCH_SLAVE_LABEL:LOCAL%
	ENDIF
NEXT
PRINTL
PRINTL [99] Cancel
INPUT
PRINTL
SELECTCASE RESULT
CASE 1 TO 10
	CALL SLAVE_SEARCH_TERM_SAVE_SLOT(RESULT)
CASE 11 TO 20
	CALL SLAVE_SEARCH_TERM_LOAD_SLOT(RESULT -10)
ENDSELECT



;セーブする
;ARG→スロット番号
@SLAVE_SEARCH_TERM_SAVE_SLOT(ARG)

;ラベルがあったら上書き確認
IF SEARCH_SLAVE_LABEL:ARG != ""
	PRINTL There is a search condition label. Do you want to overwrite it?
	CALL ASK_YN
	SIF RESULT
		RETURN
ENDIF
SEARCH_SLAVE_TRIBE:ARG = %SEARCH_SLAVE_TRIBE:0%
SEARCH_SLAVE_JOB:ARG = %SEARCH_SLAVE_JOB:0%
SEARCH_SLAVE_POSITION:ARG = %SEARCH_SLAVE_POSITION:0%
SEARCH_SLAVE_HEIGHT:ARG = %SEARCH_SLAVE_HEIGHT:0%
SEARCH_SLAVE_LOCATION:ARG = %SEARCH_SLAVE_LOCATION:0%
SEARCH_SLAVE_PRODUCT:ARG = %SEARCH_SLAVE_PRODUCT:0%
SEARCH_SLAVE_STATE:ARG = %SEARCH_SLAVE_STATE:0%
SEARCH_SLAVE_COWSHED:ARG = SEARCH_SLAVE_COWSHED:0
SEARCH_SLAVE_BUST:ARG = SEARCH_SLAVE_BUST:0
SEARCH_SLAVE_VARGIN:ARG = SEARCH_SLAVE_VARGIN:0
SEARCH_SLAVE_MILK:ARG = SEARCH_SLAVE_MILK:0
SEARCH_SLAVE_MILK_DENCE:ARG = SEARCH_SLAVE_MILK_DENCE:0
SEARCH_SLAVE_DRAIN_EP:ARG = SEARCH_SLAVE_DRAIN_EP:0
SEARCH_SLAVE_DRAIN_MP:ARG = SEARCH_SLAVE_DRAIN_MP:0
SEARCH_SLAVE_CATTLE_MIND:ARG = SEARCH_SLAVE_CATTLE_MIND:0
SEARCH_SLAVE_MIND:ARG = SEARCH_SLAVE_MIND:0

;ラベル付け
SEARCH_SLAVE_LABEL:ARG =
PRINTFORML Saved to slot {ARG,2}.
PRINTL Do you want to enter a search condition label?
PRINTL
PRINTFORML [ 0] Current search condition: ＜%SLAVE_SEARCH_TERM%＞
PRINTL
PRINTL [ 1] Manual input
PRINTL
PRINTL [ 2] Do not input
BINPUT
SELECTCASE RESULT
CASE 0
	SEARCH_SLAVE_LABEL:ARG = %SLAVE_SEARCH_TERM%
CASE 1
	PRINTL Please enter the label.
	INPUTS
	SEARCH_SLAVE_LABEL:ARG = %RESULTS%
ENDSELECT



;ロードする
;ARG→スロット番号
@SLAVE_SEARCH_TERM_LOAD_SLOT(ARG)

SEARCH_SLAVE_TRIBE:0 = %SEARCH_SLAVE_TRIBE:ARG%
SEARCH_SLAVE_JOB:0 = %SEARCH_SLAVE_JOB:ARG%
SEARCH_SLAVE_POSITION:0 = %SEARCH_SLAVE_POSITION:ARG%
SEARCH_SLAVE_HEIGHT:0 = %SEARCH_SLAVE_HEIGHT:ARG%
SEARCH_SLAVE_LOCATION:0 = %SEARCH_SLAVE_LOCATION:ARG%
SEARCH_SLAVE_PRODUCT:0 = %SEARCH_SLAVE_PRODUCT:ARG%
SEARCH_SLAVE_STATE:0 = %SEARCH_SLAVE_STATE:ARG%
SEARCH_SLAVE_COWSHED:0 = SEARCH_SLAVE_COWSHED:ARG
SEARCH_SLAVE_BUST:0 = SEARCH_SLAVE_BUST:ARG
SEARCH_SLAVE_VARGIN:0 = SEARCH_SLAVE_VARGIN:ARG
SEARCH_SLAVE_MILK:0 = SEARCH_SLAVE_MILK:ARG
SEARCH_SLAVE_MILK_DENCE:0 = SEARCH_SLAVE_MILK_DENCE:ARG
SEARCH_SLAVE_DRAIN_EP:0 = SEARCH_SLAVE_DRAIN_EP:ARG
SEARCH_SLAVE_DRAIN_MP:0 = SEARCH_SLAVE_DRAIN_MP:ARG
SEARCH_SLAVE_CATTLE_MIND:0 = SEARCH_SLAVE_CATTLE_MIND:ARG
SEARCH_SLAVE_MIND:0 = SEARCH_SLAVE_MIND:ARG


