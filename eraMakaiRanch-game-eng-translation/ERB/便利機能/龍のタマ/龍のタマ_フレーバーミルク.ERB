
;フレーバーミルク化
@SELECT_WISH_MILK_FLAVOR

;STR:コーヒーミルク→5800
STR_REF = 5800
STR_MAX = 50
PRINTFORML %CALLNAME%から出したい%SAVESTR:表記／母乳%の味を選択してください。
FOR LOCAL,STR_REF,STR_REF +STR_MAX
	SIF STR:LOCAL == ""
		CONTINUE
	PRINTFORMLC [{LOCAL -STR_REF,2}] %STR:LOCAL%
NEXT
CALL INPUTBUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 50
	RESULTS = %STR:(STR_REF +RESULT)%
CASE 900
	RESULTS =
CASE 901
	PRINTFORML %SAVESTR:表記／母乳%の味を入力してください。
	INPUTS
CASE 999
	RETURN
ENDSELECT

;RESULTSが現在と異なる場合に処理
SIF CSTR:フレーバーミルク == RESULTS
	RETURN
IF RESULTS == ""
	PRINTFORML %CALLNAME%から出る%SAVESTR:表記／母乳%を通常の%SAVESTR:表記／母乳%に戻しますか？
ELSE
	PRINTFORML %CALLNAME%から出る%SAVESTR:表記／母乳%を【%RESULTS%】にしますか？
ENDIF
CALL ASK_YN
SIF RESULT
	RETURN
CSTR:フレーバーミルク = %RESULTS%
CSTR:母乳商品名濃度自動 =
CSTR:母乳商品名自由記述 =
IF RESULTS == ""
	CALL PRINTW_WORD_COLOR,@"%CALLNAME%から出る%SAVESTR:表記／母乳%が通常の%SAVESTR:表記／母乳%に戻った！","桃"
ELSE
	CALL PRINTW_WORD_COLOR,@"%CALLNAME%から出る%SAVESTR:表記／母乳%が%CSTR:フレーバーミルク%になった！","桃"
ENDIF
ITEM:龍のタマ = 0




