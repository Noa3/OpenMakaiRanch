

;捕獲する
@SELECT_WISH_CAPTURE

PRINTFORML %CALLNAME%を問答無用で捕獲してきますか？
CALL ASK_YN
SIF RESULT
	RETURN
CALL SLAVE_RECEIVE_COMMON
ITEM:龍のタマ = 0



;強くなりたい
@SELECT_WISH_STRONGER

PRINTFORML %CALLNAME%の霊力を%VALUE_DIGIT(WISH_STRONGER_EP)%EP増加させますか？
CALL ASK_YN
SIF RESULT
	RETURN
MAXBASE:霊力 += WISH_STRONGER_EP
BASE:霊力 = MAXBASE:霊力
CALL PRINTL_WORD_COLOR,@"%CALLNAME%の霊力が%VALUE_DIGIT(WISH_STRONGER_EP)%増加した！ → %VALUE_DIGIT(MAXBASE:霊力)%","黄"
CALL MASTER_POWERUP_EP
PRINTW
ITEM:龍のタマ = 0





