
;使おうぜ、ドラゴンボール
@USE_ITEM_PLAYER_DRAGON_BALL

PRINTL ＜龍のタマ＞を7つ揃えて置いてみた…
PRINTW タマが浮遊し、円を描くように回転を始め…眩い光の後、巨大な龍が現れた！

;呼び出し状態によりセリフ変化
CALL SUMMON_DRAGON_MESSAGE

;TARGET=0して願い事選択画面へ
TARGET = 0
CALL SUMMON_DRAGON_SELECT_WISH



;願い事選択
@SUMMON_DRAGON_SELECT_WISH

CLEARLINE LINECOUNT
CALL SELECT_WISH_CHARA
CALL SELECT_WISH_NOTCHARA
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTLC [300] Prev Chara
PRINTLC [ 80] キャラ選択
PRINTL [301] Next Chara
PRINTL [ 99] もう少し考える
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL SELECT_WISH_MILK_FLAVOR
CASE 1
	CALL SELECT_WISH_NASTY_TALENT
CASE 2
	CALL SELECT_WISH_WORK_ABL
CASE 3
	CALL SELECT_WISH_DEFAULT_BUSTSIZE
CASE 4
	CALL SELECT_WISH_CAPTURE
CASE 5
	CALL SELECT_WISH_STRONGER
CASE 10
	CALL SELECT_WISH_GIVE_LINGERIE
CASE 11
	CALL SELECT_WISH_GIVE_MONEY
CASE 12
	CALL SELECT_WISH_GROW_SPA
CASE 20
	CALL DRAGON_WISH_ADD_MESSAGE
CASE 21
	CALL DRAGON_KINTAMA_MESSAGE
CASE 80
	SAVE_TARGET = TARGET
	CALL SELECT_WISH_TARGET_CHANGE
CASE 300
	CALL CHANGE_TARGET_CHARA(0,"願い事選択")
CASE 301
	CALL CHANGE_TARGET_CHARA(1,"願い事選択")
CASE 99
	CALL DRAGON_CANCEL_MESSAGE
	
	;キャンセルした状態にしとく
	FLAG:龍呼び出し状態 = 2
	SIF !RESULT
		RETURN
ENDSELECT

;願い事を決定したらキンタマ0コになってる→終了処理
SIF ITEM:龍のタマ
	RESTART
CALL WISH_AFTER_MESSAGE
FLAG:龍のタマ発見率補正 = DRAGON_BALL_CT
FLAG:龍呼び出し状態 = 1
FLAG:龍呼び出し回数 ++
RETURN



;キャラ系
@SELECT_WISH_CHARA

CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT
PRINTFORM 選択中：%CALLNAME% 
CALL PRINT_AFFILIATION_DATA
CALL MANYL(2)
IF MARK:母乳体質
	PRINTFORML [ 0] %SAVESTR:表記／母乳%フレーバー選択
ELSE
	CALL PRINTL_WORD_COLOR("　非【母乳体質】","灰")
ENDIF
IF !TARGET
	CALL PRINTL_WORD_COLOR,@"　%CALLNAME%は性器素質付与できません","灰"
ELSE
	PRINTL [ 1] 性器素質選択
ENDIF
PRINTL [ 2] 仕事能力選択
PRINTL
IF ABL:バストサイズ > ABL:初期値／バストサイズ
	PRINTFORM [ 3] バストサイズを元に戻したい：%PRINT_BUSTSIZE(ABL:バストサイズ)%
	CALL PRINT_BUST_C(1,1,0)
	PRINTFORM →%PRINT_BUSTSIZE(ABL:初期値／バストサイズ)%
	CALL PRINT_BUSTSIZE_SPECIFY(1,1,ABL:初期値／バストサイズ)
	PRINTL
ELSE
	CALL PRINTL_WORD_COLOR("　バストサイズは変化していません","灰")
ENDIF
IF CFLAG:追跡対象
	PRINTL [ 4] 捕獲してきて
ELSE
	CALL PRINTL_WORD_COLOR("　追跡対象ではありません","灰")
ENDIF
IF !TARGET
	PRINTL [ 5] 強くなりたい
ELSE
	CALL PRINTL_WORD_COLOR,@"　直接強化は%CALLNAME:0%のみ可能です","灰"
ENDIF



;キャラ以外
@SELECT_WISH_NOTCHARA

SIF TARGET
	RETURN
PRINTL
PRINTL 　《 キャラ以外 》
PRINTL [10] マノさんの着けてる下着ください
PRINTL [11] お金が欲しい
IF !ITEM:天然温泉
	IF MONEY >= ITEMPRICE:天然温泉
		PRINTFORML [12] うちの近くに温泉湧かない？（工事費用：%VALUE_DIGIT(ITEMPRICE:天然温泉)%G）
	ELSE
		CALL PRINTL_WORD_COLOR,@"　温泉の工事費用が足りません：%VALUE_DIGIT(ITEMPRICE:天然温泉)%G","灰"
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR("　温泉はもう湧いています","灰")
ENDIF
PRINTL

;初対面のみ
IF !FLAG:龍呼び出し回数
	PRINTL [20] 「願い事の数を増やして」はダメ？
	PRINTL [21] ところでこのタマってキンタマ？
ENDIF

