
;性器素質付与
@SELECT_WISH_NASTY_TALENT

;TALENT:名器→30
TALENT_REF = 30
TALENT_MAX = 20
PRINTFORML %CALLNAME%に付与したい性器素質を選択してください。
FOR LOCAL,TALENT_REF,TALENT_REF +TALENT_MAX
	TALENT_NAME = %TALENTNAME:LOCAL%
	SIF TALENT_NAME == "" || TALENT_NAME == "先天的母乳体質"
		CONTINUE
	
	;もうある場合はダメ
	IF TALENT:LOCAL
		CALL PRINTL_WORD_COLOR,@"【%TALENT_NAME%】所持","桃"
	ELSEIF TALENT_NAME == "極上乳圧" && ABL:バストサイズ < BUSTSIZE_巨乳
		CALL PRINTL_WORD_COLOR,@"【%TALENT_NAME%】は【巨乳】以上が必要です","灰"
	ELSE
		PRINTFORML [{LOCAL -TALENT_REF,2}] 【%TALENT_NAME%】
	ENDIF
NEXT
PRINTL
PRINTL [99] Cancel
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 19
	TALENT_NUM = TALENT_REF +RESULT
	PRINTFORML %CALLNAME%に素質【%TALENTNAME:TALENT_NUM%】を付与しますか？
	CALL ASK_YN
	SIF RESULT
		RETURN
	TALENT:TALENT_NUM = 1
	CALL PRINTW_WORD_COLOR,@"%CALLNAME%は【%TALENTNAME:TALENT_NUM%】を習得した！","桃"
	ITEM:龍のタマ = 0
ENDSELECT





