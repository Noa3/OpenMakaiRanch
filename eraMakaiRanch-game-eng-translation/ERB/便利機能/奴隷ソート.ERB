ENDSELECT
IF !ARG:1
	PRINT Descending
ELSE
	PRINT Ascending
ENDIF
PRINTW 



;ARG:0は入れ替える方法、ARG:1は入れ替えるキャラ（２回目の選択のみ表示）
@SELECT_CHARA_SORT(ARG:0, ARG:1)
#DIM DYNAMIC PAGE
#DIM SWAP_SLAVE_NUM

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINT Select the slaves to be sorted. Sorting Method：
SELECTCASE ARG
CASE 1
	PRINTL ＜Replace＞
CASE 2
	PRINTL ＜Insert＞
ENDSELECT
SIF ARG:1
	PRINTFORML 1st Person：%CALLNAME:(SWAP_SLAVE_NUM)%
DRAWLINE
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	IF CFLAG:牛舎番号
		CALL PRINT_WORD_COLOR("[Cowshed] ","黄")
	ELSEIF CSTR:スケジュール == "体内凌辱"
		CALL PRINT_WORD_COLOR("[T.Wall] ","桃")
	ELSE
		PRINT 　　　 
	ENDIF
	CALL TABLE_STATUS("調教対象")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTLC [  8] Change Display Settings
PRINTLC 　
PRINTL [ 99] Cancel
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	;99返すと[199]選択時と区別できないので-1
	RETURN -1
CASEELSE
	SWAP_SLAVE_NUM = RESULT -100
	SIF SWAP_SLAVE_NUM <= 0 || SWAP_SLAVE_NUM >= CHARANUM || !SWAP_SLAVE_NUM
		RESTART
	PRINTFORMW  %CALLNAME:(SWAP_SLAVE_NUM)% selected
	RETURN SWAP_SLAVE_NUM
ENDSELECT
RESTART


