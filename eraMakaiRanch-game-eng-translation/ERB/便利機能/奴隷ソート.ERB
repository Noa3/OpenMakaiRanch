
;隣接キャラをTARGETに指定し直す
@SLAVE_SORT
#DIM LOOP_BASE
#DIM TEMP_NUM

;キャンセルしたらそのまま戻るようにした
CALL MANYL(5)
IF CHARANUM < 2
	PRINTW No slaves available for listing
	RETURN
ELSE
	PRINTL Rearrange the display order of slaves
ENDIF
CALL HALFLINE
PRINTL [ 1] Change Positions（Replace）
PRINTL [ 2] Change Positions（Insert）
PRINTL [ 3] Change Order（Sort）
PRINTL
PRINTL [99] Cancel
INPUT
PRINTL
SELECTCASE RESULT
CASE 1,2
	CALL SLAVE_SORT_REPLACE(RESULT)
CASE 3
	CALL SLAVE_SORT_ALL
ENDSELECT



;入れ替え／挿入
;ARG→1：入れ替え　2：挿入
@SLAVE_SORT_REPLACE(ARG)
#DIM SWAP_NUM1
#DIM SWAP_NUM2
#DIM CHARA_NUM,2

SWAP_NUM1 = -1
SWAP_NUM2 = -1

;プロファイル表示
CALL SELECT_CHARA_SORT(ARG, 0)

;キャンセルした→キャンセルで帰ってくる数値を-1に
SIF RESULT == -1
	RETURN
SWAP_NUM1 = RESULT
CALL SELECT_CHARA_SORT(ARG, SWAP_NUM1)
SIF RESULT == -1
	RETURN
SWAP_NUM2 = RESULT

;入れ替えと挿入で変化
IF ARG == 1
	PRINTFORMW %CALLNAME:(SWAP_NUM1)% swapped with %CALLNAME:(SWAP_NUM2)%
	SWAPCHARA SWAP_NUM1, SWAP_NUM2

	;交換確認用
	;PRINTFORMW %CALLNAME:(SWAP_NUM1)%と%CALLNAME:(SWAP_NUM2)%を入れ替えました。
ELSE
	CHARA_NUM:0 = SWAP_NUM1
	IF SWAP_NUM1 < SWAP_NUM2
		PRINTFORML %CALLNAME:(SWAP_NUM1)% inserted as position {SWAP_NUM2}
		REPEAT CHARANUM
			CHARA_NUM:1 = CHARA_NUM:0 + 1
			SWAPCHARA CHARA_NUM:0,CHARA_NUM:1
			CHARA_NUM:0 += 1
			SIF CHARA_NUM:1 == SWAP_NUM2
				BREAK
		REND
	ELSEIF SWAP_NUM1 > SWAP_NUM2
		PRINTFORML %CALLNAME:(SWAP_NUM1)% inserted as position {SWAP_NUM2}
		REPEAT CHARANUM
			CHARA_NUM:1 = CHARA_NUM:0 - 1
			SWAPCHARA CHARA_NUM:1,CHARA_NUM:0
			CHARA_NUM:0 -= 1
			SIF CHARA_NUM:1 == SWAP_NUM2
				BREAK
		REND
	ENDIF
ENDIF



;ソート
@SLAVE_SORT_ALL
#DIM TEMP_FLAG

CLEARLINE LINECOUNT
PRINTL Choose how to sort by
CALL HALFLINE
PRINTL [ 0] Serial Number
PRINTL [ 1] Extractable EP
PRINTL [ 2] Extractable MP
PRINTL [ 3] Current Level
PRINTL [ 4] Breast Size
PRINTL [ 5] Favorability
PRINTL [ 6] Resistance
PRINTL [ 7] Dignity
PRINTL [ 8] Disgust
PRINTL [ 9] Reason
PRINTL [10] Fall To Dairy Cow
DRAWLINE
PRINT [98] Sorthing Method　Current：
IF TEMP_FLAG
	PRINTL Ascending
ELSE
	PRINTL Descending
ENDIF
PRINTL [99] Cancel
BINPUT
SELECTCASE RESULT
CASE 0 TO 10
	CALL SLAVE_SORT_ALL_RUN(RESULT,TEMP_FLAG)
CASE 98
	TEMP_FLAG = ABS(TEMP_FLAG -1)
	RESTART
CASEELSE
	RETURN
ENDSELECT
TEMP_FLAG = 0



;ソート実行
;ARG→ソート項目　ARG:1→TEMP_FLAG
@SLAVE_SORT_ALL_RUN(ARG,ARG:1)

;降順には末尾にバックを入れる必要があるため、IF文が２通り必要
