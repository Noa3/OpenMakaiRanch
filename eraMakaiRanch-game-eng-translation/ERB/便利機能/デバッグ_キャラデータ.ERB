
;キャラデータ変更対象選択
@DEBUG_CHARA_NAME_EDIT_SELECT
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML 名前などを変更するキャラを選択してください。
FOR TARGET_COUNT,0,20
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("牛舎")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTL [ 99] Done
BINPUT
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	CALL DEBUG_CHARA_NAME_EDIT
ENDSELECT
RESTART



;名前とかを変更する
@DEBUG_CHARA_NAME_EDIT
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML Change %CALLNAME%'s data.
PRINTL （バージョンアップによる要素追加への対応を想定しています。バグが出るかもしれません）
PRINTL ※この画面で種族などを変更しても素質などへの反映はされません。
PRINTL ※継ぎ足し拡張の影響で順番がバラバラですがご了承ください。
CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT
CALL PRINT_ALL_STATE
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
PRINTL
TRYCALLFORM DEBUG_CHARA_NAME_EDIT_PAGE_{PAGE}
CALL PRINTL_ALIGN
DRAWLINE
CALL PRINT_NOW_PAGE(PAGE)
PRINTLC [300] Prev Chara
PRINTLC 　
PRINTL [301] Next Chara
PRINTL [ 99] Done
BINPUT
SELECTCASE RESULT
CASE 0 TO 79,100 TO 199
	CALL DEBUG_CHARA_NAME_EDIT_INPUT(RESULT)
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 300
	CALL CHANGE_TARGET_CHARA(0,"キャラコンフィグ")
CASE 301
	CALL CHANGE_TARGET_CHARA(1,"キャラコンフィグ")
CASE 99
	RETURN
ENDSELECT
RESTART



@DEBUG_CHARA_NAME_EDIT_PAGE_1

CALL PRINT_IMAGE_TEST
PRINTL
PRINTFORML [  0] Display Name    ：%CALLNAME%
PRINTFORML [  1] Full Name       ：%NAME%
PRINTFORML [  2] Identifier      ：%CSTR:識別名%
PRINTFORML [  3] Source          ：%CSTR:出典作品名%
PRINTL 　　識別名・出典作品名に対応する画像を登録している場合画像が表示されます。
PRINTL

;番号整理したのでFORでできると思う
FOR LOCAL,0,20
	STR_NAME = %CSTRNAME:LOCAL%
	SIF STR_NAME == ""
		CONTINUE
	PRINTFORML [{LOCAL +100,2}] %CSTR_ENG(STR_NAME),16%：%CSTR:LOCAL%
NEXT



