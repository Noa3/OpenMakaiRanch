;変更場所
;ARG→INPUT
@DEBUG_CHARA_NAME_EDIT_INPUT(ARG)

SELECTCASE ARG
CASE 0
	PRINTL Enter a display name
	INPUTS
	SIF RESULTS != ""
		CALLNAME = %RESULTS%
CASE 1
	PRINTL Enter a full/real name
	INPUTS
	NAME = %RESULTS%
CASE 2
	PRINTL Enter an identifier
	INPUTS
	CSTR:識別名 = %RESULTS%
CASE 3
	PRINTL Enter a source
	INPUTS
	CSTR:出典作品名 = %RESULTS%
CASE 4
	PRINTL Enter an eye feature
	INPUTS
	CSTR:目の特徴 = %RESULTS%
CASE 100 TO 300
	IF CSTRNAME:(ARG -100) == "乳首の色"
		CALL CHANGE_SLAVE_NIPPLE_COLOR
	ELSE
		PRINTFORML Please enter %CSTR_ENG(CSTRNAME:(ARG -100))%
		INPUTS
		CSTR:(ARG -100) = %RESULTS%
	ENDIF
ENDSELECT




;乳首の色変更
@CHANGE_SLAVE_NIPPLE_COLOR

CLEARLINE LINECOUNT
CALL PRINT_NIPPLE_COLOR
PRINTL [ 0] Randomize
PRINTL [ 1] Manual Input
PRINTL [ 2] Color Code Input
PRINTL
PRINTL [99] Done
INPUT
SELECTCASE RESULT
CASE 0
	CALL RANDOM_SLAVE_NIPPLE_COLOR

CASE 1
	PRINTL Enter a nipple color
	INPUTS
	CSTR:乳首の色 = %RESULTS%

CASE 2
	CALL EDIT_COLOR_CODE(CFLAG:カラーコード／乳首,1)
	SIF RESULT
		CFLAG:カラーコード／乳首 = RESULT
CASE 99
	RETURN
ENDSELECT
RESTART





