
;検索条件の設定
@SLAVE_SEARCH_TERM_SELECT

VARSET CANDI_BOX
VARSET CANDI_NO_BOX
VARSET BOX_CHARA_NUM
VARSET BOX_COUNT
PRINTL Change Search Criteria
PRINTLC [ 0] Race
PRINTLC [ 1] Job
PRINTLC [ 2] Original Status
PRINTLC [ 3] Height
PRINTLC [ 4] Location
PRINTLC [ 5] Source Work
PRINTLC [ 6] Cowshed Number
PRINTLC [ 7] Breast Size
PRINTLC [ 8] Virginity
PRINTLC [ 9] Fall State
PRINTLC [10] Lactating
PRINTLC [11] Milk Richness
PRINTLC [12] EP Extractable
PRINTLC [13] MP Extractable
PRINTLC [14] Falling into a dairy cow
PRINTLC [15] Mental strength
PRINTL
PRINTL [99] Cancel
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL SLAVE_SEARCH_TERM_TRIBE
CASE 1
	CALL SLAVE_SEARCH_TERM_JOB
CASE 2
	CALL SLAVE_SEARCH_TERM_POSITION
CASE 3
	CALL SLAVE_SEARCH_TERM_HEIGHT
CASE 4
	CALL SLAVE_SEARCH_TERM_LOCATION
CASE 5
	CALL SLAVE_SEARCH_TERM_PRODUCT
CASE 6
	CALL SLAVE_SEARCH_TERM_COWSHED
CASE 7
	CALL SLAVE_SEARCH_TERM_BUST
CASE 8
	CALL SLAVE_SEARCH_TERM_VARGIN
CASE 9
	CALL SLAVE_SEARCH_TERM_STATE
CASE 10
	CALL SLAVE_SEARCH_TERM_MILK
CASE 11
	CALL SLAVE_SEARCH_TERM_MILK_DENCE
CASE 12
	CALL SLAVE_SEARCH_TERM_DRAIN_EP
CASE 13
	CALL SLAVE_SEARCH_TERM_DRAIN_MP
CASE 14
	CALL SLAVE_SEARCH_TERM_CATTLE_MIND
CASE 15
	CALL SLAVE_SEARCH_TERM_MIND
ENDSELECT



;種族
@SLAVE_SEARCH_TERM_TRIBE

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	
	;RETURN 1以外なら次へ
	SIF !RESULT
		CONTINUE
	
	;種族名を保存して種族人数を+1
	CALL SLAVE_SEARCH_TERM_BOXS(CSTR:種族)
NEXT

;結果
CALL SLAVE_SEARCH_RESULT_BOX

;1000までしか用意してないよ
SIF INPUT_NUM < 0 || INPUT_NUM >= 99
	RETURN

;中身を検索条件に追加
SEARCH_SLAVE_TRIBE = %CANDI_BOX:INPUT_NUM%



;ジョブ
@SLAVE_SEARCH_TERM_JOB

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	CALL SLAVE_SEARCH_TERM_BOXS(CSTR:ジョブ)
NEXT
CALL SLAVE_SEARCH_RESULT_BOX
SIF INPUT_NUM < 0 || INPUT_NUM >= 99
	RETURN
SEARCH_SLAVE_JOB = %CANDI_BOX:INPUT_NUM%



;元の身分
@SLAVE_SEARCH_TERM_POSITION

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	CALL SLAVE_SEARCH_TERM_BOXS(CSTR:初期値／身分)
NEXT
CALL SLAVE_SEARCH_RESULT_BOX
SIF INPUT_NUM < 0 || INPUT_NUM >= 99
	RETURN
SEARCH_SLAVE_POSITION = %CANDI_BOX:INPUT_NUM%



;身長
@SLAVE_SEARCH_TERM_HEIGHT

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	CALL SLAVE_SEARCH_TERM_BOXS(CSTR:身長)
NEXT
CALL SLAVE_SEARCH_RESULT_BOX
SIF INPUT_NUM < 0 || INPUT_NUM >= 99
	RETURN
SEARCH_SLAVE_HEIGHT = %CANDI_BOX:INPUT_NUM%



;居場所
@SLAVE_SEARCH_TERM_LOCATION

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	CALL SLAVE_SEARCH_TERM_BOXS(CSTR:居場所)
NEXT
CALL SLAVE_SEARCH_RESULT_BOX
SIF INPUT_NUM < 0 || INPUT_NUM >= 99
	RETURN
SEARCH_SLAVE_LOCATION = %CANDI_BOX:INPUT_NUM%



;出典作品名
@SLAVE_SEARCH_TERM_PRODUCT

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	CALL SLAVE_SEARCH_TERM_BOXS(CSTR:出典作品名)
NEXT
CALL SLAVE_SEARCH_RESULT_BOX
SIF INPUT_NUM < 0 || INPUT_NUM >= 99
	RETURN
SEARCH_SLAVE_PRODUCT = %CANDI_BOX:INPUT_NUM%



;牛舎番号
;文字列とちと違うことする
@SLAVE_SEARCH_TERM_COWSHED

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	
	;牛舎番号の場所の人数+1
	BOX_CHARA_NUM:(CFLAG:牛舎番号) ++
NEXT
PRINTFORMLC [ 0] Not In Cowshed：{BOX_CHARA_NUM:0}x
FOR LOCAL,1,11
	;牛舎建築してなければ帰る
	SIF LOCAL > ITEM:牛舎
		BREAK
	PRINTFORMLC [{LOCAL,2}] %ITEMS_ENG(COWSHED_NAME:LOCAL)%：{BOX_CHARA_NUM:LOCAL}x
NEXT
PRINTL
PRINTL [99] Cancel
INPUT
INPUT_NUM = RESULT
SIF INPUT_NUM < 1 || INPUT_NUM > ITEM:牛舎
	RETURN

;INPUT_NUM「+1」を直接入れる
SEARCH_SLAVE_COWSHED = INPUT_NUM +1



;バストサイズ
@SLAVE_SEARCH_TERM_BUST

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	
	;バストサイズ素質-10の人数+1
	FOR LOCAL,10,20
		IF TALENT:LOCAL
			BOX_CHARA_NUM:(LOCAL -10) ++
			BREAK
		ENDIF
	NEXT
NEXT
FOR LOCAL,0,8
	PRINTFORMLC [{LOCAL,2}] %TALENTS_ENG(TALENTNAME:(LOCAL +10))%：{BOX_CHARA_NUM:LOCAL}x
NEXT
PRINTL
PRINTL [99] Cancel
INPUT
INPUT_NUM = RESULT
SIF INPUT_NUM < 0 || INPUT_NUM >= 9
	RETURN

;バストサイズ素質に合わせて+10
SEARCH_SLAVE_BUST = INPUT_NUM +10



;処女
@SLAVE_SEARCH_TERM_VARGIN

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	
	;処女結界→0、処女→1、非処女→2番の人数+1
	IF TALENT:処女結界
		BOX_CHARA_NUM:0 ++
	ELSEIF TALENT:処女
		BOX_CHARA_NUM:1 ++
	ELSE
		BOX_CHARA_NUM:2 ++
	ENDIF
NEXT
PRINTFORMLC [ 0] 【Virginity Barrier】：{BOX_CHARA_NUM:0}x
PRINTFORMLC [ 1] 【Virgin】：{BOX_CHARA_NUM:1}x
PRINTFORMLC [ 2] 【Experienced】：{BOX_CHARA_NUM:2}x
PRINTL
PRINTL [99] Cancel
INPUT
INPUT_NUM = RESULT
SIF INPUT_NUM < 0 || INPUT_NUM >= 3
	RETURN
SEARCH_SLAVE_VARGIN = INPUT_NUM +1



;陥落状態
@SLAVE_SEARCH_TERM_STATE

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	CALL SLAVE_SEARCH_TERM_BOXS(CSTR:陥落状態)
NEXT
CALL SLAVE_SEARCH_RESULT_BOX
SIF INPUT_NUM < 0 || INPUT_NUM >= 99
	RETURN
SEARCH_SLAVE_STATE = %CANDI_BOX:INPUT_NUM%



;母乳体質
@SLAVE_SEARCH_TERM_MILK

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	
	;母乳体質でない→0、母乳体質→1、魔力母乳体質→2、絶頂魔力回復淫紋→3番の人数+1
	IF MARK:絶頂魔力回復淫紋
		BOX_CHARA_NUM:3 ++
	ELSEIF MARK:魔力母乳体質
		BOX_CHARA_NUM:2 ++
	ELSEIF MARK:母乳体質
		BOX_CHARA_NUM:1 ++
	ELSE
		BOX_CHARA_NUM:0 ++
	ENDIF
NEXT
PRINTFORMLC [ 0] Not【Lactating】：{BOX_CHARA_NUM:0}x
PRINTFORMLC [ 1] 【Lactating】：{BOX_CHARA_NUM:1}x
PRINTFORMLC [ 2] 【Mana-Infused Milk】：{BOX_CHARA_NUM:2}x
PRINTFORMLC [ 3] 【Climax Crest】：{BOX_CHARA_NUM:3}x
PRINTL
PRINTL [99] Cancel
INPUT
INPUT_NUM = RESULT
SIF INPUT_NUM < 0 || INPUT_NUM >= 4
	RETURN
SEARCH_SLAVE_MILK = INPUT_NUM +1



;母乳濃度
@SLAVE_SEARCH_TERM_MILK_DENCE

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	
	;母乳濃度刻印-19の人数+1
	IF MARK:極上母乳
		BOX_CHARA_NUM:5 ++
	ELSEIF MARK:特濃母乳
		BOX_CHARA_NUM:4 ++
	ELSEIF MARK:豊潤母乳
		BOX_CHARA_NUM:3 ++
	ELSEIF MARK:上質母乳
		BOX_CHARA_NUM:2 ++
	ELSEIF MARK:濃厚母乳
		BOX_CHARA_NUM:1 ++
	ELSEIF MARK:母乳体質
		BOX_CHARA_NUM:0 ++
	ENDIF
NEXT
PRINTFORMLC [ 0] Normal：{BOX_CHARA_NUM:0}人
PRINTFORMLC [ 1] 【濃厚母乳】：{BOX_CHARA_NUM:1}人
PRINTFORMLC [ 2] 【上質母乳】：{BOX_CHARA_NUM:2}人
PRINTFORMLC [ 3] 【豊潤母乳】：{BOX_CHARA_NUM:3}人
PRINTFORMLC [ 4] 【特濃母乳】：{BOX_CHARA_NUM:4}人
PRINTFORMLC [ 5] 【極上母乳】：{BOX_CHARA_NUM:5}人
PRINTL
PRINTL [99] Cancel
INPUT
INPUT_NUM = RESULT
SIF INPUT_NUM < 0 || INPUT_NUM > 5
	RETURN
IF INPUT_NUM == 0
	SEARCH_SLAVE_MILK_DENCE = 1
ELSE
	SEARCH_SLAVE_MILK_DENCE = INPUT_NUM +19
ENDIF



;霊力吸収可能
@SLAVE_SEARCH_TERM_DRAIN_EP

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	
	;霊力吸収可能なら1、空なら0を+1
	IF BASE:吸収可能霊力
		BOX_CHARA_NUM:1 ++
	ELSE
		BOX_CHARA_NUM:0 ++
	ENDIF
NEXT
PRINTFORMLC [ 0] MP Drained：{BOX_CHARA_NUM:0}x
PRINTFORMLC [ 1] MP Absorable：{BOX_CHARA_NUM:1}x
PRINTL
PRINTL [99] Cancel
INPUT
INPUT_NUM = RESULT
SIF INPUT_NUM < 0 || INPUT_NUM > 1
	RETURN
SEARCH_SLAVE_DRAIN_EP = INPUT_NUM +1



;魔力吸収可能
@SLAVE_SEARCH_TERM_DRAIN_MP

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	
	;魔力吸収可能なら1、元々はあって空なら0を+1
	IF BASE:吸収可能魔力
		BOX_CHARA_NUM:1 ++
	ELSEIF MAXBASE:魔力
		BOX_CHARA_NUM:0 ++
	ENDIF
NEXT
PRINTFORMLC [ 0] MP Drained：{BOX_CHARA_NUM:0}x
PRINTFORMLC [ 1] MP Absorbable：{BOX_CHARA_NUM:1}x
PRINTL
PRINTL [99] Cancel
INPUT
INPUT_NUM = RESULT
SIF INPUT_NUM < 0 || INPUT_NUM > 1
	RETURN
SEARCH_SLAVE_DRAIN_MP = INPUT_NUM +1



;乳牛堕ち
@SLAVE_SEARCH_TERM_CATTLE_MIND

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	
	;乳牛堕ち0,1～4999,5000～9999,10000以上
	SELECTCASE BASE:乳牛堕ち
	CASE 0
		BOX_CHARA_NUM:0 ++
	CASE IS < 5000
		BOX_CHARA_NUM:1 ++
	CASE IS < 10000
		BOX_CHARA_NUM:2 ++
	CASEELSE
		BOX_CHARA_NUM:3 ++
	ENDSELECT
NEXT
PRINTFORMLC [ 0] 0\%：{BOX_CHARA_NUM:0}人
PRINTFORMLC [ 1] ～49\%：{BOX_CHARA_NUM:1}人
PRINTFORMLC [ 2] ～99\%：{BOX_CHARA_NUM:2}人
PRINTFORMLC [ 3] 【乳牛堕ち】済み：{BOX_CHARA_NUM:3}人
PRINTL
PRINTL [99] キャンセル
INPUT
INPUT_NUM = RESULT
SIF INPUT_NUM < 0 || INPUT_NUM > 3
	RETURN
SEARCH_SLAVE_CATTLE_MIND = INPUT_NUM +1



;精神力
@SLAVE_SEARCH_TERM_MIND

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	CALL SLAVE_SEARCH_TERM_JUDGE
	SIF !RESULT
		CONTINUE
	
	;精神力0,1～4999,5000～9999,10000
	SELECTCASE BASE:精神力
	CASE 0
		BOX_CHARA_NUM:0 ++
	CASE IS < 5000
		BOX_CHARA_NUM:1 ++
	CASE IS < 10000
		BOX_CHARA_NUM:2 ++
	CASEELSE
		BOX_CHARA_NUM:3 ++
	ENDSELECT
NEXT
PRINTFORMLC [ 0] 【崩壊】：{BOX_CHARA_NUM:0}人
PRINTFORMLC [ 1] ～49\%：{BOX_CHARA_NUM:1}人
PRINTFORMLC [ 2] ～99\%：{BOX_CHARA_NUM:2}人
PRINTFORMLC [ 3] 100\%：{BOX_CHARA_NUM:3}人
PRINTL
PRINTL [99] キャンセル
INPUT
INPUT_NUM = RESULT
SIF INPUT_NUM < 0 || INPUT_NUM > 3
	RETURN
SEARCH_SLAVE_MIND = INPUT_NUM +1





;検索結果表示
@SLAVE_SEARCH_RESULT_BOX

IF !BOX_COUNT
	PRINTW Invalid Criteria
	INPUT_NUM = 99
	RETURN
ENDIF
FOR LOCAL,0,BOX_COUNT
	PRINTFORMLC [{LOCAL,2}] %LOCATIONS_ENG(HEIGHT_ENG(RACE_ENG(JOB_ENG(CANDI_BOX:LOCAL))))%：{BOX_CHARA_NUM:LOCAL}x
NEXT
PRINTL
PRINTL [99] Cancel
INPUT
INPUT_NUM = RESULT



;絞り込み条件を並べるための検索
;ARGS→種族とか絞り込み条件
@SLAVE_SEARCH_TERM_BOXS(ARGS)

;身分などでARGSが空なら帰る
SIF ARGS == ""
	RETURN
FOR LOCAL,0,1000
	;一致したら人数+1
	IF CANDI_BOX:LOCAL == ARGS
		BOX_CHARA_NUM:LOCAL ++
		RETURN
	
	;空なら新たにARGS入れて人数+1
	ELSEIF CANDI_BOX:LOCAL == ""
		CANDI_BOX:LOCAL = %ARGS%
		BOX_CHARA_NUM:LOCAL ++
		BOX_COUNT ++
		RETURN
	ENDIF
NEXT


