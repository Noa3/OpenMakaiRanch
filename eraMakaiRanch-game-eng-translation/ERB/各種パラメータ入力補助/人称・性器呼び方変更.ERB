	STR_REF = 1800
	PRINTFORML Select how the character refers to themself.（Currently：%CSTR:一人称%）
	;completly rewritten for translation
	PRINTFORMLC [  0] I
	;PRINTFORMLC [  1] We
	PRINTFORMLC [800] %CALLNAME%
	PRINTFORMLC [801] %CALLNAME%-chan
	
	CALL INPUTBUTTON
	BINPUT
	SELECTCASE RESULT
	CASE 0
		CSTR:一人称 = I
		CFLAG:一人称が名前 = 0
	;CASE 1
	;	CSTR:一人称 = We
	;	CFLAG:一人称が名前 = 0
	CASE 800
		CSTR:一人称 = %CALLNAME%
		CFLAG:一人称が名前 = 1
	CASE 801
		CSTR:一人称 = %CALLNAME%-chan
		CFLAG:一人称が名前 = 1
	
	;キャンセルで自動補正に行かないようにRETURN
	CASE 900
		RETURN
	CASE 901
		CALL INPUTS_NOT_EMPTY("Enter how the character refers to themself.")
		CSTR:一人称 = %RESULTS%
		CFLAG:一人称が名前 = 0
		SELF_INPUT = 1
	ENDSELECT
