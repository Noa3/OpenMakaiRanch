;手動入力してないかつ、確認しないor手を出す前の娘ならそのままおわり
;ARG→SELF_INPUT
;ARGS→呼び方変更をするCSTR
@CHANGE_PERSONAL_CALL_FIX_AFTER(ARG,ARGS)
#DIMS SWEET_CALL

SIF (!FLAG:呼び方自動補正確認 || GROUPMATCH(CSTR:状態／あなたの子,"成長中","成長後")) && !ARG
	RETURN
SWEET_CALL = %ARGS%／蕩け
