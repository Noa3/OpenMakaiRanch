
;カラーコードの指定
;ARG→1ならTARGET指定中でドットなど表示
@EDIT_COLOR_CODE(COLOR,ARG)
#DIM DYNAMIC COLOR

CLEARLINE LINECOUNT
IF ARG
	CALL PRINT_IMAGE("ステータス")
	CALL PRINT_PORTRAIT
	CALL MANYL(5)
ENDIF
IF COLOR
	SETCOLOR COLOR
	PRINTFORML Current Color：%UNICODE(0x2586)%(R:{GETRED(COLOR)} G:{GETGREEN(COLOR)} B:{GETBLUE(COLOR)})
	PRINTFORML （Reference Hexadecimal Notation：0x%TOSTR(COLOR,"X6")%）
	RESETCOLOR
ELSE
	PRINTL Color not set
ENDIF
PRINTL
PRINTLC [ 0] Direct R Input
PRINTLC [ 1] R Val+10
PRINTLC [ 2] R Val-10
PRINTLC [ 3] Direct G Input
PRINTLC [ 4] G Val+10
PRINTLC [ 5] G Val-10
PRINTLC [ 6] Direct B Input
PRINTLC [ 7] B Val+10
PRINTL [ 8] B Val-10
PRINTL
PRINTLC [ 9] Choose from sample colors
PRINTLC [90] Cancel
PRINTL [99] Done
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	PRINTFORML Specify R from 0 to 255.
	INPUT
	SIF RESULT >= 0 && RESULT < 256
		COLOR = RGBCOLOR(RESULT,GETGREEN(COLOR),GETBLUE(COLOR))

CASE 1
	LOCAL = GETRED(COLOR)
	LOCAL = LIMIT(LOCAL+10,0,255)
	COLOR = RGBCOLOR(LOCAL,GETGREEN(COLOR),GETBLUE(COLOR))

CASE 2
	LOCAL = GETRED(COLOR)
	LOCAL = LIMIT(LOCAL-10,0,255)
	COLOR = RGBCOLOR(LOCAL,GETGREEN(COLOR),GETBLUE(COLOR))
	
CASE 3
	PRINTFORML Specify G from 0 to 255.
	INPUT
	SIF RESULT >= 0 && RESULT < 256
		COLOR = RGBCOLOR(GETRED(COLOR),RESULT,GETBLUE(COLOR))

CASE 4
	LOCAL = GETGREEN(COLOR)
	LOCAL = LIMIT(LOCAL+10,0,255)
	COLOR = RGBCOLOR(GETRED(COLOR),LOCAL,GETBLUE(COLOR))

CASE 5
	LOCAL = GETGREEN(COLOR)
	LOCAL = LIMIT(LOCAL-10,0,255)
	COLOR = RGBCOLOR(GETRED(COLOR),LOCAL,GETBLUE(COLOR))
	
CASE 6
	PRINTFORML Specify B from 0 to 255.
	INPUT
	SIF RESULT >= 0 && RESULT < 256
		COLOR = RGBCOLOR(GETRED(COLOR),GETGREEN(COLOR),RESULT)

CASE 7
	LOCAL = GETBLUE(COLOR)
	LOCAL = LIMIT(LOCAL+10,0,255)
	COLOR = RGBCOLOR(GETRED(COLOR),GETGREEN(COLOR),LOCAL)

CASE 8
	LOCAL = GETBLUE(COLOR)
	LOCAL = LIMIT(LOCAL-10,0,255)
	COLOR = RGBCOLOR(GETRED(COLOR),GETGREEN(COLOR),LOCAL)

CASE 9
	CALL INPUT_SAMPLE_COLOR
	SIF RESULT
		COLOR = RESULT

CASE 90
	RETURN 0
	
CASE 99
	RETURN COLOR
	
ENDSELECT
RESTART



;サンプル色選択による文字色指定
@INPUT_SAMPLE_COLOR

CALL SAMPLE_COLOR
PRINTL
PRINTL Select a sample color

FOR LOCAL,0,30
	SIF SAMPLE_COLOR_NAME:LOCAL == ""
		BREAK
	SETCOLOR SAMPLE_COLOR:LOCAL
	PRINTFORM [{LOCAL,2}] %SAMPLE_COLOR_NAME:LOCAL,16% %UNICODE(0x2586)%%UNICODE(0x2586)%
	PRINTFORML (R:{GETRED(SAMPLE_COLOR:LOCAL)} G:{GETGREEN(SAMPLE_COLOR:LOCAL)} B:{GETBLUE(SAMPLE_COLOR:LOCAL)})
NEXT
RESETCOLOR
PRINTL
PRINTL [99] Cancel
INPUT

SIF RESULT >= 0 && RESULT < 30
	RETURN SAMPLE_COLOR:RESULT
RETURN 0



