
;種族の棚
@REFERENCE_TRIBE

CLEARLINE LINECOUNT
ALIGNMENT CENTER
PRINTL --- 種族情報 ---
PRINTL ○素質やABLの記述は未実装のものも多くあります。ご了承ください。
DRAWLINE
PRINTL --- 通常種族 ---
ALIGNMENT LEFT
FOR LOCAL,5100,5200
	IF LOCAL == 5120
		PRINTL
		ALIGNMENT CENTER
		PRINTL --- 特殊種族 ---
		ALIGNMENT LEFT
		
	ELSEIF LOCAL == 5140
		PRINTL
		ALIGNMENT CENTER
		PRINTL --- 魔界のヒト型種族 ---
		ALIGNMENT LEFT
		
	ELSEIF LOCAL == 5180
		PRINTL
		ALIGNMENT CENTER
		PRINTL --- 魔界のその他種族 ---
		ALIGNMENT LEFT
		
	ENDIF
	SIF STR:LOCAL != ""
		PRINTFORMLC [{LOCAL -4900}] %STR:LOCAL%
NEXT
CALL MANYL(2)
DRAWLINE
PRINTL [  9] 入口に戻る
INPUT
IF RESULT >= 200 && RESULT < 300
	CALL REFERENCE_SEARCH(RESULT)
ELSEIF RESULT == 9
	RETURN
ENDIF
RESTART

