
;魔界の住民の棚
@REFERENCE_RESIDENTS

CLEARLINE LINECOUNT
ALIGNMENT CENTER
PRINTL --- 魔界の住民 ---
DRAWLINE
FOR LOCAL,5200,5300
	SIF STR:LOCAL != ""
		PRINTFORMLC [{LOCAL -4900}] %STR:LOCAL%
NEXT
ALIGNMENT LEFT
CALL MANYL(2)
DRAWLINE
PRINTL [  9] 入口に戻る
INPUT
IF RESULT >= 300 && RESULT < 400
	CALL REFERENCE_SEARCH(RESULT)
ELSEIF RESULT == 9
	RETURN
ENDIF
RESTART

