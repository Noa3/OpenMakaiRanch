
;調教する奴隷変更
;夜に来た場合とかの全奴隷参照はこっち
@TRAIN_SLAVE_SELECT_ALL
#DIM DYNAMIC PAGE
#DIM TRAIN_SLAVE_NUM

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML Select %CALLNAME:0%'s training target
DRAWLINE
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	
	;調教可能　スケジュール-1だと調教可能も0だと思うけど念の為
	;調教可能でも牛舎にいるとダメ　調教可能フラグ変更は選択不可になる気がするのでPASSさ…
	;夜の場合は牛舎にいても引っ張り出せることにしよう
	;夜なら体内にいても引っ張ってこれる
	IF CFLAG:追跡対象
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：Not Captured","灰"
		CONTINUE
	ELSEIF CFLAG:牛舎番号 && TIME < 3
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：%ITEMS_ENG(COWSHED_NAME:(CFLAG:牛舎番号))%","灰"
		CONTINUE
	
	;体内凌辱中で夜ならOKの例外処理のためこんなんに
	ELSEIF CSTR:スケジュール == "体内凌辱" && TIME >= 3
	ELSEIF CSTR:居場所 == "体内" && TIME < 3
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：In body","灰"
		CONTINUE
	ELSEIF !CFLAG:調教可能 || CSTR:状態／あなたの子 == "成長中"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：Not Trainable","灰"
		CONTINUE
	ENDIF

	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	
	;夜だけ牛舎内か体内か違うか表示する
	IF TIME == 3
		IF CFLAG:牛舎番号
			CALL PRINT_WORD_COLOR("[Cowshed] ","黄")
		ELSEIF CSTR:スケジュール == "体内凌辱"
			CALL PRINT_WORD_COLOR("[Inside your body] ","桃")
		ELSE
			PRINT 　　　 
		ENDIF
	ENDIF
	CALL TABLE_STATUS("調教対象")
	SIF CMATCH(CFLAG:調教対象ID,CFLAG:ID)
		CALL PRINT_WORD_COLOR(" Training Scheduled","黄")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] Change Display Settings
PRINTLC 　
PRINTL [ 99] Cancel
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN

CASEELSE
	TRAIN_SLAVE_NUM = RESULT -100
	
	;既に調教が組まれてる場合はダメ
	IF CSTR:TRAIN_SLAVE_NUM:スケジュール == "調教対象"
		PRINTW 既に調教の予定が入っています。
		RETURN
	ENDIF
	SIF CSTR:TRAIN_SLAVE_NUM:スケジュール == "体内凌辱"
		FLAG:体内凌辱一時解除 = 1
	CSTR:0:スケジュール = 調教
	CFLAG:0:調教対象ID = CFLAG:TRAIN_SLAVE_NUM:ID
	CSTR:TRAIN_SLAVE_NUM:スケジュール = 調教対象
	CALL SCHEDULE_ADJUST
	RETURN
ENDSELECT
RESTART



;調教可能な奴隷だけ表示
@TRAIN_SLAVE_SELECT
#DIM TRAIN_SLAVE_NUM

CLEARLINE LINECOUNT
IF CSTR:SAVE_TARGET:状態／あなたの子 == "成長中"
	PRINTFORML Please select who will breastfeed %CALLNAME:SAVE_TARGET%
ELSE
	PRINTFORML Select %CALLNAME:SAVE_TARGET%'s training target.
ENDIF
DRAWLINE
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	IF CFLAG:追跡対象
		CONTINUE
	ELSEIF CFLAG:牛舎番号
		CONTINUE
	ELSEIF CSTR:居場所 == "体内"
		CONTINUE
	
	;一応この分岐も入れる
	ELSEIF !CFLAG:調教可能 || CSTR:状態／あなたの子 == "成長中"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：Cannot be trained","灰"
		CONTINUE
	ELSEIF SAVE_TARGET == TARGET
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)% oneself","灰"
		CONTINUE
	ENDIF
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("調教対象")
	SIF CMATCH(CFLAG:調教対象ID,CFLAG:ID)
		CALL PRINT_WORD_COLOR(" Training Scheduled","黄")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTFORMLC [  8] Change Display Settings
PRINTLC 　
PRINTL [ 99] Cancel
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 99
	RETURN
CASEELSE
	TRAIN_SLAVE_NUM = RESULT -100
	IF CSTR:TRAIN_SLAVE_NUM:スケジュール == "調教対象"
		PRINTW Training already scheduled
		RETURN
	ENDIF
	CSTR:SAVE_TARGET:スケジュール = 調教
	CFLAG:SAVE_TARGET:調教対象ID = CFLAG:TRAIN_SLAVE_NUM:ID
	CSTR:TRAIN_SLAVE_NUM:スケジュール = 調教対象
	CALL SCHEDULE_ADJUST
	
	;自動で繰り返すようにセット
	IF CSTR:SAVE_TARGET:状態／あなたの子 == "成長中"
		CFLAG:SAVE_TARGET:520 = CFLAG:TRAIN_SLAVE_NUM:ID
		CSTR:SAVE_TARGET:360 = 調教／対象Ａ
		CSTR:SAVE_TARGET:361 = 調教／対象Ａ
		CSTR:SAVE_TARGET:362 = 調教／対象Ａ
		VARSET CSTR:SAVE_TARGET,"カスタムＡ",350,357
	ENDIF
	RETURN
	
ENDSELECT
RESTART




