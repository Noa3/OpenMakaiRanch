;牧場リソースなど表示
@RANCH_STATUS
#DIM DYNAMIC PAGE

PAGE_MAX = 9
CLEARLINE LINECOUNT
CALL CALC_PEOPLE_FLAG
CALL SHOW_DATE(1)
CALL SHOW_WEATHER(1)
DRAWLINE

;ページごと
ALIGNMENT CENTER
TRYCALLFORM RANCH_STATUS_PAGE_{PAGE}
CALL PRINTL_ALIGN
CALL PRINT_NOW_PAGE(PAGE,1,1)
PRINTL [ 99] Return
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 89
	PAGE = 0
CASE 99
	RETURN
CASEELSE
	PAGE = RESULT
ENDSELECT
RESTART



