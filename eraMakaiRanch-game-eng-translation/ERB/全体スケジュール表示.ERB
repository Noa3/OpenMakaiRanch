
;スケジュール
@ALL_SCHEDULE_PRINT

;自室にいれば表示　などの処理
CALL SCHEDULE_PRINT_YOU
CALL SCHEDULE_PRINT_FAVORITE
CALL SCHEDULE_PRINT_PLACE("自室")
CALL SCHEDULE_PRINT_PLACE("奴隷寮")
CALL SCHEDULE_PRINT_PLACE("家畜小屋")
CALL SCHEDULE_PRINT_COWSHED
CALL SCHEDULE_PRINT_VORE

;標的判定を変更した
CALL SCHEDULE_PRINT_CHASE_SLAVE
DRAWLINE



;スケジュール表示共通
@PRINT_MAIN_SCHEDULE

PRINTFORM [{TARGET +100}] %CALLNAME,FLAG:キャラ名前欄幅,LEFT%
CALL PRINT_POST_C

;表示切り替えフラグを追加
CALL TABLE_STATUS("メイン")
PRINTL



;あなた
@SCHEDULE_PRINT_YOU
#DIMS PLACE

;あなたが外出済みかどうかで表記変更
IF FLAG:外出済み
	PLACE = 《 Travel 》
ELSE
	PLACE = 《 Office 》
ENDIF
PRINTFORML %PLACE,20%
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF !GROUPMATCH(CSTR:居場所,"事務所","行動済み")
		CONTINUE
	CALL PRINT_MAIN_SCHEDULE
NEXT
PRINTL



;お気に入りの優先表示
@SCHEDULE_PRINT_FAVORITE
#DIM CHARA_COUNT
#DIMS PLACE

;お気に入り探して0人だとおわり
CHARA_COUNT = SUMCARRAY(CFLAG:お気に入り)
SIF !CHARA_COUNT
	RETURN
PLACE = 《 Favorite 》

;FLAG:メイン／折りたたみBITのBITを取得して番号出したり折りたたみONOFFする
BIT_REF = 0
PRINTFORM %PLACE,20%：{CHARA_COUNT,3} 
PRINTFORML [{30 +BIT_REF,3}] \@ GETBIT(FLAG:メイン／折りたたみBIT,BIT_REF) ? HIDE # SHOW \@
SIF GETBIT(FLAG:メイン／折りたたみBIT,BIT_REF)
	RETURN
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:お気に入り || (FLAG:メイン／奴隷非表示 && CFLAG:表示OFF／メイン画面)
		CONTINUE
	CALL PRINT_MAIN_SCHEDULE
NEXT
PRINTL



;場所表示共通
@SCHEDULE_PRINT_PLACE(ARGS)
#DIM CHARA_COUNT
#DIMS PLACE,2

CHARA_COUNT = CMATCH(CSTR:居場所,ARGS)
SIF !CHARA_COUNT
	RETURN
PLACE:0 = 《 %LOCATIONS_ENG(ARGS)% 》
PRINTFORM %PLACE:0,20%：{CHARA_COUNT,3}

;ヒト扱いするか
IF GROUPMATCH(ARGS,"自室","奴隷寮")
	PRINT 
ELSE
	PRINT 
ENDIF

;場所でBIT_REF変更
SELECTCASE ARGS
CASE "自室"
	BIT_REF = 1
CASE "奴隷寮"
	BIT_REF = 2
CASE "家畜小屋"
	BIT_REF = 3
ENDSELECT
PRINTFORML [{30 +BIT_REF,3}] \@ GETBIT(FLAG:メイン／折りたたみBIT,BIT_REF) ? HIDE # SHOW \@
SIF GETBIT(FLAG:メイン／折りたたみBIT,BIT_REF)
	RETURN
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:居場所 != ARGS || CFLAG:お気に入り || (FLAG:メイン／奴隷非表示 && CFLAG:表示OFF／メイン画面)
		CONTINUE
	CALL PRINT_MAIN_SCHEDULE
NEXT
PRINTL



;牛舎
@SCHEDULE_PRINT_COWSHED
#DIM CHARA_COUNT
#DIMS PLACE

;牛舎建ててなければ帰る
SIF !ITEM:牛舎
	RETURN
CHARA_COUNT = CMATCH(CSTR:居場所,"牛舎")
PLACE = 《 Cowshed 》
BIT_REF = 4
PRINTFORM %PLACE,20%：{CHARA_COUNT,3} 
PRINTFORML [{30 +BIT_REF,3}] \@ GETBIT(FLAG:メイン／折りたたみBIT,BIT_REF) ? HIDE # SHOW \@
SIF GETBIT(FLAG:メイン／折りたたみBIT,BIT_REF)
	RETURN
FOR COWSHED_NUM,1,11
	;FLAG:第1牛舎増築段階→500
	FLAG_REF = 490
	COWSHED_CAPACITY = FLAG:(FLAG_REF +COWSHED_NUM *10) *10
	SIF !COWSHED_CAPACITY
		BREAK
	
	;FLAG:第1牛舎家畜頭数→502
	FLAG_REF:1 = 492
	
		;一応ここでも揃える処理書いておく：エラー出る場合使おう
		;FLAG:(FLAG_REF:1 +COWSHED_NUM *10) = CMATCH(CFLAG:牛舎番号,COWSHED_NUM)
	COWSHED_SLAVE = FLAG:(FLAG_REF:1 +COWSHED_NUM *10)
	PRINTFORML [{19 +COWSHED_NUM,3}] %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM),20%：{COWSHED_SLAVE,3}／{COWSHED_CAPACITY,3} 
NEXT
PRINTL



;体内凌辱中
@SCHEDULE_PRINT_VORE
#DIM CHARA_COUNT
#DIMS PLACE

;そもそも体内凌辱未習得なら帰る
SIF !ITEM:体内凌辱
	RETURN
CHARA_COUNT = CMATCH(CSTR:居場所,"体内")
SIF !CHARA_COUNT
	RETURN
PLACE = 《 Inside %CALLNAME:0%'s Body 》
BIT_REF = 5

;上限人数の表示
PRINTFORM %PLACE,20%：{CHARA_COUNT,3}／{ITEM:体内凌辱 +ITEM:体内容量増加}匹 
PRINTFORML [{30 +BIT_REF,3}] \@ GETBIT(FLAG:メイン／折りたたみBIT,BIT_REF) ? HIDE # SHOW \@
SIF GETBIT(FLAG:メイン／折りたたみBIT,BIT_REF)
	RETURN
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:居場所 != "体内" || CFLAG:お気に入り || (FLAG:メイン／奴隷非表示 && CFLAG:表示OFF／メイン画面)
		CONTINUE
	CALL PRINT_MAIN_SCHEDULE
NEXT
PRINTL



;追跡中
@SCHEDULE_PRINT_CHASE_SLAVE
#DIMS PLACE

CALL CHASE_SLAVE_CHECK

;いないなら帰る
SIF !FLAG:追跡中人数
	RETURN
PLACE = 《 Tracking 》
BIT_REF = 9
PRINTFORM %PLACE,20%：{FLAG:追跡中人数,3} 
PRINTFORML [{30 +BIT_REF,3}] \@ GETBIT(FLAG:メイン／折りたたみBIT,BIT_REF) ? HIDE # SHOW \@
SIF GETBIT(FLAG:メイン／折りたたみBIT,BIT_REF)
	RETURN
CALL PRINT_CHASE_SLAVE



