
;支出計算
@PAYMENT_CALC

;従業員と家畜の生活費
MONEY_COST:1 = ONEDAY_COST_BASE +WORK_MEMBER *ONEDAY_COST_WORKER +SLAVE_MEMBER *ONEDAY_COST_SLAVE

;食費計算
;適当に済ますと1人500G、夕食を作ると800G
MONEY_COST:2 = FLAG:簡易食事人数 *ONEDAY_COST_SIMPLE_FOOD +FLAG:食事人数 *ONEDAY_COST_DINNER

;ペットの食費
CALL PAYMENT_CALC_ANIMAL_FOOD

;魔力バッテリー代
CALL PAYMENT_CALC_BATTERY

;雑費
MONEY_COST:5 = ONEDAY_COST_OTHER

;合計計算→合計に関してはここで表示する
MONEY_COST:0 = SUMARRAY(MONEY_COST) -SAVE_BATTERY_COST
PRINTFORML ＜Total Expenses：%VALUE_DIGIT(MONEY_COST:0)%G＞

;カスタマイズ
CALL DIFFICULTY_CONFIG_APPLY("精算支出",MONEY_COST:0)
SIF RESULT
	MONEY_COST:0 = RESULT
PRINTL



;乳牛とペット食費計算
@PAYMENT_CALC_ANIMAL_FOOD
#DIM FOOD_TYPE

;ごはん種類は変更ないのでFORループ回すまま
;先に乳牛
MONEY_COST:3 = PET_FOOD_PRICE_BASE_COW *PET_FOOD_PRICE_FIX:(FLAG:ごはん種類／魔界乳牛) /100
CALL GET_PET_FLAG_REF
FOR LOCAL,0,20
	ANIMAL = %ITEMNAME:(ITEM_REF +LOCAL)%
	SIF ANIMAL == "" || !ITEM:ANIMAL
		CONTINUE
	FOOD_TYPE = FLAG:(FLAG_REF:2 +LOCAL)
	COST = PET_FOOD_PRICE_BASE:LOCAL *PET_FOOD_PRICE_FIX:FOOD_TYPE /100
	MONEY_COST:3 += COST
NEXT



;魔力バッテリー代：施設用のバッテリー、家用、調教追加使用分
;電気ガス水道みたいなもんだと思って
@PAYMENT_CALC_BATTERY

MONEY_COST:4 = ONEDAY_COST_RANCH_BATTERY +ONEDAY_COST_HOME_BATTERY +MONEY:バッテリー追加消費金額

;魔力貯蔵器の差し引き分計算
SIF !MONEY:貯蔵魔力 || !FLAG:魔力バッテリー経費使用
	RETURN
SAVE_BATTERY_COST = LIMIT(MONEY:貯蔵魔力,0,MONEY_COST:4 /2)
MONEY:貯蔵魔力 -= SAVE_BATTERY_COST

;1MPにつき2G節約
SAVE_BATTERY_COST *= 2




