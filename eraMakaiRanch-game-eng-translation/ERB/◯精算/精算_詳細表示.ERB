
;精算詳細
@SETTLEMENT_DETAIL
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL 　《 Settlement Details 》
CALL HALFLINE
TRYCALLFORM SETTLEMENT_DETAIL_PAGE{PAGE}
CALL PRINTL_ALIGN
DRAWLINE
PRINTFORMLC [ 0] Change Page＜PAGE{PAGE}／{PAGE_MAX}＞
PRINTFORMLC [ 1] Slave %SAVESTR:表記／母乳% details
PRINTL [99] Done
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 1
	CALL SETTLEMENT_DETAIL_MILK_INDEX
CASE 99
	RETURN
ENDSELECT
RESTART







