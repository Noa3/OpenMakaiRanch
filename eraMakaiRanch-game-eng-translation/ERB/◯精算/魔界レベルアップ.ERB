
;魔界レベル増加
@MAKAI_LVUP
#DIM NEED_MONEY
#DIM MAKAI_LV

CALL GET_TAX_FLAG_REF
FOR LOCAL,0,10
	SIF !FLAG:(FLAG_REF:1 +LOCAL)
		CONTINUE
	
	;納税額(710)と次レベル(720)までの必要資金比較
	CALL MAKAI_LVUP_NEED_MONEY_CALC(FLAG:(FLAG_REF:2 +LOCAL))
	NEED_MONEY = RESULT
	
	;必要資金が集まったらレベルアップ
	SIF FLAG:(FLAG_REF:1 +LOCAL) < NEED_MONEY
		CONTINUE
	FLAG:(FLAG_REF:2 +LOCAL) ++
	FLAG:(FLAG_REF:1 +LOCAL) -= NEED_MONEY
	MAKAI_LV = FLAG:(FLAG_REF:2 +LOCAL)
	PRINTFORML LvUP! %MAKAI_INSTITUTIONS_ENG(STR:(STR_REF:1 +LOCAL))%Lv{MAKAI_LV -1} → {MAKAI_LV}
	LOCAL --
NEXT



;魔界レベル増加の必要資金算出
;ARG→参照する魔界レベル
@MAKAI_LVUP_NEED_MONEY_CALC(ARG)

;Lv0→1：1万　Lv1→2：10万
;それ以降：現在Lv *100万 *Lv10ごとに倍率+1
SELECTCASE ARG
CASE 0
	RETURN 10000
CASE 1
	RETURN 100000
CASEELSE
	RETURN ARG *MAKAI_LVUP_MONEY *(ARG /MAKAI_LVUP_PROGRESSIVE +1)
ENDSELECT


