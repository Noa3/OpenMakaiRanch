
;個人詳細
@SETTLEMENT_DETAIL_MILK_SLAVE

CLEARLINE LINECOUNT
CALL PRINT_IMAGE("ステータス")
CALL PRINT_PORTRAIT
CALL PRINT_ALL_STATE
PRINTFORM %CALLNAME%
CALL PRINT_AFFILIATION_DATA
SIF !CFLAG:非戦闘職 || BASE:レベル > 1
	PRINTFORM Lv{BASE:レベル} 
PRINTL
PRINTFORM 【%HEIGHT_ENG(CSTR:身長)%】Breast Size：%PRINT_BUSTSIZE(ABL:バストサイズ)%
CALL PRINT_BUST_C(1,1,1)
CALL PRINT_VIRGIN_SIMPLE
PRINTL
SELECTCASE FLAG:選択画面表示形式／素質
CASE 0
	CALL SHOW_TALENT_LIST_SIMPLE
CASE 1
	CALL SHOW_TALENT_LIST
	CALL SHOW_TALENT_NASTY
ENDSELECT
SIF FLAG:選択画面表示形式／刻印 != 2
	CALL SHOW_MILK_MARK_LIST
CALL PRINTL_ALIGN(-15)
CALL PRINT_NOW_PLACE
PRINTL
CALL PRINT_MILK_NAME
PRINTFORM  %VALUE_DIGIT(CFLAG:出荷予定母乳量,"母乳")% ／ %VALUE_DIGIT(CFLAG:母乳出荷金額／当日)%G 
CALL SELL_MILK_PRICE_NEW_RECORD
CALL MANYL(2)

CALL PRINT_SELL_MILK_PRICE_FIX
SIF CFLAG:母乳価格ボーナス
	PRINTFORML %SAVESTR:表記／母乳% price bonus：{CFLAG:母乳価格ボーナス}\%
PRINTFORML %SAVESTR:表記／母乳% demand：%VALUE_DIGIT(CFLAG:母乳需要値,"母乳")%
SIF CFLAG:出荷予定母乳量 > CFLAG:母乳需要値
	PRINTFORML （Produced over demand：%VALUE_DIGIT(CFLAG:出荷予定母乳量 -CFLAG:母乳需要値,"母乳")%）
CALL PRINTL_ALIGN(-3)
PRINTFORML Total shipping volumne：%VALUE_DIGIT(CFLAG:出荷母乳／合計量,"母乳")% 
PRINTFORML  Total shipping income：%VALUE_DIGIT(CFLAG:出荷母乳／合計金額)%G 
PRINTFORML    Total milk produced：%VALUE_DIGIT(CFLAG:総搾乳量,"母乳")% 
DRAWLINE
PRINTLC [300] Prev Chara
PRINTLC [301] Next Chara
PRINTL [ 99] Done
BINPUT
PRINTL
SELECTCASE RESULT
CASE 300
	CALL CHANGE_TARGET_CHARA(0,"精算詳細")
CASE 301
	CALL CHANGE_TARGET_CHARA(1,"精算詳細")
CASE 99
	RETURN
ENDSELECT
RESTART



@PRINT_SELL_MILK_PRICE_FIX

PRINTL ＜Price Adjustment＞
EXIST = 0
IF ABL:母乳濃度
	CALL PRINT_MILKWORD_C(1,1)
	PRINTFORML ：+{ABL:母乳濃度 *30}\%
	EXIST ++
ENDIF
IF !EXP:肉体改造 && (DAY -CFLAG:捕獲日 < 20)
	PRINTFORML Natural %SAVESTR:表記／母乳%：+20\%（up to 20 days）
	EXIST ++
ENDIF
SIF !EXIST
	CALL PRINTL_WORD_COLOR,@"No Price Adjustment","灰"




