
;納税
@SETTLEMENT_TAX
#DIM MONEY_ADD

SIF MONEY_TOTAL <= 0
	RETURN

;ここに来てるなら納税可能フラグ→免除にしててもフラグはON
SETBIT ＃マイルストーン達成／納税＃

;納税免除フラグなら無視
IF FLAG:納税免除
	PRINTL （イージーモードフラグにより納税免除）
	MONEY_PLUS += MONEY_TOTAL
	MONEY_TOTAL = 0
	RETURN
ENDIF

;10%を自動的に資金還元
MONEY_ADD = MONEY_TOTAL /100
MONEY_ADD *= PROFIT_MONEY
MONEY_PLUS += MONEY_ADD
MONEY_TOTAL -= MONEY_ADD

;納税割合に応じて配分
;納税関連フラグIDの一斉取得
CALL GET_TAX_FLAG_REF
TOTAL_RATIO = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +10)
FOR LOCAL,0,10
	SIF FLAGNAME:(FLAG_REF +LOCAL) == "" || !FLAG:(FLAG_REF +LOCAL)
		CONTINUE
	MONEY_ADD = MONEY_TOTAL /TOTAL_RATIO *FLAG:(FLAG_REF +LOCAL)
	FLAG:(FLAG_REF:1 +LOCAL) += MONEY_ADD
	PRINTFORM %MAKAI_INSTITUTIONS_ENG(STR:(STR_REF +LOCAL))%+%VALUE_DIGIT(MONEY_ADD)%G 
NEXT
PRINTL



