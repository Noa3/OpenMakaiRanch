
;収入詳細
@SETTLEMENT_DETAIL_PAGE2
#DIM REWORD,10

PRINTL 　《 Income 》
PRINTFORML Milk shipped from makai dairy cows：%VALUE_DIGIT(MONEY_SELL:1)%G

;牛舎外分まとめて表示
EXIST = 0
IF COWSHED_TOTAL_MILK_CC:0
	EXIST ++
	{
	PRINTFORML Slave %SAVESTR:表記／母乳%：%VALUE_DIGIT(COWSHED_TOTAL_MILK_CC:0,"母乳"),8% ／
	%VALUE_DIGIT(COWSHED_TOTAL_MILK_PRICE:0)%G 
	}
ENDIF

;牛舎内表示
FOR LOCAL,1,11
	;そもそもまとめて表示じゃないなら0のまま
	SIF !COWSHED_TOTAL_MILK_CC:LOCAL
		CONTINUE
	EXIST ++
	{
	PRINTFORML %ITEMS_ENG(COWSHED_NAME:LOCAL),38%：%VALUE_DIGIT(COWSHED_TOTAL_MILK_CC:LOCAL,"母乳"),8% ／
	%VALUE_DIGIT(COWSHED_TOTAL_MILK_PRICE:LOCAL)%G 
	}
NEXT
SIF EXIST >= 2
	PRINTFORM Slave %SAVESTR:表記／母乳% total：%VALUE_DIGIT(MONEY_SELL:2)%G 
SIF SETTLEMENT_EFFECT_DRAGON_BALL
	CALL PRINT_WORD_COLOR,@"Dragon Ball Bonus ×2","黄"
PRINTL

;奴隷数は変更ないのでIFのまま
VARSET REWORD
IF FLAG:事業提携先奴隷数／ニンゲン搾乳牧場
	REWORD:1 = FLAG:事業提携先奴隷数／ニンゲン搾乳牧場 *PARTNER_ALLSLAVE_REWORD
	{
	PRINTFORML 　＜ニンゲン搾乳牧場＞報酬：%VALUE_DIGIT(PARTNER_ALLSLAVE_REWORD)%G×{FLAG:事業提携先奴隷数／ニンゲン搾乳牧場}匹 →
	%VALUE_DIGIT(REWORD:1)%G
	}
ENDIF
SIF MONEY_SELL:3
	PRINTFORML 　Business Partnership Gains：%VALUE_DIGIT(MONEY_SELL:3)%G
PRINTFORML ＜Total Income：%VALUE_DIGIT(MONEY_SELL:0)%G ＞


