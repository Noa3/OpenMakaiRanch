
;支出詳細
@SETTLEMENT_DETAIL_PAGE1
#DIM FOOD_TYPE

PRINTL 　《 Expenses 》
PRINTL 【Living Expenses】
{
PRINTFORML Base：%VALUE_DIGIT(ONEDAY_COST_BASE)%G 
　Workers {WORK_MEMBER,2}×%VALUE_DIGIT(ONEDAY_COST_WORKER)%G 
　Livestock {SLAVE_MEMBER,2}×%VALUE_DIGIT(ONEDAY_COST_SLAVE)%G 
}
PRINTFORML →%VALUE_DIGIT(MONEY_COST:1)%G 
PRINTL
PRINTL 【Food Expenses】

;適当に済ますと1人500G、夕食を作ると800G
{
PRINTFORML Workers and Slaves／Basic Food：{FLAG:簡易食事人数,2}×%VALUE_DIGIT(ONEDAY_COST_SIMPLE_FOOD)%G 
　Dinner {FLAG:食事人数,2}×%VALUE_DIGIT(ONEDAY_COST_DINNER)%G 
}
PRINTFORML →%VALUE_DIGIT(MONEY_COST:2)%G 

;先に乳牛
COST = PET_FOOD_PRICE_BASE_COW *PET_FOOD_PRICE_FIX:(FLAG:ごはん種類／魔界乳牛) /100
PRINTFORML       Dairy Cows：%VALUE_DIGIT(COST)%G 
CALL GET_PET_FLAG_REF
FOR LOCAL,0,20
	ANIMAL = %ITEMNAME:(ITEM_REF +LOCAL)%
	SIF ANIMAL == "" || !ITEM:ANIMAL
		CONTINUE
	PET_NAME = %PET_NAME_REF(ANIMAL)%
	FOOD_TYPE = FLAG:(FLAG_REF:2 +LOCAL)
	COST = PET_FOOD_PRICE_BASE:LOCAL *PET_FOOD_PRICE_FIX:FOOD_TYPE /100
	PRINTFORML %PET_NAME,16%：%VALUE_DIGIT(COST)%G 
NEXT
PRINTFORML →%VALUE_DIGIT(MONEY_COST:3)%G 
PRINTL
PRINTL 【Magical device Magic Battery Usage】
{
PRINTFORML Facility Usage：%VALUE_DIGIT(ONEDAY_COST_RANCH_BATTERY)%G 　Home Usage：%VALUE_DIGIT(ONEDAY_COST_HOME_BATTERY)%G 
　Aditional Cost from Training：%VALUE_DIGIT(MONEY:バッテリー追加消費金額)%G 
}
PRINTFORML →%VALUE_DIGIT(MONEY_COST:4)%G 
SIF SAVE_BATTERY_COST
	{
	CALL PRINTL_WORD_COLOR,@"　Money Saved By Using Stored Mana：%VALUE_DIGIT(SAVE_BATTERY_COST)%G　
	Stored Mana-%VALUE_DIGIT(SAVE_BATTERY_COST / 2)%MP","黄"
	}
PRINTL
PRINTL 【Other Expenses】
PRINTFORML %VALUE_DIGIT(ONEDAY_COST_OTHER)%G
PRINTL
PRINTFORML ＜Total Expenses：%VALUE_DIGIT(MONEY_COST:0)%G＞


