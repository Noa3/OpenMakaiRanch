	;あなたのみ
	TARGET = 0
	
	;Ｐサイズが入っていればここ無視
	;オトコかふたなり→Ｐサイズ入れ
	IF !ABL:170 && (TALENT:20 || ITEM:852)
		ABL:70 = CFLAG:0 / 50 + RAND:6 + 15
		ABL:170 = ABL:70
	ENDIF
	
	;オトコ→Ｖサイズ消去
	IF TALENT:20
		ABL:71 = 0
		ABL:171 = 0
	ENDIF
	
	;女あなた、Ｖサイズ0→Ｖサイズ入れ
	IF !TALENT:20 && !ABL:171
		ABL:71 = CFLAG:0 / 50 + RAND:6 + 10
		ABL:171 = ABL:71
	ENDIF
