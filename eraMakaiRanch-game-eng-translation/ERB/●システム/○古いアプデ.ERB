IF FLAG:セーブデータのバージョン < 1010
	;搾乳器購入コンフィグ
	FLAG:2373 = 0b101

	;褐色系用の乳首色
	FLAG_REF = 3170
	FOR LOCAL,0,10
		FLAG:(FLAG_REF +LOCAL) = FLAG:(FLAG_REF +LOCAL -20)
	NEXT

	;パッチ入れる前は数値が入ってないので入れる(本体更新時、@VERSION_CHECKに入れるのがよさそう)
	;入れたでー
	;ありがとうやでー
	FOR TARGET_COUNT,0,CHARANUM
		TARGET = TARGET_COUNT
		
		;一度全リセット
		VARSET ABL,0,70,80
		VARSET ABL,0,170,180
		IF !TARGET
			IF TALENT:20 || ITEM:852
				ABL:70 = CFLAG:0 / 50 + RAND:6 + 15
				ABL:170 = ABL:70
			ENDIF
			IF !TALENT:20
				ABL:71 = CFLAG:0 / 50 + RAND:6 + 10
				ABL:171 = ABL:71
			ENDIF
		ELSE
			ABL:71 = CFLAG:0 / 50 + RAND:6 + 10
			ABL:171 = ABL:71
		ENDIF
		ABL:73 = CFLAG:0 / 100 + RAND:4 + 5
		ABL:173 = ABL:73
	NEXT
	
