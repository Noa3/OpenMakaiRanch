;-------------------------------------------------
;手動入力/キャンセル選択のボタンを出力
;ARG→0：2つ　1：（指定なし）含め3つ

@INPUTBUTTON(ARG)

PRINTL
SIF ARG
	PRINTL [900] （Unspecified）
PRINTLC [901] （Input Manually）
PRINTLC [999] （Cancel）
CALL MANYL(2)



;-------------------------------------------------
;設定中にフラグとか該当数値が○か×か色付きで返す
;ARG→判定フラグ　ARG:1→改行
@PRINT_ONOFF(ARG,ARG:1)

PRINT ：
IF ARG
	SETCOLOR 0x80FFFF
	PRINTFORM ○　
ELSE
	SETCOLOR 0x707070
	PRINTFORM 　×
ENDIF
RESETCOLOR
SIF ARG:1
	PRINTL



;-------------------------------------------------
;チェックボックスで返す
;ARG→判定フラグ　ARG:1→改行
@PRINT_CHECKBOX(ARG,ARG:1)

PRINTFORM ：\@ ARG ? ☑ # □ \@
SIF ARG:1
	PRINTL



;-------------------------------------------------
;[FLAG:自動改行合わせの行数]の行数から+-ARGになるように改行を挟む
@PRINTL_ALIGN(ARG)

FOR LOCAL,LINECOUNT,FLAG:自動改行合わせの行数 +ARG
	PRINTL
NEXT



;-------------------------------------------------
;ドット絵に被らない程度に線を引くだけ
@HALFLINE

PRINTL -------------------------------------------------------



;-------------------------------------------------
;BRの値を+1してARGになったら改行、BRを0にリセット
;元ファイルのほうでFOR回す前にちゃんと0にしておこうね
;ARG→改行するBR数　ARG:1→1なら改行後にスペース入れ
@BR_PLUS(ARG,ARG:1)

IF BR < ARG
	BR ++
	RETURN
ENDIF
PRINTL
SIF ARG:1
	PRINT 　　　　    　
BR = 1



;-------------------------------------------------
;STRからランダムに1つ取り出し
;元関数でSTR_MAXの指定が必要
;ARG→だいたいの場合STR_REF
@STR_REF_SHUFFLE(ARG)
#DIMS RANDOM_STR

STR_MAX = RAND:(STR_MAX +1)
RANDOM_STR = %STR:(ARG +STR_MAX)%
SIF RANDOM_STR == ""
	RESTART
RESULTS = %RANDOM_STR%
RETURN



;-------------------------------------------------
;STRからRANDOM_BOXにフラグ参照して詰めて抽選
;元関数でFLAG_REFとSTR_REFを指定
;ARG→1回目FORループの回数
@RANDOM_BOX_LOTTERY(ARG)

;それぞれの候補割合の数だけBOXに詰めていく
VARSET RANDOM_BOX
VARSET BOX_COUNT
FOR LOCAL,0,ARG
	FLAG_NUM = FLAG_REF +LOCAL
	SIF FLAGNAME:FLAG_NUM == ""
		BREAK
	FOR LOCAL:1,0,FLAG:FLAG_NUM
		RANDOM_BOX:BOX_COUNT = %STR:(STR_REF +LOCAL)%
		BOX_COUNT ++
	NEXT
NEXT

;ランダム抽選
RESULTS = %RANDOM_BOX:RAND(BOX_COUNT)%



;-------------------------------------------------
;入力STR候補を一覧で並べる
;STR_REF,STR_MAX指定済み
;ARGS→項目名
;ARG→INPUTBUTTONに送るARG
@CHANGE_STR_LINEUP(ARGS,ARG)

IF ARGS == @"%SAVESTR:表記／乳房%の弾力"
	PRINTFORML Select %SAVESTR:表記／乳房% Firmness.
ELSE
	PRINTFORML Select %CSTR_ENG(ARGS)%.
ENDIF
FOR LOCAL,0,STR_MAX
	SIF STR:(STR_REF +LOCAL) != ""
		PRINTFORMLC [{LOCAL,3}] %STR_LINEUP_ENG(STR:(STR_REF +LOCAL))%
NEXT
CALL INPUTBUTTON(ARG)

;先に一旦リセット
RESULTS =
BINPUT
SELECTCASE RESULT
CASE 900
CASE 901
	IF ARGS == @"%SAVESTR:表記／乳房%の弾力"
		PRINTFORML Enter %SAVESTR:表記／乳房% Firmness.
	ELSE
		PRINTFORML Enter %CSTR_ENG(ARGS)%.
	ENDIF
	INPUTS
CASE 999
	;キャンセル
	RETURN 1
CASEELSE
	RESULTS = %STR:(STR_REF +RESULT)%
ENDSELECT



;-------------------------------------------------
;右側がRETURNボタンになるように行表示
;ARG→ヒントボタン表示
;ARGS→RETURNボタン文面　空なら「完了」
@RIGHT_RETURN_BUTTON(ARG,ARGS)

IF ARG
	PRINTLC [ 98] Hint
ELSE
	CALL PRINTLC_WORD_COLOR("　→Back Button→","灰")
ENDIF
PRINTLC 　
IF ARGS == ""
	PRINTL [ 99] Done
ELSE
	PRINTFORML [ 99] %BACK_BUTTON_ENG(ARGS)%
ENDIF



;-------------------------------------------------
;DRAWLINE,ON/OFF反転,デフォルト/空欄/完了ボタンのセット
@ON_OFF_BUTTON_FOOTER

DRAWLINE
PRINTFORM [82] Skip the details of the ON/OFF items and invert them.
CALL PRINT_ONOFF(FLAG:ON／OFF項目の詳細を飛ばして反転,1)
CALL DEFAULT_VOID_RETURN_BUTTON



;-------------------------------------------------
;デフォルト／空欄／完了
;ARG→DRAWLINE
@DEFAULT_VOID_RETURN_BUTTON(ARG)

SIF ARG
	DRAWLINE
PRINTLC [98] Reset to Default
PRINTLC 　
PRINTL [99] Done



;-------------------------------------------------
;COMMAND_OKが有効な番号が選択されるまでループ、INPUT_NUMに入れて返す
;BINPUTで十分なので使わないかも
@INPUT_COMMAND_OK_NUM

INPUT
SIF !COMMAND_OK:RESULT
	RESTART
INPUT_NUM = RESULT



;-------------------------------------------------
;文字列に空欄以外が入力されるまでループ
;ARGS→入力する項目
;,@""でも来れる
@INPUTS_NOT_EMPTY(ARGS)

PRINTFORML Enter value for %ARGS%.
INPUTS
SIF RESULTS == ""
	RESTART



;-------------------------------------------------
;現在ページ・最大ページ・前後ボタン表示
;ARG→現在ページ数
;ARG:1→下にDRAWLINE
;ARG:2→目次表示
@PRINT_NOW_PAGE(ARG,ARG:1,ARG:2)

PRINTLC [ 80] Previous Page
IF ARG:2
	PRINTFORMLC [ 89] Index <PAGE{ARG,2}／{PAGE_MAX}>
ELSE
	PRINTFORMLC <PAGE{ARG,2}／{PAGE_MAX}>
ENDIF
PRINTL [ 81] Next Page
SIF ARG:1
	DRAWLINE






