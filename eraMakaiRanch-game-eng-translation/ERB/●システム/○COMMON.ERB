
;共通処理など
;一覧
;	@PRINT_TIME(ARG)				秒数を渡すとhh:mm:ss表記の文字列に変換
;	@ASK_YN							「はい」/「いいえ」の２択を表示
;	@ASK_YN_DEFAULT(ARG)			「はい」/「いいえ」の２択を表示+デフォルトをそれにするか聞く
;	@ASK_ONOFF						「ON」/「OFF」の２択を表示
;	@ASK_ONOFF_DEFAULT(ARG)			「ON」/「OFF」の２択を表示+デフォルトをそれにするか聞く
;	@ASK_BIT_ONOFF(ARG,ARG:1)		種族特徴のBITをON／OFFする
;	@GET_CSVCHARA					現在のCSV数を返す
;	@HEART1							塗りつぶしハートを表示する
;	@DOT_TIMER(ARG)					・で時間経過を表現する
;	@MANYL							たくさん改行する（FORとか使わず行数削減するだけ）
;	@COUNTINUE_SELECT				コンティニューするかしないか選ぶ
;	@RANGE							「（範囲外の数値ならキャンセル）」を出力(FUNCTIONS)
;	@INPUTBUTTON(ARG)				手動入力/キャンセル選択のボタンを出力
;	@PRINT_ONOFF(ARG,ARG:1)			設定中にフラグとか該当数値が○か×か色付きで返す
;	@PRINT_CHECKBOX(ARG,ARG:1)		チェックボックスで返す
;	@PRINTL_ALIGN(ARG)				[FLAG:自動改行合わせの行数]の行数から+-ARGになるように改行を挟む
;	@HALFLINE						ドット絵に被らない程度に線を引くだけ
;	@BR_PLUS(ARG)					BRの値を+1してARGになったら改行、BRを0にリセット
;	@STR_REF_SHUFFLE(ARG)			STRからランダムに1つ取り出し
;	@RANDOM_BOX_LOTTERY(ARG)		STRからRANDOM_BOXにフラグ参照して詰めて抽選
;	@CHANGE_STR_LINEUP(ARGS)		入力STR候補を一覧で並べる
;	@RIGHT_RETURN_BUTTON(ARG,ARGS)		右側がRETURNボタンになるように行表示
;	@ON_OFF_BUTTON_FOOTER			DRAWLINE,ON/OFF反転,デフォルト/空欄/完了ボタンのセット
;	@DEFAULT_VOID_RETURN_BUTTON		デフォルト／空欄／完了
;	@INPUT_COMMAND_OK_NUM			COMMAND_OKが有効な番号が選択されるまでループ、INPUT_NUMに入れて返す
;	@PRINT_NOW_PAGE(ARG,ARG:1,ARG:2)			現在ページ・最大ページ・前後ボタン表示



;-------------------------------------------------
;プレイ時間表示
;ARG	プレイ時間(秒数)
;戻り値	表示する時間。hh:mm:ss表記
@PRINT_TIME(ARG)
#FUNCTIONS
#DIM DISP_TIME,5
#DIMS DISP_TIMES,5

;時
DISP_TIME:0 = ARG /3600

;分
DISP_TIME:1 = (ARG %3600) /60

;秒
DISP_TIME:2 = ARG %60

FOR DISP_TIME:3,0,3
	IF DISP_TIME:(DISP_TIME:3) < 10
		DISP_TIMES:(DISP_TIME:3) = {0}{DISP_TIME:(DISP_TIME:3)}
	ELSE
		DISP_TIMES:(DISP_TIME:3) = {DISP_TIME:(DISP_TIME:3)}
	ENDIF
NEXT

RETURNF (DISP_TIMES:0 +":" +DISP_TIMES:1 +":" +DISP_TIMES:2)




;-------------------------------------------------
;「はい」/「いいえ」の２択を表示
@ASK_YN

PRINTLC [ 0] Yes
PRINTLC [ 1] No
PRINTL
INPUT
IF !RESULT
	RETURN 0
ELSE
	RETURN 1
ENDIF



;-------------------------------------------------
;「はい」/「いいえ」の２択を表示+デフォルトをそれにするか聞く
;ARG→1ならキャラごと
@ASK_YN_DEFAULT(ARG)
#DIM DYNAMIC SET

LINECOUNT_BEFORE = LINECOUNT
DEFAULT_SET = SET
PRINTLC [ 0] Yes
PRINTLC [ 1] No
IF ARG
    PRINT [ 9] Set this character as default
ELSE
    PRINT [ 9] Set as default
ENDIF
CALL PRINT_CHECKBOX(SET,1)
INPUT
SELECTCASE RESULT
CASE 0
	RETURN 0
CASE 1
	RETURN 1
CASEELSE
	INVERTBIT SET,0
	CLEARLINE LINECOUNT -LINECOUNT_BEFORE
	RESTART
ENDSELECT



;-------------------------------------------------
;「ON」/「OFF」の２択を表示
;上とはRETURNが別なので気をつけて（ON=1のが都合いいため）
@ASK_ONOFF

PRINTLC [ 0] ON
PRINTLC [ 1] OFF
PRINTL
INPUT
IF !RESULT
	RETURN 1
ELSE
	RETURN 0
ENDIF



;-------------------------------------------------
;「ON」/「OFF」の２択を表示+デフォルトをそれにするか聞く
;ARG→1ならキャラごと
@ASK_ONOFF_DEFAULT(ARG)
#DIM DYNAMIC SET

LINECOUNT_BEFORE = LINECOUNT
DEFAULT_SET = SET
PRINTLC [ 0] ON
PRINTLC [ 1] OFF
IF ARG
    PRINT [ 9] Set this character as default
ELSE
    PRINT [ 9] Set as default
ENDIF
CALL PRINT_CHECKBOX(SET,1)
INPUT
SELECTCASE RESULT
