;-------------------------------------------------
;種族特徴のBITをON／OFFする
;ARG→フラグ番号　ARG:1→BIT番号
@ASK_BIT_ONOFF(ARG,ARG:1)

;飛ばすフラグがONならINVERT
IF FLAG:ON／OFF項目の詳細を飛ばして反転
	INVERTBIT FLAG:(ARG),ARG:1
	RETURN
ENDIF
PRINTLC [ 0] ON
PRINTLC [ 1] OFF
PRINTL
INPUT
IF !RESULT
	SETBIT FLAG:ARG,ARG:1
ELSE
	CLEARBIT FLAG:ARG,ARG:1
ENDIF



;-------------------------------------------------
;CSVの数を返す
@GET_CSVCHARA

VARSET CSVCHARA
FOR LOCAL,0,300
	;CSVがあったら続けるなければそこで終了
	EXISTCSV LOCAL
	IF RESULT
		CSVCHARA:0 ++
		
		;プレイヤーがカスタムしたキャラか判定
		IF CSVCFLAG(LOCAL,802) == 1
			CSVCHARA:3 ++
		ELSE
			;専用口上ありのキャラか判定
			IF CSVCFLAG(LOCAL,801) == 1
				CSVCHARA:2 ++
			ELSE
				CSVCHARA:1 ++
			ENDIF
		ENDIF
		
	ELSE
		BREAK
	ENDIF
NEXT
;あなたも数えるので合計人数と口上なしは-1
CSVCHARA:0 --
CSVCHARA:1 --



