
;システムセーブ
@SAVE_GLOBAL_CONFIG

CALL EN_SAVE_STAIN_MOD_CONFIG

;全部セーブする
FOR LOCAL,2000,4000
	GLOBAL:LOCAL = FLAG:LOCAL
NEXT

;表示設定も保存
FOR LOCAL,0,50
	GLOBALS:LOCAL = %SAVESTR:LOCAL%
NEXT

;バージョンを入れる
GLOBAL:システムデータのバージョン = GAMEBASE_VERSION
SAVEGLOBAL



;システムからロード
;ARG→コンフィグのどのページをロードするか　0：全部
@LOAD_GLOBAL_CONFIG(ARG)

LOADGLOBAL
SELECTCASE ARG
CASE 0
	CALL EN_LOAD_STAIN_MOD_CONFIG
	FOR LOCAL,2000,4000
		FLAG:LOCAL = GLOBAL:LOCAL
	NEXT
	
	;表示設定を読み込む場合GLOBALSも読み込む
	FOR LOCAL,0,50
		SAVESTR:LOCAL = %GLOBALS:LOCAL%
	NEXT
CASE 1
    CALL EN_LOAD_STAIN_MOD_CONFIG
	FOR LOCAL,2000,2300
		FLAG:LOCAL = GLOBAL:LOCAL
	NEXT
	FOR LOCAL,0,50
		SAVESTR:LOCAL = %GLOBALS:LOCAL%
	NEXT
CASE 2
	FOR LOCAL,2300,2500
		FLAG:LOCAL = GLOBAL:LOCAL
	NEXT
CASE 3
	FOR LOCAL,2500,2600
		FLAG:LOCAL = GLOBAL:LOCAL
	NEXT
CASE 4
	FOR LOCAL,2600,3000
		FLAG:LOCAL = GLOBAL:LOCAL
	NEXT
CASE 5
	;奴隷候補設定可能かどうかで変更範囲が変わる
	IF FLAG:奴隷候補設定可能
		FOR LOCAL,3000,3500
			FLAG:LOCAL = GLOBAL:LOCAL
		NEXT
	ELSE
		FOR LOCAL,3000,3050
			FLAG:LOCAL = GLOBAL:LOCAL
		NEXT
	ENDIF
CASE 6
	FOR LOCAL,3500,4000
		FLAG:LOCAL = GLOBAL:LOCAL
	NEXT
ENDSELECT



;デフォルト設定でシステムセーブを作成
@CREATE_GLOBAL_CONFIG

VARSET GLOBAL
VARSET GLOBALS

;デフォルト設定のFLAGを入れる
CALL SET_DEFAULT_CONFIG

;FLAGの設定をGLOBALにセーブ
CALL SAVE_GLOBAL_CONFIG

;FLAGをリセット　ここ来るのがゲーム開始前だけのはずなので大丈夫
;SAVESTRもリセット
VARSET FLAG
VARSET SAVESTR
PRINTW デフォルト設定でシステムセーブを作成しました。




