
;USERCOMから飛ばす用
@SHOW_STATUS_DETAIL_TRAIN

PRINTFORML [ 0] %CALLNAME%'s Status
PRINTL [ 1] Stain Display・Removal
PRINTL [ 2] Personalization
PRINTFORML [ 3] %CALLNAME:0%'s Status
PRINTL [ 4] Global Config
PRINTL

;ちょい追加
SIF FLAG:開発者モード
	PRINTL [90] Reset Training Limit Counter（Developer Mode Only）
PRINTL [99] Cancel
INPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL SHOW_STATUS_DETAIL_PLUS("調教中")
CASE 1
	CALL SHOW_STAIN
CASE 2
	CALL SLAVE_CONFIG
CASE 3
	SAVE_TARGET = TARGET
	TARGET = 0
	CALL SHOW_STATUS_DETAIL_PLUS("調教中")
	TARGET = SAVE_TARGET
CASE 4
	CALL GAME_CONFIG
	CLEARLINE LINECOUNT
CASE 90
	SIF !FLAG:開発者モード
		RETURN
	TFLAG:残り時間 = 100
	TFLAG:時間圧縮有効ターン数 = 0
	CFLAG:当日制限／肉体改造薬 = 0
	CFLAG:当日制限／肉体改造エキス = 0
ENDSELECT



;汚れ表示
@SHOW_STAIN
#DIM LIQUID

CALL MANYL(5)
PRINTFORML Stains on %CALLNAME%
FOR LOCAL,0,12
	;♂はＣＶなし、♀はＰなし
	SIF STAINNAME:LOCAL == "ペニス"
		CONTINUE
	PRINTFORM %BODYPARTS_ENG(LOCAL), 7, LEFT%：
	IF !STAIN:LOCAL
		CALL PRINTL_WORD_COLOR("Clean","灰")
		CONTINUE
	ENDIF
	FOR LIQUID,0,8
		SIF GETBIT(STAIN:LOCAL,LIQUID)
			PRINTFORM %STAINS_ENG(LIQUID + 6000)%　
	NEXT
	PRINTL
NEXT
CALL MANYL(3)
PRINTFORML Stains on %CALLNAME:0%
FOR LOCAL,0,12
	;口と手とちんぽ以外不要では？
	SIF !GROUPMATCH(STAINNAME:LOCAL,"ペニス","口","手")
		CONTINUE
	IF TEQUIP:0:コンドーム && STAINNAME:LOCAL == "ペニス"
		PRINT ゴムＰ：
	ELSE
		PRINTFORM %STAINNAME:LOCAL,6%：
	ENDIF
	IF !STAIN:0:LOCAL
		CALL PRINTL_WORD_COLOR("Clean","灰")
		CONTINUE
	ENDIF
	FOR LIQUID,0,8
		SIF GETBIT(STAIN:0:LOCAL,LIQUID)
			PRINTFORM %STAINS_ENG(LIQUID + 6000)%　
	NEXT
	PRINTL
NEXT
PRINTL
IF STAIN:0:手
	PRINTFORML [ 0] Clean %CALLNAME:0%'s Hands
ELSE
	CALL PRINTLC_WORD_COLOR("　Your hands don't require cleaning","灰")
ENDIF
PRINTL [ 9] Done
INPUT
PRINTL
SIF RESULT == 0
	CALL HAND_WASH




;TARGETに汚れ付与
;ARGS→部位
;ARGS:1→汚れ
@SET_STAIN_TARGET(ARGS,ARGS:1)
#DIM LIQUID

;STRから汚れ名を引っ張ってくる
FOR LOCAL,6000,6010
	SIF STR:LOCAL != ARGS:1
		CONTINUE
	LIQUID = LOCAL -6000
	BREAK
NEXT

;汚れがなければ付与メッセージの準備+SETBIT
IF !GETBIT(STAIN:ARGS,LIQUID)
	RESULT = GETNUM(STAIN,ARGS)
	SETBIT STAIN:RESULT,LIQUID
	SETBIT STAIN:(RESULT +50),LIQUID
ENDIF



;PLAYERに汚れ付与
;ARGS→部位
;ARGS:1→汚れ
@SET_STAIN_PLAYER(ARGS,ARGS:1)
#DIM LIQUID

FOR LOCAL,6000,6010
	SIF STR:LOCAL != ARGS:1
		CONTINUE
	LIQUID = LOCAL -6000
	BREAK
NEXT

IF !GETBIT(STAIN:0:ARGS,LIQUID)
	RESULT = GETNUM(STAIN,ARGS)
	SETBIT STAIN:0:RESULT,LIQUID
	SETBIT STAIN:0:(RESULT +50),LIQUID
ENDIF



;汚れ交換
;ARGS→TARGETの部位
;ARGS:1→PLAYERの部位
@SWAP_STAIN(ARGS,ARGS:1)

FOR LOCAL,0,10
	;奴隷→あなた
	SIF !GETBIT(STAIN:ARGS,LOCAL)
		CONTINUE
	SIF !GETBIT(STAIN:0:(ARGS:1),LOCAL)
		CALL SET_STAIN_PLAYER((ARGS:1),STR:(LOCAL +6000))
NEXT
FOR LOCAL,0,10
	;あなた→奴隷
	SIF !GETBIT(STAIN:0:(ARGS:1),LOCAL)
		CONTINUE
	SIF !GETBIT(STAIN:ARGS,LOCAL)
		CALL SET_STAIN_TARGET(ARGS,STR:(LOCAL +6000))
NEXT


