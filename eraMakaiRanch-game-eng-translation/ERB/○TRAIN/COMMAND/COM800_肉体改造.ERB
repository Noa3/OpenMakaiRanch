	CALL PRINTL_WORD_COLOR,@"Already using Mana Incitement Drug","桃"
ELSEIF !ITEM:多臓器活性薬
	CALL PRINTL_WORD_COLOR,@"No Mana Incitement Drugs owned","灰"
ELSEIF TFLAG:搾乳器
	CALL PRINTL_WORD_COLOR,@"Can't sell %SAVESTR:表記／母乳% obtained while using this drug","黄"
ELSE
	PRINTFORML [ 5] Mana Incitement Drug　Owned：{ITEM:多臓器活性薬}
ENDIF



;浸透媚薬
@COM800_DOSAGE_SENSITIVE

{
IF ABL:Ｎ感度 >= SENSITIVE_MAX && ABL:Ｂ感度 >= SENSITIVE_MAX && ABL:Ｃ感度 >= SENSITIVE_MAX 
&& ABL:Ｖ感度 >= SENSITIVE_MAX && ABL:Ａ感度 >= SENSITIVE_MAX
}
	CALL PRINTL_WORD_COLOR,@"Sensitivity cannot be further increased","桃"
ELSEIF !ITEM:受容器鋭敏化薬
	CALL PRINTL_WORD_COLOR,@"No Nerve Remodeling Drugs owned","灰"
ELSE
	PRINTFORML [ 9] Nerve Remodeling Drug　Owned：{ITEM:受容器鋭敏化薬}　Current：Ｎ{ABL:Ｎ感度}\% Ｂ{ABL:Ｂ感度}\% Ｃ{ABL:Ｃ感度}\% Ｖ{ABL:Ｖ感度}\% Ａ{ABL:Ａ感度}\%
ENDIF

IF !ITEM:浸透媚薬
	CALL PRINTL_WORD_COLOR,@"There is no permeating aphrodisiac","灰"
	RETURN
ENDIF
PRINTFORML 　　　《 Permeating Aphrodisiac 》　Owned：{ITEM:浸透媚薬}
CALL DOSAGE_SENSITIVE_UP_COMMON(10,"Ｎ")
CALL DOSAGE_SENSITIVE_UP_COMMON(11,"Ｂ")
CALL DOSAGE_SENSITIVE_UP_COMMON(12,"Ｃ")
CALL DOSAGE_SENSITIVE_UP_COMMON(13,"Ｖ")
CALL DOSAGE_SENSITIVE_UP_COMMON(14,"Ａ")



;浸透媚薬・エキス共通
;ARG→OKのとき出すコマンド番号
;ARGS→部位
@DOSAGE_SENSITIVE_UP_COMMON(ARG,ARGS)
#DIMS JUDGE_PALAM,3

JUDGE_PALAM:0 = %ARGS%露出
JUDGE_PALAM:1 = %ARGS%感度
JUDGE_PALAM:2 = %ARGS%装備

;Ｖは処女結界判定する
IF ARGS == "Ｖ" && TALENT:処女結界
	CALL PRINTL_WORD_COLOR,@"Access blocked by【Virginity Barrier】","黄"

;露出じゃないとダメ
ELSEIF !TFLAG:(JUDGE_PALAM:0) && !TFLAG:スケジュール外Ｈ
	CALL PRINTL_WORD_COLOR,@"Not exposed","灰"

;感度MAXはダメ
ELSEIF ABL:(JUDGE_PALAM:1) >= SENSITIVE_MAX
	CALL PRINTL_WORD_COLOR,@"%ARGS% Sensitivity cannot be further increased","桃"

;装備あるとダメ
ELSEIF TFLAG:(JUDGE_PALAM:2)
	CALL PRINTL_WORD_COLOR,@"%ARGS% equipment must be removed","黄"

;OKならボタン
ELSE
	PRINTFORML [{ARG,2}] Enhance %ABL_ENG(JUDGE_PALAM:1)%　Current：{ABL:(JUDGE_PALAM:1)}\%
ENDIF



