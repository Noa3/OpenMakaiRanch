;関数分け→薬品投与
@COM800_DOSAGE

PRINTL 　　　《 Administer Drugs 》
IF !(CFLAG:無抵抗 || TFLAG:拘束BIT || !BASE:体力) && !TFLAG:スケジュール外Ｈ
	CALL PRINTL_WORD_COLOR,@"Resistant slaves must be either restrained or at 0 HP to administer drugs.","黄"
	RETURN
ENDIF

;母乳関連
CALL COM800_DOSAGE_MILK

;膨乳薬
CALL COM800_DOSAGE_BUSTUP
PRINTL

;多臓器活性薬
SIF !TFLAG:スケジュール外Ｈ
	CALL COM800_DOSAGE_ORGANS

;感度増加
CALL COM800_DOSAGE_SENSITIVE
PRINTL



;触手エキス
;ARG→肉体改造可能回数
@COM800_DOSAGE_TENTACLE(ARG)

;薬剤と同じ条件で触手も判定→NGの場合こっちはメッセージ出さずに帰る
SIF !(CFLAG:無抵抗 || TFLAG:拘束BIT || !BASE:体力) && !TFLAG:スケジュール外Ｈ
	RETURN
PRINTFORML 　　　《Tentacle Body Modification》 {ARG} more times. %CALLNAME:0%'s magic power: %VALUE_DIGIT(BASE:0:魔力)% MP.

;母乳関連
CALL COM800_DOSAGE_TENTACLE_MILK

;膨乳薬
CALL COM800_DOSAGE_TENTACLE_BUSTUP
PRINTL

;感度増加
CALL COM800_DOSAGE_TENTACLE_SENSITIVE
PRINTL



;母乳関連
@COM800_DOSAGE_MILK

IF !TFLAG:Ｎ露出 && !TFLAG:スケジュール外Ｈ
	CALL PRINTL_WORD_COLOR,@"Milk-related drugs can only be administered if the slave's nipples are exposed","黄"
	RETURN
ENDIF

IF MARK:母乳体質
	CALL PRINTL_WORD_COLOR,@"Already【Lactating】","桃"
	PRINTL
ELSE
	;Ｎ注射共通部分
	CALL DOSAGE_ITEM_NIPPLE_COMMON(0,"母乳体質化薬")
	IF !TFLAG:調教中
		CALL PRINTL_WORD_COLOR,@"Can only be used during training.","灰"
	ELSEIF GETBIT(＃有効薬品／魔力母乳分泌促進薬＃)
		CALL PRINTL_WORD_COLOR,@"Currently using ＜Mana-Infused Breast Milk Stimulant＞","黄"
	ELSEIF GETBIT(＃有効薬品／母乳分泌促進薬＃)
		CALL PRINTL_WORD_COLOR,@"Currently using ＜Breast Milk Stimulant＞","黄"
	ELSE
		CALL DOSAGE_ITEM_NIPPLE_COMMON(50,"母乳分泌促進薬")
	ENDIF
ENDIF

IF MARK:魔力母乳体質
	CALL PRINTL_WORD_COLOR,@"Milk is already【Mana-Infused】","桃"
	PRINTL
ELSEIF !MAXBASE:魔力
	CALL PRINTL_WORD_COLOR,@"Target has no Mana","灰"
	PRINTL
ELSE
	CALL DOSAGE_ITEM_NIPPLE_COMMON(1,"魔力母乳体質化薬")
	IF !TFLAG:調教中
		CALL PRINTL_WORD_COLOR,@"Can only be used during training.","灰"
	ELSEIF GETBIT(＃有効薬品／魔力母乳分泌促進薬＃)
		CALL PRINTL_WORD_COLOR,@"Currently using ＜Mana-Infused Breast Milk Stimulant＞","黄"
	ELSE
		CALL DOSAGE_ITEM_NIPPLE_COMMON(51,"魔力母乳分泌促進薬")
	ENDIF
ENDIF

IF ABL:母乳濃度 >= 5
	CALL PRINTL_WORD_COLOR,@"Milk already of highest quality","桃"
ELSEIF !MARK:母乳体質
	CALL PRINTL_WORD_COLOR,@"Target must be【Lactating】","灰"
ELSE
	CALL DOSAGE_ITEM_NIPPLE_COMMON(2,"母乳濃厚化薬")
ENDIF



;Ｎ注射共通
;ARG→OK時の番号
;ARGS→アイテム名
@DOSAGE_ITEM_NIPPLE_COMMON(ARG,ARGS)

IF !ITEM:ARGS
	CALL PRINTL_WORD_COLOR,@"No %ITEMS_ENG(ARGS)% owned","灰"
ELSEIF TFLAG:Ｎ装備
	CALL PRINTL_WORD_COLOR,@"Ｎ Equipment must be removed","黄"
ELSE
	PRINTFORM [{ARG,2}] %ITEMS_ENG(ARGS)%　Owned：{ITEM:ARGS}
	SIF ARGS == "母乳濃厚化薬"
		PRINTFORM 　Current Quality：%PRINT_MILKWORD(2)%
	PRINTL
ENDIF



;膨乳薬
@COM800_DOSAGE_BUSTUP

IF ABL:バストサイズ >= BUSTSIZE_神乳
	CALL PRINTL_WORD_COLOR,@"Breast size cannot be increased further by this drug","灰"
ELSEIF !ITEM:膨乳薬
	CALL PRINTL_WORD_COLOR,@"No Breast Expansion Drugs owned","灰"
ELSE
	PRINTFORML [ 3] Breast Expansion Drug　Owned：{ITEM:膨乳薬}　Current Size：%PRINT_BUSTSIZE(ABL:バストサイズ)%
ENDIF

IF ABL:バストサイズ >= BUSTSIZE_MAX
	CALL PRINTL_WORD_COLOR,@"Breast size cannot be increased further by this drug","桃"
ELSEIF !ITEM:超乳薬
	CALL PRINTL_WORD_COLOR,@"No Mega Milk Drugs owned","灰"
ELSE
	PRINTFORML [ 4] Mega Milk Drug　Owned：{ITEM:超乳薬}　Current Size：%PRINT_BUSTSIZE(ABL:バストサイズ)%
ENDIF



;多臓器活性薬
@COM800_DOSAGE_ORGANS
