@COM105
;触手Ｖ挿入

IF TEQUIP:SELECTCOM
	TRYCALLFORM COM{SELECTCOM}_REMOVE
	TRYCALLFORM COM{SELECTCOM}_REMOVE_MESSAGE
	TFLAG:膣内精液 = 0
	RETURN 1
ENDIF
CALL V_INSERT_CONFIRM(1)
SIF RESULT
	RETURN
LOSEBASE:気力 += 10
SOURCE:異形恐怖 += 500
SOURCE:経過時間 = 1
TEQUIP:触手Ｖ挿入 = 1
SIF !FLAG:あなたの触手もあなた扱い
	V_PENIS = 触手

;増量あれば潤滑増加
SIF ITEM:触手分泌液増量 && GETBIT(＃有効／触手分泌液増量＃)
	SOURCE:Ｖ潤滑追加 += 10000
RETURN 1



