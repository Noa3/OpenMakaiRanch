
@COM100
;触手乳揉み

;取り外し共通呼び出し処理
IF TEQUIP:SELECTCOM
	TRYCALLFORM COM{SELECTCOM}_REMOVE
	TRYCALLFORM COM{SELECTCOM}_REMOVE_MESSAGE
	RETURN 1
ENDIF

;継続SOURCEが入るので少なめ
LOSEBASE:気力 += 10
SOURCE:異形恐怖 += 500
SOURCE:経過時間 = 1
CALL BUST_TENTACLE_RESET
TEQUIP:触手乳揉み = 1
RETURN 1



