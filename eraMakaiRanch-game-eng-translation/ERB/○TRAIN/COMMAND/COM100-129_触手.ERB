@COM110
;ブラシ触手
;装備として処理されずに別の装備をつけたらひっこむ

;ブラシ触手は番号違う
IF TEQUIP:ブラシ触手
	VARSET TEQUIP,0,150,160
	TRYCALLFORM COM{SELECTCOM}_REMOVE_MESSAGE
	RETURN 1
ENDIF
LOSEBASE:気力 += 10
SOURCE:異形恐怖 += 500
SOURCE:経過時間 = 1
CALL OPEN_NIPPLE_SLIT

;部位ごとに判断
SIF !TFLAG:Ｎ装備 && TFLAG:Ｎ露出
	TEQUIP:ブラシ触手Ｎ = 1
SIF !TFLAG:Ａ装備 && TFLAG:Ａ露出
	TEQUIP:ブラシ触手Ａ = 1
SIF !TFLAG:Ｂ装備 && TFLAG:Ｂ露出
	TEQUIP:ブラシ触手Ｂ = 1
SIF !TFLAG:Ｃ装備 && TFLAG:Ｃ露出
	TEQUIP:ブラシ触手Ｃ = 1

;Ｖのみ処女結界も判定
SIF !TALENT:処女結界 && !TFLAG:Ｖ装備 && TFLAG:Ｖ露出
	TEQUIP:ブラシ触手Ｖ = 1
TEQUIP:ブラシ触手 = 1

;コマンドを選んだフラグがないと解除しちゃう
SOURCE:ブラシ触手コマンド = 1
RETURN 1



@COM112
;触手目隠し
;経過時間なし

IF TEQUIP:SELECTCOM
	TRYCALLFORM COM{SELECTCOM}_REMOVE
	TRYCALLFORM COM{SELECTCOM}_REMOVE_MESSAGE
	RETURN 1
ENDIF
TEQUIP:触手目隠し = 1

;経過時間ない場合汎用装備フラグも必要
TFLAG:目隠し = 1
TRYCALLFORM COM{SELECTCOM}_MESSAGE
EXP:(SELECTCOM +1000) ++
RETURN 1



