
;搾乳器装着　ARGS:装着する搾乳器
@MOUNTING_LACTATION_MACHINE(ARGS)

CALL OPEN_NIPPLE_SLIT
TEQUIP:ARGS = 1
EXP:(SELECTCOM +1000) ++

;ここはSELECTCOM変更するので先にメッセージ出す
CALL MOUNTING_LACTATION_MACHINE_MESSAGE(ARGS)

;巨乳で乳搾り、そうでないなら乳揉みに自動派生
IF ABL:バストサイズ < BUSTSIZE_巨乳
	CALL COM10
	SELECTCOM = 10
ELSE
	CALL COM11
	SELECTCOM = 11
ENDIF



@COM60
;家畜用搾乳器

CALL MOUNTING_LACTATION_MACHINE("家畜用搾乳器")
RETURN 1



@COM61
;魔動快楽搾乳器

