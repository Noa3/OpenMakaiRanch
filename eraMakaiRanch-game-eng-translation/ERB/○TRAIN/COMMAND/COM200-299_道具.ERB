@COM290
;Ｖローション

SELECTCOM = 290
ITEM:ローション --
CALL COM290_MESSAGE
EXP:(SELECTCOM +1000) ++
TFLAG:Ｖローション = 1
PALAM:Ｖ潤滑 += 15000
CALL SET_STAIN_TARGET("膣","ローション")
PRINTFORML Ｖ Lubrication+15000 

;潤滑上限は99999
PALAM:Ｖ潤滑 = LIMIT(PALAM:Ｖ潤滑,0,99999)
CALL TRAIN_STAIN_SETTING



