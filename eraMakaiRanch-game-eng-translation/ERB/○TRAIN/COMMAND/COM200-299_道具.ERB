
@COM201
;バイブ
;継続SOURCEが入るので少なく

IF TEQUIP:SELECTCOM
	TRYCALLFORM COM{SELECTCOM}_REMOVE
	TRYCALLFORM COM{SELECTCOM}_REMOVE_MESSAGE
	RETURN 1
ENDIF
CALL V_INSERT_CONFIRM(1)
SIF RESULT
	RETURN
LOSEBASE:気力 += 10
SOURCE:屈辱 += 500
SOURCE:経過時間 = 1
TFLAG:Ｖ装備 = 1
TEQUIP:バイブ = 1
V_PENIS = バイブ
RETURN 1



