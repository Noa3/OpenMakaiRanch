@COM547
;淫乳改造エキス
#DIM RATE
#DIM BUSTUP_COUNT
#DIM BUSTUP_DONE

;超乳寸前の場合確認
CALL BUSTUP_HUGE_BUST_COMFIRM
SIF RESULT
	RETURN
SELECTCOM = 547

;膨乳したフラグ一旦OFF
BUSTUP_DONE = 0
SOURCE:Ｂ快楽／触手 = 2000
SOURCE:Ｂ痛み = 2000
SOURCE:経過時間 = 1
SOURCE:選択コマンド口上非表示 = 1
BASE:0:魔力 -= MAGIC_USE_MP:GETNUM(ITEM,"淫乳改造エキス")
CFLAG:当日制限／肉体改造エキス ++
EXP:肉体改造 ++
CALL BUST_TENTACLE_RESET
TRYCALLFORM COM{SELECTCOM}_MESSAGE
CALL COM547_BUSTUP_RATE
RATE = RESULT

;1回は確定で発生なので-10してやればいい　かと思ったけどFORするので+でいい
BUSTUP_COUNT = (RATE +10) /20

;ZZなら大きくならない
IF ABL:バストサイズ < BUSTSIZE_MAX
	PRINTFORML ...Due to the effect of the extract, %CALLNAME%'s %SLANG_B()% is gradually getting bigger!
	CALL BUSTUP
	
	;膨乳したフラグON
	BUSTUP_DONE = 1
ENDIF

;膨乳回数になるまで繰り返し
FOR LOCAL,0,BUSTUP_COUNT
	;追加増加制限と一致する場合ストップ
	SIF ABL:バストサイズ == FLAG:膨乳一時停止バストサイズ
		BREAK
	
	;超乳直前か超乳だとストップ
	SIF ABL:バストサイズ >= BUSTSIZE_超乳 -1
		BREAK
	PRINTFORML Due to the effect of the extract, %CALLNAME%'s %SLANG_B()% will become even bigger...!
	CALL BUSTUP
	
	;膨乳のたび体力・気力減少
	LOSEBASE:体力 += 100
	LOSEBASE:気力 += 150
NEXT

;Ｂ感度を増加　300未満の場合のみ、それ以上は感度上昇使ってね
CALL COM547_BUST_SENSITIVE_UP(BUSTUP_DONE)
RETURN 1



;淫乳改造エキス：追加でＢ感度増加
;ARG→BUSTUP_DONE
@COM547_BUST_SENSITIVE_UP(ARG)
#DIM SENSITIVE_PLUS

SIF ABL:Ｂ感度 >= 300
	RETURN

;100ごとに増加幅変化
IF ABL:Ｂ感度 < 100
	SENSITIVE_PLUS = 30
ELSEIF ABL:Ｂ感度 < 200
	SENSITIVE_PLUS = 20
ELSE
	SENSITIVE_PLUS = 10
ENDIF
ABL:Ｂ感度 += SENSITIVE_PLUS
CALL COM547_BUST_SENSITIVE_UP_MESSAGE(ARG,SENSITIVE_PLUS)



;淫乳改造エキス：最大魔力量により増加幅決定　そもそも10万以上あるはず
@COM547_BUSTUP_RATE
#DIM RATE

;感度が低いほど効果が高い
FIX = 100 -(ABL:Ｂ感度 /10) -(ABL:Ｂ感度 %10)
FIX = LIMIT(FIX,0,50)

;20万ごとに感度+10%、増加幅+10 /20=バストサイズ増加幅
RATE = MAXBASE:0:魔力 /10000
RATE -= (RATE %10)
RATE = LIMIT(RATE,10,FIX)
RETURN RATE



