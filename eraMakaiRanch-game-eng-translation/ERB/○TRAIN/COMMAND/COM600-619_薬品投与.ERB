@COM605
;超乳薬
#DIM USING_HP

;超乳寸前の場合確認
CALL BUSTUP_HUGE_BUST_COMFIRM
SIF RESULT
	RETURN
SELECTCOM = 605
SOURCE:非性感帯痛み = 1000

;膨乳段階により計算前に恥辱、屈辱、支配追加
SOURCE:経過時間 = 1
SOURCE:選択コマンド口上非表示 = 1
EXP:肉体改造 ++
ITEM:超乳薬 --
CFLAG:当日制限／肉体改造薬 = 1
CALL BUST_TENTACLE_RESET
TRYCALLFORM COM{SELECTCOM}_MESSAGE
CALL BUSTUP
USING_HP = 100

;体力尽きるまで繰り返し
WHILE BASE:体力 > LOSEBASE:体力
	;追加増加制限と一致する場合ストップ
	SIF ABL:バストサイズ == FLAG:膨乳一時停止バストサイズ
		BREAK

	;超乳直前か超乳だとストップ
	SIF ABL:バストサイズ >= BUSTSIZE_超乳 -1
		BREAK
	PRINTFORML Due to the effect of the drug, %CALLNAME%'s %SLANG_B()% will become even bigger...!
	CALL BUSTUP
	
	;膨乳のたび体力・気力減少
	LOSEBASE:体力 += USING_HP
	LOSEBASE:気力 += 150
	USING_HP *= 15
	USING_HP /= 10
WEND
PRINTW
RETURN 1



@COM606
;受容器鋭敏化薬
#DIM SENSITIVE_BEFORES,5

;LOCAL→部位
FOR LOCAL,0,5
	;ABL:Ａ感度→10
	SENSITIVE_BEFORES:LOCAL = ABL:(LOCAL +10)

	IF ABL:(LOCAL +10) < 500
		FIX = 30
	ELSE
		FIX = 20
	ENDIF

	;Ｎ、Ｃに使う場合は増加幅倍増
	SIF LOCAL == 2 || LOCAL == 4
		FIX *= 2

	;990越えないように
	ABL:(LOCAL +10) += LIMIT(FIX,0,SENSITIVE_MAX -ABL:(LOCAL +10))
NEXT
SELECTCOM = 605
LOSEBASE:体力 += 1000
LOSEBASE:気力 += 2000
SOURCE:恥辱 = 50000
SOURCE:屈辱 = 34000
SOURCE:支配 = 30000
SOURCE:非性感帯痛み = 1000
SOURCE:経過時間 = 1
SOURCE:選択コマンド口上非表示 = 1
ITEM:受容器鋭敏化薬 --
EXP:肉体改造 ++
CFLAG:当日制限／肉体改造薬 = 1
TRYCALLFORM COM{SELECTCOM}_MESSAGE

;とりあえずここ
SETCOLOR 0xFF70FF
SIF ABL:Ａ感度 - SENSITIVE_BEFORES:0 > 0
	PRINTFORML 【Ａ感度+{ABL:Ａ感度 - SENSITIVE_BEFORES:0}→{ABL:Ａ感度}\%】
SIF ABL:Ｂ感度 - SENSITIVE_BEFORES:1 > 0
	PRINTFORML 【Ｂ感度+{ABL:Ｂ感度 - SENSITIVE_BEFORES:1}→{ABL:Ｂ感度}\%】
SIF ABL:Ｃ感度 - SENSITIVE_BEFORES:2 > 0
	PRINTFORML 【Ｃ感度+{ABL:Ｃ感度 - SENSITIVE_BEFORES:2}→{ABL:Ｃ感度}\%】
SIF ABL:Ｖ感度 - SENSITIVE_BEFORES:3 > 0
	PRINTFORML 【Ｖ感度+{ABL:Ｖ感度 - SENSITIVE_BEFORES:3}→{ABL:Ｖ感度}\%】
SIF ABL:Ｎ感度 - SENSITIVE_BEFORES:4 > 0
	PRINTFORML 【Ｎ感度+{ABL:Ｎ感度 - SENSITIVE_BEFORES:4}→{ABL:Ｎ感度}\%】
CALL NIPPLE_SENSITIVE_FIX
RESETCOLOR
PRINTW
RETURN 1



