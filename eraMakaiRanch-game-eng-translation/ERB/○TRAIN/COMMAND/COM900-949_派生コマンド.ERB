;霊力注入
@COM905
#DIM GIVE_EP
#DIM WANT_EP

;霊力の1%　1000～10000まで　大量は10万
GIVE_EP = BASE:0:霊力 /100
GIVE_EP -= (GIVE_EP %10)
GIVE_EP = LIMIT(GIVE_EP,1000,10000)
PRINTFORML Pour Spirit Energy infused semen into %CALLNAME%.
PRINTL ・Every 100EP will increase slave's HP by 10
PRINTL ・If her Spirit Energy is low, it will restore the amount given.
PRINTL
SIF BASE:0:体力 <= 1500
	SETCOLOR 0xFFFF70
PRINTFORM 　%CALLNAME:0%　HP：{BASE:0:体力,4} 
RESETCOLOR
CALL PRINT_COLORBAR(BASE:0:体力,MAXBASE:0:体力,8,BARCOLORSET("青緑"),RESULT:1)
PRINTFORM 　%CALLNAME:0%s Spirit Energy：%VALUE_DIGIT(BASE:0:霊力)%／%VALUE_DIGIT(MAXBASE:0:霊力)%EP 
CALL PRINT_COLORBAR(BASE:0:霊力,MAXBASE:0:霊力,8,BARCOLORSET(""),RESULT:1)
PRINTL
IF !EXP:霊力ゼロ
	CALL PRINTL_WORD_COLOR("　Spirit Energy was never extracted, cannot infuse","灰")
ELSEIF !＃陥落状態／隷属＃
	CALL PRINTL_WORD_COLOR("　Only【Love Slave】can accumulate Spirit Energy this way","灰")
ELSE
	IF BASE:霊力 >= MAXBASE:霊力
		PRINTFORML ・Spirit Energy Capacity increases by 1／4 of infused（Upper limit equal to %CALLNAME:0%'s）
		PRINTL （Not including cases where spirit energy is reduced during extraction）
		PRINTL
	ENDIF
	IF MAXBASE:体力 >= HP_MAX
		CALL PRINTL_WORD_COLOR,@"※%CALLNAME%'s maximum HP cannot be increased any further","灰"
	ELSE
		WANT_EP = MAXBASE:体力 *50 -CFLAG:霊力蓄積量
		PRINTFORML ・Infuse %VALUE_DIGIT(WANT_EP)%EP to increase %CALLNAME%'s maximum HP
	ENDIF
ENDIF
PRINTL
PRINTFORML [ 0] Inject A Moderate Amount（（%VALUE_DIGIT(GIVE_EP)%EP）
PRINTFORML [ 1] Inject A Copious Amount（%VALUE_DIGIT(GIVE_EP *10)%EP）
PRINTL [99] Cancel
INPUT
IF RESULT == 0
	SOURCE:注ぎ込み霊力量 = GIVE_EP
ELSEIF RESULT == 1
	GIVE_EP *= 10
	SOURCE:大量注ぎ込み = 1
	SOURCE:注ぎ込み霊力量 = GIVE_EP
ELSE
	RETURN
ENDIF
CALL PISTON_SOURCE
RETURN 1



