
;ぞろぞろ並べる
;なんも書かないとRETURN0で不可能やねんな
;--------------------------------------------------,
;乳揉み
@COM_ABLE10
SIF SKIP_COM_ABLE
	RETURN 0

;共通判定にまとめた
SIF !GETBIT(＃コマンド有効／乳揉み＃)
	RETURN 0
RETURN 1



;乳搾り
@COM_ABLE11
SIF SKIP_COM_ABLE
	RETURN 0

SIF !GETBIT(＃コマンド有効／乳揉み＃)
	RETURN 0

;巨乳以上ないと搾れない
SIF ABL:バストサイズ < BUSTSIZE_巨乳
	RETURN 0

;乳首露出の時だけ
SIF TFLAG:Ｎ露出
	RETURN 1



;乳首つまみ
@COM_ABLE12
SIF SKIP_COM_ABLE
	RETURN 0

SIF !GETBIT(＃コマンド有効／乳首責め＃)
	RETURN 0

;乳首になにかついてると乳首責め不可
SIF TFLAG:Ｎ装備
	RETURN 0
SIF TFLAG:Ｎ露出
	RETURN 1

;横乳露出かＢ露出かつ、Ｎ露出できる場合でも横から手を入れて乳首責めできるようにする
{
SIF (TFLAG:横乳露出 || TFLAG:Ｂ露出) && (!EQUIP:装備中ID／下着上 || GETBIT(＃半脱ぎ／下着上＃) ||
TFLAG:一時的脱衣／下着上 || ＃着用下着上／名称＃ == "乳首露出ブラ" || ＃着用下着上／名称＃ == "授乳スリットブラ")
}
	RETURN 1

;授乳スリット状態でもできる分岐
;ブラ判定まで来ないとフラグが立たないので服の上ということはないはず
;次服の上から可能なようにしようかな？
SIF TFLAG:授乳スリット
	RETURN 1



