@COM581
#DIM FIXATION_RATE
;絶頂体力回復淫紋

;基本5%、好感度の1/3を上乗せした確率で定着
FIXATION_RATE = 500 +BASE:好感度 /3
FIXATION_RATE = LIMIT(FIXATION_RATE,500,10000)
PRINTFORML The success chance to engrave【Health Recovering Climax Crest】is: {FIXATION_RATE /100}.{FIXATION_RATE %100}\%
CALL PRINTL_WORD_COLOR("The success chance increases by 1/3 of【Favorability】","黄")
IF FIXATION_RATE < 10000
	PRINTFORML Regardless of success or failure, time will pass and %VALUE_DIGIT(MAGIC_USE_MP:GETNUM(ITEM,"絶頂体力回復淫紋"))% MP will be consumed.
	PRINTL （There are no other failure penalties.）
ENDIF
PRINTL Would you like to apply ＜Health Recovering Climax Crest＞?
CALL ASK_YN
SIF RESULT
	RETURN
SELECTCOM = 581
LOSEBASE:体力 += 500
LOSEBASE:気力 += 500

;あなたで触れてないので器具扱い
SOURCE:Ｂ快楽／器具 = 30000
SOURCE:Ｎ快楽／器具 = 30000
SOURCE:恥辱 = 10000
SOURCE:情愛 = 10000
SOURCE:屈辱 = 10000
SOURCE:支配 = 30000
SOURCE:経過時間 = 1
SOURCE:選択コマンド口上非表示 = 1
BASE:0:魔力 -= MAGIC_USE_MP:GETNUM(ITEM,"絶頂体力回復淫紋")
TRYCALLFORM COM{SELECTCOM}_MESSAGE

;成功・失敗を判定
IF RAND:10000 < FIXATION_RATE
	MARK:絶頂体力回復淫紋 = 1
	CALL COM581_SUCCESS_MESSAGE
	CALL MILKTANK_CALC
;失敗
ELSE
	CALL COM581_FAILED_MESSAGE
ENDIF
RETURN 1



@COM582
#DIM FIXATION_RATE
;絶頂魔力回復淫紋

;基本5%、好感度および乳牛堕ちの1/3を上乗せした確率で定着
;けっこうなエンドコンテンツ感出したかった
FIXATION_RATE = 500 +(BASE:好感度 +BASE:乳牛堕ち) /3
FIXATION_RATE = LIMIT(FIXATION_RATE,500,10000)
PRINTFORML The success chance to engrave【Mana Recovering Climax Crest】is: {FIXATION_RATE /100}.{FIXATION_RATE %100}\%.
CALL PRINTL_WORD_COLOR("The success chance increases by a value equal to 1/3 of the total of【Favorability】and【Fall to Dairy Cow】","黄")
IF FIXATION_RATE < 10000
	PRINTFORML Regardless of success or failure, time will pass and %VALUE_DIGIT(MAGIC_USE_MP:GETNUM(ITEM,"絶頂魔力回復淫紋"))% MP will be consumed.
	PRINTL (There are no other failure penalties.)
ENDIF
PRINTL Would you like to apply ＜Mana Recovering Climax Crest＞?
CALL ASK_YN
SIF RESULT
	RETURN
SELECTCOM = 582
LOSEBASE:体力 += 500
LOSEBASE:気力 += 500

;あなたで触れてないので器具扱い
SOURCE:Ｂ快楽／器具 = 30000
SOURCE:Ｎ快楽／器具 = 30000
SOURCE:恥辱 = 10000
SOURCE:情愛 = 10000
SOURCE:屈辱 = 10000
SOURCE:支配 = 30000
SOURCE:経過時間 = 1
SOURCE:選択コマンド口上非表示 = 1
BASE:0:魔力 -= MAGIC_USE_MP:GETNUM(ITEM,"絶頂魔力回復淫紋")
TRYCALLFORM COM{SELECTCOM}_MESSAGE

;成功・失敗を判定
IF RAND:10000 < FIXATION_RATE
	MARK:絶頂魔力回復淫紋 = 1
	CALL COM582_SUCCESS_MESSAGE
	CALL MILKTANK_CALC

	;魔力10万以下なら引き上げ
	IF MAXBASE:魔力 < INFINITY_MILK_TANK
		MAXBASE:魔力 = INFINITY_MILK_TANK
		CALL PRINTL_WORD_COLOR,@"Due to the secondary effect of 【Mana Recovering Climax Crest】, %CALLNAME%'s maximum magic power increases → %VALUE_DIGIT(INFINITY_MILK_TANK)% MP.","水色"
	ENDIF
;失敗
ELSE
	CALL COM582_FAILED_MESSAGE
ENDIF
RETURN 1






