@COM504
#DIM NOW_SIZE
;ペニス変化

SELECTCOM = 504
PRINTFORML "Will change the size of your %SAVESTR:表記／ペニス%."
PRINTFORML "What size do you want to change it to? (Selecting the current size will be treated as cancel.)"
CANDI_BOX:0 = 馬並
CANDI_BOX:1 = 極太
CANDI_BOX:2 = 巨根
CANDI_BOX:3 = 太め
CANDI_BOX:4 = 普通
CANDI_BOX:5 = 短小
CANDI_BOX:6 = 極小
FIX:0 = ABL:PLAYER:初期値／ペニスサイズ * 5 / 2 - 2
FIX:1 = ABL:PLAYER:初期値／ペニスサイズ * 2 - 2
FIX:2 = ABL:PLAYER:初期値／ペニスサイズ * 3 / 2 - 2
FIX:3 = ABL:PLAYER:初期値／ペニスサイズ * 5 / 4 - 2
FIX:4 = ABL:PLAYER:初期値／ペニスサイズ
FIX:5 = ABL:PLAYER:初期値／ペニスサイズ * 3 / 4
FIX:6 = ABL:PLAYER:初期値／ペニスサイズ / 2
NOW_SIZE = 4
SELECTCASE ABL:PLAYER:ペニスサイズ
	CASE IS >= FIX:0
		NOW_SIZE = 0
	CASE IS >= FIX:1
		NOW_SIZE = 1
	CASE IS >= FIX:2
		NOW_SIZE = 2
	CASE IS >= FIX:3
		NOW_SIZE = 3
	CASE IS < FIX:5
		NOW_SIZE = 6
	CASE IS < FIX:4
		NOW_SIZE = 5
ENDSELECT
REPEAT 7
	PRINTFORM [ {COUNT}] %CANDI_BOX:COUNT%
	SIF COUNT == NOW_SIZE
		CALL PRINT_WORD_COLOR( "<現在>","水色")
	PRINTL
REND
BINPUT
SELECTCASE RESULT
CASE IS == NOW_SIZE
	RETURN
CASE 4
	ABL:PLAYER:ペニスサイズ = FIX:4
CASEELSE
	ABL:PLAYER:ペニスサイズ = FIX:RESULT + RAND:3
ENDSELECT
PRINTFORML The size of your %SAVESTR:表記／ペニス% has become %CANDI_BOX:RESULT%.
BASE:0:魔力 -= MAGIC_USE_MP:GETNUM(ITEM,"ペニス変化")
RETURN 1



