
@COM50
;素股
;継続SOURCEが入るのであまりない状態にしとく

SIF !TFLAG:拘束BIT
	CALL SERVICE_JUDGE
;SIF !RESULT && !TFLAG:拘束BIT
;	RETURN
SOURCE:恥辱 += 300
SOURCE:不潔 += 400
SOURCE:経過時間 = 1
TEQUIP:素股 = 1

;奴隷のおまた／あなたのちんぽで汚れ移動　射精判定部分で行う
RETURN 1



