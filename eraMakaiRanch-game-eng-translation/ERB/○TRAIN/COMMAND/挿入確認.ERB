;サイズ差確認
@SIZE_CONFIRM
#DIM SIZE_DIFF

SIF !GETBIT(＃Ｖサイズ確認＃) || !PLAYER_PENIS
	RETURN
SIZE_DIFF = ABL:0:ペニスサイズ - ABL:Ｖサイズ - ABL:Ｖ拡張
SIF !(SIZE_DIFF > 20 || (ABL:0:ペニスサイズ - ABL:初期値／Ｖサイズ * 3 > 0 && SIZE_DIFF > 0))
	RETURN
CALL PRINTL_WORD_COLOR,@"%CALLNAME%'s %SAVESTR:表記／膣% is too small to accept %CALLNAME:0%'s %SAVESTR:表記／ペニス%, causing severe pain.","黄"
RETURN 1



