
;Ｖ挿入前の確認
;ARG→サイズ確認スキップ
@V_INSERT_CONFIRM(ARG)

EXIST = 0
IF !ARG
	CALL SIZE_CONFIRM
	SIF RESULT
		EXIST ++
ENDIF
CALL LUBRICATION_CONFIRM
SIF RESULT
	EXIST ++
CALL LOST_VARGIN_CONFIRM
SIF RESULT
	EXIST ++

;Ｖのみ【異種族孕ませ】確認
CALL PREGNANT_CONFIRM
SIF RESULT
	EXIST ++
SIF !EXIST
	RETURN
PRINTL Do you want to insert?
CALL ASK_YN

;[いいえ]なら1
SIF RESULT
	RETURN 1



;Ｖ処女喪失確認
@LOST_VARGIN_CONFIRM

;確認しない設定か非処女なら飛ばす
