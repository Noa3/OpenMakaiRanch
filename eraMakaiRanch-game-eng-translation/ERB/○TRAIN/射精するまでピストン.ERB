
;射精するまでピストン
@EJACULATION_PISTON

;ループ内部へ
CALL EJACULATION_PISTON_LOOP

;ペニス引き抜き
CALL COM890

;[おっぱい吸わせて]とかから来てる場合飛ばす
SIF !TFLAG:Ｐ引き抜き後WAITスキップ
	PRINTW



@EJACULATION_PISTON_LOOP
#DIM DYNAMIC KEEP_PISTON

;ピストン8回しても射精しないのはなんか変なので帰っとく
;射精していたら終わり
SIF KEEP_PISTON >= 8 || TFLAG:コマンド中射精回数
	RETURN
IF GETBIT(＃Ｐ使用／Ｖ挿入＃)
	CALL EJACULATION_PISTON_V
ELSEIF GETBIT(＃Ｐ使用／Ａ挿入＃)
	CALL EJACULATION_PISTON_A
ELSEIF GETBIT(＃Ｐ使用／パイズリ＃)
	CALL EJACULATION_PISTON_B
ELSEIF TEQUIP:手コキ
	CALL EJACULATION_PISTON_HAND

;ペニス使ってない場合終わり
ELSE
	RETURN
ENDIF
CALL KOJO_PRINT("調教コマンド",TRAINNAME:SELECTCOM,"実行")
CALL SOURCE_CHECK
KEEP_PISTON ++

;回数数える必要が出てきた
TFLAG:スキンシップ回数 ++
PRINTL
RESTART



;Ｖピストンパラメータ
@EJACULATION_PISTON_V

V_PENIS = %CALLNAME:0%
SOURCE:Ｖ快楽／あなた責め += 1000
SOURCE:恥辱 += 1000
SOURCE:情愛 += 3000
SOURCE:屈辱 += 1000
SOURCE:不潔 += 500
SOURCE:支配 += 1000
SELECTCOM = 30

;汎用を呼ぶ
CALL SEX_MESSAGE()
CALL ONOMATOPOEIA("ピストン","Ｖ")



