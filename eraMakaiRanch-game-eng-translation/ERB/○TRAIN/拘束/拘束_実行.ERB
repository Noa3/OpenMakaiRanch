
;拘束
;ARG→拘束番号
;ARG:1→調教終了時にPRINTWせず返す
@TRAIN_BIND_RUN(ARG,ARG:1)

;元々と同じ選択肢、-1だとおわり　解除は通す
;TFLAG:拘束BIT→80
SIF ARG < 0 || (!ARG && !TFLAG:拘束BIT)
	RETURN

;キャンセルされないように修正
IF ARG
	SIF GETBIT(TFLAG:拘束BIT,ARG -1)
		RETURN
ENDIF

;三角木馬用
IF GETBIT(＃拘束／三角木馬＃)
	TFLAG:Ｃ装備 = 0
	TFLAG:Ｖ装備 = 0
ENDIF

;一旦解除→ARG -1をSETBIT
TFLAG:拘束BIT = 0
