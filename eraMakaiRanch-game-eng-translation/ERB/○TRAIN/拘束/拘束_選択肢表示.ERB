
;拘束選択肢
;ARGS→来た場所
@BIND_CHOICE(ARGS)
#DIM DYNAMIC SET
#DIM CHOISE_REF

LINECOUNT_BEFORE = LINECOUNT
DEFAULT_SET = SET
PRINTL

;選択肢に+する数値
CHOISE_REF = 0
SELECTCASE ARGS
CASE "個人設定"
	CHOISE_REF = 1
	PRINTL [ 0] Use Common Setting（Default）

;特に何もない
CASE "開始時選択","調教中","全体設定"
ENDSELECT

;拘束中なら解除
IF TFLAG:拘束BIT
	PRINTFORML [{0 +CHOISE_REF,2}] Release Restraints
ELSE
	PRINTFORM [{0 +CHOISE_REF,2}] No Restraints
	SIF ARGS == "全体設定"
		PRINT （Default）
	PRINTL
ENDIF

;STR:拘束中→3930
STR_REF = 3930
FOR LOCAL,0,20
	SIF STR:(STR_REF +LOCAL) == ""
		CONTINUE
	
	;拘束必要アイテム参照
	CALL BIND_NEED_ITEM(LOCAL)
	
	;必要アイテム所持か必要ないなら選択肢
	IF NEED_ITEM_ID && !ITEM:NEED_ITEM_ID
		;必要アイテム番号がNEED_ITEM_ID:0,1に入ってる
		CALL PRINT_WORD_COLOR,@"<{LOCAL +1 +CHOISE_REF,2}> %RESTRAINTS_LONG_ENG(RESULTS),20,LEFT%","灰"
		IF !NEED_ITEM_ID:1
			PRINTFORML ：＜%ITEMS_ENG(ITEMNAME:NEED_ITEM_ID)%＞ required
		ELSE
			PRINTFORML ：＜%ITEMS_ENG(ITEMNAME:NEED_ITEM_ID)%＞ and ＜%ITEMS_ENG(ITEMNAME:(NEED_ITEM_ID:1))%＞ required
		ENDIF
	ELSEIF NEED_ITEM_ID:1 && !ITEM:(NEED_ITEM_ID:1)
		CALL PRINT_WORD_COLOR,@"<{LOCAL +1 +CHOISE_REF,2}> %RESTRAINTS_LONG_ENG(RESULTS),20,LEFT%","灰"
		PRINTFORML ：＜%ITEMS_ENG(ITEMNAME:NEED_ITEM_ID)%＞ and ＜%ITEMS_ENG(ITEMNAME:(NEED_ITEM_ID:1))%＞ required
	ELSE
		;三角木馬の場合はＣＶの判定
		IF RESULTS == "三角木馬拘束"
			IF TFLAG:Ｃ装備 || TFLAG:Ｖ装備
				CALL PRINTL_WORD_COLOR,@"　Not allowed with %SAVESTR:表記／陰核% or %SAVESTR:表記／膣% equipment","灰"
				CONTINUE
			ELSEIF ARGS != "全体設定" && TALENT:処女結界
				CALL PRINTL_WORD_COLOR,@"　Not possible due to【Virginity Barrier】","灰"
				CONTINUE
			ENDIF
		ENDIF
		PRINTFORML [{LOCAL +1 +CHOISE_REF,2}] %RESTRAINTS_LONG_ENG(RESULTS)%
	ENDIF
NEXT
PRINTL

;開始時はデフォルト設定も入れる
IF ARGS == "開始時選択"
	PRINT [90] Set As Default For This Character
	CALL PRINT_CHECKBOX(SET,1)
	PRINTL [98] Hint
ELSE
	PRINTL [98] Hint
	PRINTL [99] Cancel
ENDIF
BINPUT
SELECTCASE RESULT
CASE 90
	;デフォルト設定の場合LINE消しつつRESTART
	INVERTBIT SET,0
	CLEARLINE LINECOUNT -LINECOUNT_BEFORE
	RESTART
CASE 98
	CALL BROWSE_HINT("拘束")
	RESTART
CASE 99
	RETURN -1
ENDSELECT
RETURN RESULT


