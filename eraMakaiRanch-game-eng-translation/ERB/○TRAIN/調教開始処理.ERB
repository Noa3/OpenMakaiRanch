
;調教前に衣服状態と拘束状態を変更
@BEFORE_TRAIN_COMMAND_BEFORE
#DIM STRIP
#DIM BIND
#DIM LOTION
#DIM BIYAKU

CALL BEFORE_TRAIN_AJUST_STRIP_FLAG

;ここで止めればちょうどいい
WAIT

;フラグを呼び出してきて実行予約
CALL BEFORE_TRAIN_AUTO_STRIP_CHECK
STRIP = RESULT
CALL BEFORE_TRAIN_AUTO_BIND_CHECK
BIND = RESULT
CALL BEFORE_TRAIN_AUTO_LOTION_CHECK
LOTION = RESULT
CALL BEFORE_TRAIN_AUTO_BIYAKU_CHECK
BIYAKU = RESULT
CALL BEFORE_TRAIN_COMMAND(STRIP,BIND,LOTION,BIYAKU)

;１ターン目にそのまま反映されてしまうので初期化
SOURCE:Ｂ露出地の文表示 = 0
SOURCE:Ｎ露出地の文表示 = 0
SOURCE:Ｖ露出地の文表示 = 0
SOURCE:脱衣メッセージ表示 = 0



;変更
@BEFORE_TRAIN_COMMAND(SELECT_STRIP,SELECT_BIND,USE_LOTION,USE_BIYAKU)
#DIM DYNAMIC SELECT_STRIP
#DIM DYNAMIC SELECT_BIND
#DIM DYNAMIC USE_LOTION
#DIM DYNAMIC USE_BIYAKU

COST = MAGIC_USE_MP:GETNUM(ITEM,"媚薬粘液")
IF FLAG:調教開始時設定確認
	CALL BEFORE_TRAIN_COMMAND_RUN(SELECT_STRIP,SELECT_BIND,USE_LOTION,USE_BIYAKU)
	RETURN
ENDIF

CALL MANYL(3)
CALL SHOW_EQUIP
SELECTCASE SELECT_STRIP
CASE -1
	CALL PRINTL_WORD_COLOR("< 0> ＜Naked＞","桃")
CASEELSE
	;STR:デフォルト脱衣状態→8130
	STR_REF = 8130
	PRINTFORML [ 0] Clothes：%STRIP_SELECT_ENG(STR:(STR_REF +SELECT_STRIP))%
ENDSELECT
SELECTCASE SELECT_BIND
CASE 0
	PRINTL [ 1] No Restraints
CASEELSE
	;STR:拘束中→3930
	STR_REF = 3930
	PRINTFORML [ 1] Restraint：%RESTRAINTS_ENG(STR:(STR_REF +SELECT_BIND -1))%
ENDSELECT

;ローション、媚薬もここで見る
PRINTL
IF ITEM:ローション
	PRINTFORML ・Use Lotion（Applied if available after undressing：{ITEM:ローション} in possession）
	PRINTFORM [10] %SAVESTR:表記／膣,12%
	CALL PRINT_ONOFF(GETBIT(USE_LOTION,0),1)
	PRINTFORM [11] %SAVESTR:表記／アナル,12%
	CALL PRINT_ONOFF(GETBIT(USE_LOTION,1),1)
	PRINTFORM [12] %SAVESTR:表記／乳房,12%
	CALL PRINT_ONOFF(GETBIT(USE_LOTION,2),1)
ELSE
	CALL PRINTL_WORD_COLOR,@"No ＜Lotion＞","灰"
ENDIF
PRINTL
IF !ITEM:媚薬
	CALL PRINTL_WORD_COLOR,@"No ＜Aphrodisiac＞","灰"
ELSE
	ITEM_NAME = 媚薬
	PRINTFORM [20] %ITEMS_ENG(ITEM_NAME),12%
	CALL PRINT_ONOFF(USE_BIYAKU == 1)
	PRINTFORML （{ITEM:媚薬} in possession）
ENDIF
IF !ITEM:媚薬粘液
	CALL PRINTL_WORD_COLOR,@"No ＜Aphrodisiac Slime＞","灰"
ELSEIF BASE:0:魔力 < COST
	CALL PRINTL_WORD_COLOR,@"Not enough MP for ＜Aphrodisiac Slime＞（%VALUE_DIGIT(COST)% MP necessary）","灰"
ELSE
	ITEM_NAME = 媚薬粘液
	PRINTFORM [21] %ITEMS_ENG(ITEM_NAME),12%
	CALL PRINT_ONOFF(USE_BIYAKU == 2)
	PRINTFORML %VALUE_DIGIT(COST)%MP
ENDIF
PRINTL
PRINTL [99] Start Training
BINPUT
SELECTCASE RESULT
CASE 0
	CALL BEFORE_TRAIN_STRIP_SELECT
	
	;キャンセル以外
	SIF RESULT >= 0
		SELECT_STRIP = RESULT
	
	;別に消さなくてもいいかな
	;CLEARLINE 16
CASE 1
	CALL BEFORE_TRAIN_BIND_SELECT
	SIF RESULT >= 0
		SELECT_BIND = RESULT
CASE 10 TO 12
	INVERTBIT USE_LOTION,RESULT -10
CASE 20,21
	IF USE_BIYAKU == RESULT -19
		USE_BIYAKU = 0
	ELSE
		USE_BIYAKU = RESULT -19
	ENDIF
CASE 99
	;実行して調教へ
	CALL BEFORE_TRAIN_COMMAND_RUN(SELECT_STRIP,SELECT_BIND,USE_LOTION,USE_BIYAKU)
	RETURN
ENDSELECT
RESTART



;Ｖ潤滑を増加
@BEFORE_TRAIN_LUBRICATION

IF CFLAG:乳牛 || CFLAG:洗脳 || ＃陥落状態／隷属＃
	PALAM:Ｖ潤滑 += 10000
ELSEIF ＃陥落状態／恋慕以上＃
	PALAM:Ｖ潤滑 += 5000
ELSEIF ＃陥落状態／陥落以上＃
	PALAM:Ｖ潤滑 += 2000
ENDIF
SIF PALAM:Ｖ潤滑
	SETBIT STAIN:膣,1


;ローションフラグ参照
@BEFORE_TRAIN_AUTO_LOTION_CHECK
#DIM LOTION

LOTION = CFLAG:個別設定／調教開始自動処理／ローション
IF GETBIT(LOTION,0)
	;BIT1つずらし
	LOTION = LOTION >> 1
ELSE
	LOTION = FLAG:デフォルト使用アイテム／ローション
ENDIF

;他はキャラ個別設定を見る
RETURN LOTION



;媚薬フラグ参照
@BEFORE_TRAIN_AUTO_BIYAKU_CHECK
#DIM BIYAKU

BIYAKU = CFLAG:個別設定／調教開始自動処理／媚薬 - 1

;-1だと全体コンフィグ準拠
SIF BIYAKU == -1
	BIYAKU = FLAG:デフォルト使用アイテム／媚薬

;他はキャラ個別設定を見る→そのまま
RETURN BIYAKU



@BEFORE_TRAIN_COMMAND_RUN(SELECT_STRIP,SELECT_BIND,USE_LOTION,USE_BIYAKU)
#DIM SELECT_STRIP
#DIM SELECT_BIND
#DIM USE_LOTION
#DIM USE_BIYAKU

;0～2の脱ぎは先に拘束
IF SELECT_STRIP < 3
	CALL TRAIN_BIND_RUN(SELECT_BIND)
	CALL BEFORE_TRAIN_STRIP_RUN(SELECT_STRIP)
ELSE
	CALL BEFORE_TRAIN_STRIP_RUN(SELECT_STRIP)
	CALL TRAIN_BIND_RUN(SELECT_BIND)
ENDIF

;媚薬
IF USE_BIYAKU == 2 && ITEM:媚薬粘液 && BASE:0:魔力 >= COST
	CALL COM550
ELSEIF USE_BIYAKU == 1 && ITEM:媚薬
	CALL COM251
ENDIF

;衣服変更してからローション
SIF ITEM:ローション && GETBIT(USE_LOTION,0) && TFLAG:Ｖ露出 && !TALENT:処女結界
	CALL COM290
SIF ITEM:ローション && GETBIT(USE_LOTION,1) && TFLAG:Ａ露出
	CALL COM291
SIF ITEM:ローション && GETBIT(USE_LOTION,2) && TFLAG:Ｂ露出
	CALL COM292





