
;アイテム・特殊魔術入り口
@TRAIN_ITEM_COMMON

;時間経過ないものまとめ
CALL TRAIN_ITEM_LOTION
CALL TRAIN_ITEM_COMDOM
CALL TRAIN_ITEM_BIYAKU
CALL TRAIN_MAGIC_COMMON
PRINTL [99] Cancel
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL COM290
CASE 1
	CALL COM291
CASE 2
	CALL COM292
CASE 3
	CALL COM252
CASE 4
	CALL COM895
CASE 10
	CALL COM251
CASE 11
	CALL COM550
CASE 12
	CALL COM253
CASE 20
	CALL COM505
CASE 21
	CALL COM504
	SIF !RESULT
		RETURN
CASE 22
	CALL COM503
CASE 30
	CALL COM580
CASE 99
	RETURN
ENDSELECT
WAIT
RETURN 1





;ローション
@TRAIN_ITEM_LOTION

