	CALL PRINTL_WORD_COLOR,@"%SAVESTR:表記／膣% exposure required","黄"
ELSEIF TFLAG:Ｖ装備
	CALL PRINTL_WORD_COLOR,@"%SAVESTR:表記／膣% penetrated","黄"
	IF TFLAG:Ｖローション
		CALL PRINTL_WORD_COLOR,@"%SAVESTR:表記／膣% lotion alraedy applied","灰"
	ELSE
		PRINTFORML [ 0] %SAVESTR:表記／膣%
