
;汚れ処理
@TRAIN_STAIN_SETTING
#DIM STAIN_DISP,2

;噴乳時の母乳付着
IF NOWEX:噴乳
	CALL SET_STAIN_TARGET("乳首","母乳")

	;Ｎ装備なしか1000cc出るならＢにも
	SIF !TFLAG:Ｎ装備 || NOWEX:噴乳
		CALL SET_STAIN_TARGET("乳房","母乳")
		
	;乳吸いなら口に母乳追加
	SIF TFLAG:乳吸い
		CALL SET_STAIN_PLAYER("口","母乳")
ENDIF
VARSET STAIN_DISP

;汚れ追加した場合ここで表示
STR_REF = 6000
IF SUMARRAY(STAIN,50,70)
	SETCOLOR 0xEE10EE
	PRINTFORM %CALLNAME%：
	FOR STAIN_DISP,50,70
		SIF !STAIN:STAIN_DISP
			CONTINUE
		PRINTFORM %STAIN_PLACE_ENG(STAINNAME:(STAIN_DISP -50))%→
		FOR STAIN_DISP:1,0,10
			SIF GETBIT(STAIN:STAIN_DISP,STAIN_DISP:1)
				PRINTFORM %STAIN_MAT_ENG(STR:(STAIN_DISP:1 +STR_REF))% 
		NEXT
	NEXT
	PRINTL stained 
	VARSET STAIN,0,50,70
ENDIF

;STAINのキャラ指定がなんかうまくいかないのでTARGETを変更
SAVE_TARGET = TARGET
TARGET = MASTER
IF SUMARRAY(STAIN,50,70)
	SETCOLOR 0xEE10EE
	PRINTFORM %CALLNAME%：
	FOR STAIN_DISP,50,70
		SIF !STAIN:STAIN_DISP
			CONTINUE
		IF TEQUIP:0:コンドーム && STAINNAME:(STAIN_DISP -50) == "ペニス"
			PRINT ゴムＰ→
		ELSE
			PRINTFORM %STAIN_PLACE_ENG(STAINNAME:(STAIN_DISP -50))%→
		ENDIF
		FOR STAIN_DISP:1,0,10
			SIF GETBIT(STAIN:STAIN_DISP,STAIN_DISP:1)
				PRINTFORM %STAIN_MAT_ENG(STR:(STAIN_DISP:1 +STR_REF))% 
		NEXT
	NEXT
	PRINTL stained 
	VARSET STAIN,0,50,70
ENDIF
TARGET = SAVE_TARGET
RESETCOLOR



