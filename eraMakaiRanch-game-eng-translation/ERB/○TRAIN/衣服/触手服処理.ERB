
;調教開始時に触手服を着ている場合
@BEFORE_TRAIN_T_CLOTHE

IF ＃着用下着下／名称＃ == "触手服"
	PALAM:Ｖ潤滑 += 10000
	PALAM:Ａ潤滑 += 10000
	FOR LOCAL,0,5
		PALAM:LOCAL += RAND:((ABL:LOCAL + 5) * ABL:(LOCAL + 10))
		SIF PALAM:LOCAL > 9999
			PALAM:LOCAL = 9999
	NEXT
	SETBIT STAIN:アナル,5
	SETBIT STAIN:乳房,5
	SETBIT STAIN:乳首,5
	SETBIT STAIN:尻,5
	IF TALENT:オトコ
		SETBIT STAIN:ペニス,5
	ELSE
		SETBIT STAIN:陰核,5
		SETBIT STAIN:膣,5
	ENDIF
ENDIF

;調教開始時にあなたが触手服を着ている場合
@BEFORE_TRAIN_T_CLOTHE_M

CALL PLAYER_PENIS_CHECK
IF ITEMNAME:(EQUIP:0:装備中ID／下着下) == "触手服"
	SETBIT STAIN:0:アナル,5
	SETBIT STAIN:0:乳房,5
	SETBIT STAIN:0:乳首,5
	SETBIT STAIN:0:尻,5
	IF PLAYER_PENIS
		SETBIT STAIN:0:ペニス,5
	ELSE
		SETBIT STAIN:0:陰核,5
	ENDIF
	SIF !TALENT:0:オトコ
		SETBIT STAIN:0:膣,5
ENDIF



;触手服を着ている場合ブラシ触手効果
@TRAIN_T_CLOTHE

SIF ＃着用下着下／名称＃ != "触手服" || TFLAG:一時的脱衣／下着下 || !BASE:0:魔力
	RETURN
TEQUIP:ブラシ触手 = 1
FOR LOCAL,150,155
	TEQUIP:LOCAL = 1
NEXT
SIF TALENT:処女結界
	TEQUIP:ブラシ触手Ｖ = 0
IF TFLAG:一時的脱衣／下着上
	TEQUIP:ブラシ触手Ｂ = 0
	TEQUIP:ブラシ触手Ｎ = 0
ENDIF

FOR LOCAL,0,5
	SIF !TEQUIP:(LOCAL+150)
		CONTINUE
	;触手服を着ていて半脱ぎにもなってない場合はそのまま
	SIF (LOCAL == 1 || LOCAL == 4) && !GETBIT(＃半脱ぎ／下着上＃) && !TFLAG:一時的脱衣／下着上
		CONTINUE
	SIF (LOCAL == 0 || LOCAL == 2 || LOCAL == 3) && !GETBIT(＃半脱ぎ／下着下＃)
		CONTINUE

	;尻撫で、お腹撫でのみの場合除外
	SIF SELECTCOM == 16 && LOCAL == 0 && !SOURCE:(LOCAL+10) && !TFLAG:(60+LOCAL)
		CONTINUE
	SIF SELECTCOM == 19 && LOCAL == 3 && !SOURCE:(LOCAL+10) && !TFLAG:(60+LOCAL)
		CONTINUE

	;Ａ装備→TFLAG:60
	SIF SOURCE:LOCAL || SOURCE:(LOCAL+10) || TFLAG:(60+LOCAL)
		TEQUIP:(LOCAL+150) = 0
NEXT

CALL EQUIP_155_CONTINUE
IF TFLAG:調教中 || TFLAG:スケジュール外Ｈ || SOURCE:体内凌辱中継続メッセージ表示
	TRYCALLFORM EQUIP_155_CONTINUE_MESSAGE
	CALL KOJO_PRINT("調教コマンド","触手服","継続")
ENDIF
VARSET TEQUIP,0,150,156



;触手服を着ている場合時間経過で責め発生
@NO_TRAIN_T_CLOTHE
#DIM DISP_MESSAGE

SIF !BASE:0:魔力
	RETURN
DISP_MESSAGE = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF !TARGET || CSTR:状態／あなたの子 == "成長中"
		CONTINUE
	SIF ＃着用下着下／名称＃ != "触手服" || GROUPMATCH(CSTR:スケジュール,"搾乳","抽出","牛舎","体内凌辱","解放","触手責め搾乳","調教対象") || CFLAG:追跡対象 == 2
		CONTINUE
	IF !DISP_MESSAGE
		DISP_MESSAGE = 1
		PRINTL 　　　《 Tentacle Suit 》
		PRINTL The tentacle suit continues to torment the wearer with countless tentacles that sprout from its inside...
	ENDIF
	
	CALL TRAIN_T_CLOTHE_S
NEXT
SIF !DISP_MESSAGE
	RETURN
CALL SECTION_MP_COST
DRAWLINE
CALL RESET_TRAIN_PALAM
PLAYER = -1
WAIT



;触手服責め
@TRAIN_T_CLOTHE_S
#DIM DISP_COUNT
;今のところあなたは除外

CALL STATUS_BEFORE_RECORD
CALL RESET_TRAIN_PALAM
CALL BEFORE_TRAIN_T_CLOTHE

FOR LOCAL,0,10
	CALL SOURCE_CHECK
	VARSET LOSEBASE
NEXT
CALL SCHEDULE_ECSTASY_FIX
PRINTFORM %CALLNAME%　
CALL PRINT_TOTAL_GOBLINS
CALL TRAIN_END_PALAM_CALC
CALL ABL_UP
CALL MARK_GET

;陥落があったらWAIT
DISP_COUNT = LINECOUNT
CALL CAPITULATION_JUDGE
IF DISP_COUNT != LINECOUNT
	WAIT
	WAIT_ON = 0
ENDIF
PRINTL 

