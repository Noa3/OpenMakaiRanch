
;USERCOMから飛ばす用
;服入り口　処理が面倒だし使う？という感じなので着せる処理はないよ
@TRAIN_CLOTHES_COMMON

;もう全裸なら帰る　という処理だったんだけどいろいろ組んだので無効
VARSET COMMAND_OK
CALL TRAIN_STRIP_COMMAND_CLOTHE
CALL TRAIN_STRIP_LINGERIE_BUST
CALL TRAIN_STRIP_LINGERIE_VAGINA
CALL TRAIN_STRIP_JACKET
CALL TRAIN_STRIP_ACCESSORY
CALL TRAIN_STRIP_BULK
PRINTL [99] Cancel
BINPUT
SOURCE:脱衣メッセージ表示 = 1
SELECTCASE RESULT
CASE 0
	CALL TRAIN_CLOTHE_STRIP("衣服","上半脱ぎ")
CASE 1
	;衣服破る前の確認
	CALL CONFIRM_TRAIN_CLOTHE_BREAK
	SIF RESULT
		RETURN
	CALL TRAIN_CLOTHE_STRIP("衣服","上破き")
CASE 2
	CALL TRAIN_CLOTHE_STRIP("衣服","下半脱ぎ")
CASE 3
	CALL CONFIRM_TRAIN_CLOTHE_BREAK
	SIF RESULT
		RETURN
	CALL TRAIN_CLOTHE_STRIP("衣服","下破き")

CASE 10
	CALL TRAIN_CLOTHE_STRIP("下着","上脱衣")
CASE 11
	CALL TRAIN_CLOTHE_STRIP("下着","上半脱ぎ")
CASE 12
	CALL TRAIN_CLOTHE_STRIP("下着","下脱衣")
CASE 13
	CALL TRAIN_CLOTHE_STRIP("下着","下半脱ぎ")

CASE 14
	CALL TRAIN_CLOTHE_STRIP("上着","半脱ぎ")

CASE 20 TO 29
	CALL TRAIN_CLOTHE_STRIP("アクセサリー","",RESULT -10)

CASE 30
	CALL TRAIN_CLOTHE_STRIP("衣服","脱衣")
CASE 31
	CALL TRAIN_CLOTHE_STRIP("衣服","一括半脱ぎ")
CASE 32
	CALL CONFIRM_TRAIN_CLOTHE_BREAK
	SIF RESULT
		RETURN
	CALL TRAIN_CLOTHE_STRIP("衣服","一括破き")
CASE 33
	CALL TRAIN_CLOTHE_STRIP("一括","上半脱ぎ")
CASE 34
	CALL TRAIN_CLOTHE_STRIP("一括","下半脱ぎ")
CASE 35
	CALL TRAIN_CLOTHE_STRIP("下着","脱衣")
CASE 36
	CALL TRAIN_CLOTHE_STRIP("下着","一括半脱ぎ")
CASE 37
	CALL TRAIN_CLOTHE_STRIP("一括","全半脱ぎ")
CASE 38
	CALL TRAIN_CLOTHE_STRIP("一括","全脱衣")
CASE 39
	CALL TRAIN_CLOTHE_STRIP("アクセサリー","一括外し")
CASE 99
	RETURN 1
ENDSELECT

;ここ来てる場合脱がしたので止める
PRINTW

;SOURCEをリセットしないと脱衣メッセージが重複した
VARSET SOURCE



;衣服破る前の確認
@CONFIRM_TRAIN_CLOTHE_BREAK

;従順な場合だけ聞くようにする
SIF !CFLAG:無抵抗
	RETURN
PRINTFORML %CALLNAME% is obedient, and you don't really need to tear her clothes.
PRINTFORML That being said, do so anyway?
CALL ASK_YN
SIF RESULT
	RETURN 1


