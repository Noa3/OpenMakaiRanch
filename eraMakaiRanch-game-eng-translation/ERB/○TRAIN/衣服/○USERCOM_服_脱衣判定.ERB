;アクセサリー外し表示
@TRAIN_STRIP_ACCESSORY

;アクセサリー一時的脱衣フラグ：130～
;アクセサリー装備箇所のSTR：6670～
EXIST = 0
PRINTL 　《 Accessories 》
FLAG_REF = 120
STR_REF = 6660
FOR LOCAL,10,20
	SIF EQUIPNAME:LOCAL == ""
		CONTINUE
	IF !EQUIP:LOCAL || TFLAG:(LOCAL +FLAG_REF)
		;表示が長いので装備してない場合も飛ばすことにした
		;CALL PRINTL_WORD_COLOR,@"　%STR:(LOCAL +STR_REF)%装備なし","灰"
		CONTINUE
	
	;下半身埋め拘束だと脚はダメ
	ELSEIF GETBIT(＃拘束／下半身埋め壁乳＃) && LOCAL == 13
		CALL PRINTL_WORD_COLOR("Leg accessories cannot be removed while lower body embedded in wall","灰")
		CONTINUE
	ENDIF
	PRINTFORML [{LOCAL +10,2}] Take off ＜%ITEMS_ENG(ITEMNAME:(EQUIP:LOCAL))%＞
	COMMAND_OK:(LOCAL +10) = 1
	EXIST ++
NEXT

;ない場合ないって書く
SIF !EXIST
	CALL PRINTL_WORD_COLOR("No accessories","灰")
PRINTL



