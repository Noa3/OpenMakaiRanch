
;脱衣フラグ参照
@BEFORE_TRAIN_AUTO_STRIP_CHECK
#DIM STRIP

;全裸なら無視
SIF !SUMARRAY(EQUIP,0,20)
	RETURN -1
STRIP = CFLAG:個別設定／調教開始自動処理／脱衣 - 1

;0だと全体コンフィグ準拠→無抵抗・抵抗時でそれぞれ参照フラグが違う
IF STRIP == -1
	IF CFLAG:無抵抗
		STRIP = FLAG:デフォルト脱衣状態／無抵抗
	ELSE
		STRIP = FLAG:デフォルト脱衣状態／抵抗
	ENDIF
ENDIF

;他はキャラ個別設定を見る→そのまま
RETURN STRIP



;脱衣選択
@BEFORE_TRAIN_STRIP_SELECT
#DIM DYNAMIC SET
#DIM STRIP

LINECOUNT_BEFORE = LINECOUNT
CALL MANYL(3)
DEFAULT_SET = SET
PRINTFORML Do you want to strip %CALLNAME%?
CALL SHOW_EQUIP

;STR:デフォルト脱衣状態→8130
STR_REF = 8130
FOR LOCAL,0,7
	PRINTFORM [{LOCAL,2}] %STRIP_SELECT_ENG(STR:(STR_REF +LOCAL))%
	PRINTL
	IF LOCAL == 2 && !CFLAG:無抵抗
		CALL PRINTL_WORD_COLOR("　Can not remove clothing when【Resisting】","灰")
		BREAK
	ENDIF
NEXT
PRINTL
PRINT [ 9] Set as default for this character.
CALL PRINT_CHECKBOX(SET,1)
BINPUT
SELECTCASE RESULT
CASE 0 TO 7
	;デフォルトセット
	SIF DEFAULT_SET
		CFLAG:個別設定／調教開始自動処理／脱衣 = RESULT +1
	RETURN RESULT
CASE 9
	INVERTBIT SET,0
ENDSELECT
CLEARLINE LINECOUNT -LINECOUNT_BEFORE
RESTART



;脱衣実行
;ARG→STRIP
@BEFORE_TRAIN_STRIP_RUN(ARG)

;0はスルー
SELECTCASE ARG
CASE 1
	CALL TRAIN_CLOTHE_STRIP("一括","全半脱ぎ")
CASE 2
	CALL TRAIN_CLOTHE_STRIP("一括","上半脱ぎ")
CASE 3
	;無抵抗じゃないと無効→BINPUTで飛ばす
	CALL TRAIN_CLOTHE_STRIP("一括","全脱衣")
CASE 4
	CALL TRAIN_CLOTHE_STRIP("一括","全脱衣")
	CALL TRAIN_CLOTHE_STRIP("アクセサリー","一括外し")
CASE 5
	CALL TRAIN_CLOTHE_STRIP("衣服","脱衣")
	CALL TRAIN_CLOTHE_STRIP("アクセサリー","一括外し")
CASE 6
	CALL TRAIN_CLOTHE_STRIP("衣服","脱衣")
	CALL TRAIN_CLOTHE_STRIP("下着","一括半脱ぎ")
	CALL TRAIN_CLOTHE_STRIP("アクセサリー","一括外し")
ENDSELECT



