
;調教後スキルポイント獲得計算
@TRAIN_AFTER_SKILL_POINT_CALC
#DIM SKILL_POINT

;調教AP：蓄積値50→1AP
SKILL_POINT = MONEY:調教AP蓄積値 /50
IF SKILL_POINT
	MONEY:調教AP += SKILL_POINT
	MONEY:調教AP累計値 += SKILL_POINT
	MONEY:調教AP蓄積値 -= (SKILL_POINT *50)
	CALL PRINT_WORD_COLOR,@"【Training AP+{SKILL_POINT}】","水色"
ENDIF

;魔術AP：蓄積値100→1AP
SKILL_POINT = MONEY:魔術AP蓄積値 /100
IF SKILL_POINT
	MONEY:魔術AP += SKILL_POINT
	MONEY:魔術AP累計値 += SKILL_POINT
	MONEY:魔術AP蓄積値 -= (SKILL_POINT *100)
	CALL PRINT_WORD_COLOR,@"【Magic AP+{SKILL_POINT}】","水色"
ENDIF

;触手AP：蓄積値100→1AP
SKILL_POINT = MONEY:触手AP蓄積値 /100
IF SKILL_POINT
	MONEY:触手AP += SKILL_POINT
	MONEY:触手AP累計値 += SKILL_POINT
	MONEY:触手AP蓄積値 -= (SKILL_POINT *100)
	CALL PRINT_WORD_COLOR,@"【Tentacle AP+{SKILL_POINT}】","水色"
ENDIF
SIF !LINEISEMPTY()
	PRINTL






