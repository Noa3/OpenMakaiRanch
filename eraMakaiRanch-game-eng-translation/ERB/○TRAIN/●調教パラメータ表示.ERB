;潤滑表示
;ARGS→どっち
@PRINT_LUBRICATION(ARGS)

IF !TALENT:オトコ || ARGS == "Ａ潤滑"
	PRINTFORM %PALAM_ENG(ARGS)%：{PALAM:ARGS,5} 
	SETCOLOR 0x00FFFF
	IF PALAM:ARGS >= 30000
		PRINT <Flood>　
		
	ELSEIF PALAM:ARGS >= 10000
		PRINT <Wet>　
		
	ELSEIF PALAM:ARGS >= 5000
		PRINT <Moist>　
		
	ELSE
		PRINT <Dry>　
		
	ENDIF
	RESETCOLOR
ELSE
	PRINT 　　　　　　　　　　　
ENDIF



;ペニスサイズ表示
@PRINT_PSIZE

CALL TARGET_PENIS_CHECK
SIF TARGET_PENIS
	PRINTFORM Ｐ：{ABL:ペニスサイズ,3}mm 



;Ｖサイズ表示
@PRINT_VSIZE
#DIM SIZE_DIFF

IF TALENT:オトコ
	PRINT 　　　　　　　　　　　
ELSE
	;ちんぽあるかチェック済み
	SIZE_DIFF = ABL:0:ペニスサイズ - ABL:Ｖサイズ - ABL:Ｖ拡張
	{
	SIF TARGET && (TFLAG:調教中 || TFLAG:スケジュール外Ｈ) && 
	(SIZE_DIFF > 20 || (ABL:0:ペニスサイズ - ABL:初期値／Ｖサイズ * 3 > 0 && SIZE_DIFF > 0)) && PLAYER_PENIS
	}
		SETCOLOR BARCOLORSET("薄赤")
	IF ABL:Ｖ拡張
		PRINTFORM Ｖ：{ABL:Ｖサイズ,3}～{ABL:Ｖサイズ + ABL:Ｖ拡張,3}mm　
	ELSE
		PRINTFORM Ｖ：{ABL:Ｖサイズ,3}mm　　 　
	ENDIF
	RESETCOLOR
ENDIF



;Ａのサイズ表示
@PRINT_ASIZE
#DIM SIZE_DIFF

SIZE_DIFF = ABL:0:ペニスサイズ - ABL:Ａサイズ - ABL:Ａ拡張
{
SIF TARGET && (TFLAG:調教中 || TFLAG:スケジュール外Ｈ) && 
(SIZE_DIFF > 20 || (ABL:0:ペニスサイズ - ABL:初期値／Ａサイズ * 6 > 0 && SIZE_DIFF > 0)) && PLAYER_PENIS
}
	SETCOLOR BARCOLORSET("薄赤")
IF ABL:Ａ拡張
	PRINTFORM Ａ：{ABL:Ａサイズ,3}～{ABL:Ａサイズ + ABL:Ａ拡張,3}mm　
ELSE
	PRINTFORM Ａ：{ABL:Ａサイズ,3}mm　
ENDIF
RESETCOLOR



