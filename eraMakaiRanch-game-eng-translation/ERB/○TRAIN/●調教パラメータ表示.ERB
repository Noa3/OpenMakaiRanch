;BRが6以上なら改行開始
;拘束状態表示
;STR:拘束中→3930
STR_REF = 3930
EXIST = 0

;LOCALのBIT番号がONになってるかを見る
FOR LOCAL,0,20
	SIF !GETBIT(TFLAG:拘束BIT,LOCAL)
		CONTINUE
	PRINTFORM 【%RESTRAINTS_ENG(STR:(STR_REF +LOCAL))% restraints】
	CALL BR_PLUS(6)
	EXIST ++
	BREAK
NEXT

;液体状態
FOR LOCAL,40,50
	SIF !TFLAG:LOCAL
		CONTINUE
	CALL PRINT_WORD_COLOR,@"【%LIQUIDS_ENG(TFLAGNAME:LOCAL)%】","桃"
	CALL BR_PLUS(6)
NEXT

FOR LOCAL,30,300
	;ブラシ触手判定用は表示しない
	SIF TEQUIPNAME:LOCAL == "ブラシ触手"
		CONTINUE
	SIF !TEQUIP:LOCAL
		CONTINUE
	PRINTFORM 【%TEQUIP_ENG(TEQUIPNAME:LOCAL)%】
	CALL BR_PLUS(6)
NEXT



