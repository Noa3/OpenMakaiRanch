
;搾乳を自動スケジュールするか
@AUTO_SCHEDULE_LACTATION

SIF TFLAG:調教前母乳体質 || !MARK:母乳体質
	RETURN
CALL MANYL(3)
PRINTFORML Now that %CALLNAME% is 【Lactating】, change her scheduling？
PRINTL （Change all weekdays at once）
PRINTL
PRINTLC [ 0] Keep As Is
PRINTLC [ 1] Milking／All Day
PRINTL [ 2] Milking／Morning+Evening
IF !ITEM:霊力抽出装置
	CALL PRINTL_WORD_COLOR("　Extraction schedule not unlocked","灰")
ELSEIF !BASE:霊力 && !MAXBASE:魔力
	CALL PRINTL_WORD_COLOR("　Nothing to extract","灰")
ELSE
	PRINTL
	PRINTLC [ 3] Extraction／All Day
	PRINTLC [ 4] Extraction／Morning+Evening
	PRINTL [ 5] Milking→Extraction
ENDIF
PRINTL
BINPUT
SELECTCASE RESULT
CASE 1
	CALL AUTO_SCHEDULE_LIST_SET(200,99)
CASE 2
	CALL AUTO_SCHEDULE_LIST_SET(201,99)
CASE 3
	CALL AUTO_SCHEDULE_LIST_SET(202,99)
CASE 4
	CALL AUTO_SCHEDULE_LIST_SET(203,99)
CASE 5
	CALL AUTO_SCHEDULE_LIST_SET(204,99)
ENDSELECT
CALL AUTO_SCHEDULE_REST_FIX



;超乳化した家畜のスケジュール変更
@AUTO_SCHEDULE_CATTLE_LACTATION
#DIMS CHANGE_SCHEDULE

;CSTR:自動スケジュール／月→350
CSTR_REF = 350
EXIST = 0
CHANGE_SCHEDULE =
FOR LOCAL,CSTR_REF,CSTR_REF +7
	;CSTRに業務にあたる文字が含まれているかチェック
	CALL AUTO_SCHEDULE_WORK_NAME_CHECK(LOCAL)
	EXIST += RESULT
NEXT

;EXISTがあれば再設定する
SIF !EXIST
	RETURN
CALL MANYL(5)
RESETCOLOR
PRINTFORML %CALLNAME%'s【Supreme Breasts】prevent her from working.

;母乳体質じゃない場合全部休日
IF !MARK:母乳体質
	PRINTW 自動スケジュールを全て【休日】に設定し直します。
	CALL AUTO_SCHEDULE_LIST_SET(10,99)
	RETURN
ENDIF
PRINTL 自動スケジュールを再設定してください。（全ての曜日を一括変更します）
PRINTL
PRINTLC [ 0] 休日
PRINTLC [ 1] Milking／All Day
PRINTL [ 2] Milking／Morning+Evening
IF !ITEM:霊力抽出装置
	CALL PRINTL_WORD_COLOR("　Schedule extraction not unlocked","灰")
ELSEIF !BASE:霊力 && !MAXBASE:魔力
	CALL PRINTL_WORD_COLOR("　Nothing to extract","灰")
ELSE
	PRINTL
	PRINTLC [ 3] Extraction／All Day
	PRINTLC [ 4] Extraction／Morning+Evening
	PRINTL [ 5] Milking→Extraction
ENDIF
PRINTL
BINPUT
SELECTCASE RESULT
CASE 0
	CALL AUTO_SCHEDULE_LIST_SET(10,99)
CASE 1
	CALL AUTO_SCHEDULE_LIST_SET(200,99)
CASE 2
	CALL AUTO_SCHEDULE_LIST_SET(201,99)
CASE 3
	CALL AUTO_SCHEDULE_LIST_SET(202,99)
CASE 4
	CALL AUTO_SCHEDULE_LIST_SET(203,99)
CASE 5
	CALL AUTO_SCHEDULE_LIST_SET(204,99)
ENDSELECT
CALL AUTO_SCHEDULE_REST_FIX

;カスタムの中身が業務なら自由に変更
;CSTR:自動スケジュール／カスタムＡ／朝→360
CSTR_REF = 360
FOR LOCAL,CSTR_REF,CSTR_REF +9
	SIF GROUPMATCH(CSTR:LOCAL,＃業務スケジュール＃)
		CSTR:LOCAL = 自由
NEXT



;CSTRに業務にあたる文字が含まれているかチェック
;ARG→LOCAL
@AUTO_SCHEDULE_WORK_NAME_CHECK(ARG)

STRFIND CSTR:ARG,"酪農"
SIF RESULT >= 0
	RETURN 1
STRFIND CSTR:ARG,"事務"
SIF RESULT >= 0
	RETURN 1
STRFIND CSTR:ARG,"調合"
SIF RESULT >= 0
	RETURN 1
STRFIND CSTR:ARG,"掃除"
SIF RESULT >= 0
	RETURN 1

;めんどいのでカスタムの場合も含まれてる判定するよ
STRFIND CSTR:ARG,"カスタム"
SIF RESULT >= 0
	RETURN 1



