
;リソース目次
@HINT_RESOURCE

CLEARLINE LINECOUNT
PRINTL 解説を見る項目を選択してください。
DRAWLINE
BR = 0
STR_REF = 9200
CALL HINT_BUTTON_LIST
DRAWLINE
CALL HINT_DETAIL_RESOURCE
CALL PRINTL_ALIGN(5)
DRAWLINE
PRINTL [99] Return
INPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 29
	SELECT_TIPS = RESULT
CASE 99
	RETURN
ENDSELECT
RESTART



;リソースの解説
@HINT_DETAIL_RESOURCE

STR_NUM = STR_REF +SELECT_TIPS

;対応IDでないなら汎用出して帰る
IF SELECT_TIPS < 0 || SELECT_TIPS >= 30 || STR:STR_NUM == ""
	CALL NOT_SELECT_HINT_COMMON
	RETURN
ENDIF

;項目名
PRINTFORML 　《 %STR:STR_NUM% 》
SELECTCASE STR:STR_NUM
CASE "資金"
	PRINTL 牧場が所持している資金です。
	CALL PRINTL_WORD_COLOR("・当バリアントでは資金0になってもゲームオーバーにはなりません。","黄")
	PRINTL
	PRINTL 《 資金使用先 》
	PRINTL 街の施設でのアイテム購入／牧場拡張
	PRINTL 朝のスケジュール終了後の「精算」時の牧場の維持費
	PRINTL 【競売所】の奴隷の購入
	PRINTL 傭兵アルバイトの雇用
	PRINTL 奴隷受け取り時の＜家畜用搾乳器＞の購入
	PRINTL
	PRINTL 《 資金調達 》
	PRINTFORML 朝のスケジュール終了後の「精算」時、【魔界乳牛】のミルクや奴隷の%SAVESTR:表記／母乳%を出荷
	
CASE "貯蔵霊力"
