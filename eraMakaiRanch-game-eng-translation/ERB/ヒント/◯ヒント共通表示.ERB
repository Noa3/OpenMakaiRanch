
;ボタンリスト
;ARG→分割するときその数値から開始
;ARG:1→分割するときの終点
@HINT_BUTTON_LIST(ARG,ARG:1)

SIF !ARG:1
	ARG:1 = 99

;STR_REFを元関数で指定してね
;50まで行くけど空ならそこまで
FOR LOCAL,ARG,ARG:1
	STR_NUM = STR_REF +LOCAL
	SIF STR:STR_NUM == ""
		BREAK
	CALL BR_PLUS(3)
	PRINTFORMLC [{LOCAL,2}] %STR:STR_NUM% 
NEXT
PRINTL



