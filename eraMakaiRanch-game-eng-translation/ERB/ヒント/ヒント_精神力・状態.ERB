
;精神力・状態目次
@HINT_MIND_STATUS
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTL 解説を見る項目を選択してください。
DRAWLINE
BR = 0
STR_REF = 9130
SELECTCASE PAGE
CASE 1
	CALL HINT_BUTTON_LIST(0,7)
CASE 2
	CALL HINT_BUTTON_LIST(7)
ENDSELECT
DRAWLINE
CALL HINT_DETAIL_MIND_STATUS
CALL PRINTL_ALIGN(5)
DRAWLINE
PRINTLC [90] ページ切り替え
PRINTFORMLC PAGE：{PAGE}／{PAGE_MAX}
PRINTL [99] Return
INPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 29
	SELECT_TIPS = RESULT
CASE 90
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_TIPS = -1
CASE 99
	RETURN
ENDSELECT
RESTART



