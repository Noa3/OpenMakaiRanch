
;ヒントを見る
;ARGS→来た場所
@BROWSE_HINT(ARGS)

CALL MANYL(5)
PRINTL ◯ヒント
PRINTL
SELECTCASE ARGS
CASE "メインメニュー"
	CALL HINT_MAIN_MENU
	
	;メインメニューは項目多いので常にRETURN
	RETURN
CASE "調教"
	CALL HINT_TRAIN
	
	;調教中も
	RETURN
CASE "あなた設定"
	CALL HINT_PLAYER
CASE "スレイ設定"
	CALL HINT_FIRST_SLAVE
CASE "処女結界奴隷設定"
	CALL HINT_BARRIER_SLAVE
CASE "魔術師奴隷設定"
	CALL HINT_SORCEROUS_SLAVE
CASE "開発・習得"
	CALL HINT_UPGRADE
CASE "製薬"
	CALL HINT_PHARMACEUTICAL
CASE "街入り口"
	CALL HINT_TOWN
CASE "町役場"
	CALL HINT_TOWN_HALL
CASE "傭兵アルバイト雇用"
	CALL HINT_MERCENARY
CASE "自動スケジュール"
	CALL HINT_AUTO_SCHEDULE
CASE "プレイヤー戦闘"
	CALL HINT_BATTLE_PLAYER
CASE "料理"
	CALL HINT_COOKING
CASE "拘束"
	CALL HINT_BIND
CASE "ペットのごはん"
	CALL HINT_PET_FOOD
CASE "魔界乳牛用設備"
	CALL HINT_COWSHED_DEVICE
CASE "ペット追加"
	CALL HINT_ADD_PET
CASE "ペットと遊ぶ"
	CALL HINT_PLAY_PET
CASE "納税割合"
	CALL HINT_TAX_SELECT
CASE "事業提携先"
	CALL HINT_BUISINESS_PARTNER
CASEELSE
	PRINTL （ヒントが読み込めませんでした。この表示が出たらバグ報告してくれると助かります）
ENDSELECT

;個別ヒント内部で選択肢出してる場合→RETURN1してくる、その場合止めずスキップ
SIF RESULT
	RETURN
DRAWLINE
PRINTW


