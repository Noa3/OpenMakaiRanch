PRINTLC [ 4] 「milk makers」
CALL PRINT_ONOFF(GETBIT(FLAG:スラング表示／乳首,4),1)
PRINTLC [ 5] 「buds」
CALL PRINT_ONOFF(GETBIT(FLAG:スラング表示／乳首,5),1)
