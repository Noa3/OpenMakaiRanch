CALL PRINT_ONOFF(GETBIT(FLAG:スラング接頭語／乳首,3),0)
PRINTL 　（When ＮSensiv at least 150%）
PRINTL
PRINTL 　《 Special Substitutions 》
PRINTLC [20] Priority for Special Substitutions
CALL PRINT_ONOFF(GETBIT(FLAG:スラング置換／乳首,0),0)
PRINTL 　give Priority to cases that meet the conditions for special substitution 
PRINTLC [21] 「《Breast Size》' tips」
CALL PRINT_ONOFF(GETBIT(FLAG:スラング置換／乳首,1),0)
