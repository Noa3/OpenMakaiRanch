PRINTLC [10] [nipple color]
CALL PRINT_ONOFF(GETBIT(FLAG:スラング接頭語／乳首,0),1)
PRINTLC [11] 「lewd」
CALL PRINT_ONOFF(GETBIT(FLAG:スラング接頭語／乳首,1),0)
PRINTL 　（When lewd breasts）
PRINTLC [12] 「obscene」
CALL PRINT_ONOFF(GETBIT(FLAG:スラング接頭語／乳首,2),0)
PRINTL 　（When lewd breasts）
