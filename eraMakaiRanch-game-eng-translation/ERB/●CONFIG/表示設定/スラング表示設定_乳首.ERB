CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 5
	INVERTBIT FLAG:スラング表示／乳首,RESULT
CASE 10 TO 13
	INVERTBIT FLAG:スラング接頭語／乳首,(RESULT -10)
CASE 20 TO 22
	INVERTBIT FLAG:スラング置換／乳首,(RESULT -20)
CASE 80
	FLAG:スラング表示／乳首 = 65535
CASE 81
	FLAG:スラング接頭語／乳首 = 65535
CASE 82
	FLAG:スラング置換／乳首 = 65535
CASE 90
	FLAG:スラング表示／乳首 = 0
CASE 91
	FLAG:スラング接頭語／乳首 = 0
CASE 92
	FLAG:スラング置換／乳首 = 0
CASE 98
	PRINTL Reset slang options for nipples to default?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_NIPPLE
CASE 99
	IF !FLAG:スラング表示／乳首
		PRINTW At least one slang option must be selected.
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


