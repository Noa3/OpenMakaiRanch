;PRINTL 　…特殊置換の条件を満たす場合に優先して表示されます
CALL SLANG_CONFIG_FOOTER
INPUT
SELECTCASE RESULT
CASE 0 TO 6
	INVERTBIT FLAG:スラング表示／尻,RESULT
CASE 10 TO 22
	INVERTBIT FLAG:スラング接頭語／尻,(RESULT -10)
CASE 80
	FLAG:スラング表示／尻 = 65535
CASE 81
	FLAG:スラング接頭語／尻 = 65535
CASE 82
	FLAG:スラング置換／尻 = 65535
CASE 90
	FLAG:スラング表示／尻 = 0
CASE 91
	FLAG:スラング接頭語／尻 = 0
CASE 92
	FLAG:スラング置換／尻 = 0
CASE 98
	PRINTL Reset slang options for ass to default?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_SLANG_CONFIG_HIP
CASE 99
	IF !FLAG:スラング表示／尻
		PRINTW At least one slang option must be selected.
	ELSE
		RETURN
	ENDIF
ENDSELECT
RESTART


