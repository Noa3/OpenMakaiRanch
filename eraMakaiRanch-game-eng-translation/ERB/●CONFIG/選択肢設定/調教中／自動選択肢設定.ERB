		PRINTL On Breasts
	CASE 3
		PRINTL On Face
	ENDSELECT

CASE "射精箇所／フェラチオ","射精箇所／イラマチオ"
	SELECTCASE FLAG:FLAG_NAME
	CASE 0
		PRINTL Always Ask
	CASE 1
		PRINTL In Mouth
	CASE 2
		PRINTL On Face
	ENDSELECT

CASE "射精箇所／Ｖセックス"
	SELECTCASE FLAG:FLAG_NAME
	CASE 0
		PRINTL Always Ask
	CASE 1
		PRINTL In Pussy
	CASE 2
		PRINTL Outside
