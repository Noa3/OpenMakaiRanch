;FLAG:射精箇所／パイズリ→2410
;ARG >=10だと-10する関係でどうせ2400
FLAG_REF = 2400

;FLAG_NAMEを入れてCASEする
FLAG_NAME = %FLAGNAME:(ARG +FLAG_REF)%
PRINTFORM [{ARG,2}] %CONFIG_FLAGS_ENG(FLAG_NAME),35,LEFT%：
SELECTCASE FLAG_NAME
CASE "デフォルト脱衣状態／抵抗","デフォルト脱衣状態／無抵抗"
	;ver1.030で「毎回選ぶ」がなくなったので-1されてる
	;STR:デフォルト脱衣状態→8130
	STR_REF = 8130
	PRINTFORML %STRIP_SELECT_ENG(STR:(STR_REF +FLAG:FLAG_NAME))%

CASE "デフォルト拘束状態／抵抗","デフォルト拘束状態／無抵抗"
	;STR:拘束中→3930
	STR_REF = 3930
	SELECTCASE FLAG:FLAG_NAME
	CASE 0
		PRINTL No Restraints
	CASEELSE
		;拘束必要アイテム参照
		CALL BIND_NEED_ITEM(FLAG:FLAG_NAME -1)
		PRINTFORM %RESTRAINTS_LONG_ENG(RESULTS),20,LEFT%
		
		;必要アイテムIDが入っていれば表示
		IF !NEED_ITEM_ID
			PRINTL
		ELSEIF !NEED_ITEM_ID:1
			PRINTFORML ：＜%ITEMS_ENG(ITEMNAME:NEED_ITEM_ID)%＞ required
		ELSE
			PRINTFORML ：＜%ITEMS_ENG(ITEMNAME:NEED_ITEM_ID)%＞ and ＜%ITEMS_ENG(ITEMNAME:(NEED_ITEM_ID:1))%＞ required
		ENDIF
	ENDSELECT
CASE "デフォルト使用アイテム／ローション"
	IF !FLAG:FLAG_NAME
		PRINTL Do not use 
	ELSE
		SIF GETBIT(FLAG:FLAG_NAME,0)
			PRINT Ｖ
		SIF GETBIT(FLAG:FLAG_NAME,1)
			PRINT Ａ
		SIF GETBIT(FLAG:FLAG_NAME,2)
			PRINT Ｂ
