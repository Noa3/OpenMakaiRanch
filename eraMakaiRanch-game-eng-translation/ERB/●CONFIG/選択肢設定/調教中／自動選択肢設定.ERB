	CASE 0
		PRINTL Do not use
	CASE 1
        PRINTL Using ＜Aphrodisiac＞
    CASE 2
        PRINTL Using ＜Aphrodisiac Slime＞
	ENDSELECT
CASE "射精箇所／パイズリ","射精箇所／縦パイズリ"
	SELECTCASE FLAG:FLAG_NAME
	CASE 0
		PRINTL Always Ask
	CASE 1
		IF FLAG_NAME == "射精箇所／パイズリ"
			PRINTL In-Between Breasts（On Breasts if size is Small or below）
		ELSE
			PRINTL In-Between Breasts
		ENDIF
