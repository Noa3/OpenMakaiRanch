
;子供性経験割合設定
@TENDENCY_CONFIG_CHILD_VARGIN

;FLAG:子供候補割合／性経験／無垢→3220
FLAG_REF = 3220
STR_REF = 6590
FLAG:(FLAG_REF +9) = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +9)
CLEARLINE LINECOUNT
PRINTL Set sex experience distribution for child sized ningen.
CALL CONFIG_CHANGE_FLAG_CHECK
CALL CHILD_HEIGHT_RANGE
CALL PRINT_TENDENCY_BUTTON
CALL PRINTL_ALIGN(-10)

PRINTL [90] Same distribution as adults
CALL TENDENCY_CONFIG_FOOTER
CALL TENDENCY_INPUT
SELECTCASE RESULT
CASE 90
	PRINTL Copy sex experience distribution from adults?
	CALL ASK_YN
	IF !RESULT
		;FLAG:候補割合／性経験／無垢→3130,-90
		FOR LOCAL,0,10
			FLAG:(FLAG_REF +LOCAL) = FLAG:(FLAG_REF +LOCAL -90)
		NEXT
	ENDIF

CASE 98
	PRINTL Restore to Default?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TENDENCY_CONFIG_CHILD_VARGIN
CASE 99
	RETURN
ENDSELECT
RESTART



