
;乳首の色割合設定
@TENDENCY_CONFIG_NIPPLE_COLOR

;FLAG:候補割合／乳首の色／ピンク→3150
FLAG_REF = 3150
STR_REF = 6570
FLAG:(FLAG_REF +9) = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +9)
CLEARLINE LINECOUNT
PRINTL Set ningen nipple color distribution.
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
TOTAL_RATIO = FLAG:(FLAG_REF +9)
FOR LOCAL,0,9
	SIF FLAGNAME:(LOCAL +FLAG_REF) == ""
		BREAK
	
	;色つけたいので他と変える
	PRINTFORM [{LOCAL,3}] 
	SELECTCASE LOCAL
	CASE 0
		SETCOLOR NIPPLE_COLOR_CODE_PINK
		PRINT          Pink
	CASE 1
		SETCOLOR NIPPLE_COLOR_CODE_DEEPPINK
		PRINT     Deep Pink
	CASE 2
		SETCOLOR NIPPLE_COLOR_CODE_HOTPINK
		PRINT      Hot Pink
	CASE 3
		SETCOLOR NIPPLE_COLOR_CODE_CHERRYPINK
		PRINT   Cherry Pink
	CASE 4
		SETCOLOR NIPPLE_COLOR_CODE_LIGHTPINK
		PRINT    Light Pink
	CASE 5
		SETCOLOR NIPPLE_COLOR_CODE_RUBYRED
		PRINT      Ruby Red
	CASE 6
		SETCOLOR NIPPLE_COLOR_CODE_RUSSETBROWN
		PRINT    Dark Brown
	CASE 7
		SETCOLOR NIPPLE_COLOR_CODE_BROWN
		PRINT         Brown
	ENDSELECT
	PRINTFORM 　%UNICODE(0x2586)%%UNICODE(0x2586)%：
	SIF !FLAG:(LOCAL +FLAG_REF)
		SETCOLOR 0x606060
	PRINTFORM ：{FLAG:(LOCAL +FLAG_REF),4}
	PRINTPLAIN 　
	RESETCOLOR
	PRINTBUTTON "[+10]",LOCAL +100
	PRINTBUTTON "[-10]",LOCAL +200
	PRINTPLAIN 　
	PRINTBUTTON "[×2]",LOCAL +300
	PRINTBUTTON "[÷2]",LOCAL +400
	PRINTPLAIN 　
	IF !TOTAL_RATIO
		SIF !LOCAL
			CALL PRINT_WORD_COLOR("！Total weight is 0","黄")
		PRINTL
		CONTINUE
	ENDIF
	CONFIG_RATIO = FLAG:(FLAG_REF +LOCAL) *100
	CONFIG_RATIO /= TOTAL_RATIO
	IF !CONFIG_RATIO && FLAG:(FLAG_REF +LOCAL)
		PRINT close to 0% 
	ELSE
		PRINTFORM 　{CONFIG_RATIO,3}\% 
	ENDIF
	PRINTL
NEXT
CALL PRINTL_ALIGN(-10)
CALL TENDENCY_CONFIG_FOOTER
CALL TENDENCY_INPUT
IF RESULT == 98
	PRINTL Reset to Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TENDENCY_CONFIG_NIPPLE_COLOR
ELSEIF RESULT == 99
	RETURN
ENDIF
RESTART



