
;ボタン出力
;ARG→TOTAL_RATIOを上書きしない
@PRINT_TENDENCY_BUTTON(ARG)

DRAWLINE
SIF !ARG
	TOTAL_RATIO = FLAG:(FLAG_REF +9)
FOR LOCAL,0,9
	SIF FLAGNAME:(LOCAL +FLAG_REF) == ""
		BREAK
	PRINTFORM [{LOCAL,2}] %TENDENCY_EN(STR:(LOCAL +STR_REF)),24%
	SIF !FLAG:(LOCAL +FLAG_REF)
		SETCOLOR 0x606060
	PRINTFORM ：{FLAG:(LOCAL +FLAG_REF),4}
	PRINTPLAIN 　
	RESETCOLOR
	PRINTBUTTON "[+10]",LOCAL +100
	PRINTBUTTON "[-10]",LOCAL +200
	PRINTPLAIN 　
	PRINTBUTTON "[×2]",LOCAL +300
	PRINTBUTTON "[÷2]",LOCAL +400
	PRINTPLAIN 　
	
	;合計0だとこの先飛ばす
	IF !TOTAL_RATIO
		SIF !LOCAL
			CALL PRINT_WORD_COLOR("！Total Ratio is 0","黄")
		PRINTL
		CONTINUE
	ENDIF
	CONFIG_RATIO = FLAG:(FLAG_REF +LOCAL) *100
	CONFIG_RATIO /= TOTAL_RATIO
	
	;0ではないけど計算結果0なら「ほぼ0」
	IF !CONFIG_RATIO && FLAG:(FLAG_REF +LOCAL)
		PRINT close to 0% 
	ELSE
		PRINTFORM 　{CONFIG_RATIO,3}\% 
	ENDIF
	PRINTL
NEXT



;割合変更
@TENDENCY_INPUT

SELECTCASE INPUT_NUM
CASE 0 TO 8
	PRINTFORML Enter weights for %CONFIG_FLAGS_ENG(FLAGNAME:(INPUT_NUM +FLAG_REF))%.（0～1000）
	
	;性経験のときはちとわかりにくいので補足
	SIF FLAG_REF == 3130
		CALL VARGIN_TENDENCY_TIPS(INPUT_NUM)
	INPUT
	SIF RESULT >= 0 && RESULT <= 1000
		FLAG:(INPUT_NUM +FLAG_REF) = RESULT

CASE 100 TO 108
	;+10
	FLAG_NUM = (INPUT_NUM +FLAG_REF -100)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM +10,0,1000)

CASE 200 TO 208
	;-10
	FLAG_NUM = (INPUT_NUM +FLAG_REF -200)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM -10,0,1000)

CASE 300 TO 308
	;×2
	FLAG_NUM = (INPUT_NUM +FLAG_REF -300)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM *2,0,1000)

CASE 400 TO 408
	;÷2
	FLAG_NUM = (INPUT_NUM +FLAG_REF -400)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM /2,0,1000)

CASE 90
	;元関数に90を返してそっちで何するか判定
	RETURN 90

CASE 98
	RETURN 98

CASE 99
	;種族設定から来たらそっちに任せる
	IF FLAG_REF == 2620 || FLAG_REF == 2630
		RETURN 99
	
	;一応残しておく
	ELSEIF TOTAL_RATIO <= 0 || TOTAL_RATIO > 1000
		PRINTW Total weights must be from 1～1000.
	ELSE
		;OKなら元関数に99
		RETURN 99
	ENDIF
ENDSELECT



