
;子供体型割合設定
@TENDENCY_CONFIG_CHILD_SHAPE

;FLAG:子供候補割合／体型／標準体型→3210
FLAG_REF = 3210
STR_REF = 6560
FLAG:(FLAG_REF +9) = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +9)
CLEARLINE LINECOUNT
PRINTL Set body shape distribution for child sized ningen.
CALL CONFIG_CHANGE_FLAG_CHECK
CALL CHILD_HEIGHT_RANGE
CALL PRINT_TENDENCY_BUTTON
CALL PRINTL_ALIGN(-10)
PRINTL [90] Same distribution as adults
CALL TENDENCY_CONFIG_FOOTER
CALL TENDENCY_INPUT
SELECTCASE RESULT
CASE 90
	PRINTL Copy body shape distribution from adults?
	CALL ASK_YN
	IF !RESULT
		;FLAG:候補割合／体型／スレンダー→3120,-90
		FOR LOCAL,0,10
			FLAG:(FLAG_REF +LOCAL) = FLAG:(FLAG_REF +LOCAL -90)
		NEXT
	ENDIF

CASE 98
	PRINTL Restore to Default?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TENDENCY_CONFIG_CHILD_SHAPE
CASE 99
	RETURN
ENDSELECT
RESTART


