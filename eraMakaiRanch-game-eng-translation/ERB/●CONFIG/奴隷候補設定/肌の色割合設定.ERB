
;肌の色割合設定
@TENDENCY_CONFIG_SKIN_COLOR

;FLAG:候補割合／肌の色／アルビノ→3160
FLAG_REF = 3160
STR_REF = 6580
FLAG:(FLAG_REF +9) = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +9)
CLEARLINE LINECOUNT
PRINTL Select ningen skin color distribution.
CALL CONFIG_CHANGE_FLAG_CHECK
CALL PRINT_TENDENCY_BUTTON
CALL PRINTL_ALIGN(-10)
CALL TENDENCY_CONFIG_FOOTER
CALL TENDENCY_INPUT
IF RESULT == 98
	PRINTL Reset skin color distribution to default?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TENDENCY_CONFIG_SKIN_COLOR
ELSEIF RESULT == 99
	RETURN
ENDIF
RESTART



