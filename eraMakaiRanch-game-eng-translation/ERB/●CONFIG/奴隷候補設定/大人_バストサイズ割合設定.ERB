
;バストサイズ割合設定
@TENDENCY_CONFIG_BUST

;FLAG:候補割合／バストサイズ／絶壁→3110
FLAG_REF = 3110
STR_REF = 6550

;合計は+9
FLAG:(FLAG_REF +9) = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +9)
CLEARLINE LINECOUNT
PRINTL Set the breast size distribution for Ningen.
CALL CONFIG_CHANGE_FLAG_CHECK

;ボタン出力
CALL PRINT_TENDENCY_BUTTON
CALL PRINTL_ALIGN(-10)

;フッター出力
CALL TENDENCY_CONFIG_FOOTER

;割合変更　INPUT_NUMを渡してる
CALL TENDENCY_INPUT

;98→デフォルト　99→戻る
IF RESULT == 98
	PRINTL Restore to Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TENDENCY_CONFIG_BUST
ELSEIF RESULT == 99
	RETURN
ENDIF
RESTART


