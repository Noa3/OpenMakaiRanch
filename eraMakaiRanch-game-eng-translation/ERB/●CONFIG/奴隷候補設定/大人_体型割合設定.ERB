
;体型割合設定
@TENDENCY_CONFIG_SHAPE

;FLAG:候補割合／体型／スレンダー→3120
FLAG_REF = 3120
STR_REF = 6560
FLAG:(FLAG_REF +9) = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +9)
CLEARLINE LINECOUNT
PRINTL Set ningen body shape distribution.
CALL CONFIG_CHANGE_FLAG_CHECK
CALL PRINT_TENDENCY_BUTTON
CALL PRINTL_ALIGN(-10)
CALL TENDENCY_CONFIG_FOOTER
CALL TENDENCY_INPUT
IF RESULT == 98
	PRINTL Restore to Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TENDENCY_CONFIG_SHAPE
ELSEIF RESULT == 99
	RETURN
ENDIF
RESTART

