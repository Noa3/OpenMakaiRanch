
;ハーフリング
@TRIBE_FEATURE_CONFIG_HALFLING

CLEARLINE LINECOUNT
PRINTL Modifying【Halfling】
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTLC [ 0] Height Tends Towards【Child】
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／ハーフリング,0),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(4)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL If【Petite】or taller, replaced with【Child】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／ハーフリング"),INPUT_NUM)
CASE 98
	PRINTL Restore【Halfling】Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_HALFLING
CASE 99
	RETURN
ENDSELECT
RESTART


