
;狐耳族
@TRIBE_FEATURE_CONFIG_FOXEAR

CLEARLINE LINECOUNT
PRINTL Modifying【Fox-Ear】
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL Fixed：【Animal Ears】・【Tail】
PRINTLC [ 0] 【Subversive】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／狐耳族,0),1)
PRINTLC [ 1] 【Prideful】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／狐耳族,1),1)
PRINTLC [ 2] 【Lazy】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／狐耳族,2),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(9)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL Add the【煽動】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／狐耳族"),INPUT_NUM)
CASE 1
	PRINTL Add the【Prideful】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／狐耳族"),INPUT_NUM)
CASE 2
	PRINTL Add the【Lazy】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／狐耳族"),INPUT_NUM)
CASE 98
	PRINTL Restore【Fox-Ear】Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_FOXEAR
CASE 99
	RETURN
ENDSELECT
RESTART


