
;翼人
@TRIBE_FEATURE_CONFIG_WINGHUMAN

CLEARLINE LINECOUNT
PRINTL Modifying【Winged Race】
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTLC [ 0] Skin Tends Towards【Fair】
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／翼人,0),1)
PRINTLC [ 1] Body Tends Towards【Slender】
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／翼人,1),1)
PRINTLC [ 2] Hair Color Is【Azure】
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／翼人,2),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(5)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL If【Standard】、【Brown】、【Tanned】, replaced with【Fair】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／翼人"),INPUT_NUM)
CASE 1
	PRINTL Body figure limited to【Slender】and【Skinny】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／翼人"),INPUT_NUM)
CASE 2
	PRINTL Fix hair color to【Azure】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／翼人"),INPUT_NUM)
CASE 98
	PRINTL Restore【Winged Race】Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_WINGHUMAN
CASE 99
	RETURN
ENDSELECT
RESTART


