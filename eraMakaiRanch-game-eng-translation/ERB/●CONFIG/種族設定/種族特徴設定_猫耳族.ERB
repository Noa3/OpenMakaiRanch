
;猫耳族
@TRIBE_FEATURE_CONFIG_CATEAR

CLEARLINE LINECOUNT
PRINTL Modifying【Cat-Ear】
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL Fixed：【Animal Ears】・【Tail】
PRINTLC [ 0] 【Cat Tongue】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／猫耳族,0),1)
PRINTLC [ 1] 【Hates Baths】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／猫耳族,1),1)
PRINTLC [ 2] 【Moody】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／猫耳族,2),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(7)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL Add the【Cat Tongue】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／猫耳族"),INPUT_NUM)
CASE 1
	PRINTL Add the【Hates Baths】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／猫耳族"),INPUT_NUM)
CASE 2
	PRINTL Add the【Moody】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／猫耳族"),INPUT_NUM)
CASE 98
	PRINTL Restore【Cat-Ear】Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_CATEAR
CASE 99
	RETURN
ENDSELECT
RESTART


