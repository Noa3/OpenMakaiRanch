
;狸耳族
@TRIBE_FEATURE_CONFIG_RACCOONEAR

CLEARLINE LINECOUNT
PRINTL Modifying【Tanuki-Ear】
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL Fixed：【Animal Ears】・【Tail】
PRINTLC [ 0] 【Optimistic】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／狸耳族,0),1)
PRINTLC [ 1] 【Loves Baths】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／狸耳族,1),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(10)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL Add the【Optimistic】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／狸耳族"),INPUT_NUM)
CASE 1
	PRINTL Add the【Loves Baths】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／狸耳族"),INPUT_NUM)
CASE 98
	PRINTL Restore【Tanuki-Ear】Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_RACCOONEAR
CASE 99
	RETURN
ENDSELECT
RESTART


