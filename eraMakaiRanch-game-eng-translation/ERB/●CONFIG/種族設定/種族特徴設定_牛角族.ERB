
;牛角族
@TRIBE_FEATURE_CONFIG_COWHORN

CLEARLINE LINECOUNT
PRINTL Modifying【Cow-Horn】
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL Fixed：【Animal Ears】・【Tail】・【Horns】
PRINTLC [ 0] 【Glutton】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／牛角族,0),1)
PRINTLC [ 1] 【Docile】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／牛角族,1),1)
PRINTLC [ 2] Limit Breast Size to【Huge】・【Enormous】
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／牛角族,2),1)
PRINTLC [ 3] 【Innate Lactation】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／牛角族,3),1)
PRINTLC [ 4] Milk Capacity・Production＋30%
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／牛角族,4),1)
PRINTLC [ 5] Physical Strength＋200
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／牛角族,5),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(11)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL Add the【Glutton】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／牛角族"),INPUT_NUM)
CASE 1
	PRINTL Add the【Docile】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／牛角族"),INPUT_NUM)
CASE 2
	PRINTL Breast size limtied to【Huge】and【Enormous】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／牛角族"),INPUT_NUM)
CASE 3
	PRINTL Add the【Innate Lactation】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／牛角族"),INPUT_NUM)
CASE 4
	PRINTL Milk Capacity・Production is increased by 30% after base calculations
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／牛角族"),INPUT_NUM)
CASE 5
	PRINTL Strength is increased by 200 after base calculations
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／牛角族"),INPUT_NUM)
CASE 98
	PRINTL Restore【Cow-Horn】Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_COWHORN
CASE 99
	RETURN
ENDSELECT
RESTART


