
;羊角族
@TRIBE_FEATURE_CONFIG_SHEEPHORN

CLEARLINE LINECOUNT
PRINTL Modifying【Sheep-Horn】
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL Fixed：【Animal Ears】・【Tail】・【Horns】
PRINTLC [ 0] 【Docile】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／羊角族,0),1)
PRINTLC [ 1] Hair Color Is【White】
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／羊角族,1),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(12)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL Add the【Docile】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／羊角族"),INPUT_NUM)
CASE 1
	PRINTL Fix hair color to【White】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／羊角族"),INPUT_NUM)
CASE 98
	PRINTL Restore【Sheep-Horn】Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_SHEEPHORN
CASE 99
	RETURN
ENDSELECT
RESTART


