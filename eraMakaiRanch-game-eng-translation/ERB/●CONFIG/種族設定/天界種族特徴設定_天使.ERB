
;天使
@TRIBE_FEATURE_CONFIG_ANGEL

CLEARLINE LINECOUNT
PRINTL Modifying【Angel】
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL Fixed：Always Has Mana・【Celestial】
PRINTLC [ 0] Skin Tends Towards【Fair】
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,0),1)
PRINTLC [ 1] Always【Virgin】・【ＡVirgin】
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,1),1)
PRINTLC [ 2] Always【Virginity Barrier】
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,2),1)
PRINTLC [ 3] If【Virgin】,【Virtuous】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,3),1)
PRINTLC [ 4] 【Loved By Animals】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,4),1)
PRINTLC [ 5] 【Drug Resistant】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,5),1)
PRINTL
PRINTLC [10] 【Honest】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,10),1)
PRINTLC [11] 【High Pain Tolerance】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,11),1)
PRINTLC [12] 【Composed】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,12),1)
PRINTLC [13] 【Reserved】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,13),1)
PRINTLC [14] 【Shy】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,14),1)
PRINTLC [15] 【Devoted】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,15),1)
PRINTLC [16] 【Self-Conscious】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,16),1)
PRINTLC [17] 【Pure】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,17),1)
PRINTLC [18] 【Righteous】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／天使,18),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(18)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL If【Standard】、【Brown】、【Tanned】, replaced with【Fair】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 1
	PRINTL Adds the【Virgin】・【ＡVirgin】traits
	PRINTL ※Mutually exclusive with【Virginity Barrier】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
	SIF GETBIT(FLAG:種族設定／天使,1) && GETBIT(FLAG:種族設定／天使,2)
		CLEARBIT FLAG:種族設定／天使,2
CASE 2
	PRINTL Adds【Virginity Barrier】（and【Virgin】）traits
	PRINTL ※Mutually exclusive with Virginity option
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
	SIF GETBIT(FLAG:種族設定／天使,1) && GETBIT(FLAG:種族設定／天使,2)
		CLEARBIT FLAG:種族設定／天使,1
CASE 3
	PRINTL If【Virgin】, adds【Virtuous】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 4
	PRINTL Add the【Loved By Animals】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 5
	PRINTL Add the【Drug Resistant】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 10
	PRINTL Add the【Honest】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 11
	PRINTL Add the【High Pain Tolerance】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 12
	PRINTL Add the【Composed】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 13
	PRINTL Add the【Reserved】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 14
	PRINTL Add the【Shy】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 15
	PRINTL Add the【Devoted】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 16
	PRINTL Add the【Self-Conscious】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 17
	PRINTL Add the【Pure】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 18
	PRINTL Add the【Righteous】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／天使"),INPUT_NUM)
CASE 98
	PRINTL Restore【Angel】Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_ANGEL
CASE 99
	RETURN
ENDSELECT
RESTART


