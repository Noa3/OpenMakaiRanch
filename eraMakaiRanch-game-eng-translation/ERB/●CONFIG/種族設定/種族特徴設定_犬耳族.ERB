
;犬耳族
@TRIBE_FEATURE_CONFIG_DOGEAR

CLEARLINE LINECOUNT
PRINTL Modifying【Dog-Ear】
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL Fixed：【Animal Ears】・【Tail】
PRINTLC [ 0] 【Sharp Teeth】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／犬耳族,0),1)
PRINTLC [ 1] 【Curious】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／犬耳族,1),1)
PRINTLC [ 2] 【Smell Sensitive】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／犬耳族,2),1)
PRINTLC [ 3] 【Submissive】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／犬耳族,3),1)
PRINTLC [ 4] Physical Strength＋200
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／犬耳族,4),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(6)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL Add the【Sharp Teeth】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／犬耳族"),INPUT_NUM)
CASE 1
	PRINTL Add the【Curious】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／犬耳族"),INPUT_NUM)
CASE 2
	PRINTL Add the【Smell Sensitive】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／犬耳族"),INPUT_NUM)
CASE 3
	PRINTL Add the【Submissive】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／犬耳族"),INPUT_NUM)
CASE 4
	PRINTL Strength is increased by 200 after base calculations
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／犬耳族"),INPUT_NUM)
CASE 98
	PRINTL Restore【Dog-Ear】Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_DOGEAR
CASE 99
	RETURN
ENDSELECT
RESTART


