	PRINTL ※Mutually exclusive with【Arrogant】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／妖狐"),INPUT_NUM)
	SIF GETBIT(FLAG:種族設定／妖狐,12) && GETBIT(FLAG:種族設定／妖狐,13)
		CLEARBIT FLAG:種族設定／妖狐,13
CASE 13
	PRINTL Add the【Arrogant】trait
	PRINTL ※Mutually exclusive with【Prideful】
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／妖狐"),INPUT_NUM)
