		PRINTL Probably due to how long it takes to a wet tail
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／妖狐"),INPUT_NUM)
CASE 17
	PRINTL Add the【Vain】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／妖狐"),INPUT_NUM)
CASE 98
