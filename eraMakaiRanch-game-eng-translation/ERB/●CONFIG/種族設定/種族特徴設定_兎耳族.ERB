
;兎耳族
@TRIBE_FEATURE_CONFIG_RABBITEAR

CLEARLINE LINECOUNT
PRINTL Modifying【Rabbit-Ear】
CALL CONFIG_CHANGE_FLAG_CHECK
DRAWLINE
PRINTL Fixed：【Animal Ears】・【Tail】
PRINTLC [ 0] 【Timid】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／兎耳族,0),1)
PRINTLC [ 1] 【Lazy】Trait
CALL PRINT_ONOFF(GETBIT(FLAG:種族設定／兎耳族,1),1)
CALL PRINTL_ALIGN
CALL PRINT_SLAVE_CONFIG_FOOTER(8)
SELECTCASE INPUT_NUM
CASE 0
	PRINTL Add the【Timid】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／兎耳族"),INPUT_NUM)
CASE 1
	PRINTL Add the【Lazy】trait
	CALL ASK_BIT_ONOFF(GETNUM(FLAG,"種族設定／兎耳族"),INPUT_NUM)
CASE 98
	PRINTL Restore【Rabbit-Ear】Defaults?
	CALL ASK_YN
	SIF !RESULT
		CALL DEFAULT_TRIBE_FEATURE_CONFIG_RABBITEAR
CASE 99
	RETURN
ENDSELECT
RESTART


