
;身長でのプレイ制限設定
@HEIGHT_PLAY_LIMIT_CONFIG

CLEARLINE LINECOUNT
PRINTL Disable specific sex options based on height difference （Only valid during training）
DRAWLINE
PRINTL If height difference is too big （bigger difference allowed with larger breast size）：
PRINT [ 0] Hide breast sucking while inserting    
CALL PRINT_ONOFF(GETBIT(＃身長差制限／挿入乳吸い＃),1)
PRINTL
PRINTL ・If height difference is too big：
PRINT [ 1] Hide kissing while inserting           
CALL PRINT_ONOFF(GETBIT(＃身長差制限／挿入キス＃),1)
PRINTL
PRINTL ・If height difference is too small：
PRINT [ 2] Hide Paizuri during standing restraints
CALL PRINT_ONOFF(GETBIT(＃身長差制限／立ちパイズリ＃),1)

CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 98
	PRINTL Disable height-based sex restrictions?
	CALL ASK_YN
	SIF !RESULT
		FLAG:身長でのプレイ制限BIT = 0
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_HEIGHT_PLAY_LIMIT_CONFIG(RESULT)
ENDSELECT
RESTART



;設定変更
;ARG→INPUT
@CHANGE_HEIGHT_PLAY_LIMIT_CONFIG(ARG)

;ひっくり返すだけ
INVERTBIT FLAG:身長でのプレイ制限BIT,ARG


