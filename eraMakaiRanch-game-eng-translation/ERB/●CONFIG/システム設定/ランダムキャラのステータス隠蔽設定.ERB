
;ランダムキャラのステータス隠蔽設定
@HIDE_RANDOM_STATUS_CONFIG

CLEARLINE LINECOUNT
PRINTL Set part of the status for random characters to【Unknown】until discovered or reshuffled.
DRAWLINE
PRINTLC [ 0] Work ABL
CALL PRINT_ONOFF(GETBIT(＃ステータス隠蔽／業務ABL＃),1)
PRINTLC [ 1] Sex ABL
CALL PRINT_ONOFF(GETBIT(＃ステータス隠蔽／性ABL＃),1)
PRINTLC [ 2] Traits
CALL PRINT_ONOFF(GETBIT(＃ステータス隠蔽／素質＃),1)
PRINTLC [ 3] Sensitivity
CALL PRINT_ONOFF(GETBIT(＃ステータス隠蔽／感度＃),1)
PRINTLC [ 4] Sexual Traits
CALL PRINT_ONOFF(GETBIT(＃ステータス隠蔽／性体質＃),1)
PRINTLC [ 5] Breast Details
CALL PRINT_ONOFF(GETBIT(＃ステータス隠蔽／おっぱい詳細＃),1)
PRINTLC [ 6] Pubic Hair
CALL PRINT_ONOFF(GETBIT(＃ステータス隠蔽／陰毛＃),1)

CALL PRINTL_ALIGN(-5)
CALL DEFAULT_VOID_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 98
	PRINTL Reset status concealment settings to default?
	CALL ASK_YN
	SIF !RESULT
		FLAG:ランダムキャラステータス隠蔽BIT = 0
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_HIDE_RANDOM_STATUS_CONFIG(RESULT)
ENDSELECT
RESTART



;設定変更
;ARG→INPUT
@CHANGE_HIDE_RANDOM_STATUS_CONFIG(ARG)

;ひっくり返すだけ
INVERTBIT FLAG:ランダムキャラステータス隠蔽BIT,ARG


