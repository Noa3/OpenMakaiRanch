
;ハードモード設定
@HARDMODE_CONFIG

CLEARLINE LINECOUNT
PRINTL ＜Hard Mode＞ Settings
CALL PRINTL_WORD_COLOR("《 Hard Mode Settings 》can only be changed before the game starts or in Developer Mode","黄")
PRINTL If at least one option here is set to ON and not in [DEVELOP],[CUSTOM] or [EASY], the difficulty will be displayed as [HARD].
CALL PRINT_DIFFICULTY
DRAWLINE
FLAG_REF = 3700

;半減の場合STRを使う
;STR:噴乳量 = 6860
STR_REF = 6860 -20
FOR LOCAL,0,70
	SIF FLAGNAME:(LOCAL +FLAG_REF) == ""
		CONTINUE
	IF LOCAL == 20
		PRINTL
		PRINTL 《 Parameter Halving 》
	ENDIF
	CALL PRINT_CONFIG_HARDMODE(LOCAL)
NEXT
CALL PRINTL_ALIGN(-5)
CALL ON_OFF_BUTTON_FOOTER
BINPUT
PRINTL
SELECTCASE RESULT
CASE 82
	PRINTL For all toggable options, no explaination for [ON] will be given.
	CALL ASK_ONOFF
	FLAG:ON／OFF項目の詳細を飛ばして反転 = RESULT
CASE 98
	;日付が1日目以降かつ開発者モード以外の場合RETURN
	SIF !FLAG:開発者モード && DAY
		RETURN
	PRINTL Do you want to reset all <Hard Mode> settings to OFF?
	CALL ASK_YN
	SIF !RESULT
		VARSET FLAG,0,3700,3800
CASE 99
	RETURN
CASEELSE
	CALL CHANGE_HARDMODE_CONFIG(RESULT)
ENDSELECT
RESTART



;ARG→LOCAL　FLAG_REFを足すことでフラグ番号
@PRINT_CONFIG_HARDMODE(ARG)

FLAG_NAME = %FLAGNAME:(ARG +FLAG_REF)%
SELECTCASE FLAG_NAME
CASEELSE
	IF ARG >= 20
		PRINTFORM [{ARG,2}] %CONFIG_FLAGS_ENG(STR:(STR_REF +ARG)),32%
	ELSE
		PRINTFORM [{ARG,2}] %CONFIG_FLAGS_ENG(FLAG_NAME),32%
	ENDIF
	CALL PRINT_ONOFF(FLAG:FLAG_NAME)
ENDSELECT
PRINTL



;ARG→INPUT
@CHANGE_HARDMODE_CONFIG(ARG)

SIF !FLAG:開発者モード && DAY
	RETURN
FLAG_NUM = ARG +FLAG_REF
FLAG_NAME = %FLAGNAME:FLAG_NUM%
CALL CHANGE_CONFIG_INVERTBIT
SIF RESULT
	RETURN
SELECTCASE FLAG_NAME
CASE "ランダムキャラのみ許可"
	PRINTL If ON, disables [Town Hall]'s [Special Release Gate]・[Ningen Search]・[Recollection]
	;PRINTL （「ランダムキャラのみ」とは言いますが、ゲームを進めることで固定入力可能な奴隷には影響しません。）
	PRINTL For those who want only random and plot-given characters.
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "半減／噴乳量"
	PRINTL The milk ejection volume during milking will be reduced by half.
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "半減／母乳容量・生産力"
	PRINTL Slave breast milk capacity and production volume will be reduced by half.
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "半減／母乳出荷価格"
	PRINTL Funds obtained from breast milk shipments will be reduced by half.
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "半減／業務EXP獲得量"
	PRINTL EXP gained from executing business schedules will be reduced by half.
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "半減／性EXP獲得量"
	PRINTL EXP gained from executing training schedules will be reduced by half.
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "半減／戦闘与ダメージ"
	PRINTL Damage dealt by allies (makai side) to ningens during combat will be reduced by half.
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT

CASE "半減／快楽値"
	PRINTL Sexual pleasure to body parts during the execution of training schedules will be reduced by half.
	PRINTL
	CALL ASK_ONOFF
	FLAG:FLAG_NUM = RESULT
ENDSELECT



