
;デフォルト設定
;GLOBALがない場合に来たり初期化するときに来たりする
;ARG→どのページのデフォルト設定をするか
@SET_DEFAULT_CONFIG(ARG)

SELECTCASE ARG
CASE 0
	;全部
	CALL DEFAULT_CONFIG_DISPLAY
	CALL DEFAULT_CONFIG_CHOICE
	CALL DEFAULT_CONFIG_SYSTEM
	CALL DEFAULT_CONFIG_TRIBE
	CALL DEFAULT_CONFIG_SLAVE_BODY
	CALL DEFAULT_CONFIG_DIFFICULTY
CASE 1
	CALL DEFAULT_CONFIG_DISPLAY
CASE 2
	CALL DEFAULT_CONFIG_CHOICE
CASE 3
	CALL DEFAULT_CONFIG_SYSTEM
CASE 4
	CALL DEFAULT_CONFIG_TRIBE
CASE 5
	;奴隷候補設定可能かどうかで変更範囲が変わる
	IF FLAG:奴隷候補設定可能
		CALL DEFAULT_CONFIG_SLAVE_BODY
	ELSE
		CALL DEFAULT_CONFIG_SLAVE_BODY_MINI
	ENDIF
CASE 6
	CALL DEFAULT_CONFIG_DIFFICULTY
ENDSELECT

