
;コンフィグ設定
@GAME_CONFIG
#DIM DYNAMIC PAGE

PAGE_MAX = 6
CLEARLINE LINECOUNT
ALIGNMENT CENTER
SELECTCASE PAGE
CASE 0
	CALL LIST_CONFIG_INDEX
CASE 1
	CALL LIST_CONFIG_DISPLAY
CASE 2
	CALL LIST_CONFIG_CHOICE
CASE 3
	CALL LIST_CONFIG_SYSTEM
CASE 4
	CALL LIST_CONFIG_TRIBE
CASE 5
	CALL LIST_CONFIG_SLAVE_BODY
CASE 6
	CALL LIST_CONFIG_DIFFICULTY
ENDSELECT
CALL PRINTL_ALIGN
CALL PRINT_NOW_PAGE(PAGE,1,1)
PRINTFORM [82] Fast ON／OFF Toggle
CALL PRINT_ONOFF(FLAG:ON／OFF項目の詳細を飛ばして反転,1)
PRINTLC [90] Save／Load／Restore System Data
PRINTLC 　
PRINTL [ 99] Done
BINPUT
PRINTL
SELECTCASE RESULT
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 82
	PRINTL For all toggleable options, no explanation for [ON] will be given.
	CALL ASK_ONOFF
	FLAG:ON／OFF項目の詳細を飛ばして反転 = RESULT
CASE 89
	PAGE = 0
CASE 90
	CALL CONFIG_DEFAULT_SYSTEM_SAVE(PAGE)
CASE 99
	;一応もっかい難易度表示計算
	CALL PRINT_DIFFICULTY_CALC
	
	;システムデータにセーブするか聞く　ない場合聞かない
	LOADGLOBAL
	IF !RESULT
		CALL SAVE_GLOBAL_CONFIG
	ELSEIF !GLOBAL:システムデータのバージョン
		PRINTL Save System Data?
		CALL ASK_YN
		SIF !RESULT
			CALL SAVE_GLOBAL_CONFIG
	ENDIF
	
	;スタートキットコンフィグ→スタートアップの最後にやる
	RETURN
CASEELSE
	SELECTCASE PAGE
	CASE 0
		PAGE = RESULT
	CASE 1
		CALL CHANGE_CONFIG_DISPLAY(RESULT)
	CASE 2
		CALL CHANGE_CONFIG_CHOICE(RESULT)
	CASE 3
		CALL CHANGE_CONFIG_SYSTEM(RESULT)
	CASE 4
		CALL CHANGE_CONFIG_TRIBE(RESULT)
	CASE 5
		CALL CHANGE_CONFIG_SLAVE_BODY(RESULT)
	CASE 6
		CALL CHANGE_CONFIG_DIFFICULTY(RESULT)
	ENDSELECT
ENDSELECT
RESTART

