
;母乳体質化　この訳でいいかは知らない
@MAKEUP_MILK

MARK:母乳体質 = 1
SOURCE:母乳体質化 = 1
CALL MAKEUP_MILK_MESSAGE_1
CALL KOJO_PRINT("イベント","母乳体質化")
CALL MAKEUP_MILK_MESSAGE_END

;↓の中にWAITがあるので一工夫
CALL MILKTANK_CALC
CALL PURPOSE_CHANGE_CALC("体を元に戻してもらう")
SIF !SOURCE:目的変更
	WAIT
CALL SET_STAIN_TARGET("乳首","母乳")




;魔力母乳体質化
@MAKEUP_MAGIC_MILK

;元々母乳体質かどうか
IF MARK:母乳体質
	CALL MAKEUP_MAGIC_MILK_MESSAGE_1
	CALL KOJO_PRINT("イベント","魔力母乳体質化")
	MARK:魔力母乳体質 = 1
	CALL MAKEUP_MAGIC_MILK_MESSAGE_END
ELSE
	CALL MAKEUP_MILK_MESSAGE_1
	CALL MAKEUP_MAGIC_MILK_MESSAGE_2
	CALL KOJO_PRINT("イベント","母乳体質化")
	CALL KOJO_PRINT("イベント","魔力母乳体質化")
	MARK:母乳体質 = 1
	MARK:魔力母乳体質 = 1
	SOURCE:母乳体質化 = 1
	CALL MAKEUP_MAGIC_MILK_MESSAGE_END
	CALL MILKTANK_CALC
ENDIF
CALL PURPOSE_CHANGE_CALC("体を元に戻してもらう")
SIF !SOURCE:目的変更
	WAIT
CALL SET_STAIN_TARGET("乳首","母乳")


