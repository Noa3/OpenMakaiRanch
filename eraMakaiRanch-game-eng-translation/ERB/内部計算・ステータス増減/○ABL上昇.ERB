
;EXP見てABL上昇判定する
@ABL_UP

ABL_UP_EXIST = 0
MILKTANK_UP = 0
CALL ABL_UP_WORK
CALL ABL_UP_SENSITIVE_ECSTASY
CALL ABL_UP_SENSITIVE_EXP
RESETCOLOR

;母乳生産力増加フラグあればそちらへ
SIF MILKTANK_UP
	CALL MILKTANK_CALC



;仕事系
@ABL_UP_WORK

;仕事系のABLは水色
SETCOLOR 0x00FFFF
FOR LOCAL,20,30
	;次までの経験値を求める式
	CALL NEXT_EXP(ABLNAME:LOCAL)
	
	;MAXは99
	SIF RESULT > EXP:LOCAL || ABL:LOCAL >= 99
		CONTINUE
	ABL:LOCAL ++
	
	;増加後に次回ABL増加を上回っていたら-1にする
	CALL NEXT_EXP(ABLNAME:LOCAL)
	SIF RESULT <= EXP:LOCAL
		EXP:LOCAL = RESULT -1
	
	;LvUPメッセージ呼び出し
	CALL PRINT_ABL_LVUP(LOCAL,ABL_UP_EXIST)
	ABL_UP_EXIST ++
	
	;LOCALを-1してもう1回やる
	LOCAL --
NEXT



;H系絶頂回数系
@ABL_UP_SENSITIVE_ECSTASY

;5感覚と搾乳中毒・触手中毒は絶頂回数により上がるのでEXPを下げずにRESTARTする
;H系はピンク
SETCOLOR 0xFF70FF
FOR LOCAL,0,5
	CALL NEXT_EXP(ABLNAME:LOCAL)
	SIF RESULT > EXP:LOCAL || ABL:LOCAL >= 99
		CONTINUE
	ABL:LOCAL ++
	CALL PRINT_ABL_LVUP(LOCAL,ABL_UP_EXIST)
	ABL_UP_EXIST ++
	LOCAL --
NEXT



;H系経験値
@ABL_UP_SENSITIVE_EXP

;中毒・生産力
SETCOLOR 0xFF70FF
FOR LOCAL,41,100
	SIF ABLNAME:LOCAL == ""
		CONTINUE
	CALL NEXT_EXP(ABLNAME:LOCAL)
	SIF RESULT > EXP:LOCAL || ABL:LOCAL >= 99 || (ABLNAME:LOCAL == "母乳濃度" && ABL:LOCAL == 5)
		CONTINUE
	ABL:LOCAL ++
	CALL NEXT_EXP(ABLNAME:LOCAL)
	SIF RESULT <= EXP:LOCAL
		EXP:LOCAL = RESULT -1
	
	;母乳濃度は刻印で処理するのでLV表示しない
	SIF ABLNAME:LOCAL == "母乳濃度"
		CONTINUE
	CALL PRINT_ABL_LVUP(LOCAL,ABL_UP_EXIST)
	ABL_UP_EXIST ++
	
	;母乳生産力が増加する場合フラグ立て
	SIF ABLNAME:LOCAL == "母乳生産力"
		MILKTANK_UP = 1
	LOCAL --
NEXT



;LvUPメッセージ
;ARG→ABL番号
;ARG:1→ABL_UP_EXIST
@PRINT_ABL_LVUP(ARG,ARG:1)

;ABL_UP_EXISTが0なら改行+名前表示
IF !ARG:1
	SIF !LINEISEMPTY()
		PRINTL
	PRINTFORM LvUP! %CALLNAME%：
ENDIF
PRINTFORM 【%ABL_ENG(ABLNAME:ARG)%Lv{ABL:ARG -1}→{ABL:ARG}】


