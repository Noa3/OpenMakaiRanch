
;リソースに上限を入れておく
;9223372036854775807を超えるとオーバーフローするかと
@RESOURCE_LIMIT

MAXBASE:0:霊力 = LIMIT(MAXBASE:0:霊力,0,RESOURCE_MAX)
MAXBASE:0:魔力 = LIMIT(MAXBASE:0:魔力,0,RESOURCE_MAX)

;資金マイナスってこともまれにある
MONEY = LIMIT(MONEY,-1 *RESOURCE_MAX,RESOURCE_MAX)
MONEY:貯蔵霊力 = LIMIT(MONEY:貯蔵霊力,0,RESOURCE_MAX)
MONEY:貢献PT = LIMIT(MONEY:貢献PT,0,RESOURCE_MAX)
FLAG:母乳合計出荷量 = LIMIT(FLAG:母乳合計出荷量,0,RESOURCE_MAX)
FLAG:母乳合計出荷金額 = LIMIT(FLAG:母乳合計出荷金額,0,RESOURCE_MAX)

;スキルポイントも上限つけとく　多分いかないけど
FOR LOCAL,20,25
	MONEY:LOCAL = LIMIT(MONEY:LOCAL,0,RESOURCE_MAX)
NEXT








