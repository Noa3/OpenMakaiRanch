
;カラーコードの設定
;髪色
@AUTOSET_HAIR_COLOR_CODE

SELECTCASE CSTR:髪色
CASE "黒髪"
	CFLAG:カラーコード／髪 = 0
CASE "金髪"
	CFLAG:カラーコード／髪 = 0xFFD700
CASE "栗毛"
	CFLAG:カラーコード／髪 = 0xD26930
CASE "赤髪"
	CFLAG:カラーコード／髪 = 0xFF2020
CASE "桃髪"
	CFLAG:カラーコード／髪 = 0xF19CA7
CASE "青髪"
	CFLAG:カラーコード／髪 = 0x49BDF0
CASE "緑髪"
	CFLAG:カラーコード／髪 = 0x00FF00
CASE "銀髪"
	CFLAG:カラーコード／髪 = 0xA9AAAA
CASE "紫髪"
	CFLAG:カラーコード／髪 = 0xFF82FF
CASE "白髪"
	CFLAG:カラーコード／髪 = 0xF8F8F8
CASE "橙髪"
	CFLAG:カラーコード／髪 = 0xF5A323
CASE "空色髪"
	CFLAG:カラーコード／髪 = 0x7FFFD4
ENDSELECT


;目の色
@AUTOSET_EYE_COLOR_CODE

;左右別のほうが手動時便利
CALL AUTOSET_EYE_COLOR_CODE_RIGHT
CALL AUTOSET_EYE_COLOR_CODE_LEFT



