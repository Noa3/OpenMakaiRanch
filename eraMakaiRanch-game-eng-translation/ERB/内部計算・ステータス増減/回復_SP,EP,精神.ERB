
;先に名前表示
;ARG→非表示優先コンフィグ
@HEAL_NAME(ARG)

SELECTCASE FLAG:休憩時回復表示形式
CASE 1
	SIF !HEAL_PRINT_DONE
		PRINTFORM %CALLNAME_DIGIT()% 
CASE 2
	SIF !ARG
		PRINTFORM %CALLNAME_DIGIT()% 
CASE 3
	PRINTFORM %CALLNAME_DIGIT()% 
ENDSELECT



;休憩時の気力割合回復
;ARG→回復割合
;ARG:1→非表示優先コンフィグ
@SP_HEAL_RATIO(ARG,ARG:1)

;崩壊状態は回復しない、必要ないなら表示しない
SIF BASE:気力 >= MAXBASE:気力 || CFLAG:崩壊
	RETURN

;割合回復
HEAL = MAXBASE:気力 *ARG /100
CALL RANDOM_FIX(HEAL,10,"気力回復量")
HEAL += FIX
HEAL -= (HEAL %10)
BASE:気力 = LIMIT(BASE:気力 +HEAL,0,MAXBASE:気力)
SELECTCASE FLAG:休憩時回復表示形式
CASE 1
	SIF !HEAL_PRINT_DONE && !ARG:1
		PRINTFORM SP+{ARG,2}\% 
CASE 2
	SIF !ARG:1
		PRINTFORM SP+{ARG,2}\% 
CASE 3
	PRINTFORM SP+{ARG,2}\% → %VALUE_DIGIT(BASE:気力)% 
ENDSELECT




;休憩時の精神力回復
;ARG→回復量
;ARG:1→非表示優先コンフィグ
@MIND_HEAL(ARG,ARG:1)

;精神力少しずつ回復、10%で崩壊から回復　崩壊時はHPMAXでないなら回復しない、必要ないなら表示もなし
SIF (CFLAG:崩壊 && BASE:体力 < MAXBASE:体力) || BASE:精神力 >= MAXBASE:精神力
	RETURN
HEAL = ARG
CALL RANDOM_FIX(HEAL,10,"精神回復量")
HEAL += FIX
BASE:精神力 = LIMIT(BASE:精神力 +HEAL,0,MAXBASE:精神力)
SELECTCASE FLAG:休憩時回復表示形式
CASE 1
	SIF !HEAL_PRINT_DONE && !ARG:1
		PRINTFORM Will+%PRINT_PALAM_PERCENT(HEAL)% 
CASE 2
	SIF !ARG:1
		PRINTFORM Will+%PRINT_PALAM_PERCENT(HEAL)% 
CASE 3
	PRINTFORM Will+%PRINT_PALAM_PERCENT(HEAL)% → %PRINT_PALAM_PERCENT(BASE:精神力)% 
ENDSELECT

;精神力回復時の崩壊回復
CALL RECOVER_MIND_BREAK



;精神回復時、崩壊で10%以上のとき回復
@RECOVER_MIND_BREAK

SIF !CFLAG:崩壊 || BASE:精神力 < BASE_BREAK_HEAL_MIND
	RETURN
CFLAG:崩壊 = 0
SIF !LINEISEMPTY()
	PRINTL
CALL PRINTL_WORD_COLOR,@"After a long rest, %CALLNAME% regained her senses.","水色"
CALL PURPOSE_CHANGE_CALC("絶望")



;霊力回復　あなただけ
;ARG→回復割合
;ARG:1→非表示優先コンフィグ
@EP_HEAL(ARG,ARG:1)

;TARGETがあなた以外ならおわり、MAXなら帰る
SIF TARGET != 0 || BASE:霊力 == MAXBASE:霊力
	RETURN
HEAL = MAXBASE:霊力 *ARG /100
CALL RANDOM_FIX(HEAL,5,"霊力回復量")
HEAL += FIX
BASE:霊力 = LIMIT(BASE:霊力 +HEAL,0,MAXBASE:霊力)
SELECTCASE FLAG:休憩時回復表示形式
CASE 1
	SIF !HEAL_PRINT_DONE && !ARG:1
		PRINTFORM EP+%VALUE_DIGIT(HEAL)% 
CASE 2
	SIF !ARG:1
		PRINTFORM EP+%VALUE_DIGIT(HEAL)% 
CASE 3
	PRINTFORM EP+%VALUE_DIGIT(HEAL)% → %VALUE_DIGIT(BASE:霊力)% 
ENDSELECT



;精力回復　あなただけ
;ARG→回復割合
;ARG:1→非表示優先コンフィグ
@VIGOR_HEAL(ARG,ARG:1)

;TARGETがあなた以外ならおわり、MAXなら帰る
SIF TARGET != 0 || BASE:精力 == MAXBASE:精力
	RETURN
HEAL = MAXBASE:精力 *ARG /100
CALL RANDOM_FIX(HEAL,5,"精力回復量")
HEAL += FIX

;絶倫のときMAXにする
SIF ITEM:絶倫 && GETBIT(＃有効／絶倫＃)
	HEAL = MAXBASE:精力
BASE:精力 = LIMIT(BASE:精力 +HEAL,0,MAXBASE:精力)
SELECTCASE FLAG:休憩時回復表示形式
CASE 1
	SIF !HEAL_PRINT_DONE && !ARG:1
		PRINTFORM Vigor +%VALUE_DIGIT(HEAL)% 
CASE 2
	SIF !ARG:1
		PRINTFORM Vigor +%VALUE_DIGIT(HEAL)% 
CASE 3
	PRINTFORM Vigor +%VALUE_DIGIT(HEAL)% → %VALUE_DIGIT(BASE:精力)% 
ENDSELECT








