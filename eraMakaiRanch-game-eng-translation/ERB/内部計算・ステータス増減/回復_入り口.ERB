
;回復処理もろもろ
;HEAL_PRINT_DONEは来る前のところで0にリセットしておく
;寝落ち
@FALL_ASLEEP

CALL HEAL_NAME
CALL HP_HEAL_RATIO(10)
SIF !LINEISEMPTY()
	PRINTL



;休憩
;ARG→コンフィグにより非表示：牛舎など
@REST_HEAL(ARG)

;自室あるかで変化
HP_BEFORE = BASE:体力
CALL HEAL_NAME(ARG)
IF EQUIP:自室
	HEAL = 25
ELSE
	HEAL = 20
ENDIF
SIF ＃着用下着下／名称＃ == "触手服" && BASE:0:魔力
	HEAL /= 2
CALL HP_HEAL_RATIO(HEAL,ARG)

;回復前の体力基準に気力回復
;割合と同じ、5～30or20%
HEAL = 100 *HP_BEFORE /MAXBASE:体力
IF EQUIP:自室
	HEAL = LIMIT(HEAL,5,30)
ELSE
	HEAL = LIMIT(HEAL,5,20)
ENDIF
SIF ＃着用下着下／名称＃ == "触手服" && BASE:0:魔力
	HEAL /= 2
CALL SP_HEAL_RATIO(HEAL,ARG)

IF EQUIP:自室
	HEAL = 300
ELSE
	HEAL = 100
ENDIF
SIF ＃着用下着下／名称＃ == "触手服" && BASE:0:魔力
	HEAL /= 2
CALL MIND_HEAL(HEAL,ARG)
HEAL_PRINT_DONE ++
SIF !LINEISEMPTY()
	PRINTL



;就寝
;ARG→1はコンフィグにより非表示：牛舎など
@SLEEP_HEAL(ARG)

HP_BEFORE = BASE:体力
CALL HEAL_NAME(ARG)
IF EQUIP:自室
	HEAL = 40
ELSE
	HEAL = 30
ENDIF
SIF ＃着用下着下／名称＃ == "触手服" && BASE:0:魔力
	HEAL /= 2
CALL HP_HEAL_RATIO(HEAL,ARG)

;回復前の体力基準に気力回復→5～50or30%
HEAL = 100 *HP_BEFORE /MAXBASE:体力
IF EQUIP:自室
	HEAL = LIMIT(HEAL,5,50)
ELSE
	HEAL = LIMIT(HEAL,5,30)
ENDIF
SIF ＃着用下着下／名称＃ == "触手服" && BASE:0:魔力
	HEAL /= 2
CALL SP_HEAL_RATIO(HEAL,ARG)

IF EQUIP:自室
	HEAL = 30
ELSE
	HEAL = 10
ENDIF
SIF ＃着用下着下／名称＃ == "触手服" && BASE:0:魔力
	HEAL /= 2
CALL MIND_HEAL(HEAL,ARG)
CALL EP_HEAL(2,ARG)
CALL MP_HEAL_RATIO(ARG)
CALL VIGOR_HEAL(50,ARG)
HEAL_PRINT_DONE ++
SIF !LINEISEMPTY()
	PRINTL



;体内休息
@VORE_SLEEP_HEAL

