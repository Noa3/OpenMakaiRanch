;風呂
;ARG→1はコンフィグにより非表示：あなたと呼んだ奴隷以外など
@BATHING_HEAL(ARG)

;温泉あると回復量増加
CALL HEAL_NAME
IF ITEM:天然温泉
	HEAL = 30
ELSE
	HEAL = 20
ENDIF
CALL HP_HEAL_RATIO(HEAL,ARG)

IF ITEM:天然温泉
	HEAL = 30
ELSE
	HEAL = 20
ENDIF
CALL SP_HEAL_RATIO(HEAL,ARG)

IF ITEM:天然温泉
	HEAL = 20
ELSE
	HEAL = 10
ENDIF
CALL MIND_HEAL(HEAL,ARG)

IF ITEM:天然温泉
	HEAL = 40
ELSE
	HEAL = 10
ENDIF
CALL VIGOR_HEAL(HEAL,ARG)
HEAL_PRINT_DONE ++
SIF !LINEISEMPTY()
	PRINTL



;2人で風呂
@DUO_BATHING_HEAL

SAVE_TARGET = TARGET
TARGET = 0
CALL BATHING_HEAL

;2人分出すために一旦リセット
HEAL_PRINT_DONE = 0
TARGET = SAVE_TARGET
CALL BATHING_HEAL



;食事での回復
;ARG→計算したHEAL
@DINNER_HEAL(ARG)

CALL HEAL_NAME
CALL HP_HEAL_CONST(ARG)
CALL SP_HEAL_RATIO(ARG)
CALL MIND_HEAL(ARG)
HEAL_PRINT_DONE ++
SIF !LINEISEMPTY()
	PRINTL



;ペットと遊んだあとの回復
;TARGET,ANIMAL,PET_NAME指定済み
@PLAY_ANIMAL_AFTER_HEAL

