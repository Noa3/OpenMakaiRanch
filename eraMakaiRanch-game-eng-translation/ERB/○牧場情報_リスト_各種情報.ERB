@RANCH_STATUS_FACILITY

CALL SHOW_COW_HEALTH(1)
CALL SHOW_FINANCE_VALUE(1)
CALL SHOW_BATHLOOM_CLEAN(1)
IF FLAG:調合中薬品ID
	PRINTFORML Mixing：%ITEMS_ENG(ITEMNAME:(FLAG:調合中薬品ID))%　　Progress：{MONEY:調合進行度}／{ITEMPRICE:(FLAG:調合中薬品ID) *2} 
ELSE
	CALL PRINTL_WORD_COLOR,@"No Drug Mixing Orders","灰"
ENDIF
PRINTL
LOCALS = 霊力抽出装置
PRINTFORML %ITEMS_ENG(LOCALS),25,LEFT%：{ITEM:LOCALS} 

;どの魔力貯蔵器があるか
;ITEM:魔改造魔力貯蔵器→53
;逆順FORを珍しく使う
ITEM_REF = 53
ITEM_MAX = -4
LOCALS = Mana Reservoir grade
FOR LOCAL,ITEM_REF,ITEM_REF +ITEM_MAX,-1
	SIF ITEMNAME:LOCAL == ""
		CONTINUE
	IF ITEM:LOCAL
		PRINTFORML %LOCALS,20%：%ITEMS_ENG(ITEMNAME:LOCAL)%
		BREAK
	ENDIF
	
	;どれもない時ないと表示
	SIF LOCAL == 50
		CALL PRINTL_WORD_COLOR,@"No Mana Reservoir","灰"
NEXT

;ITEM:牛床マット→40
ITEM_REF = 40
ITEM_MAX = 10
FOR LOCAL,ITEM_REF,ITEM_REF +ITEM_MAX
	SIF ITEMNAME:LOCAL == ""
		CONTINUE
	PRINTFORM %ITEMS_ENG(ITEMNAME:LOCAL),25,LEFT%：
	IF !ITEM:LOCAL
		CALL PRINTL_WORD_COLOR("0 days left","灰")
	ELSE
		PRINTFORML {ITEM:LOCAL,2} days left
	ENDIF
NEXT

;龍のタマ→補正・揃ってるとき案内
LOCALS = 龍のタマ
IF ITEM:LOCALS >= 7
	CALL PRINTL_WORD_COLOR,@"%ITEMS_ENG(LOCALS),25%：{ITEM:LOCALS}：[%CALLNAME:0%]Select → Can be used with [Use Item]","水色"
ELSE
	SIF !ITEM:LOCALS
		SETCOLOR 0x606060
	PRINTFORM %ITEMS_ENG(LOCALS),25,LEFT%：{ITEM:LOCALS} 
	IF FLAG:龍のタマ発見率補正 < 0
		PRINTFORML ＜Discovery Chance Corretion：{FLAG:龍のタマ発見率補正}\%＞
	ELSE
		PRINTFORML ＜Discovery Chance Corretion：+{FLAG:龍のタマ発見率補正}\%＞
	ENDIF
ENDIF
RESETCOLOR
PRINTL



