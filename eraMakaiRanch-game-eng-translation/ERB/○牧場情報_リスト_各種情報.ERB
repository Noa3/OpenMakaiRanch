;魔界レベル
@RANCH_STATUS_MAKAI_LV
#DIM TAX_RATIO

;納税関連フラグIDの一斉取得
CALL GET_TAX_FLAG_REF
PRINTL 　《 Makai Level 》
TOTAL_RATIO = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +10)

;一応0除算しないように
IF !TOTAL_RATIO
	FLAG:FLAG_REF = 1
	RESTART
ENDIF
FOR LOCAL,0,10
	SIF FLAGNAME:(FLAG_REF +LOCAL) == ""
		CONTINUE
	TAX_RATIO = FLAG:(FLAG_REF +LOCAL) *100
	TAX_RATIO /= TOTAL_RATIO
	PRINTFORM %MAKAI_INSTITUTIONS_ENG(STR:(STR_REF:1 +LOCAL)),25% Lv：{FLAG:(FLAG_REF:2 +LOCAL),2} Tax Rate：
	
	;0ではないけど計算結果0なら「ほぼ0」
	IF !TAX_RATIO && FLAG:(FLAG_REF +LOCAL)
		PRINT ≒0% 
	ELSE
		PRINTFORM {TAX_RATIO,3}\% 
	ENDIF
	PRINTFORM Accumulated Funds：%VALUE_DIGIT(FLAG:(FLAG_REF:1 +LOCAL)),8%G 
	CALL MAKAI_LVUP_NEED_MONEY_CALC(FLAG:(FLAG_REF:2 +LOCAL))
	CALL PRINT_COLORBAR(FLAG:(FLAG_REF:1 +LOCAL),RESULT,8,BARCOLORSET("青緑"),RESULT:1)
	PRINTL
NEXT
PRINTL



;ペット
@RANCH_STATUS_PET

;ペット小屋は確定
PRINTFORML Pet House：{ITEM:ペット小屋 -FLAG:空きペット小屋数}／{ITEM:ペット小屋}（In Use／Total）

;ペット関係のフラグ番号一斉取得
CALL GET_PET_FLAG_REF
FOR LOCAL,0,10
	ANIMAL = %ITEMNAME:(ITEM_REF +LOCAL)%
	IF ANIMAL == ""
		CONTINUE
	ELSEIF !ITEM:(ITEM_REF +LOCAL)
		CALL PRINTL_WORD_COLOR,@"%ITEMS_ENG(ANIMAL)%","灰"
		CONTINUE
	ENDIF
	PRINTFORM %PET_NAME_REF(ANIMAL)%　
	CALL PRINT_PET_GENDER(FLAG:(FLAG_REF +LOCAL),1)
	
	;あなたへのなつき度表示
	{
	PRINTFORM 　　Affection：{BASE:0:(BASE_REF +LOCAL) /100,3}\%　
	Fur：%SAVESTR:(STR_REF:1 +LOCAL)%%SAVESTR:(STR_REF:2 +LOCAL)%
	}
	CALL PRINT_PET_SHAPE(ANIMAL,1)
	PRINTFORML 　Food：%PRINT_PET_FOOD(ANIMAL)%
NEXT
PRINTL



