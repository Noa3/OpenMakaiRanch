
;コンフィグによりk,M,G,T表示or万,億,兆or短縮なし
;ARG→数値
;ARGS→母乳の場合（Lにするため）：合計量の時だけ来る
@VALUE_DIGIT(ARG,ARGS)
#FUNCTIONS
#DIMS TOSTR_VALUE
#DIM MILK_VALUE

MILK_VALUE = 0
SELECTCASE FLAG:桁数の短縮表示形式
CASE 0
	TOSTR_VALUE = %TOSTR(ARG,"#,0")%
	SIF ARGS == "母乳"
		TOSTR_VALUE += MILK_COUNTING()
CASE 1
	;kMGT表示
	;母乳量の場合
	IF ARGS == "母乳"
		MILK_VALUE = 1
		IF ARG < (10 *1000)
			TOSTR_VALUE = %TOSTR(ARG)%
			MILK_VALUE = 0
		ELSEIF ARG < (10 *1000 *1000)
			TOSTR_VALUE = %TOSTR(ARG /1000)%
		ELSEIF ARG < (10 *1000 *1000 *1000)
			TOSTR_VALUE = %TOSTR(ARG /1000 /1000)%k
		ELSEIF ARG < (10 *1000 *1000 *1000 *1000)
			TOSTR_VALUE = %TOSTR(ARG /1000 /1000 /1000)%M
		ELSE
			TOSTR_VALUE = %TOSTR(ARG /1000 /1000 /1000 /1000)%G
		ENDIF
		TOSTR_VALUE += MILK_COUNTING(MILK_VALUE)
	ELSE
		IF ARG < (10 *1000)
			TOSTR_VALUE = %TOSTR(ARG)%
		ELSEIF ARG < (10 *1000 *1000)
			TOSTR_VALUE = %TOSTR(ARG /1000)%k
		ELSEIF ARG < (10 *1000 *1000 *1000)
			TOSTR_VALUE = %TOSTR(ARG /1000 /1000)%M
		ELSEIF ARG < (10 *1000 *1000 *1000 *1000)
			TOSTR_VALUE = %TOSTR(ARG /1000 /1000 /1000)%G
		ELSE
			TOSTR_VALUE = %TOSTR(ARG /1000 /1000 /1000 /1000)%T
		ENDIF
	ENDIF
CASE 2
	;万億兆表示
	IF ARG < (10 *10000)
		TOSTR_VALUE = %TOSTR(ARG)%
	ELSEIF ARG < (10 *10000 *10000)
		TOSTR_VALUE = %TOSTR(ARG /10000)%万
	ELSEIF ARG < (10 *10000 *10000 *10000)
		TOSTR_VALUE = %TOSTR(ARG /10000 /10000)%億
	ELSE
		TOSTR_VALUE = %TOSTR(ARG /10000 /10000 /10000)%兆
	ENDIF
	SIF ARGS == "母乳"
		TOSTR_VALUE += MILK_COUNTING()
ENDSELECT
RETURNF TOSTR_VALUE




