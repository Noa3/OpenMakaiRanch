
;文中で指定の文章（単語）だけ色替え
@PRINT_WORD_COLOR(ARGS,ARGS:1)

;指定した色に変更
SETCOLOR BARCOLORSET(ARGS:1)
PRINTFORM %ARGS%
RESETCOLOR

;色替えして改行
@PRINTL_WORD_COLOR(ARGS,ARGS:1)

SETCOLOR BARCOLORSET(ARGS:1)
PRINTFORML %ARGS%
RESETCOLOR

;色替えしてPRINTFORMLC
@PRINTLC_WORD_COLOR(ARGS,ARGS:1)

SETCOLOR BARCOLORSET(ARGS:1)
PRINTFORMLC %ARGS%
RESETCOLOR

;色替えしてWAIT
@PRINTW_WORD_COLOR(ARGS,ARGS:1)

SETCOLOR BARCOLORSET(ARGS:1)
PRINTFORMW %ARGS%
RESETCOLOR


