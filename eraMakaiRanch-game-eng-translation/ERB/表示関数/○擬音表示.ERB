;乳房露出擬音
@ONOMATOPOEIA_STRIP_BUST

;ここは繰り返さない
CALL ONOMATOPOEIA_COMMON
SELECTCASE ABL:バストサイズ
CASE 0
	PRINT Bounce...❤
CASE 1 TO BUSTSIZE_並乳 -1
	PRINT Plump❤
CASE BUSTSIZE_並乳 TO BUSTSIZE_巨乳 -1
	PRINT Ploon❤
CASE BUSTSIZE_巨乳 TO BUSTSIZE_豊乳 -1
	SELECTCASE RAND:3
	CASE 0
		PRINT Ploon❤
	CASE 1
		PRINT Bounce❤
	CASEELSE
		PRINT Jiggle❤
	ENDSELECT
CASE BUSTSIZE_豊乳 TO BUSTSIZE_爆乳 -1
	SELECTCASE RAND:5
	CASE 0
		PRINT Ploon❤
	CASE 1
		PRINT Bounce❤
	CASEELSE
		PRINT Boing❤
	ENDSELECT

;爆乳以上
CASEELSE
	SELECTCASE RAND:5
	CASE 0
		PRINT Jiggle❤
	CASE 1
		PRINT Boing❤
	CASEELSE
		PRINT Bounce❤
	ENDSELECT
ENDSELECT

;淫乳で+2コ
