
;擬音用の共通
@ONOMATOPOEIA_COMMON

;擬音用文字色
SETCOLOR FLAG:擬音表示カラーコード

;適当にスペース
FOR LOCAL,0,RAND:10
	PRINT  
NEXT



;擬音表示：こちらに一本化
;ARGS→基本分類　ARGS:1→ピストン時の部位とか
@ONOMATOPOEIA(ARGS,ARGS:1)

SELECTCASE ARGS
CASE "乳吸い"
	;個別でONOFF見てOFFなら帰る
	SIF !GETBIT(FLAG:擬音表示,0)
		RETURN
	IF BASE:母乳容量 || NOWEX:噴乳
		SELECTCASE RAND:4
		CASE 0
			CALL ONOMATOPOEIA_SUCK
		CASEELSE
			CALL ONOMATOPOEIA_MILK_SUCK
		ENDSELECT
	ELSE
		CALL ONOMATOPOEIA_SUCK
	ENDIF
	
CASE "乳揉み"
	SIF !GETBIT(FLAG:擬音表示,1)
		RETURN
	
	;おっぱいサイズで擬音変えてみる
	IF ABL:バストサイズ >= BUSTSIZE_爆乳
		CALL ONOMATOPOEIA_RUB_VERY_BIG_BOOB
	ELSEIF ABL:バストサイズ >= BUSTSIZE_巨乳
		CALL ONOMATOPOEIA_RUB_BIG_BOOB
	ELSEIF ABL:バストサイズ == 0
		CALL ONOMATOPOEIA_RUB_WALL_BOOB
	ELSE
		CALL ONOMATOPOEIA_RUB_BOOB
	ENDIF
	
CASE "搾乳器"
	SIF !GETBIT(FLAG:擬音表示,2)
		RETURN
	CALL ONOMATOPOEIA_LACTATION_CUP
	
CASE "舐める"
	SIF !GETBIT(FLAG:擬音表示,3)
		RETURN
	CALL ONOMATOPOEIA_LICK

CASE "ピストン"
	SIF !GETBIT(FLAG:擬音表示,4)
		RETURN
	
	;該当部位が濡れているかの判定
	IF ARGS:1 == "Ｖ" && PALAM:Ｖ潤滑 >= 10000
		CALL ONOMATOPOEIA_PISTON_LUBRICATION
	ELSEIF ARGS:1 == "Ａ" && PALAM:Ａ潤滑 >= 10000
		CALL ONOMATOPOEIA_PISTON_LUBRICATION
	ELSEIF ARGS:1 == "Ｍ"
		CALL ONOMATOPOEIA_PISTON_MOUSE
	ELSEIF ARGS:1 == "パイズリ"
		CALL ONOMATOPOEIA_PISTON_PAIZURI
	ELSE
		CALL ONOMATOPOEIA_PISTON
	ENDIF

CASE "射精"
	SIF !GETBIT(FLAG:擬音表示,5)
		RETURN
	CALL ONOMATOPOEIA_EJACULATION
	
CASE "クリ吸い"
	SIF !GETBIT(FLAG:擬音表示,6)
		RETURN
	CALL ONOMATOPOEIA_SUCK
	
CASE "乳包み花弁搾乳触手"
	SIF !GETBIT(FLAG:擬音表示,7)
		RETURN
	
	;2段にしよう
	CALL ONOMATOPOEIA_LACTATION_TENTACLE_FLOWER1
	CALL ONOMATOPOEIA_LACTATION_TENTACLE_FLOWER2
	
CASE "透明カップ搾乳触手"
	SIF !GETBIT(FLAG:擬音表示,8)
		RETURN
	CALL ONOMATOPOEIA_LACTATION_TENTACLE_CUP1
	CALL ONOMATOPOEIA_LACTATION_CUP
	
CASE "搾乳ワーム触手"
	SIF !GETBIT(FLAG:擬音表示,9)
		RETURN
	CALL ONOMATOPOEIA_LACTATION_TENTACLE_WORM
	
CASE "触手ピストン"
	SIF !GETBIT(FLAG:擬音表示,10)
		RETURN
	
	;濡れている場合と同じにした
	CALL ONOMATOPOEIA_PISTON_LUBRICATION
	
CASE "乳房露出"
	SIF !GETBIT(FLAG:擬音表示,11)
		RETURN
	CALL ONOMATOPOEIA_STRIP_BUST
	
CASE "乳首露出"
	SIF !GETBIT(FLAG:擬音表示,12)
		RETURN
	CALL ONOMATOPOEIA_STRIP_NIPPLE

ENDSELECT
RESETCOLOR
SIF !LINEISEMPTY()
	PRINTL



;濡れている場合のピストン擬音
@ONOMATOPOEIA_PISTON_LUBRICATION

;擬音個別表示にしたので関数使う
CALL ONOMATOPOEIA_COMMON
FOR LOCAL,0,6
	SELECTCASE RAND:10
	CASE 0
    	PRINT Slurp
	CASE 1
    	PRINT Squish
	CASE 2
    	PRINT Plop
    ONOMATO_SKIP ++
	CASE 3
    	PRINT Squelch
	CASE 4
    	PRINT Slurp
	CASEELSE
    	PRINT Squelch
	ENDSELECT
	
	;1/2で「っ」追加　ONOMATO_SKIPが1ならスキップ
	SIF !RAND:2 && !ONOMATO_SKIP
		PRINT !
	ONOMATO_SKIP = 0
	SELECTCASE RAND:100
	CASE 0 TO 69
		PRINT ❤ 
	CASEELSE
		PRINT ❤❤ 
	ENDSELECT
NEXT



