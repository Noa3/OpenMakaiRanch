
;開発などリソース表示
;ARGS→表示リソース
@SHOW_RESOURCE_UPGRADE(ARGS)

DRAWLINE
CALL SHOW_DATE

;CALL SHOW_WEATHER
SELECTCASE ARGS
CASE "資金"
	CALL SHOW_MONEY(1)
CASE "アイテム作成"
	CALL SHOW_MONEY(1)
	CALL SHOW_STORAGE_POWER
	CALL SHOW_MASTER_EP
CASE "調教AP","魔術AP","触手AP","禁断AP"
	PRINTFORML 　【%AP_ENG(ARGS)%】%VALUE_DIGIT(MONEY:ARGS)%

CASE "ALL"
	CALL SHOW_MONEY(1)
	{
	PRINTFORML 【Training AP】%VALUE_DIGIT(MONEY:調教AP)%　【Magic AP】%VALUE_DIGIT(MONEY:魔術AP)% 
	【Tentacle AP】%VALUE_DIGIT(MONEY:触手AP)%　【Forbidden AP】%VALUE_DIGIT(MONEY:禁断AP)%　
	}
	CALL SHOW_STORAGE_POWER
	CALL SHOW_MASTER_EP
ENDSELECT
DRAWLINE



;町役場用
@SHOW_RESOURCE_HALL

DRAWLINE
CALL SHOW_DATE
CALL SHOW_WEATHER
PRINTL
CALL SHOW_MONEY
CALL SHOW_BUDGET(1)
CALL SHOW_MASTER_EP
PRINTFORML Mana Shackles：{FLAG:追跡中人数 +CMATCH(EQUIP:魔力枷,1)}／{ITEM:魔力枷}（In Use＋Reserved／Total）
DRAWLINE



;研究所用
@SHOW_RESOURCE_INSTITUTE

DRAWLINE
CALL SHOW_DATE
CALL SHOW_WEATHER
PRINTL
CALL SHOW_STORAGE_POWER
CALL SHOW_MONEY
CALL SHOW_BUDGET
PRINTFORML 　　　Contribution Points：%VALUE_DIGIT(MONEY:貢献PT)%pt
DRAWLINE




;通常店用
@SHOW_RESOURCE_SHOP

CALL SHOW_DATE
CALL SHOW_WEATHER
PRINTL
CALL SHOW_MONEY
CALL SHOW_BUDGET(1)
DRAWLINE



;ローン組む場合
@SHOW_RESOURCE_SHOP_LOAN

CALL SHOW_DATE
CALL SHOW_WEATHER
PRINTL
CALL SHOW_MONEY
CALL SHOW_LOAN
DRAWLINE



;メインメニュー
@SHOW_RESOURCE_MAIN

DRAWLINE
PRINT 　
CALL SHOW_DATE
CALL SHOW_WEATHER
CALL SHOW_MONEY(1)
PRINT 　
CALL SHOW_STORAGE_POWER
CALL SHOW_COW_HEALTH(2)
CALL SHOW_FINANCE_VALUE
CALL SHOW_BATHLOOM_CLEAN(1)
DRAWLINE



;資金表示
;ARG→改行
@SHOW_MONEY(ARG)

;行になんかあれば空欄つける
SIF !LINEISEMPTY()
	PRINT 　　　
PRINTFORM 　Funds：%VALUE_DIGIT(MONEY)%G　
SIF ARG
	PRINTL



;経費計上可能額の表示
;ARG→改行
@SHOW_BUDGET(ARG)

SIF !LINEISEMPTY()
	PRINT 　　　
PRINTFORM Expenses：%VALUE_DIGIT(MONEY:経費計上)%／%VALUE_DIGIT(FLAG:最大一日売上)%G 
CALL PRINT_COLORBAR(MONEY:経費計上,FLAG:最大一日売上,8,BARCOLORSET("赤"),RESULT:1)
SIF ARG
	PRINTL



;ローン可能額の表示
@SHOW_LOAN
#DIM LOAN_VALUE

SIF !LINEISEMPTY()
	PRINT 　　　

;ローン可能額→最大一日売上*20*自治体レベル
IF !FLAG:魔界レベル／オカチ街
	CALL PRINTL_WORD_COLOR("Loan：Okachi City Lv1 required","灰")
	RETURN
ENDIF
LOAN_VALUE = FLAG:最大一日売上 *20 *FLAG:魔界レベル／オカチ街
PRINTFORM Loan：%VALUE_DIGIT(MONEY:ローン)%／%VALUE_DIGIT(LOAN_VALUE)%G 
CALL PRINT_COLORBAR(MONEY:ローン,LOAN_VALUE,8,BARCOLORSET("赤"),RESULT:1)
PRINTL



;貯蔵霊力魔力表示
;ARG→途中で改行
@SHOW_STORAGE_POWER(ARG)

PRINTFORMLC Stored Spirit Energy：%VALUE_DIGIT(MONEY:貯蔵霊力)%EP
SIF ARG
	PRINTL

;貯蔵できない状態なら帰る
IF !FLAG:貯蔵魔力上限値
	CALL PRINTL_WORD_COLOR("No Mana Reservoir","灰")
	RETURN
ENDIF
PRINTFORM Stored Mana：%VALUE_DIGIT(MONEY:貯蔵魔力)%／%VALUE_DIGIT(FLAG:貯蔵魔力上限値)%MP 
CALL PRINT_COLORBAR(MONEY:貯蔵魔力,FLAG:貯蔵魔力上限値,8,BARCOLORSET("濃紫"),RESULT:1)
PRINTL



;あなた霊力魔力表示
;ARG→改行
@SHOW_MASTER_EP(ARG)

PRINTFORM %CALLNAME:0%'s Spirit Energy：%VALUE_DIGIT(BASE:0:霊力)%／%VALUE_DIGIT(MAXBASE:0:霊力)%EP 
CALL PRINT_COLORBAR(BASE:0:霊力,MAXBASE:0:霊力,8,BARCOLORSET(""),RESULT:1)
IF ARG
	PRINTL
ELSE
	PRINT 　　　
ENDIF
PRINTFORM %CALLNAME:0%'s Mana：%VALUE_DIGIT(BASE:0:魔力)%／%VALUE_DIGIT(MAXBASE:0:魔力)%MP 
CALL PRINT_COLORBAR(BASE:0:魔力,MAXBASE:0:魔力,8,BARCOLORSET("濃紫"),RESULT:1)
PRINTL



;魔界乳牛の健康度表示
;ARG→1：改行　2：メインメニューの1スペース
@SHOW_COW_HEALTH(ARG)

SIF !LINEISEMPTY()
	PRINT 　　　
SIF ARG == 2
	PRINT 　
PRINTFORM Cattle Health：{FLAG:乳牛健康度,3} 
CALL PRINT_COLORBAR(FLAG:乳牛健康度,100,8,BARCOLORSET("青緑"),RESULT:1)
SIF ARG == 1
	PRINTL



;事務作業量表示
;ARG→改行
@SHOW_FINANCE_VALUE(ARG)

SIF !LINEISEMPTY()
	PRINT 　　　
PRINTFORM Administrative Workload：{FLAG:事務作業量} 
CALL PRINT_COLORBAR(FLAG:事務作業量,20,8,BARCOLORSET("赤"),RESULT:1)
SIF FLAG:事務作業量 >= 20
	CALL PRINT_WORD_COLOR("！Work is piling up！","黄")
SIF ARG
	PRINTL



;風呂の掃除進捗
;ARG→改行
@SHOW_BATHLOOM_CLEAN(ARG)

SIF !LINEISEMPTY()
	PRINT 　　　
IF FLAG:あなた用風呂掃除完了
	PRINT Clean Bathtub：◯
ELSE
	PRINT Clean Bathtub：☓
ENDIF

;大浴場建ててるかで変える
IF ITEM:大浴場
	PRINTFORM 　　　Bathhouse：{FLAG:大浴場掃除完了度}\% 
	CALL PRINT_COLORBAR(FLAG:大浴場掃除完了度,100,8,BARCOLORSET("水色"),RESULT:1)
ENDIF
SIF ARG
	PRINTL



