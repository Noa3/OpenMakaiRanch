
;母乳の商品名表示
;ARG→0：名前を右揃え+商品名左揃え　1：揃えない
@PRINT_MILK_NAME(ARG)
#DIMS MILKWORD

SIF !MARK:母乳体質
	RETURN
MILKWORD =

;フレーバーミルク判定追加
IF CSTR:フレーバーミルク != ""
	CALL PRINT_MILK_NAME_PREFIX(ARG)
	MILKWORD += RESULTS
	MILKWORD += CSTR:フレーバーミルク
	CALL PRINT_MILK_NAME_RESULT(ARG,MILKWORD)

ELSEIF CSTR:母乳商品名自由記述 != ""
	SETCOLOR 0xFF70FF
	IF ARG
		PRINTFORM %CSTR:母乳商品名自由記述%
	ELSE
		PRINTFORM %CSTR:母乳商品名自由記述,(FLAG:キャラ名前欄幅 +28)%
	ENDIF

ELSEIF CSTR:母乳商品名濃度自動 != ""
	CALL PRINT_MILK_NAME_PREFIX(ARG)
	MILKWORD += RESULTS
	MILKWORD += CSTR:母乳商品名濃度自動
	CALL PRINT_MILK_NAME_RESULT(ARG,MILKWORD)
	
ELSE
	CALL PRINT_MILK_NAME_PREFIX(ARG)
	MILKWORD += RESULTS
	SIF !EXP:肉体改造
		MILKWORD += "All-Natural"
	SIF TALENT:処女
		MILKWORD += "Virgin "
	SIF GROUPMATCH(CSTR:身長,"小柄","子供体型") && TALENT:巨乳
		MILKWORD += "Oppai Loli "
	SIF GROUPMATCH(CSTR:身長,"幼児体型","子供体型") && ABL:バストサイズ < BUSTSIZE_並乳
		MILKWORD += "Loli "
	SIF CFLAG:上位種族 || TALENT:天界種族
		MILKWORD += CSTR:種族
	SIF CSTR:初期値／身分 == "王族"
		MILKWORD += "Royal "
	SIF CSTR:初期値／身分 == "貴族"
		MILKWORD += "Aristocratic "
		
	;CSV取り込みキャラ用の素質
	SIF TALENT:ＪＳ
		MILKWORD += "ＪＳ "
	SIF TALENT:ＪＣ
		MILKWORD += "ＪＣ "
	SIF TALENT:ＪＫ
		MILKWORD += "ＪＫ "
		
	IF MARK:魔力母乳体質
		MILKWORD += SAVESTR:表記／魔力母乳 
	ELSE
		MILKWORD += SAVESTR:表記／母乳 
	ENDIF
	CALL PRINT_MILK_NAME_RESULT(ARG,MILKWORD)
ENDIF
RESETCOLOR



;接頭語共通
;ARG→0：名前を右揃え+商品名左揃え　1：揃えない
@PRINT_MILK_NAME_PREFIX(ARG)

IF ARG
	PRINTFORM %CALLNAME%'s Special 
ELSE
	PRINTFORM %CALLNAME_DIGIT()%'s Special
ENDIF
SELECTCASE ABL:母乳濃度
CASE 0
	RESULTS =
CASE 1
	RESULTS = Thick 
CASE 2
	RESULTS = Fine 
CASE 3
	RESULTS = Rich 
CASE 4
	RESULTS = Potent 
CASE 5
	RESULTS = Premium 
ENDSELECT



;結果表示共通
;ARG→0：名前を右揃え+商品名左揃え　1：揃えない
;ARGS→MILKWORD
@PRINT_MILK_NAME_RESULT(ARG,ARGS)

SETCOLOR 0xFF70FF
IF ARG
	PRINTFORM %ARGS%
ELSE
	PRINTFORM %ARGS,24,LEFT%
ENDIF



