IF GETBIT(＃ステータス隠蔽／おっぱい詳細＃) && !GETBIT(＃再シャッフル／おっぱい＃) && FLAG:キャラメイク隠蔽有効
	CALL PRINTL_WORD_COLOR("[Nipple color unknown] ","灰")
	RETURN
ENDIF
SETCOLOR CFLAG:カラーコード／乳首
