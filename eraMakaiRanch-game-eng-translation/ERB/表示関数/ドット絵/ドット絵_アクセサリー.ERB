
;アクセサリー
@PRINT_PORTRAIT_ACCESSORY

CALL PRINT_PORTRAIT_ACCESSORY_EYE
CALL PRINT_PORTRAIT_ACCESSORY_HEAD
CALL PRINT_PORTRAIT_ACCESSORY_ARM
CALL PRINT_PORTRAIT_ACCESSORY_LEG
CALL PRINT_PORTRAIT_ACCESSORY_NECK
CALL PRINT_PORTRAIT_ACCESSORY_JACKET





;アクセサリ(眼)
@PRINT_PORTRAIT_ACCESSORY_EYE

SIF TFLAG:一時的脱衣／眼 || !EQUIP:装備中ID／眼
	RETURN
SELECTCASE ITEMNAME:(EQUIP:装備中ID／眼)
CASE "メガネ"
	SPRITECREATED @"%CSTR:(EQUIP:装備中ID／眼)%メガネ"
	IF RESULT
		PRT:12 = <nonbutton pos='%PY_2%'><img src='%CSTR:(EQUIP:装備中ID／眼)%メガネ' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>
	ELSE
		PRT:12 = <nonbutton pos='%PY_2%'><img src='メガネ' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>
	ENDIF
CASE "伊達メガネ"
	SPRITECREATED @"%CSTR:(EQUIP:装備中ID／眼)%伊達メガネ"
	IF RESULT
		PRT:12 = <nonbutton pos='%PY_2%'><img src='%CSTR:(EQUIP:装備中ID／眼)%伊達メガネ' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>
	ELSE
		PRT:12 = <nonbutton pos='%PY_2%'><img src='伊達メガネ' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>
	ENDIF
ENDSELECT



;アクセサリ(頭)
@PRINT_PORTRAIT_ACCESSORY_HEAD

SPRITECREATED @"%ITEMNAME:(EQUIP:装備中ID／頭)%"
SIF !RESULT || TFLAG:一時的脱衣／頭 || !EQUIP:装備中ID／頭
	RETURN
SPRITECREATED @"%CSTR:(EQUIP:装備中ID／頭)%%ITEMNAME:(EQUIP:装備中ID／頭)%"
PRT:11 = <nonbutton pos='%PY_2%'><img src='%CSTR:(EQUIP:装備中ID／頭)%%ITEMNAME:(EQUIP:装備中ID／頭)%' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>
SIF !RESULT
	PRT:11 = <nonbutton pos='%PY_2%'><img src='%ITEMNAME:(EQUIP:装備中ID／頭)%' height='%PY_3%' ypos = '%PY_FIX%'></nonbutton>



