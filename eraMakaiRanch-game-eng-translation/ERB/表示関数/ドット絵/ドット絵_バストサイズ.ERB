
;バストサイズ
@PRINT_PORTRAIT_BUSTSIZE

IF TALENT:絶壁 || CSTR:状態／あなたの子 == "成長中"
	PRTCHR_2 = 絶壁
ELSEIF TALENT:貧乳
	PRTCHR_2 = 貧乳
	PRT:1 = <nonbutton pos='%PY_2%'><img src='%PRTCHR_1%_貧乳_%CSTR:カテゴリ／肌の色%' height='%PY_3_2%' ypos = '%PY_1%'></nonbutton>
ELSEIF TALENT:並乳
	PRTCHR_2 = 並乳
	PRT:1 = <nonbutton pos='%PY_2%'><img src='%PRTCHR_1%_並乳_%CSTR:カテゴリ／肌の色%' height='%PY_3_2%' ypos = '%PY_1%'></nonbutton>
ELSEIF TALENT:巨乳
	PRTCHR_2 = 巨乳
	PRT:1 = <nonbutton pos='%PY_2%'><img src='%PRTCHR_1%_巨乳_%CSTR:カテゴリ／肌の色%' height='%PY_3_2%' ypos = '%PY_1%'></nonbutton>
ELSEIF TALENT:豊乳
	PRTCHR_2 = 豊乳
	PRT:1 = <nonbutton pos='%PY_2%'><img src='%PRTCHR_1%_豊乳_%CSTR:カテゴリ／肌の色%' height='%PY_3_2%' ypos = '%PY_1%'></nonbutton>
ELSEIF TALENT:爆乳
	PRTCHR_2 = 爆乳
	PRT:1 = <nonbutton pos='%PY_2%'><img src='%PRTCHR_1%_爆乳_%CSTR:カテゴリ／肌の色%' height='%PY_3_2%' ypos = '%PY_1%'></nonbutton>

;ドット絵はとりあえず神乳・魔乳を同じにするよ
ELSEIF TALENT:神乳 || TALENT:魔乳
	PRTCHR_2 = 神乳
	PRT:1 = <nonbutton pos='%PY_2%'><img src='%PRTCHR_1%_神乳_%CSTR:カテゴリ／肌の色%' height='%PY_3_2%' ypos = '%PY_1%'></nonbutton>
ELSEIF TALENT:超乳
	PRTCHR_2 = 超乳
	PRT:1 = <nonbutton pos='%PY_2%'><img src='%PRTCHR_1%_超乳_%CSTR:カテゴリ／肌の色%' height='%PY_3%' ypos = '%PY_1%'></nonbutton>
ENDIF












