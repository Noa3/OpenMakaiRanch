
;自室持ち／寮の部屋番号を表示する
@PRINT_ROOM_NUM

IF EQUIP:個室
	CALL PRINTL_WORD_COLOR("Private Room","水色")
ELSEIF CFLAG:寮番号
	CALL PRINT_DORMITORY_NUM(1)
ELSE
	CALL PRINTL_WORD_COLOR("No Room","灰")
ENDIF



;寮の部屋番号
;ARG→1なら改行
@PRINT_DORMITORY_NUM(ARG)
#DIM ROOMMATE

;同じ部屋に何人いるか出す
ROOMMATE = CMATCH(CFLAG:寮番号,CFLAG:寮番号)
PRINTFORM Dormitory Room {CFLAG:寮番号 +100}（{ROOMMATE}／4）
SIF ARG
	PRINTL



;ルームメイトの表示
@PRINT_SLAVE_DORMITORY_ROOMMATE
#DIM DORMITORY_NUM

DORMITORY_NUM = CFLAG:寮番号
PRINT Roommates：
SAVE_TARGET = TARGET
EXIST = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	
	;寮番号が同じなら表示
	SIF TARGET == SAVE_TARGET || CFLAG:寮番号 != DORMITORY_NUM
		CONTINUE
	SIF EXIST
		PRINT ・
	PRINTFORM %CALLNAME%
	EXIST ++
NEXT
SIF !EXIST
	CALL PRINT_WORD_COLOR("None","灰")
PRINTL
TARGET = SAVE_TARGET




