
;魔術説明
;ARG→SELECT_ITEM
@ITEM_DETAIL_MAGIC(ARG)

;非対応IDか名称なしならそのまま帰る
IF ARG < ITEM_ID_MIN || ARG >= ITEM_ID_MAX || ITEMNAME:ARG == ""
	PRINTL  　《 Magic Description Displayed Here 》
	RETURN
ENDIF

;1限チェック
CALL ITEM_GET_ONCE_CHECK(ARG)

;アイテム名、価格を出す→ここでは基礎値
IF FLAG:１コ限定アイテム
	PRINTFORML 　《 %ITEMS_ENG(ITEMNAME:ARG)% 》%VALUE_DIGIT(ITEMPRICE:ARG)%AP
ELSE
	PRINTFORML 　《 %ITEMS_ENG(ITEMNAME:ARG)% 》%VALUE_DIGIT(ITEMPRICE:ARG)%AP（Base Value）:Currently Lv{ITEM:ARG}
ENDIF

