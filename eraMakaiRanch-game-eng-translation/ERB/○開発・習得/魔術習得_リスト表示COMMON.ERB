
;魔術習得リスト共通
;ARG→参照AP
@MAGIC_GET_LIST_COMMON(ARG)

FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	;価格設定されていれば表示
	SIF !ITEMPRICE:LOCAL
		CONTINUE
	CALL BR_PLUS(3)
	
	;ID改行
	IF GROUPMATCH(LOCAL,620,630,730,780,790)
		BR = 0
		PRINTL
	ENDIF
	
	;もろもろ条件チェック
	CALL ITEM_GET_ONCE_CHECK(LOCAL)
	CALL ABILITY_GET_COST_CALC(LOCAL)
	
	;前提条件を見る
	IF MAGIC_GET_PREMISE:LOCAL && !ITEM:(MAGIC_GET_PREMISE:LOCAL)
		CALL PRINTLC_WORD_COLOR,@"[{LOCAL,3}] %ITEMS_ENG(ITEMNAME:LOCAL)%","灰"
	
	;1コ限定の場合持ってたらダメ
	ELSEIF FLAG:１コ限定アイテム && ITEM:LOCAL
		CALL PRINTLC_WORD_COLOR,@"[{LOCAL,3}] %ITEMS_ENG(ITEMNAME:LOCAL)%","水色"
	
	;AP不足だとダメ
	ELSEIF COST > ARG
		CALL PRINTLC_WORD_COLOR,@"[{LOCAL,3}] %ITEMS_ENG(ITEMNAME:LOCAL)%","灰"
	ELSE
		PRINTFORMLC [{LOCAL,3}] %ITEMS_ENG(ITEMNAME:LOCAL)% 
	ENDIF
NEXT



;1コ限定チェック
;ARG→アイテムID
@ITEM_GET_ONCE_CHECK(ARG)

SELECTCASE ARG
CASE 630 TO 649,780 TO 789
	FLAG:１コ限定アイテム = 0
CASEELSE
	FLAG:１コ限定アイテム = 1
ENDSELECT





