
;搾乳器の開発
@UPGRADE_LACTATION_MACHINE

CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("アイテム作成")
PRINTFORML Use money or %CALLNAME:0%'s Mana to create pleasurable milking machines.
FOR LOCAL,900,910
	;価格設定されていれば表示
	SIF ITEMPRICE:LOCAL
		PRINTFORMLC [{LOCAL}] %ITEMS_ENG(ITEMNAME:LOCAL)% 
NEXT
PRINTL
DRAWLINE

;解説と開発画面
CALL ITEM_DETAIL_LACTATION_MACHINE
CALL PRINTL_ALIGN
DRAWLINE
IF ITEMNAME:SELECT_ITEM == "魔動快楽搾乳器"
	IF ITEM:SELECT_ITEM
		PRINTL No need to have more than one in current version
	ELSEIF ITEMPRICE:SELECT_ITEM <= MONEY
		PRINTL [  0] Create 
	ELSE
		PRINTL Insufficient Funds
	ENDIF
ELSEIF ITEMNAME:SELECT_ITEM == "触手快楽搾乳器"
	IF ITEM:SELECT_ITEM
		PRINTL No need to have more than one in current version
	ELSEIF ITEMPRICE:SELECT_ITEM <= BASE:0:魔力
		PRINTL [  0] Create 
	ELSE
		PRINTL Insufficient MP
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR("　Development","灰")
ENDIF
DRAWLINE
CALL RIGHT_RETURN_BUTTON(0,"戻る")
BINPUT
SELECTCASE RESULT
CASE 0
	;購入処理　霊力か魔力
	IF ITEMNAME:SELECT_ITEM == "魔動快楽搾乳器"
		ITEM:SELECT_ITEM ++
		MONEY -= ITEMPRICE:SELECT_ITEM
		PRINTFORMW 【%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%】created 
	ELSEIF ITEMNAME:SELECT_ITEM == "触手快楽搾乳器"
		ITEM:SELECT_ITEM ++
		BASE:0:魔力 -= ITEMPRICE:SELECT_ITEM
		PRINTFORMW 【%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%】created 
	ENDIF

CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART

