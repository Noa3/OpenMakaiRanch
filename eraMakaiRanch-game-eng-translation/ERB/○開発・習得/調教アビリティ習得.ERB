
;調教アビリティ
@ABILITY_GET
#DIM DYNAMIC PAGE

PAGE_MAX = 3
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("調教AP")
PRINTL You can use 【Training AP】 to acquire training abilities.
PRINTL
BR = 0
TRYCALLFORM ABILITY_GET_LIST_{PAGE}
PRINTL
DRAWLINE
CALL ITEM_DETAIL_ABILITY(SELECT_ITEM)
CALL PRINTL_ALIGN
CALL ABILITY_GET_JUDGE(SELECT_ITEM,"調教アビリティ")
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTLC [ 90] Learn All
PRINTLC 　
PRINTL [ 99] Complete
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;購入処理
	CALL ABILITY_GET_COST_CALC(SELECT_ITEM)
	ITEM:SELECT_ITEM ++
	MONEY:調教AP -= COST
	IF ITEM:SELECT_ITEM == 1
		CALL PRINTW_WORD_COLOR,@"【%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%】Mastered.","水色"
	ELSE
		CALL PRINTW_WORD_COLOR,@"【%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%】LvUP！ → {ITEM:SELECT_ITEM}","水色"
	ENDIF
	
	;ふたなりにしたらペニスサイズ計算
	IF ITEMNAME:SELECT_ITEM == "ふたなりちんぽ"
		ABL:0:ペニスサイズ = CFLAG:0:身長 / 50 + RAND:6 + 15
		ABL:0:初期値／ペニスサイズ = ABL:0:ペニスサイズ
	ENDIF
CASE 1
	;連続LvUP
	CALL ABILITY_GET_CONTINUE
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 90
	CALL ABILITY_GET_BULK
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;連続習得
@ABILITY_GET_CONTINUE

;最大5まで一括増加
FOR LOCAL,0,5
	CALL ABILITY_GET_COST_CALC(SELECT_ITEM)
	SIF COST > MONEY:調教AP
		BREAK
	ITEM:SELECT_ITEM ++
	MONEY:調教AP -= COST
	CALL PRINTL_WORD_COLOR,@"【%ITEMNAME:SELECT_ITEM%】LvUP！ → Lv{ITEM:SELECT_ITEM}","水色"
NEXT
PRINTW



;一括習得
@ABILITY_GET_BULK

PRINTL You will acquire all abilities listed on the page that can be learned with your current skill points.
PRINTL ・If AP is insufficient, no further abilities will be acquired.
PRINTL ・Only Lv1 will be acquired.
PRINTL Do you want to proceed with learn all acquisition?
CALL ASK_YN
SIF RESULT
	RETURN

;記録
AP_BEFORE = MONEY:調教AP
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	;習得前提アビリティも見る
	SIF !ITEMPRICE:LOCAL || ITEM:LOCAL || (MAGIC_GET_PREMISE:LOCAL && !ITEM:(MAGIC_GET_PREMISE:LOCAL))
		CONTINUE
	
	;習得不可APで終了
	SIF ITEMPRICE:LOCAL > MONEY:調教AP
		BREAK
	ITEM:LOCAL ++
	MONEY:調教AP -= ITEMPRICE:LOCAL
	CALL PRINTL_WORD_COLOR,@"【%ITEMS_ENG(ITEMNAME:LOCAL)%】Mastered.","水色"
	
	;ふたなりにしたらペニスサイズ計算
	IF ITEMNAME:SELECT_ITEM == "ふたなりちんぽ"
		ABL:0:ペニスサイズ = CFLAG:0:身長 / 50 + RAND:6 + 15
		ABL:0:初期値／ペニスサイズ = ABL:0:ペニスサイズ
	ENDIF
NEXT
PRINTFORML 消費AP：%TOSTR(AP_BEFORE -MONEY:調教AP)%
IF AP_BEFORE == MONEY:調教AP
	PRINTW You were unable to acquire the ability.

;LOCALがITEM_ID_MAXなら全て習得した
ELSEIF LOCAL >= ITEM_ID_MAX
	PRINTW 《 You have acquired all abilities 》
ELSE
	PRINTW
ENDIF
SELECT_ITEM = 0

