
;アビリティ習得リスト共通
@ABILITY_GET_LIST_COMMON

FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	;価格設定されていれば表示
	SIF !ITEMPRICE:LOCAL
		CONTINUE
	CALL BR_PLUS(3)
	
	;もろもろ条件チェック
	CALL ABILITY_GET_ONCE_CHECK(LOCAL)
	CALL ABILITY_GET_COST_CALC(LOCAL)
	
	;レベル制限を見る
	IF ABILITY_LEVEL_MAX:LOCAL && ABILITY_LEVEL_MAX:LOCAL <= ITEM:LOCAL
		CALL PRINTLC_WORD_COLOR,@"[{LOCAL,3}] %ITEMS_ENG(ITEMNAME:LOCAL)%","水色"
	
	;AP不足だとダメ
	ELSEIF COST > MONEY:調教AP
		CALL PRINTLC_WORD_COLOR,@"[{LOCAL,3}] %ITEMS_ENG(ITEMNAME:LOCAL)%","灰"
	ELSE
		;あなた性別での制限
		IF TALENT:0:オトコ
			IF GROUPMATCH(ITEMNAME:LOCAL,"ふたなりちんぽ")
				CALL PRINTLC_WORD_COLOR,@"[{LOCAL,3}] %ITEMNAME:LOCAL%","灰"
				CONTINUE
			ENDIF
		ELSE
			IF GROUPMATCH(ITEMNAME:LOCAL,"百合手折り")
				CALL PRINTLC_WORD_COLOR,@"[{LOCAL,3}] %ITEMNAME:LOCAL%","灰"
				CONTINUE
			ENDIF
		ENDIF
		PRINTFORMLC [{LOCAL,3}] %ITEMS_ENG(ITEMNAME:LOCAL)% 
	ENDIF
NEXT



;コスト計算
;ARG→アイテムID
@ABILITY_GET_COST_CALC(ARG)

;LvUPありで取得済みだとコスト計算
;基礎コスト*現在Lv+1,Lv5ごとに倍率増加
COST = ITEMPRICE:ARG *(ITEM:ARG +1) *(ITEM:ARG /5 +1)

;0コ所持の場合もこれで出るからいいや



;1コ限定チェック
;ARG→アイテムID
@ABILITY_GET_ONCE_CHECK(ARG)

;アビリティMAXLvだけで見てよさそう
IF ABILITY_LEVEL_MAX:ARG == 1
	FLAG:１コ限定アイテム = 1
ELSE
	FLAG:１コ限定アイテム = 0
ENDIF




