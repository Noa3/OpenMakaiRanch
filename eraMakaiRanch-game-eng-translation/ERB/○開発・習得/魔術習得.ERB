
;魔術習得
;ネクロノミコン未所持はそもそもここに来ない
@MAGIC_GET
#DIM DYNAMIC PAGE

PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("魔術AP")
PRINTL You will acquire magic spells using 【Magic AP】
PRINTL
BR = 0
TRYCALLFORM MAGIC_GET_LIST_{PAGE}
PRINTL
DRAWLINE
CALL ITEM_DETAIL_MAGIC(SELECT_ITEM)
CALL PRINTL_ALIGN
CALL ABILITY_GET_JUDGE(SELECT_ITEM,"通常魔術")
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTLC [ 90] Learn all
PRINTLC 　
PRINTL [ 99] Complete
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;購入処理
	CALL ABILITY_GET_COST_CALC(SELECT_ITEM)
	ITEM:SELECT_ITEM ++
	MONEY:魔術AP -= COST
	IF ITEM:SELECT_ITEM == 1
		CALL PRINTW_WORD_COLOR,@"【%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%】learned.","水色"
	ELSE
		CALL PRINTW_WORD_COLOR,@"【%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%】LvUP！ → {ITEM:SELECT_ITEM}","水色"
	ENDIF
	
	;一部習得時はマイルストーン直接呼び出し
	SELECTCASE ITEMNAME:SELECT_ITEM
	CASE "搾乳エナジードレイン"
		CALL MILESTONE_CHECK(GETNUM(FLAG,"魔術＜搾乳エナジードレイン＞取得"))
	CASE "テレポート"
		CALL MILESTONE_CHECK(GETNUM(FLAG,"魔術＜テレポート＞習得"))
	ENDSELECT
	
CASE 1
	;連続LvUP
	CALL MAGIC_GET_CONTINUE
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 90
	CALL MAGIC_GET_BULK
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;連続習得
@MAGIC_GET_CONTINUE

;最大5まで一括増加
FOR LOCAL,0,5
	CALL ABILITY_GET_COST_CALC(SELECT_ITEM)
	SIF COST > MONEY:魔術AP
		BREAK
	ITEM:SELECT_ITEM ++
	MONEY:魔術AP -= COST
	CALL PRINTL_WORD_COLOR,@"【%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%】LvUP！ → Lv{ITEM:SELECT_ITEM}","水色"
NEXT
PRINTW



;一括習得
@MAGIC_GET_BULK

PRINTL You will acquire all magic spells listed on the page that can be learned with your current skill points.
PRINTL ・If AP is insufficient, no further abilities will be acquired.
PRINTL ・Only Lv1 will be acquired.
PRINTL Do you want to proceed with learn all acquisition?
CALL ASK_YN
SIF RESULT
	RETURN

;記録
AP_BEFORE = MONEY:魔術AP
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	;習得前提魔術も見る
	SIF !ITEMPRICE:LOCAL || ITEM:LOCAL || (MAGIC_GET_PREMISE:LOCAL && !ITEM:(MAGIC_GET_PREMISE:LOCAL))
		CONTINUE
	
	;習得不可魔力で終了
	SIF ITEMPRICE:LOCAL > MONEY:魔術AP
		BREAK
	ITEM:LOCAL ++
	MONEY:魔術AP -= ITEMPRICE:LOCAL
	CALL PRINTL_WORD_COLOR,@"【%ITEMS_ENG(ITEMNAME:LOCAL)%】Mastered.","水色"
NEXT
PRINTFORML AP Consumption：%TOSTR(AP_BEFORE -MONEY:魔術AP)%
IF AP_BEFORE == MONEY:魔術AP
	PRINTW No new magics were mastered.

;LOCALがITEM_ID_MAXなら全て習得した
ELSEIF LOCAL >= ITEM_ID_MAX
	PRINTW 《 All Magics Mastered 》
ELSE
	PRINTW
ENDIF
SELECT_ITEM = 0

