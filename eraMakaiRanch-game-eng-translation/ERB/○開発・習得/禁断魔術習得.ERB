
;禁断魔術
@FORBIDDEN_MAGIC_GET
#DIM DYNAMIC PAGE

PAGE_MAX = 1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("禁断AP")
PRINTL You will use 【Forbidden AP】 to learn Forbidden Magic.
PRINTL
BR = 0
TRYCALLFORM FORBIDDEN_MAGIC_GET_LIST_{PAGE}
PRINTL
DRAWLINE
CALL ITEM_DETAIL_FORBIDDEN_MAGIC(SELECT_ITEM)
CALL PRINTL_ALIGN
CALL ABILITY_GET_JUDGE(SELECT_ITEM,"禁断魔術")
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTLC [ 90] Activate All
PRINTLC 
PRINTL [ 99] Complete
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;購入処理
	CALL ABILITY_GET_COST_CALC(SELECT_ITEM)
	ITEM:SELECT_ITEM ++
	MONEY:禁断AP -= COST
	IF ITEM:SELECT_ITEM == 1
		CALL PRINTW_WORD_COLOR,@"【%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%】Mastered.","水色"
	ELSE
		CALL PRINTW_WORD_COLOR,@"【%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%】LvUP！ → {ITEM:SELECT_ITEM}","水色"
	ENDIF
CASE 1
	;連続LvUP
	CALL FORBIDDEN_MAGIC_GET_CONTINUE
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 90
	CALL FORBIDDEN_MAGIC_GET_BULK
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;連続習得
@FORBIDDEN_MAGIC_GET_CONTINUE

;最大5まで一括増加
FOR LOCAL,0,5
	CALL ABILITY_GET_COST_CALC(SELECT_ITEM)
	SIF COST > MONEY:禁断AP
		BREAK
	ITEM:SELECT_ITEM ++
	MONEY:禁断AP -= COST
	CALL PRINTL_WORD_COLOR,@"【%ITEMNAME:SELECT_ITEM%】LvUP！ → Lv{ITEM:SELECT_ITEM}","水色"
NEXT
PRINTW



;一括習得
@FORBIDDEN_MAGIC_GET_BULK

PRINTL You will learn all the magic spells available within the current page based on your current skill points, starting from the beginning of the list.
PRINTL ・If you lack sufficient AP, any subsequent magic learning will not proceed.
PRINTL Do you want to proceed with auto-learning?
CALL ASK_YN
SIF RESULT
	RETURN

;記録
AP_BEFORE = MONEY:禁断AP
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	;習得前提魔術も見る
	SIF !ITEMPRICE:LOCAL || ITEM:LOCAL || (MAGIC_GET_PREMISE:LOCAL && !ITEM:(MAGIC_GET_PREMISE:LOCAL))
		CONTINUE
	
	;習得不可魔力で終了
	SIF ITEMPRICE:LOCAL > MONEY:禁断AP
		BREAK
	ITEM:LOCAL ++
	MONEY:禁断AP -= ITEMPRICE:LOCAL
	CALL PRINTL_WORD_COLOR,@"%ITEMS_ENG(ITEMNAME:LOCAL)%】Mastered","水色"
NEXT
PRINTFORML 消費AP：%TOSTR(AP_BEFORE -MONEY:禁断AP)%
IF AP_BEFORE == MONEY:禁断AP
	PRINTW No new magics were mastered.

;LOCALがITEM_ID_MAXなら全て習得した
ELSEIF LOCAL >= ITEM_ID_MAX
	PRINTW 《 All Magics Mastered 》
ELSE
	PRINTW
ENDIF
SELECT_ITEM = 0

