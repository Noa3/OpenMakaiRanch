
;開発・習得の入り口
@UPGRADE_INDEX

SELECT_ITEM = 0
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("ALL")
PRINTL [ 0] Drug Manufacturing
IF ITEM:工具セット
	PRINTL [ 1] Milker Development
ELSE
	CALL PRINTL_WORD_COLOR,@"＜ Tool Set > Required","灰"
ENDIF
IF ITEM:触手装備作成
	PRINTL [ 2] Tentacle Equipment Creation
ELSE
	CALL PRINTL_WORD_COLOR,@"＜Tentacle Equipment Creation > Required","灰"
ENDIF
PRINTL

PRINTL [10] Ability Acquisition
IF ITEM:ネクロノミコン
	PRINTL [11] Magic Acquisition
ELSE
	CALL PRINTL_WORD_COLOR,@"＜Necronomicon＞ Required","灰"
ENDIF
IF ITEM:触手生物生態図鑑
	PRINTL [12] Tentacle Magic Acquisition
ELSE
	CALL PRINTL_WORD_COLOR,@"＜Tentacle Creature Ecology Encyclopedia＞ Required","灰"
ENDIF
CALL MILESTONE_UNLOCK_CHECK("禁断魔術","L")
SIF RESULT
	PRINTL [13] Forbidden Magic Acquisition
PRINTL
PRINTL [20] Abilities & Magic ON/OFF
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1,"戻る")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL PHARMACEUTICAL
CASE 1
	CALL UPGRADE_LACTATION_MACHINE
CASE 2
	CALL ITEM_CREATION

CASE 10
	CALL ABILITY_GET
CASE 11
	CALL MAGIC_GET
CASE 12
	CALL TENTACLE_MAGIC_GET
CASE 13
	CALL FORBIDDEN_MAGIC_GET

CASE 20
	CALL ABILITY_ACTIVATION
CASE 98
	CALL BROWSE_HINT("開発・習得")
CASE 99
	CLEARLINE LINECOUNT
	RETURN
ENDSELECT
RESTART






