
;魔術・アビリティを習得できるか判定
;ARG→SELECT_ITEM
;ARGS→種類
@ABILITY_GET_JUDGE(ARG,ARGS)

CALL ABILITY_GET_COST_CALC(ARG)

;非対応IDか名称なしならそのまま帰る
IF ARG < ITEM_ID_MIN || ARG >= ITEM_ID_MAX || ITEMNAME:ARG == ""
	PRINTL

;１コ限定で持ってるとダメ
ELSEIF FLAG:１コ限定アイテム && ITEM:ARG
	CALL PRINTL_WORD_COLOR,@"Already Mastered","水色"

;それ以外はARGSで分岐
ELSE
	SELECTCASE ARGS
	CASE "調教アビリティ"
		CALL ABILITY_GET_JUDGE_TRAIN(ARG)
	CASE "通常魔術"
		CALL ABILITY_GET_JUDGE_MAGIC(ARG)
	CASE "触手魔術"
		CALL ABILITY_GET_JUDGE_TENTACLE(ARG)
	CASE "禁断魔術"
		CALL ABILITY_GET_JUDGE_FORBIDDEN(ARG)
	ENDSELECT
ENDIF




;調教アビリティ習得判定
@ABILITY_GET_JUDGE_TRAIN(ARG)

;オトコあなたはふたなり不可、女あなたは百合手折り不可
;ふたなり持ってないと他取得不可
IF TALENT:0:オトコ
	IF GROUPMATCH(ITEMNAME:ARG,"ふたなりちんぽ")
		CALL PRINTL_WORD_COLOR,@"Cannot Obtain","灰"
		RETURN
	ENDIF
ELSE
	IF GROUPMATCH(ITEMNAME:ARG,"百合手折り")
		CALL PRINTL_WORD_COLOR,@"Cannot Obtain","灰"
		RETURN
	ENDIF
ENDIF

;ふたなりちんぽ必要はあとで


;レベル制限の上限だとダメ
IF ABILITY_LEVEL_MAX:ARG && ABILITY_LEVEL_MAX:ARG <= ITEM:ARG
	CALL PRINTL_WORD_COLOR,@"At maximum level","水色"

;AP不足だとダメ
ELSEIF COST > MONEY:調教AP
	CALL PRINTL_WORD_COLOR,@"Insufficient Training AP: %VALUE_DIGIT(COST)% AP required","灰"
ELSE
	;レベル制限のないアビリティなら連続を出す
	IF ABILITY_LEVEL_MAX:ARG
		PRINTFORML [  0] Acquisition：%VALUE_DIGIT(COST)%AP
	ELSE
		PRINTFORMLC [  0] LvUP：%VALUE_DIGIT(COST)%AP
		PRINTL [  1] Continuous LvUP
	ENDIF
ENDIF



;通常魔術習得判定
@ABILITY_GET_JUDGE_MAGIC(ARG)

;前提条件を見る
IF MAGIC_GET_PREMISE:ARG && !ITEM:(MAGIC_GET_PREMISE:ARG)
	CALL PRINTL_WORD_COLOR,@"＜%ITEMS_ENG(ITEMNAME:(MAGIC_GET_PREMISE:ARG))%＞ required","灰"

;AP不足だとダメ
ELSEIF COST > MONEY:魔術AP
	CALL PRINTL_WORD_COLOR,@"Insufficient Magic AP: %VALUE_DIGIT(COST)% AP required","灰"
ELSE
	;１コ限定orレベルあり
	IF FLAG:１コ限定アイテム
		PRINTFORML [  0] Acquisition：%VALUE_DIGIT(COST)%AP
	ELSE
		PRINTFORMLC [  0] LvUP：%VALUE_DIGIT(COST)%AP
		PRINTL [  1] Continuous LvUP
	ENDIF
ENDIF



;触手習得判定
@ABILITY_GET_JUDGE_TENTACLE(ARG)

;だいたい通常魔術と同じ
IF MAGIC_GET_PREMISE:ARG && !ITEM:(MAGIC_GET_PREMISE:ARG)
	CALL PRINTL_WORD_COLOR,@"＜%ITEMS_ENG(ITEMNAME:(MAGIC_GET_PREMISE:ARG))%＞ required","灰"
ELSEIF COST > MONEY:触手AP
	CALL PRINTL_WORD_COLOR,@"Insufficient Tentacle AP: %VALUE_DIGIT(COST)% AP required","灰"
ELSE
	IF FLAG:１コ限定アイテム
		PRINTFORML [  0] Acquisition：%VALUE_DIGIT(COST)%AP
	ELSE
		PRINTFORMLC [  0] LvUP：%VALUE_DIGIT(COST)%AP
		PRINTL [  1] Continous LvUP
	ENDIF
ENDIF



;禁断魔術習得判定
@ABILITY_GET_JUDGE_FORBIDDEN(ARG)

;だいたい通常魔術と同じ
IF MAGIC_GET_PREMISE:ARG && !ITEM:(MAGIC_GET_PREMISE:ARG)
	CALL PRINTL_WORD_COLOR,@"＜%ITEMS_ENG(ITEMNAME:(MAGIC_GET_PREMISE:ARG))%＞ required","灰"
ELSEIF COST > MONEY:禁断AP
	CALL PRINTL_WORD_COLOR,@"Forbidden AP Insufficient: %VALUE_DIGIT(COST)% AP Required","灰"
ELSE
	IF FLAG:１コ限定アイテム
		PRINTFORML [  0] Acquisition：%VALUE_DIGIT(COST)%AP
	ELSE
		PRINTFORMLC [  0] LvUP：%VALUE_DIGIT(COST)%AP
		PRINTL [  1] Continuous LvUP
	ENDIF
ENDIF






