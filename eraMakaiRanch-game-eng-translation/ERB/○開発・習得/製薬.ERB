
;薬品開発
@PHARMACEUTICAL
#DIM DYNAMIC PAGE

BUY_NUM = 0
NEED_MP_COST = 0
PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_UPGRADE("アイテム作成")
PRINTL Using the spiritual energy from the spiritual energy extraction device, you will mix the potion.
PRINTL
BR = 0
TRYCALLFORM PHARMACEUTICAL_LIST_{PAGE}
PRINTL
DRAWLINE
CALL ITEM_DETAIL_DRUG
CALL PRINTL_ALIGN
CALL PHARMACEUTICAL_JUDGE
DRAWLINE
CALL PRINT_NOW_PAGE(PAGE)
CALL RIGHT_RETURN_BUTTON(1,"戻る")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	;購入処理　霊力を見る
	CALL PHARMACEUTICAL_BUY
CASE 1
	CALL PHARMACEUTICAL_BULK_BUY
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 98
	CALL BROWSE_HINT("製薬")
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;1コ製薬処理
@PHARMACEUTICAL_BUY

ITEM:SELECT_ITEM ++
MONEY:貯蔵霊力 -= ITEMPRICE:SELECT_ITEM
SIF NEED_MP_COST
	MONEY:貯蔵魔力 -= ITEMPRICE:SELECT_ITEM
PRINTFORMW ＜%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%＞ synthesized.



;複数製薬処理
@PHARMACEUTICAL_BULK_BUY
#DIM BUY_NUM2

COST = ITEMPRICE:SELECT_ITEM

;MP要求かどうか見る
IF NEED_MP_COST
	BUY_NUM2 = LIMIT(MONEY:貯蔵魔力 /COST,1,100)
	BUY_NUM = LIMIT(MONEY:貯蔵霊力 /COST,BUY_NUM2,100)
ELSE
	BUY_NUM = LIMIT(MONEY:貯蔵霊力 /COST,1,100)
ENDIF
PRINTFORML How many ＜%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%＞ do you wish to make?
PRINTFORML Max《 {BUY_NUM}x 》producible
PRINTL [ 0] Cancel
INPUT
SIF RESULT <= 0 || RESULT > BUY_NUM
	RETURN
BUY_NUM = RESULT
ITEM:SELECT_ITEM += BUY_NUM
MONEY:貯蔵霊力 -= (COST *BUY_NUM)
PRINTFORMW 《 {BUY_NUM} 》x ＜%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%＞ synthesized


