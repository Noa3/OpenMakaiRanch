
;アビリティ・魔術ON／OFF
@ABILITY_ACTIVATION

CLEARLINE LINECOUNT
PRINTL Toggle the activation or deactivation of abilities and magic. (Includes those not yet learned)
DRAWLINE

;STR:アビリティ有効BIT→22000
STR_REF = 22000
FOR LOCAL,0,20
	SIF STR:(STR_REF +LOCAL) == ""
		CONTINUE
	
	;オトコならふたなりちんぽ除外
	SIF STR:(STR_REF +LOCAL) == "ふたなりちんぽ" && TALENT:0:オトコ
		CONTINUE
	PRINTFORMLC [{LOCAL,2}] %ABILITIES_ACTIVE_ENG(STR:(STR_REF +LOCAL))%
	CALL PRINT_ONOFF(GETBIT(FLAG:アビリティ有効BIT,LOCAL),1)
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
PRINTLC [ 90] Activate All
PRINTLC 
PRINTL [ 99] Complete
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 19
	INVERTBIT FLAG:アビリティ有効BIT,RESULT
CASE 90
	FLAG:アビリティ有効BIT = 65535
CASE 99
	RETURN
ENDSELECT
RESTART

