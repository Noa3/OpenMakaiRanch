
;アイテム説明目次：衣服は別関数
;ARG→PAGE
;ARGS→店
;ITEM_ID_MIN,ITEM_ID_MAX指定済み
@ITEM_SHOP_DETAIL_COMMON(ARG,ARGS)

;対応IDでないなら汎用出して帰る
;ホームセンターで魔力貯蔵器見てる時は別
IF SELECT_ITEM < ITEM_ID_MIN || SELECT_ITEM >= ITEM_ID_MAX || ITEMNAME:SELECT_ITEM == ""
	IF ARGS == "ホームセンター" && ARG == 2 && GROUPMATCH(ITEMNAME:SELECT_ITEM,"大容量魔力貯蔵器")
	ELSE
		PRINTL  　《 Clothing Description Shown Here 》
		RETURN
	ENDIF
ENDIF

;店ごとの商品説明を呼ぶ
SELECTCASE ARGS
CASE "アダルト"
	;PAGEによって呼ぶリスト変えとく（多いので分割）
	;ITEM_ID_MINによって変えても大丈夫
	SELECTCASE ARG
	CASE 1
		CALL ITEM_SHOP_ADULT_DETAIL_DISPOSABLE
	CASE 2
		CALL ITEM_SHOP_ADULT_DETAIL_DEVICE
	ENDSELECT
	
CASE "ホームセンター"
	SELECTCASE ARG
	CASE 1
		CALL ITEM_SHOP_WORK_DETAIL_DISPOSABLE
	CASE 2
		CALL ITEM_SHOP_WORK_DETAIL_DEVICE
	ENDSELECT

CASE "家具屋"
	;今1ページだけ
	CALL ITEM_SHOP_FURNITURE_DETAIL_DEVICE

CASE "ペット"
	CALL ITEM_SHOP_PET_DETAIL_DISPOSABLE
ENDSELECT


