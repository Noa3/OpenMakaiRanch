;ホームセンター
@ITEM_SHOP_WORK
#DIM DYNAMIC PAGE

;ID指定の関係で2ページになった
CALL ITEM_SHOP_BUDGET_MONEY_JUDGE
BUY_NUM = 0
PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
BR = 0
SELECTCASE PAGE
CASE 1
	CALL ITEM_SHOP_WORK_DISPOSABLE
CASE 2
	CALL ITEM_SHOP_WORK_DEVICE
ENDSELECT
PRINTL
DRAWLINE
CALL ITEM_SHOP_DETAIL_COMMON(PAGE,"ホームセンター")
CALL PRINTL_ALIGN
CALL BUY_ITEM_JUDGE("ホームセンター")
CALL ITEM_SHOP_FOOTER(PAGE)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0,1
	CALL BUY_ITEM_COMMON(RESULT)
	
	;魔力貯蔵器を買った場合上限増加させる
	SIF ITEMNAME:SELECT_ITEM == "大容量魔力貯蔵器"
		CALL MAGIC_STORAGE
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 90
	CALL BULK_BUYING_COMMON(0,"ホームセンター")
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;ホームセンター販売品
