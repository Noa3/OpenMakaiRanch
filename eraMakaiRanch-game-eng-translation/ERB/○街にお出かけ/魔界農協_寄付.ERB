
;寄付
@AGRI_COOP_DONATION
#DIM UNIT_NUM
#DIM DONATE_MONEY

CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
PRINTFORML You can donate from the ranch funds to various budgets in Makai（一口%VALUE_DIGIT(DONATION_UNIT)%G）
PRINTL
CALL GET_TAX_FLAG_REF
FOR LOCAL,0,10
	SIF FLAGNAME:(FLAG_REF:1 +LOCAL) == ""
		CONTINUE
	PRINTFORM [{LOCAL,2}] %MAKAI_INSTITUTIONS_ENG(STR:(STR_REF +LOCAL)),25%
	
	;現在の納税額も表示
	{
	PRINTFORM 　%STR:(STR_REF +LOCAL),12%Lv：{FLAG:(FLAG_REF:2 +LOCAL),2}
	積立額：%VALUE_DIGIT(FLAG:(FLAG_REF:1 +LOCAL)),8%G 
	}
	CALL MAKAI_LVUP_NEED_MONEY_CALC(FLAG:(FLAG_REF:2 +LOCAL))
	CALL PRINT_COLORBAR(FLAG:(FLAG_REF:1 +LOCAL),RESULT,8,BARCOLORSET("青緑"),RESULT:1)
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON
BINPUT
PRINTL
INPUT_NUM = RESULT
SELECTCASE INPUT_NUM
CASE 0 TO 8
	;何口出せるか：1回の上限1000
	UNIT_NUM = LIMIT(MONEY /DONATION_UNIT,1,1000)
	PRINTFORML How many donations to %MAKAI_INSTITUTIONS_ENG(STR:(STR_REF +INPUT_NUM))%?（%VALUE_DIGIT(DONATION_UNIT)%G per donation）
	PRINTLC [ 0] cancel
	PRINTLC [ 1] 1 donation
	SIF UNIT_NUM >= 10
		PRINTLC [10] 10 donations
	SIF UNIT_NUM > 10
		PRINTFORMLC [{UNIT_NUM}] {UNIT_NUM} donations
	PRINTL
	PRINTFORML Or enter amount of donations up to {UNIT_NUM}。
	INPUT
	IF RESULT >= 1 && RESULT <= UNIT_NUM
		PRINTL
		DONATE_MONEY = DONATION_UNIT *RESULT
		PRINTFORML Make {RESULT} donations（%VALUE_DIGIT(DONATE_MONEY)%G）？
		CALL ASK_YN
		IF !RESULT
			PRINTL
			MONEY -= DONATE_MONEY
			FLAG:(INPUT_NUM +FLAG_REF:1) += DONATE_MONEY
			PRINTFORML Donated to %MAKAI_INSTITUTIONS_ENG(STR:(STR_REF +INPUT_NUM))%.
			CALL MAKAI_LVUP
			PRINTW
		ENDIF
	ENDIF
	
	;10万以下になったら帰る
	SIF MONEY < DONATION_UNIT
		RETURN
CASE 99
	RETURN
ENDSELECT
RESTART


