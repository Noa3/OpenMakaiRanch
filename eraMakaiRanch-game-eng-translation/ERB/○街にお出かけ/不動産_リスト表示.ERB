
;不動産リスト
@ESTATE_LIST

;他の店とは違い一括判定しづらいので個別に
FOR LOCAL,10,11 +ESTATE_LIST_NUM
	CALL ESTATE_LIST_COLOR(LOCAL)
	CALL ESTATE_LIST_PART(LOCAL)
	RESETCOLOR
NEXT
PRINTL



;色変更するかの個別判定
;ARG→選択肢番号
@ESTATE_LIST_COLOR(ARG)
#DIM COLOR_SET

COLOR_SET = 0
SELECTCASE ARG
CASE 10
	SIF ITEM:牛舎 >= ESTATE_COWSHED_LIMIT || CAN_LOAN_MONEY +MONEY < ITEMPRICE:牛舎
		COLOR_SET ++
CASE 11
	SIF !ITEM:牛舎 || CAN_LOAN_MONEY +MONEY < ESTATE_COWSHED_EXTENSION
		COLOR_SET ++
CASE 12
	SIF ITEM:事務所増築 >= ESTATE_OFFICE_LIMIT || CAN_LOAN_MONEY +MONEY < ITEMPRICE:事務所増築
		COLOR_SET ++
CASE 13
	SIF ITEM:家族風呂 || CAN_LOAN_MONEY +MONEY < ITEMPRICE:家族風呂 || !ITEM:事務所増築
		COLOR_SET ++
CASE 14
	SIF ITEM:大浴場 || CAN_LOAN_MONEY +MONEY < ITEMPRICE:大浴場 || !ITEM:家族風呂
		COLOR_SET ++
CASE 15
	SIF ITEM:ペット小屋 >= ESTATE_PETHOUSE_LIMIT || CAN_LOAN_MONEY +MONEY < ITEMPRICE:ペット小屋 || !ITEM:事務所増築
		COLOR_SET ++
CASE 16
	SIF ITEM:奴隷寮 || CAN_LOAN_MONEY +MONEY < ITEMPRICE:奴隷寮 || !ITEM:事務所増築
		COLOR_SET ++
CASE 17
	;元が建ってないとダメ
	;10回くらいにしとく
	SIF !ITEM:奴隷寮 || ITEM:奴隷寮増築 >= ESTATE_DORMITORY_LIMIT || CAN_LOAN_MONEY +MONEY < ITEMPRICE:奴隷寮増築
		COLOR_SET ++
CASE 18
	SIF ITEM:システムキッチン || CAN_LOAN_MONEY +MONEY < ITEMPRICE:システムキッチン || !ITEM:事務所増築
		COLOR_SET ++
	
ENDSELECT
SIF COLOR_SET
	SETCOLOR 0x606060



;選択肢表示
;ARG→選択肢番号
@ESTATE_LIST_PART(ARG)

SELECTCASE ARG
CASE 10
	PRINTLC [10] Construct Cowshed
CASE 11
	PRINTLC [11] Expand Cowshed
CASE 12
	PRINTLC [12] Expand Office
CASE 13
	PRINTLC [13] Convert to Family Bath
CASE 14
	PRINTLC [14] Construct Bathhouse
CASE 15
	PRINTLC [15] Expand Pet House
CASE 16
	PRINTLC [16] Construct Dormitory
CASE 17
	PRINTLC [17] Expand Dormitory
CASE 18
	PRINTLC [18] Convert to Built-in Kitchen
ENDSELECT
RESETCOLOR




