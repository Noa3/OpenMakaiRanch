
;アイテム購入処理
;ARG→RESULT
@BUY_ITEM_COMMON(ARG)

;衣服セット対応のためここでCOST計算
CALL BUY_ITEM_PRICE_CALC
SELECTCASE ARG
CASE 0
	;購入処理　所持金
	ITEM:SELECT_ITEM ++
	SIF ITEMNAME:SELECT_ITEM == "コンドーム"
		ITEM:SELECT_ITEM += 4
	
	;経費計上か財布かで変更
	IF FLAG:買い物／経費計上
		MONEY:経費計上 += COST
	ELSE
		MONEY -= COST
	ENDIF
	CALL PRINTW_WORD_COLOR,@"＜%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%＞ purchased。","水色"

CASE 1
	;複数購入
	ITEM:SELECT_ITEM += BUY_NUM
	SIF ITEMNAME:SELECT_ITEM == "コンドーム"
		ITEM:SELECT_ITEM += BUY_NUM * 4
	IF FLAG:買い物／経費計上
		MONEY:経費計上 += (COST *BUY_NUM)
	ELSE
		MONEY -= (COST *BUY_NUM)
	ENDIF
	
	;ついでに衣服だと「着」
	IF SELECT_ITEM >= 1000
		CALL PRINTW_WORD_COLOR,@"{BUY_NUM} ＜%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%＞ purchased.","水色"
	ELSE
		CALL PRINTW_WORD_COLOR,@"{BUY_NUM} ＜%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%＞ purchased.","水色"
	ENDIF
ENDSELECT



;ローン購入処理
;ARG→価格
@ITEM_LOAN_BUY(ARG)
#DIM LOAN_OVER

;ARG分ローン増加→足りないとき所持金減少
IF CAN_LOAN_MONEY < ARG
	LOAN_OVER = ARG -CAN_LOAN_MONEY
	MONEY:ローン += CAN_LOAN_MONEY
	MONEY -= LOAN_OVER
	PRINTFORML Loan + %VALUE_DIGIT(CAN_LOAN_MONEY)%G / Funds - %VALUE_DIGIT(LOAN_OVER)%G
ELSE
	MONEY:ローン += ARG
	PRINTFORML Loan + %VALUE_DIGIT(ARG)%G
ENDIF




