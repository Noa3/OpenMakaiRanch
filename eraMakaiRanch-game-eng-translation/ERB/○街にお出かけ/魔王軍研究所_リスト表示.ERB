
;魔王軍研究所商品リスト
@INSTITUTE_LIST

;他の店とは違い一括判定しづらいので個別に
FOR LOCAL,10,11 +INSTITUTE_LIST_NUM
	CALL INSTITUTE_LIST_COLOR(LOCAL)
	CALL INSTITUTE_LIST_PART(LOCAL)
	RESETCOLOR
NEXT
PRINTL



;色変更するかの個別判定
;ARG→選択肢番号
@INSTITUTE_LIST_COLOR(ARG)
#DIM COLOR_SET

COLOR_SET = 0
SELECTCASE ARG
CASE 10
	SIF MONEY:貯蔵霊力 < EP_CONTRIBUTION_PT
		COLOR_SET ++
CASE 11
	SIF MONEY:貯蔵霊力 < ITEMPRICE:奴隷候補設定変更チケット
		COLOR_SET ++
CASE 12
	SIF MONEY:貯蔵霊力 < ITEMPRICE:霊力抽出装置 /2 || MONEY < ITEMPRICE:霊力抽出装置
		COLOR_SET ++
CASE 13
	SIF MONEY:貯蔵魔力 < ITEMPRICE:魔力枷 /2 || MONEY < ITEMPRICE:魔力枷
		COLOR_SET ++
CASE 14
	SIF ITEM:魔力補給装置 || MONEY < ITEMPRICE:魔力補給装置 || MONEY:貯蔵霊力 < ITEMPRICE:魔力補給装置
		COLOR_SET ++
CASE 15
	SIF ITEM:魔改造魔力貯蔵器 || !ITEM:大容量魔力貯蔵器 || MONEY:貯蔵魔力 < MAGIC_TANK_LARGE_CAPACITY
		COLOR_SET ++
CASE 16
	SIF ITEM:小型霊力抽出装置 || MONEY < ITEMPRICE:小型霊力抽出装置
		COLOR_SET ++
ENDSELECT
SIF COLOR_SET
	SETCOLOR 0x606060


;選択肢表示
;ARG→選択肢番号
@INSTITUTE_LIST_PART(ARG)

SELECTCASE ARG
CASE 10
	PRINTLC [10] Contribution Point Conversion
CASE 11
	PRINTFORMLC [11] %ITEMS_ENG("奴隷候補設定変更チケット")%
CASE 12
	PRINTFORMLC [12] %ITEMS_ENG("霊力抽出装置")%
CASE 13
	PRINTFORMLC [13] %ITEMS_ENG("魔力枷")%
CASE 14
	PRINTFORMLC [14] %ITEMS_ENG("魔力補給装置")%
CASE 15
	PRINTFORMLC [15] %ITEMS_ENG("魔改造魔力貯蔵器")%
CASE 16
	PRINTFORMLC [16] %ITEMS_ENG("小型霊力抽出装置")%
ENDSELECT
RESETCOLOR

