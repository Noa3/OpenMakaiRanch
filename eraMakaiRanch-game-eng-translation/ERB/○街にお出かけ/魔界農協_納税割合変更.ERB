
;納税割合変更
@AGRI_COOP_TAX_RATIO_SELECT
#DIM TAX_RATIO

;納税関連フラグIDの一斉取得
CALL GET_TAX_FLAG_REF
CLEARLINE LINECOUNT
PRINTL Set the tax rate for settlement.
DRAWLINE
TOTAL_RATIO = SUMARRAY(FLAG,FLAG_REF,FLAG_REF +10)
FOR LOCAL,0,10
	SIF FLAGNAME:(FLAG_REF +LOCAL) == ""
		CONTINUE
	PRINTFORM [{LOCAL,2}] %MAKAI_INSTITUTIONS_ENG(STR:(STR_REF +LOCAL)),25%
	SIF !FLAG:(FLAG_REF +LOCAL)
		SETCOLOR 0x606060
	PRINTFORM ：{FLAG:(FLAG_REF +LOCAL),4}
	PRINTPLAIN 　
	RESETCOLOR
	PRINTBUTTON "[+10]",LOCAL +100
	PRINTBUTTON "[-10]",LOCAL +200
	PRINTPLAIN 　
	PRINTBUTTON "[×2]",LOCAL +300
	PRINTBUTTON "[÷2]",LOCAL +400
	PRINTPLAIN 　
	
	;合計0だとこの先飛ばす
	IF !TOTAL_RATIO
		SIF !LOCAL
			CALL PRINT_WORD_COLOR("！割合合計が0です","黄")
		PRINTL
		CONTINUE
	ENDIF
	TAX_RATIO = FLAG:(FLAG_REF +LOCAL) *100
	TAX_RATIO /= TOTAL_RATIO
	
	;0ではないけど計算結果0なら「ほぼ0」
	IF !TAX_RATIO && FLAG:(FLAG_REF +LOCAL)
		PRINT ≒0% 
	ELSE
		PRINTFORM {TAX_RATIO,3}\% 
	ENDIF
	
	;現在の納税額も表示
	{
	PRINTFORM 　%STR:(STR_REF:1 +LOCAL),8%Lv：{FLAG:(FLAG_REF:2 +LOCAL),2}
	積立額：%VALUE_DIGIT(FLAG:(FLAG_REF:1 +LOCAL)),8%G 
	}
	CALL MAKAI_LVUP_NEED_MONEY_CALC(FLAG:(FLAG_REF:2 +LOCAL))
	CALL PRINT_COLORBAR(FLAG:(FLAG_REF:1 +LOCAL),RESULT,8,BARCOLORSET("青緑"),RESULT:1)
	PRINTL
NEXT
CALL PRINTL_ALIGN(-10)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1)
BINPUT
PRINTL
INPUT_NUM = RESULT
SELECTCASE INPUT_NUM
CASE 0 TO 8
	PRINTFORML Please input the value of %STR:(STR_REF +INPUT_NUM)% (0–1000)
	INPUT
	SIF RESULT >= 0 && RESULT <= 1000
		FLAG:(INPUT_NUM +FLAG_REF) = RESULT

CASE 100 TO 108
	;+10
	FLAG_NUM = (INPUT_NUM +FLAG_REF -100)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM +10,0,1000)

CASE 200 TO 208
	;-10
	FLAG_NUM = (INPUT_NUM +FLAG_REF -200)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM -10,0,1000)

CASE 300 TO 308
	;×2
	FLAG_NUM = (INPUT_NUM +FLAG_REF -300)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM *2,0,1000)

CASE 400 TO 408
	;÷2
	FLAG_NUM = (INPUT_NUM +FLAG_REF -400)
	FLAG:FLAG_NUM = LIMIT(FLAG:FLAG_NUM /2,0,1000)
CASE 98
	CALL BROWSE_HINT("納税割合")
CASE 99
	RETURN
ENDSELECT
RESTART






