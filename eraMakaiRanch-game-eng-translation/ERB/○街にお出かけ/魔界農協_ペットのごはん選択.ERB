
;ペットのごはん選択
@AGRI_COOP_PET_FOOD_SELECT

;ペットがいる部分を選択肢表示
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
PRINTL 　《 Pet Food 》

;ITEM:堕天馬→100　選択肢を1から始めるので-1
ITEM_REF = 100 -1
PRINTFORML [ 0] Makai Dairy Cow：%PRINT_PET_FOOD("魔界乳牛")%
PRINTL
FOR LOCAL,1,21
	ANIMAL = %ITEMNAME:(ITEM_REF +LOCAL)%
	SIF ANIMAL == ""
		CONTINUE
	IF ITEM:ANIMAL
		PET_NAME = %PET_NAME_REF(ANIMAL)%
		PRINTFORMLC [{LOCAL,2}] %ITEMS_ENG(ANIMAL)%／%PET_NAME%
		PRINTFORML ：%PRINT_PET_FOOD(ANIMAL)%
	ELSE
		CALL PRINTL_WORD_COLOR,@"　%ITEMS_ENG(ANIMAL)%","灰"
	ENDIF
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL PET_FOOD_SELECT_INPUT("魔界乳牛")
CASE 1 TO 21
	ANIMAL = %ITEMNAME:(ITEM_REF +RESULT)%
	PET_NAME = %PET_NAME_REF(ANIMAL)%
	SIF ANIMAL != "" && ITEM:ANIMAL
		CALL PET_FOOD_SELECT_INPUT(ANIMAL,PET_NAME)
CASE 98
	CALL BROWSE_HINT("ペットのごはん")
CASE 99
	RETURN
ENDSELECT
RESTART



;ペットのごはん種類
;ARGS→動物名
@PRINT_PET_FOOD(ARGS)
#FUNCTIONS

FLAG_NAME = ごはん種類／%ARGS%
SELECTCASE FLAG:FLAG_NAME
CASE 0
	RETURNF "General"
CASE 1
	RETURNF "Healthy"
CASE 2
	RETURNF "Nutritious"
CASE 3
	RETURNF "High Quality Balanced"
ENDSELECT



;ごはん選択
;ARGS→動物名
;ARGS:1→ペット名
@PET_FOOD_SELECT_INPUT(ARGS,ARGS:1)

FLAG_NAME = ごはん種類／%ARGS%
IF ARGS == "魔界乳牛"
	PRINTFORML Select food for Makai Dairy Cow.
ELSEIF ARGS:1 == ""
	PRINTFORML Select food for %ARGS%.
ELSE
	PRINTFORML Select food for %ARGS:1%.
ENDIF
PRINTL [ 0] General
PRINTL [ 1] Healthy
PRINTL [ 2] Nutritious
PRINTL [ 3] Quality Balanced
INPUT
SIF RESULT >= 0 && RESULT <= 3
	FLAG:FLAG_NAME = RESULT






