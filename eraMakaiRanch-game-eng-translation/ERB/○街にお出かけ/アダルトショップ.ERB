
;アダルトショップ
@ITEM_SHOP_ADULT
#DIM DYNAMIC PAGE
#DIM MILESTONE

CALL ITEM_SHOP_BUDGET_MONEY_JUDGE
BUY_NUM = 0
PAGE_MAX = 2
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
BR = 0
SELECTCASE PAGE
CASE 1
	CALL ITEM_SHOP_ADULT_DISPOSABLE
CASE 2
	CALL ITEM_SHOP_ADULT_DEVICE
ENDSELECT
PRINTL
DRAWLINE
CALL ITEM_SHOP_DETAIL_COMMON(PAGE,"アダルト")
CALL PRINTL_ALIGN
CALL BUY_ITEM_JUDGE("アダルト")
CALL ITEM_SHOP_FOOTER(PAGE)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0,1
	;購入処理→共通関数へ
	CALL BUY_ITEM_COMMON(RESULT)
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 90
	CALL BULK_BUYING_COMMON(0,"アダルト")
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT

;7コ以上調教グッズを買うマイルストーンがある
MILESTONE = GETNUM(FLAG,"【アダルトショップ】の調教グッズを7コ以上購入")
SIF !FLAG:MILESTONE
	CALL MILESTONE_CHECK(MILESTONE)
RESTART



;アダルトショップリスト
;調教消耗品
@ITEM_SHOP_ADULT_DISPOSABLE

ITEM_ID_MIN = 250
ITEM_ID_MAX = 300
PRINTL 　《 Consumables 》
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	CALL ITEM_SHOP_LOOP_JUDGE(LOCAL)
NEXT



;調教グッズ
@ITEM_SHOP_ADULT_DEVICE

FLAG:１コ限定アイテム = 1
ITEM_ID_MIN = 500
ITEM_ID_MAX = 550
PRINTL 　《 Training Goods 》
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	CALL ITEM_SHOP_LOOP_JUDGE(LOCAL)
NEXT




