
;家具屋
@ITEM_SHOP_FURNITURE
#DIM DYNAMIC PAGE

CALL ITEM_SHOP_BUDGET_MONEY_JUDGE
BUY_NUM = 0
PAGE_MAX = 1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
BR = 0
SELECTCASE PAGE
CASE 1
	CALL ITEM_SHOP_FURNITURE_FACILITY
;CASE 2
	;CALL ITEM_SHOP_FURNITURE_DEVICE
ENDSELECT
PRINTL
DRAWLINE
CALL ITEM_SHOP_DETAIL_COMMON(PAGE,"家具屋")
CALL PRINTL_ALIGN
CALL BUY_ITEM_JUDGE("家具屋")
CALL ITEM_SHOP_FOOTER(PAGE,"1ページ")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL BUY_ITEM_COMMON(RESULT)
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 90
	CALL BULK_BUYING_COMMON(0,"家具屋")
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



;設備リスト
