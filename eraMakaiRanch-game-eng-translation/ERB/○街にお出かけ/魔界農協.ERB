
;魔界農協
@TOWN_AGRI_COOP
#DIM DYNAMIC SELECT_NUM

CLEARLINE LINECOUNT
CALL PET_HOUSE_BLANC_CHECK
CALL SHOW_RESOURCE_SHOP
PRINTL You can change the food and equipment for the pets on the farm, as well as handle financial matters.
PRINTL
PRINTL [ 0] Change Pet Food

CALL MILESTONE_UNLOCK_CHECK("魔界乳牛用設備","")
IF !RESULT
	CALL PRINTL_WORD_COLOR,@"　Dairy Farming Lv1","灰"
ELSE
	PRINTL [ 1] Installation of equipment for Makai dairy cows
ENDIF

CALL MILESTONE_UNLOCK_CHECK("不動産","L")
IF RESULT
	IF !FLAG:空きペット小屋数
		CALL PRINTL_WORD_COLOR,@"　An available space is needed in the ＜Pet House＞","灰"
	ELSE
		PRINTL [ 2] Adopt Large Pet
	ENDIF
ENDIF
PRINTL

CALL MILESTONE_UNLOCK_CHECK("納税","L")
SIF RESULT
	PRINTL [10] Tax Distribution
IF !MONEY
	CALL PRINT_WORD_COLOR("You do not have any funds.","灰")
ELSEIF MONEY:経費計上 || MONEY:ローン
	PRINT [11] Repay Loan Early
ELSE
	CALL PRINT_WORD_COLOR("Expense recording: No loan","灰")
ENDIF
PRINTL 
IF MONEY < DONATION_UNIT
	CALL PRINT_WORD_COLOR("Not Enough Money","灰")
ELSE
	PRINTL [12] Donate
ENDIF
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL AGRI_COOP_PET_FOOD_SELECT
CASE 1
	CALL AGRI_COOP_COWSHED_DEVICE_SELECT
CASE 2
	CALL AGRI_COOP_BUY_BIG_PET
CASE 10
	CALL AGRI_COOP_TAX_RATIO_SELECT
CASE 11
	CALL AGRI_COOP_LOAN_REPAY
CASE 12
	CALL AGRI_COOP_DONATION
CASE 99
	RETURN
ENDSELECT
RESTART


