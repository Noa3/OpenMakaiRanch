
;街での行動
@TOWN

;店から戻ったら毎回リセット
FLAG:１コ限定アイテム = 0
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
SELECT_ITEM = 0
CALL MILESTONE_UNLOCK_CHECK("奴隷捕獲","L")
SIF RESULT
	PRINTL [ 0] Town Hall
CALL MILESTONE_UNLOCK_CHECK("魔王軍研究所","L")
SIF RESULT
	PRINTL [ 1] Demon King's Army Research Institute

;Lvで目安になるので表示変え
CALL MILESTONE_UNLOCK_CHECK("アダルトショップ","")
IF !RESULT
	CALL PRINTL_WORD_COLOR("　Okachi City Lv1","灰")
ELSE
	PRINTL [ 2] Adult Shop
ENDIF
PRINTL [ 3] Home Center
CALL MILESTONE_UNLOCK_CHECK("不動産","L")
SIF RESULT
	PRINTL [ 4] Real Estate
PRINTL [ 5] Fashion Street

CALL MILESTONE_UNLOCK_CHECK("家具屋","")
IF !RESULT
	CALL PRINTL_WORD_COLOR("　Okachi City Lv3","灰")
ELSE
	PRINTL [ 6] Furniture Store
ENDIF
PRINTL [ 7] Pet Shop
PRINTL [ 8] Makai Agricultural Cooperative・Okachi City Branch
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1,"牧場に戻る")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL TOWN_HALL
CASE 1
	CALL TOWN_INSTITUTE
CASE 2
	CALL ITEM_SHOP_ADULT
CASE 3
	CALL ITEM_SHOP_WORK
CASE 4
	CALL ITEM_SHOP_ESTATE
CASE 5
	CALL ITEM_SHOP_CLOTHE
CASE 6
	CALL ITEM_SHOP_FURNITURE
CASE 7
	CALL ITEM_SHOP_PET
CASE 8
	CALL TOWN_AGRI_COOP
CASE 98
	CALL BROWSE_HINT("街入り口")
CASE 99
	;個人用転移門以外で外出していたら予定を行動済みに変更
	SIF FLAG:外出済み != 20
		CSTR:0:スケジュール = 行動済み
	CALL SCHEDULE_ADJUST
	RETURN
ENDSELECT
RESTART



