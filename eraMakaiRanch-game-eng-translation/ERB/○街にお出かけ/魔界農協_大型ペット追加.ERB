
;大型ペット追加
@AGRI_COOP_BUY_BIG_PET

;ITEM:堕天馬→100
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP_LOAN
CALL CAN_LOAN_MONEY_CALC
CALL PET_HOUSE_BLANC_CHECK
PRINTL 　《 Adopt a New Pet 》
BR = 0
ITEM_ID_MIN = 100
ITEM_ID_MAX = 110
FOR LOCAL,ITEM_ID_MIN,ITEM_ID_MAX
	SIF !ITEMPRICE:LOCAL
		CONTINUE
	CALL BR_PLUS(3)
	
	;持っている場合は買えない
	IF ITEM:LOCAL
		CALL PRINTLC_WORD_COLOR,@"[{LOCAL,3}] %ITEMNAME:LOCAL%","水色"
	
	;大型ペットはペット小屋に空きが必要
	ELSEIF ITEMPRICE:LOCAL > CAN_LOAN_MONEY +MONEY || !FLAG:空きペット小屋数
		CALL PRINTLC_WORD_COLOR,@"[{LOCAL,3}] %ITEMNAME:LOCAL%","灰"
	ELSE
		PRINTFORMLC [{LOCAL,3}] %ITEMNAME:LOCAL% 
	ENDIF
NEXT
PRINTL
DRAWLINE
CALL ITEM_SHOP_BIG_ANIMAL_DETAIL
CALL PRINTL_ALIGN(5)
CALL BUY_ITEM_JUDGE("ペット")
DRAWLINE
CALL RIGHT_RETURN_BUTTON
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL BUY_PET
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART



