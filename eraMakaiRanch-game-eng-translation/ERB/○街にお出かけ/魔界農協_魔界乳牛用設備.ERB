
;魔界乳牛用の設備設置
@AGRI_COOP_COWSHED_DEVICE_SELECT

;ITEM:牛床マット→40
ITEM_REF = 40
ITEM_MAX = 10
CALL ITEM_SHOP_BUDGET_MONEY_JUDGE
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
PRINTL 　《 Installation of Equipment for Makai Dairy Cows 》
FOR LOCAL,ITEM_REF,ITEM_REF +ITEM_MAX
	SIF ITEMNAME:LOCAL == ""
		CONTINUE
	PRINTFORM [{LOCAL -ITEM_REF,2}] %ITEMS_ENG(ITEMNAME:LOCAL),20%＜{ITEMPRICE:LOCAL}G／Day＞：
	IF !ITEM:LOCAL
		CALL PRINTL_WORD_COLOR("0 days left","灰")
	ELSE
		PRINTFORML {ITEM:LOCAL,2} days left
	ENDIF
NEXT
CALL PRINTL_ALIGN(-5)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1)
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 9
	CALL AGRI_COOP_COWSHED_DEVICE_ORDER(RESULT)
CASE 98
	CALL BROWSE_HINT("魔界乳牛用設備")
CASE 99
	RETURN
ENDSELECT
RESTART



;購入処理
;ARG→INPUT
@AGRI_COOP_COWSHED_DEVICE_ORDER(ARG)
#DIM ITEM_MAX_BUY
#DIM ITEM_BUY_PRICE
#DIM ITEM_MAX_PRICE

;USE_MONEYをどっち参照するか
IF FLAG:買い物／経費計上
	USE_MONEY = FLAG:最大一日売上 -MONEY:経費計上
ELSE
	USE_MONEY = MONEY
ENDIF
ITEM_NUM = ARG +ITEM_REF
SIF ITEMNAME:ITEM_NUM == ""
	RETURN
IF ITEMPRICE:ITEM_NUM *COWSHED_DEVICE_DAY > MONEY && !FLAG:買い物／経費計上
	PRINTFORMW Not enough funds.（Has to be bought in {COWSHED_DEVICE_DAY} day increments）
	RETURN
ELSEIF ITEM:ITEM_NUM >= COWSHED_DEVICE_DAY_MAX
	PRINTFORMW Maximum amount has been reached.
	RETURN
ENDIF

;MAX購入の個数・金額
ITEM_MAX_BUY = COWSHED_DEVICE_DAY_MAX -ITEM:ITEM_NUM
ITEM_MAX_PRICE = ITEM_MAX_BUY *ITEMPRICE:ITEM_NUM

PRINTFORML For how many days do you want to order %ITEMS_ENG(ITEMNAME:ITEM_NUM)%？（You can order in {COWSHED_DEVICE_DAY} day increments）
FOR LOCAL,1,4
	;100日超える場合・お金ない場合はスキップ
	ITEM_BUY_PRICE = LOCAL *ITEMPRICE:ITEM_NUM *COWSHED_DEVICE_DAY
	SIF ITEM_MAX_BUY < LOCAL *COWSHED_DEVICE_DAY || (ITEM_BUY_PRICE > MONEY && !FLAG:買い物／経費計上)
		CONTINUE
	PRINTFORML [{LOCAL,2}] {LOCAL *COWSHED_DEVICE_DAY} days：{ITEM_BUY_PRICE}G 
	
	;これを買うと経費超えるところで終了
	SIF FLAG:買い物／経費計上 && ITEM_BUY_PRICE >= USE_MONEY
		BREAK
NEXT
PRINTL

;条件的に経費のMAX買いができないけどまあ仕方なし
SIF ITEM_MAX_BUY >= COWSHED_DEVICE_DAY && ITEM_MAX_PRICE <= USE_MONEY
	PRINTFORML [ 9] Maximum number of days:（{ITEM_MAX_BUY}）：{ITEM_MAX_PRICE}G
PRINTL [99] Cancel
BINPUT
PRINTL
SELECTCASE RESULT
CASE 1 TO 3
	BUY_NUM = RESULT *COWSHED_DEVICE_DAY
	ITEM_BUY_PRICE = BUY_NUM *ITEMPRICE:ITEM_NUM
	ITEM:ITEM_NUM += BUY_NUM
	IF FLAG:買い物／経費計上
		MONEY:経費計上 += ITEM_BUY_PRICE
	ELSE
		MONEY -= ITEM_BUY_PRICE
	ENDIF
	CALL PRINTW_WORD_COLOR,@"＜%ITEMNAME:ITEM_NUM%＞ ordered for {BUY_NUM} days.","水色"

CASE 9
	ITEM:ITEM_NUM += ITEM_MAX_BUY
	IF FLAG:買い物／経費計上
		MONEY:経費計上 += ITEM_MAX_PRICE
	ELSE
		MONEY -= ITEM_MAX_PRICE
	ENDIF
	CALL PRINTW_WORD_COLOR,@"＜%ITEMNAME:ITEM_NUM%＞ ordered for {ITEM_MAX_BUY} days.","水色"
ENDSELECT



