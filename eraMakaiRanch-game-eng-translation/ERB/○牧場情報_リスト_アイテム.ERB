
;消耗品リスト表示
;ITEM_REF・ITEM_MAX指定済み
@RANCH_STATUS_USED_ITEM_LIST

BR = 0
FOR LOCAL,ITEM_REF,ITEM_REF +ITEM_MAX
	SIF ITEMNAME:LOCAL == ""
		CONTINUE
	SIF !ITEM:LOCAL
		SETCOLOR 0x606060
	CALL BR_PLUS(3)
	PRINTFORMLC %ITEMS_ENG(ITEMNAME:LOCAL),25,LEFT%：{ITEM:LOCAL,3} 
	RESETCOLOR
NEXT
SIF !LINEISEMPTY()
	PRINTL
PRINTL



;非消耗品リスト表示
;ITEM_REF・ITEM_MAX指定済み
@RANCH_STATUS_NOUSE_ITEM_LIST

BR = 0
FOR LOCAL,ITEM_REF,ITEM_REF +ITEM_MAX
	SIF ITEMNAME:LOCAL == ""
		CONTINUE
	SIF !ITEM:LOCAL
		SETCOLOR 0x606060
	CALL BR_PLUS(6)
	PRINTFORM 【%ITEMS_ENG(ITEMNAME:LOCAL)%】
	RESETCOLOR
NEXT



