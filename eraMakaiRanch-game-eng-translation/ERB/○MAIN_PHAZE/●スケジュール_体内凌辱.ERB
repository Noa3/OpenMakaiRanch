
;体内凌辱本体
@MASTER_VORE_SEX

;人数
CATTLE_COUNT = CMATCH(CSTR:スケジュール,"体内凌辱")
SIF !CATTLE_COUNT
	RETURN
PLAYER = MASTER
PRINTL 　　　《 体内凌辱 》
VARSET DRAIN_POWER

;最大EP,現在EP,最大MP,現在MP
DRAIN_POWER:0 = MAXBASE:0:霊力
DRAIN_POWER:1 = BASE:0:霊力
DRAIN_POWER:2 = MAXBASE:0:魔力
DRAIN_POWER:3 = BASE:0:魔力
FLAG:体内凌辱持ち越し魔力 = 0
CALL RANDOM_CHARA_SCHEDULE_COMMON("体内凌辱")
CALL SECTION_MP_COST
CALL SCHEDULE_ABL_MARK_BULK(1,"体内凌辱")

;あなたEP,MPの前後差を表示
CALL PRINT_MASTER_VORE_SEX_EPMP

;あなたの体力増加・レベルアップ
CALL MASTER_POWERUP_EP
CALL MASTER_POWERUP_MP
PRINTW
DRAWLINE
PLAYER = -1
CALL RESET_TRAIN_PALAM



;抽選したキャラの体内凌辱風景表示
@MASTER_VORE_SEX_ENTRANCE

IF !EXP:実行回数／体内凌辱
	KOJO_TYPE = 初回
ELSE
	KOJO_TYPE = 通常
ENDIF
CALL MASTER_VORE_SEX_STANDBY_MESSAGE
CALL MASTER_VORE_SEX_RUN_MESSAGE
CALL SLAVE_LACTATION_RUN(1,"体内凌辱")
FLAG:前回表示キャラID／体内凌辱 = CFLAG:ID
WAIT
CALL MANYL(2)



;あなたEP,MPの前後差を表示
@PRINT_MASTER_VORE_SEX_EPMP

;各差分
DRAIN_POWER:4 = MAXBASE:0:霊力 -DRAIN_POWER:0
DRAIN_POWER:5 = BASE:0:霊力 -DRAIN_POWER:1
DRAIN_POWER:6 = MAXBASE:0:魔力 -DRAIN_POWER:2
DRAIN_POWER:7 = BASE:0:魔力 -DRAIN_POWER:3

;どれも同じ場合でも消費魔力が全回復してることになる
PRINTFORM %CALLNAME:0%：
SIF DRAIN_POWER:4
	PRINTFORM 最大霊力+%VALUE_DIGIT(DRAIN_POWER:4)%EP　
SIF DRAIN_POWER:5 && DRAIN_POWER:4 != DRAIN_POWER:5
	PRINTFORM 霊力+%VALUE_DIGIT(DRAIN_POWER:5)%EP　
SIF DRAIN_POWER:6
	PRINTFORM 最大魔力+%VALUE_DIGIT(DRAIN_POWER:6)%MP　
IF DRAIN_POWER:6 != DRAIN_POWER:7
	IF DRAIN_POWER:7 > 0
		PRINTFORM 魔力+%VALUE_DIGIT(DRAIN_POWER:7)%MP　
	ELSE
		PRINTFORM 魔力-%VALUE_DIGIT(DRAIN_POWER:7 *-1)%MP　
	ENDIF
ELSE
	PRINT 消費魔力全回復　
ENDIF



;ランダムに触手使用
@VORE_SEX_RANDOM_TENTACLE

TFLAG:搾乳責め = 1
TFLAG:搾乳触手 = 1
SIF GETBIT(＃個人有効／搾乳エナジードレイン＃) && GETBIT(＃有効／搾乳エナジードレイン＃)
	TFLAG:エナジードレイン = 1
TFLAG:Ａ装備 = 1
TFLAG:Ｂ装備 = 1
TFLAG:Ｃ装備 = 1
TFLAG:Ｎ装備 = 1
SIF !TALENT:処女結界
	TFLAG:Ｖ装備 = 1

;体内凌辱継続ならランダムにする　他は確定させる（地の文との兼ね合い）
IF CFLAG:体内凌辱継続
	IF RAND:100 < 85
		TEQUIP:乳包み花弁搾乳触手 = 1
	ELSE
		TEQUIP:透明カップ搾乳触手 = 1
	ENDIF
	IF ABL:バストサイズ < BUSTSIZE_巨乳 || RAND:100 < 85
		TEQUIP:触手乳揉み = 1
	ELSEIF RAND:100 < 10
		TEQUIP:ブラシ触手Ｂ = 1
	ELSE
		TEQUIP:触手乳搾り = 1
	ENDIF
	SIF ABL:バストサイズ >= BUSTSIZE_巨乳 && RAND:100 < 50
		TEQUIP:触手強制パイズリ = 1
	
	IF RAND:100 < 90
		TEQUIP:触手Ａ挿入 = 1
	ELSE
		TEQUIP:ブラシ触手Ａ = 1
	ENDIF
	IF RAND:100 < 90
		TEQUIP:触手クリ吸い = 1
	ELSE
		TEQUIP:ブラシ触手Ｃ = 1
	ENDIF
	
	IF !TALENT:処女結界
		IF RAND:100 < 90
			TEQUIP:触手Ｖ挿入 = 1
		ELSE
			TEQUIP:ブラシ触手Ｖ = 1
		ENDIF
	ENDIF
	
	IF RAND:100 < 20
		TEQUIP:触手イラマチオ = 1
		TFLAG:Ｍ装備 = 1
	ENDIF
	IF RAND:100 < 20
		TEQUIP:触手目隠し = 1
		TFLAG:目隠し = 1
	ENDIF
	IF RAND:100 < 20
		TEQUIP:触手耳姦 = 1
		TFLAG:Ｅ装備 = 1
	ENDIF
ELSE
	TEQUIP:乳包み花弁搾乳触手 = 1
	IF ABL:バストサイズ < BUSTSIZE_巨乳
		TEQUIP:触手乳揉み = 1
	ELSE
		TEQUIP:触手乳搾り = 1
	ENDIF
	TEQUIP:触手Ａ挿入 = 1
	TEQUIP:触手クリ吸い = 1
	SIF !TALENT:処女結界
		TEQUIP:触手Ｖ挿入 = 1
ENDIF

;ブラシ触手ONにするコマンド
IF MATCH(TEQUIP,1,150,155)
	TEQUIP:ブラシ触手 = 1
	SOURCE:ブラシ触手コマンド = 1
ENDIF

IF FLAG:あなたの触手もあなた扱い
	V_PENIS = %CALLNAME:0%
	A_PENIS = %CALLNAME:0%
	M_PENIS = %CALLNAME:0%
	PAIZURI_PENIS = %CALLNAME:0%
	KISS_PLAYER = %CALLNAME:0%
	MILK_SUCK_PLAYER = %CALLNAME:0%
ELSE
	V_PENIS = 触手
	A_PENIS = 触手
	M_PENIS = 触手
	PAIZURI_PENIS = 触手
	KISS_PLAYER = 触手
	MILK_SUCK_PLAYER = 触手
ENDIF



;体内凌辱中の一部SOURCE上書き
;SOURCE_CHECKから来るよ
@VORE_SEX_LOOP_SOURCE

SIF !TFLAG:体内凌辱中
	RETURN

;一旦触手快楽SOURCEを半減してから増加
;SOURCE:Ａ快楽／触手→130
FOR LOCAL,130,140
	SOURCE:LOCAL /= 2
NEXT
SOURCE:Ａ快楽／触手 += 3000
SOURCE:Ｂ快楽／触手 += 3000
SOURCE:Ｃ快楽／触手 += 3000
SOURCE:Ｎ快楽／触手 += 3000
SIF !TALENT:処女結界
	SOURCE:Ｖ快楽／触手 += 3000
SIF BASE:母乳容量
	SOURCE:異形授乳 += 1000
LOSEBASE:体力 = 50
LOSEBASE:気力 = 50
SOURCE:支配 += 5000
SOURCE:異形恐怖 += 1000

;魔力消費がクッソ多いよ
SOURCE:触手魔力消費量 = 5000
SOURCE:Ｖ潤滑追加 += 1000
SOURCE:Ａ潤滑追加 += 1000



