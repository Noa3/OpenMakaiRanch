
;スケジュール実行処理の共通部分

;人数とABLの最大値をセットする
;ARGS→スケジュール
@WORKER_ABL_SET(ARGS)

;人数とあなたが入ってるかを見て「たち」表記するか判断
WORK_GROUP = WORKER
SIF CSTR:0:スケジュール == ARGS
	WORK_GROUP --
SELECTCASE ARGS
CASE "調剤"
	ABL_NAME = 薬学
CASE "大浴場掃除"
	ABL_NAME = 掃除
CASEELSE
	ABL_NAME = %ARGS%
ENDSELECT

;メンバー内でのABL最大値
FLAG:作業ABL最大値 = 0
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:スケジュール == ARGS && FLAG:作業ABL最大値 < ABL:ABL_NAME
		FLAG:作業ABL最大値 = ABL:ABL_NAME
NEXT
FLAG:作業ABL最大値 = LIMIT(FLAG:作業ABL最大値,0,10)



;メッセージ込みでスケジュールを実行するキャラを優先度つけて選んで実行
;ARGS→スケジュール
@RANDOM_CHARA_SCHEDULE_COMMON(ARGS)

PRINT_DONE = 0
SELECTCASE ARGS
CASE "体内凌辱準備"
	EXP_NAME = 実行回数／体内凌辱
CASEELSE
	EXP_NAME = 実行回数／
	EXP_NAME += ARGS
ENDSELECT

;1人にフォーカスして地の文表示
;[EXP:実行回数]が0は全員表示　業務で体力0の場合を除く
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:スケジュール != ARGS || EXP:EXP_NAME || (!BASE:体力 && GROUPMATCH(ARGS,＃業務スケジュール＃))
		CONTINUE
	
	;メッセージ表示+実行
	CALL SCHEDULE_RUN(ARGS)
	PRINT_DONE ++
NEXT

;全員表示フラグがONならさらに全員
IF FLAG:スケジュール全員詳細表示
	FOR TARGET_COUNT,1,CHARANUM
		TARGET = TARGET_COUNT
		SIF CSTR:スケジュール != ARGS || CFLAG:行動済み
			CONTINUE
		CALL SCHEDULE_RUN(ARGS)
		PRINT_DONE ++
	NEXT
ENDIF

;初スケジュールがいなかったなら1人選ぶ関数を呼び出し
IF !PRINT_DONE
	CALL RANDOM_CHARA_SCHEDULE_BOX(ARGS)
	
	;BOX_COUNTが0で業務スケジュール→あなたを表示
	;業務じゃないのに0でここ外す場合はエラー吐いていい
	IF !BOX_COUNT && GROUPMATCH(ARGS,＃業務スケジュール＃)
		TARGET = 0
		CALL SCHEDULE_RUN(ARGS)
		
	;BOX_COUNTが1以上→ランダム選択して表示
	ELSE
		CALL PRINT_SCHEDULE_CHARA_LOTTERY(ARGS)
		CALL SCHEDULE_RUN(ARGS)
	ENDIF
ENDIF

;表示しなかったキャラの作業簡易実行
FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	
	;実行したキャラは行動済みフラグで飛ばされる
	SIF CSTR:スケジュール != ARGS || CFLAG:行動済み
		CONTINUE
	CALL SCHEDULE_RUN_SIMPLE(ARGS)
NEXT



;スケジュール実行+メッセージ
@SCHEDULE_RUN(ARGS)

SELECTCASE ARGS
CASE "酪農"
	CALL WORK_LACTATION_ENTRANCE
CASE "事務"
	CALL WORK_FINANCE_ENTRANCE
CASE "調剤"
	CALL WORK_PHARMACY_ENTRANCE
CASE "大浴場掃除"
	CALL WORK_LARGE_BATHLOOM_CLEANING_ENTRANCE
CASE "搾乳"
	CALL SLAVE_LACTATION_ENTRANCE
CASE "抽出"
	CALL SLAVE_DRAIN_ENTRANCE
CASE "体内凌辱準備"
	CALL MASTER_VORE_MOVE_ENTRANCE
CASE "体内凌辱"
	CALL MASTER_VORE_SEX_ENTRANCE
CASE "触手責め搾乳"
	CALL SLAVE_T_LACTATION_ENTRANCE
ENDSELECT



;メッセージなし簡易実行
@SCHEDULE_RUN_SIMPLE(ARGS)

SELECTCASE ARGS
CASE "酪農"
	CALL WORK_LACTATION_RUN
CASE "事務"
	CALL WORK_FINANCE_RUN
CASE "調剤"
	CALL WORK_PHARMACY_RUN
CASE "大浴場掃除"
	;大浴場掃除は最初の1人以外出さなくてOK
	
CASE "搾乳"
	CALL SLAVE_LACTATION_RUN(0,"搾乳")
CASE "抽出"
	CALL SLAVE_LACTATION_RUN(0,"抽出")
CASE "体内凌辱準備"
	CALL MASTER_VORE_MOVE_ENTRANCE(1)
CASE "体内凌辱"
	CALL SLAVE_LACTATION_RUN(0,"体内凌辱")
CASE "触手責め搾乳"
	CALL SLAVE_LACTATION_RUN(0,"触手責め搾乳")
ENDSELECT



;調教者人数と技巧補正値計算
@SLAVE_LACTATION_TECHNIQUE_SET

;あなたが搾乳するならあなたのABL、あなた不在なら最大技巧の半分
;あとあなた除く人数も計算
WORK_GROUP = 0
FLAG:補正技巧値 = 0
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:スケジュール == "酪農"
		WORK_GROUP ++
	SIF CSTR:スケジュール == "酪農" && FLAG:補正技巧値 < ABL:技巧
		FLAG:補正技巧値 = ABL:技巧
NEXT
IF CSTR:0:スケジュール == "酪農"
	FLAG:補正技巧値 = ABL:0:技巧
	PLAYER = MASTER
ELSE
	FLAG:補正技巧値 = FLAG:補正技巧値 /2
	PLAYER = -1
ENDIF



;「たち」表示
@PRINT_WORK_GROUP
#FUNCTIONS

SIF WORK_GROUP >= 2
	RETURNF " and the others"



;スケジュール実行後まとめてABL,MARK処理
;ARG→MARKも見る
;ARGS→スケジュール
@SCHEDULE_ABL_MARK_BULK(ARG,ARGS)

FOR TARGET_COUNT,0,CHARANUM
	TARGET = TARGET_COUNT
	SIF CSTR:スケジュール != ARGS
		CONTINUE
	CALL ABL_UP
	SIF ARG
		CALL MARK_GET
	
	;体内凌辱の時だけ虚脱判定
	SIF ARGS == "体内凌辱"
		CALL COLLAPSE_CHECK
NEXT



;虚脱チェック
@COLLAPSE_CHECK

;体力0で虚脱じゃない場合に虚脱化
SIF BASE:体力 || CFLAG:虚脱
	RETURN
CFLAG:虚脱 = 1
CALL BECOME_COLLAPSE_MESSAGE



