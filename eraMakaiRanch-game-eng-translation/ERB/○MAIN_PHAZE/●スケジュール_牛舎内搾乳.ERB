
;牛舎にいる家畜の搾乳
@COWSHED_LACTATION

;人数　有無しかCMATCHは取れないっぽいので牛舎番号でなくスケジュール
CATTLE_COUNT = CMATCH(CSTR:スケジュール,"牛舎")
SIF !CATTLE_COUNT
	RETURN

;家畜小屋の搾乳の直後に来るんだけど家畜小屋に誰もいない場合があるので改めて
SIF !CMATCH(CSTR:スケジュール,"酪農")
	RETURN
CALL SLAVE_LACTATION_TECHNIQUE_SET
PRINTL 　　　《 Cowshed 》

;FLAG:第1牛舎スケジュール→501
;FLAG:第1牛舎家畜頭数→502
;FLAG:第1牛舎スケジュール表示→503
FLAG_REF = 491
FLAG_REF:1 = 492
FLAG_REF:2 = 493
FOR COWSHED_NUM,1,11
	;建ってなければ終了
	SIF COWSHED_NUM > ITEM:牛舎
		BREAK
		
	;家畜がいなければ飛ばす
	SIF !FLAG:(FLAG_REF:1 +COWSHED_NUM *10)
		CONTINUE
	
	;昼でスケジュールが0なら休憩
	IF !FLAG:(FLAG_REF +COWSHED_NUM *10) && TIME == 1
		PRINTFORML The dairy cows in %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)% are resting.
		CALL COWSHED_LACTATION_REST
	ELSE
		CALL COWSHED_LACTATION_RUN
	ENDIF
	PRINTL
NEXT
CALL SECTION_MP_COST
CALL COWSHED_LACTATION_ABL_MARK_BULK
PRINTW
DRAWLINE
CALL RESET_TRAIN_PALAM
PLAYER = -1



;休憩
@COWSHED_LACTATION_REST

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CFLAG:牛舎番号 != COWSHED_NUM
		CONTINUE
	CALL REST_HEAL(1)
NEXT



;搾乳本体
@COWSHED_LACTATION_RUN
#DIM TOTAL_MILK

;フラグにより表示するか判定
FLAG:牛舎搾乳表示スキップ = FLAG:(FLAG_REF:2 +COWSHED_NUM *10)
TOTAL_MILK = 0
CALL RANDOM_CHARA_SCHEDULE_COWSHED

;BOX_COUNTに何もないとたぶん壊れてる、RAND:0するのでエラー落ち
TARGET = RANDOM_NO_BOX:RAND(BOX_COUNT)
CALL COWSHED_LACTATION_START_MESSAGE

SIF !FLAG:牛舎搾乳表示スキップ
	CALL SLAVE_LACTATION_RUN(1,"牛舎")

;合計値増加
TOTAL_MILK += EX:噴乳

;その後全員
;裸を見られた口上はここではいいや
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF CFLAG:牛舎番号 != COWSHED_NUM || CFLAG:行動済み
		CONTINUE
	;表示まるごとスキップ判定がここ
	SKIPDISP FLAG:牛舎搾乳表示スキップ
	CALL SLAVE_LACTATION_RUN(0,"牛舎")
	TOTAL_MILK += EX:噴乳
NEXT

;SKIPDISPは刻印通る場所で0に戻ってる
PRINTFORML %ITEMS_ENG(COWSHED_NAME:COWSHED_NUM)%：%VALUE_DIGIT(TOTAL_MILK,"母乳")% Milked 
FLAG:牛舎搾乳表示スキップ = 0



;牛舎内をまとめてABL,MARK
@COWSHED_LACTATION_ABL_MARK_BULK
#DIM SKIP

FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	SIF !CFLAG:牛舎番号
		CONTINUE
	SKIP = 0
	
	;FLAG:第1牛舎スケジュール表示→503
	SIF FLAG:(493 +CFLAG:牛舎番号 *10) == 2
		SKIP = 1
	SKIPDISP SKIP
	CALL ABL_UP
	SIF SKIP
		SKIPDISP 0
	CALL MARK_GET
NEXT




