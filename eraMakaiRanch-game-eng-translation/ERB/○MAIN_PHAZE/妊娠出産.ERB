
;妊娠日数経過
@CHILDBIRTH_COUNT
#DIM LINES

LINES = LINECOUNT
FOR TARGET,1,CHARANUM
	;妊娠日数がない場合は無視
	SIF !CFLAG:妊娠日数
		CONTINUE
	CFLAG:妊娠日数 ++
	
	;CFLAG:妊娠日数が10(丸８日経過)で妊娠発覚、16で出産
	;触手はCFLAG:妊娠日数が93(丸一日経過)で妊娠発覚、95で出産
	SELECTCASE CFLAG:妊娠日数
		CASE 10
			;あなたに初めて孕ませられた場合あなたの孕ませ人数(EXP:出産でカウント)を加算
			IF !EXP:経験回数／あなた／出産
				SIF !EXP:0:出産
					CSTR:0:初経験／出産 = %CALLNAME%
				EXP:0:出産 ++
			ENDIF
			PRINTFORMW %CALLNAME%のお腹が少し膨らんできている、%CALLNAME:0%の子を妊娠していたようだ…
			PRINTL 
			PRINTW 注意：産まれた子を手元で育てたい場合、出産時に個室の空きが必要になります
		CASE 13
			PRINTFORMW %CALLNAME%のお腹はだいぶ大きくなってきた…
		CASE 15
			PRINTFORMW %CALLNAME%のお腹の子は、明日には産まれそうだ…
		;前Verまで31までだったのでその対処用
		;CASE 16
		CASE 16 TO 31
			CALL CHILDBIRTH
		CASE 93
			PRINTFORMW %CALLNAME%のお腹が少し膨らんできている、触手の子を妊娠していたようだ…
			;TARGETのリアクションも書こうかと思ったけどあなたとの経験もある場合、
			;本人はどっちの子かまだ判断できなさそうな気がするので見送り
		CASE 94
			PRINTFORMW %CALLNAME%のお腹が大きく膨らんできている、明日には産まれそうだ…
		CASE 95
			CALL TENTACLE_BIRTH
	ENDSELECT
NEXT
SIF LINES != LINECOUNT
	CALL HALFLINE



;出産
;今のところ一人ずつだけど一応双子以上にも対応可
@CHILDBIRTH
#DIM CHILDBIRTH_COUNT = 1
#DIM SOURCE_FIX

PRINTFORML %CALLNAME%が産気づいたようだ…
PRINTL 
IF CSTR:スケジュール == "体内凌辱"
	PRINTFORML %CALLNAME:0%は体内空間で拘束している%CALLNAME%に意識を向けた…
	PRINTFORMW さらに触手を%SLANG_V()%に侵入させ、中をほぐしながら子宮を刺激し出産を促した…
	PRINTFORML しばらく刺激を続けたのちに触手を%SLANG_V()%から引き抜くと、すぐにお産が始まり
ELSE
	PRINTFORML %CALLNAME:0%は%CALLNAME%の元へ向かうと、
	PRINTFORMW 暴れぬよう%CALLNAME%をベッドの上に股を開かせた格好で拘束した…
	PRINTFORML %CALLNAME%を見守っていると、しばらくした後にお産が始まり
ENDIF
PRINTFORM %CALLNAME%は苦痛
IF BASE:好感度 >= BASE_FIRST_MAX || CFLAG:崩壊 || CFLAG:洗脳
	PRINT に耐えながら
ELSE
	PRINT と絶望感で泣き叫びながら
ENDIF
SIF BASE:好感度 >= BASE_FIRST_MAX
	PRINT 愛する
PRINTFORM %CALLNAME:0%との子を
SIF CHILDBIRTH_COUNT > 1
	PRINTFORM {CHILDBIRTH_COUNT}人
PRINTL 出産した…
IF !MARK:母乳体質
	MARK:母乳体質 = 1
	CALL PRINTL_WORD_COLOR("出産したことで、%CALLNAME%の%SLANG_N()%から%SAVESTR:表記／母乳%が出るようになった…","桃")
	CALL MILKTANK_CALC
ENDIF
WAIT

PLAYER = 0
CALL STATUS_BEFORE_RECORD
CALL RESET_TRAIN_PALAM
TFLAG:調教中 = 0
IF CSTR:スケジュール == "体内凌辱"
	TFLAG:Ｖ装備 = 1
	TEQUIP:触手Ｖ挿入 = 1
	SETBIT ＃拘束／触手＃
	IF FLAG:あなたの触手もあなた扱い
		V_PENIS = %CALLNAME:0%
	ELSE
		V_PENIS = 触手
	ENDIF
ELSE
	SETBIT ＃拘束／まんぐり＃
ENDIF

;BASE:好感度次第で100～0%まで減少補正
;ニンゲンからしたらあなたも異種族だし基礎値は触手と同じでいいかな？
SOURCE_FIX = LIMIT(1000000 - (BASE:好感度 * BASE:好感度),0,1000000)
LOSEBASE:体力 = 200 * CHILDBIRTH_COUNT

;気力は基本0になる
LOSEBASE:気力 = 5000
SOURCE:情愛 = CHILDBIRTH_COUNT * LIMIT(BASE:好感度 * BASE:好感度 / 100 - 2500,0,10000)
SOURCE:Ｖ痛み = 20000 * CHILDBIRTH_COUNT
SOURCE:恥辱 = 100000 * CHILDBIRTH_COUNT * SOURCE_FIX / 1000000
SOURCE:屈辱 = 200000 * CHILDBIRTH_COUNT * SOURCE_FIX / 1000000
SOURCE:失意 = 100000 * CHILDBIRTH_COUNT * SOURCE_FIX / 1000000
SOURCE:反感 = 50000 * CHILDBIRTH_COUNT * SOURCE_FIX / 1000000
SOURCE:支配 = 50000 * CHILDBIRTH_COUNT * SOURCE_FIX / 1000000
CALL SOURCE_CHECK
CALL TRAIN_END_PALAM_CALC
CALL PRINT_STATUS_BEFORE_AFTER
CALL ABL_UP
CALL MARK_GET
CALL CHILDBIRTH_AVOID_MIND_BREAK
CALL CAPITULATION_JUDGE
CALL SECTION_MP_COST

SIF CSTR:初経験／出産 == "" && !EXP:出産
	CSTR:初経験／出産 = %CALLNAME:MASTER%
EXP:出産 += CHILDBIRTH_COUNT
EXP:経験回数／あなた／出産 += CHILDBIRTH_COUNT
CFLAG:妊娠日数 = 0
PRINTL 
IF FLAG:個室数／空室
	PRINTFORML 産まれた子を手元で育てますか？
	CALL ASK_YN
ELSE
	RESULT = 1
ENDIF
IF !RESULT
	FLAG:個室数／空室 --
	CALL CHARA_MAKE_CHILD
ELSE
	PRINTFORMW 産まれた子は知り合いの孤児院に預けることにしました
ENDIF
CALL MANYL(3)






;触手出産
@TENTACLE_BIRTH
#DIM TENTACLE_BIRTH_COUNT
#DIM SOURCE_FIX

PLAYER = 0
;とりあえず5～8匹で
TENTACLE_BIRTH_COUNT = 5 + RAND:4

PRINTFORML %CALLNAME%が産気づいたようだ…
PRINTL 
IF CSTR:スケジュール == "体内凌辱"
	PRINTFORML %CALLNAME:0%は体内空間で拘束している%CALLNAME%に意識を向けた…
ELSE
	PRINTFORML %CALLNAME:0%は%CALLNAME%の元へ向かうと、
	PRINTFORML 体から伸ばした触手で%CALLNAME%を拘束し、股を開かせた…
ENDIF
PRINTFORMW さらに触手を%SLANG_V()%に侵入させ、中をほぐしながら子宮を刺激し出産を促した…
PRINTL 
PRINTFORML しばらく刺激を続けたのちに触手を%SLANG_V()%から引き抜くと、すぐにお産が始まり
PRINTFORM %CALLNAME%は苦痛と快感
IF ABL:触手中毒 > 9 || CFLAG:崩壊 || CFLAG:洗脳
	PRINT で喘ぎ
ELSE
	PRINT 、絶望感で泣き叫び
ENDIF
PRINTFORML ながら触手を{TENTACLE_BIRTH_COUNT}匹出産した…
IF !MARK:母乳体質
	MARK:母乳体質 = 1
	PRINTFORML 出産を経験し%CALLNAME%の%SLANG_N()%から%SAVESTR:表記／母乳%が出るようになった…
	CALL MILKTANK_CALC
ENDIF
PRINTFORMC 現在の触手の総数 <{FLAG:触手出産合計 + TENTACLE_BIRTH_COUNT}匹> 
IF FLAG:触手出産合計 < 10 && FLAG:触手出産合計 + TENTACLE_BIRTH_COUNT >= 10
	CALL MANYL(3)
	PRINTL スケジュールで＜触手責め搾乳＞が選択できるようになりました。
	PRINTL 一人につき触手10匹必要になります。
ENDIF
WAIT

CALL STATUS_BEFORE_RECORD
CALL RESET_TRAIN_PALAM
TFLAG:調教中 = 0
TFLAG:Ｖ装備 = 1
SETBIT ＃拘束／触手＃
TEQUIP:触手Ｖ挿入 = 1
IF FLAG:あなたの触手もあなた扱い
	V_PENIS = %CALLNAME:0%
ELSE
	V_PENIS = 触手
ENDIF

;ABL:触手中毒があると100～20%まで減少補正
SOURCE_FIX = LIMIT(500 - (ABL:触手中毒 * ABL:触手中毒),100,500)
LOSEBASE:体力 = 200 * TENTACLE_BIRTH_COUNT
LOSEBASE:気力 = 5000
SOURCE:Ｖ快楽／触手 = 10000 * TENTACLE_BIRTH_COUNT
SOURCE:Ｖ痛み = 20000 * TENTACLE_BIRTH_COUNT
SOURCE:苦痛 = 20000 * TENTACLE_BIRTH_COUNT
SOURCE:恥辱 = 100000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:屈辱 = 200000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:淫欲 = 100 * TENTACLE_BIRTH_COUNT * LIMIT(ABL:触手中毒 - 4,0,99)
SOURCE:失意 = 100000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:反感 = 50000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:出産恐怖 = 100000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:不潔 = 30000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:支配 = 50000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:異形恐怖 = 30000 * TENTACLE_BIRTH_COUNT * SOURCE_FIX / 500
SOURCE:Ｖ潤滑追加 = 10000
CALL SOURCE_CHECK
CALL TRAIN_END_PALAM_CALC
SIF EX:総絶頂
	PRINTFORMC %CALLNAME_DIGIT()% <{EX:総絶頂,4}回絶頂> 
CALL PRINT_STATUS_BEFORE_AFTER
CALL ABL_UP
CALL MARK_GET
CALL CHILDBIRTH_AVOID_MIND_BREAK
CALL CAPITULATION_JUDGE
CALL SECTION_MP_COST

FLAG:触手出産合計 += TENTACLE_BIRTH_COUNT
;あなたの触手もあなた扱いフラグONでも触手の子の認識
SIF CSTR:初経験／出産 == "" && !EXP:出産
	CSTR:初経験／出産 = 触手
EXP:出産 += TENTACLE_BIRTH_COUNT
EXP:経験回数／異形／出産 += TENTACLE_BIRTH_COUNT
CFLAG:妊娠日数 = 0
CALL MANYL(3)



;崩壊回避手段がなさそうなので洗脳して崩壊回避するかを選択(一時的なヤツなので消費半分)
@CHILDBIRTH_AVOID_MIND_BREAK

USE_MP = MAGIC_USE_MP:GETNUM(ITEM,"洗脳") /2
IF !BASE:精神力 && !CFLAG:崩壊 && !CFLAG:洗脳 && ITEM:洗脳 && BASE:0:魔力 >= USE_MP
	PRINTFORML このままだと%CALLNAME%の精神が限界を迎えそうだ…
	PRINTFORML 魔力を{USE_MP}消費して洗脳触手を使い、精神崩壊を防ぎますか？
	PRINTFORML %CALLNAME:0%の魔力：%VALUE_DIGIT(BASE:0:魔力)%MP 
	CALL ASK_YN
	IF !RESULT
		PRINTFORML %CALLNAME:MASTER%は洗脳触手を使って%CALLNAME%を一時的に洗脳し、
		PRINTFORMW %CALLNAME%の精神をなんとか安定させた…
		BASE:精神力 = 10
		BASE:0:魔力 -= USE_MP
	ENDIF
ELSE
	WAIT
ENDIF



