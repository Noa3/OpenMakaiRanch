
;調教外責めの結果表示
@SCHEDULE_LACTATION_TOTAL_RESULT

;揃える表示を別に使いたいかもしれない
;母乳体質ではない場合
RESETCOLOR
IF !MARK:母乳体質
	PRINTFORMC %CALLNAME_DIGIT()% <{EX:総絶頂,4} Orgasms> 
	CALL PRINT_STATUS_BEFORE_AFTER

;母乳体質の場合
ELSE
	PRINTFORMC %CALLNAME_DIGIT()%'s %PRINT_BUST()% spurt 
	CALL PRINT_TOTAL_MILK_FLAVOR
	PRINTFORM  %VALUE_DIGIT(EX:噴乳)%%MILK_COUNTING()% Milked <{EX:総絶頂,2} Orgasms> 
	CALL PRINT_STATUS_BEFORE_AFTER
	
	;ここでフラグ立てる
	SIF !BASE:霊力
		EXP:霊力ゼロ = 1
ENDIF
IF CFLAG:崩壊
	CALL PRINTL_WORD_COLOR("[Mindbroken] ","赤")
ELSE
	SIF !CFLAG:牛舎番号
		PRINTL
	CALL TRAIN_END_PALAM_CALC
ENDIF

;牛舎搾乳での表示スキップ判定を解除
SKIPDISP 0

;崩壊寸前や乳牛堕ち寸前なら常に表示
SIF BASE:精神力 < BASE_LIMITER_HEAL_MIND && !CFLAG:崩壊
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%　Will：%PRINT_PALAM_PERCENT(BASE:精神力)% ","赤"
SIF BASE:乳牛堕ち >= BASE_ENDURE_COW && !CFLAG:乳牛 && !CFLAG:崩壊
	CALL PRINTL_WORD_COLOR,@"%CALLNAME%　Fall to Dairy Cow：%PRINT_PALAM_PERCENT(BASE:乳牛堕ち)% ","桃"
CALL CAPITULATION_JUDGE

;あなたの体力増加・レベルアップ
CALL MASTER_POWERUP

;霊力・魔力の注入
CALL POWER_INJECTION

;あなたABL,MARK
CALL PLAYER_SOURCE_UP_AFTER_STATUS_UP(1)



@PRINT_TOTAL_MILK_FLAVOR
#DIMS MILK

MILK =
;濃度表示
SELECTCASE ABL:母乳濃度
CASE 1
	MILK = Thick
CASE 2
	MILK = Fine
CASE 3
	MILK = Rich
CASE 4
	MILK = Potent
CASE 5
	MILK = Premium
ENDSELECT
MILK += " Milk"
CALL PRINT_WORD_COLOR,@"%MILK,8,LEFT%","桃"
;PRINTFORM %MILK,8,RIGHT%



;調教前後のステータス表示
@PRINT_STATUS_BEFORE_AFTER

;牛舎内なら表示しない
SIF CFLAG:牛舎番号
	RETURN
IF HP_BEFORE > BASE:体力
	PRINTFORM HP-{HP_BEFORE -BASE:体力,4,LEFT} 
	SIF !BASE:体力
		PRINT 【0 HP】
ENDIF
IF SP_BEFORE > BASE:気力
	PRINTFORM SP-{SP_BEFORE -BASE:気力,4,LEFT} 
	SIF !BASE:気力
		PRINT 【0 SP】
ENDIF

;ここからドレイン
IF MARK:絶頂魔力回復淫紋
	IF TFLAG:抽出中
		DAMAGE = EX:噴乳 *(ABL:母乳濃度 +1)
		PRINTFORM MP %VALUE_DIGIT(DAMAGE)% generated 
	ELSEIF GROUPMATCH(CSTR:スケジュール,"抽出","体内凌辱")
		DAMAGE = EX:噴乳 *(ABL:母乳濃度 +1)
		PRINTFORM MP %VALUE_DIGIT(DAMAGE)% absorbed 
	ENDIF
ENDIF
IF MP_BEFORE > BASE:魔力
	PRINTFORM MP-%VALUE_DIGIT(MP_BEFORE -BASE:魔力)% 
	SIF !BASE:魔力
		PRINT 【0 MP】
ENDIF
IF EP_BEFORE > BASE:霊力
	PRINTFORM EP-%VALUE_DIGIT(EP_BEFORE -BASE:霊力)% 
	SIF !BASE:霊力
		PRINT 【0 EP】
ENDIF



