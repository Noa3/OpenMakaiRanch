
;1日終了の処理
@ONE_DAY_END
#DIM BP_MIN

;夜に調教していた時用の処理
CALL NIGHT_TRAIN_AFTER

;体内凌辱中奴隷をちょっと回復
CALL SLEEP_NIKUKABE

;1日1回系フラグをリセット・母乳回復
CALL RESET_DAY_FLAG

;日付+1して週など計算
DAY ++
TIME = 0
CALL DATE_CALC

;妊娠日数経過
CALL CHILDBIRTH_COUNT

;成長期終わり判定
CALL GROWTH_CHECK

;風呂掃除フラグリセット
FLAG:あなた用風呂掃除完了 = 0

;大浴場の掃除完了度-10
FLAG:大浴場掃除完了度 = LIMIT(FLAG:大浴場掃除完了度 -10,0,100)

;牛舎設備を1消費
;ITEM:牛床マット→40
FOR LOCAL,40,50
	ITEM:LOCAL = LIMIT(ITEM:LOCAL -1,0,COWSHED_DEVICE_DAY_MAX)
NEXT

;たまに戦闘適性がちょっぴり鈍る
;MAX値を保存しておいて70%未満にはならない
IF RAND:100 < 30
	BP_MIN = MAXBASE:0:戦闘適性 *70
	BP_MIN /= 100
	SIF !BP_MIN
		BP_MIN ++
	BASE:0:戦闘適性 = LIMIT(BASE:0:戦闘適性 -1,BP_MIN,100)
ENDIF

;天気変更
CALL RANDOM_WEATHER
PRINTL All the dairy cows seem to have fallen sleep.
PRINTW Another day's work done.

;節目ならメッセージ
CALL ANNIVERSARY_MESSAGE
CALL MANYL(5)

;起床+朝ごはん
CALL MORNING_ACT

;魔力枷のついた奴隷が抵抗する
;体内凌辱中ならスキップ
WAIT_ON = 0
FOR TARGET_COUNT,1,CHARANUM
	TARGET = TARGET_COUNT
	IF EQUIP:魔力枷 && CSTR:スケジュール != "体内凌辱"
		CALL RESIST_SHACKLE
		WAIT_ON = 1
	ENDIF
NEXT
SIF WAIT_ON
	PRINTW

;MAIN_TURNENDに戻るのでセーブとかは不要



;夜に調教していた時用の処理
@NIGHT_TRAIN_AFTER

;調教していた場合メッセージと回復
SIF CSTR:0:スケジュール != "調教"
	RETURN

FINDCHARA CFLAG:ID,CFLAG:0:調教対象ID
SIF RESULT <= 0
	RETURN
TARGET = RESULT
CALL RESUME_VORE_SEX_CONFIRM
CALL NIGHT_TRAIN_AFTER_SLAVE
TARGET = 0
PRINTFORML %CALLNAME% also goes back to his room...
HEAL_PRINT_DONE = 0
CALL SLEEP_HEAL_TRAIN_AFTER
PRINTW



;再度体内凌辱するか確認
@RESUME_VORE_SEX_CONFIRM

SIF !FLAG:体内凌辱一時解除
	RETURN
IF !BASE:0:魔力
	PRINTFORML Due to insufficient Mana, %CALLNAME:0% cannot sustain the internal violation.
	RETURN
ENDIF
PRINTFORML Continue violating %CALLNAME% in your body?
CALL ASK_YN
IF !RESULT
	PRINTFORML After training %CALLNAME% is thrown back into %CALLNAME:0%'s body...
	CALL KOJO_PRINT("スケジュール","調教","再度体内凌辱")
	CSTR:スケジュール = 体内凌辱
	CSTR:居場所 = 体内
	PRINTFORML %CALLNAME:0% heads back for the night.
ELSE
	PRINTFORML %CALLNAME% is left outside.
ENDIF



;夜調教後の奴隷メッセージ+回復
@NIGHT_TRAIN_AFTER_SLAVE

;もう1度しまったら飛ばす
SIF CSTR:スケジュール == "体内凌辱"
	RETURN

;あとであなた部屋で一緒に寝るのも作りたい
IF EQUIP:自室
	IF !BASE:体力
		PRINTFORML You carry %CALLNAME%, who is limp from exhaustion, back into her room and put her to bed.  
	ELSE
		PRINTFORML After training, %CALLNAME% is sent back to her room.
	ENDIF
	CALL KOJO_PRINT("スケジュール","調教","夜調教後自室へ")
ELSE
	IF !BASE:体力
		PRINTFORML You leave %CALLNAME%, who is limp from exhaustion, on the training bed.
	ELSE
		PRINTFORML After training, %CALLNAME% collapses on the training bed.
	ENDIF
ENDIF
PRINTFORML %CALLNAME% appears to have fallen asleep.
HEAL_PRINT_DONE = 0
CALL SLEEP_HEAL_TRAIN_AFTER

