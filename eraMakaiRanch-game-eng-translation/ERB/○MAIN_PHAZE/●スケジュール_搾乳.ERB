
;奴隷の搾乳
@SLAVE_LACTATION

CATTLE_COUNT = CMATCH(CSTR:スケジュール,"搾乳")
SIF !CATTLE_COUNT
	RETURN

;酪農が1人もいないと搾れない
SIF !CMATCH(CSTR:スケジュール,"酪農")
	RETURN
PRINTL 　　　《 Milking 》

;調教者人数と技巧補正値計算
CALL SLAVE_LACTATION_TECHNIQUE_SET
CALL RANDOM_CHARA_SCHEDULE_COMMON("搾乳")
CALL SECTION_MP_COST
CALL SCHEDULE_ABL_MARK_BULK(1,"搾乳")
PRINTW
DRAWLINE
CALL RESET_TRAIN_PALAM
PLAYER = -1



;抽選したキャラの搾乳風景表示
@SLAVE_LACTATION_ENTRANCE

SIF CSTR:状態／あなたの子 == "成長後"
	CALL CHILD_REBELLION(1)
IF !EXP:実行回数／搾乳
	KOJO_TYPE = 初回
ELSE
	KOJO_TYPE = 通常
ENDIF
CALL STANDBY_SLAVE_LACTATION_MESSAGE
CALL SLAVE_LACTATION_RUN(1,"搾乳")

;実行後の地の文は↑の中
FLAG:前回表示キャラID／搾乳 = CFLAG:ID

;TFLAGでABLUPしたか判定が必要　なかった
WAIT

;改行しないと見にくい
CALL MANYL(2)




