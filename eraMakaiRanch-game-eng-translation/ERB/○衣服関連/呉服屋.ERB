
;呉服屋
@ITEM_SHOP_CLOTHE
#DIM DYNAMIC PAGE

CALL ITEM_SHOP_BUDGET_MONEY_JUDGE
BUY_NUM = 0
PAGE_MAX = 9
CLEARLINE LINECOUNT
CALL SHOW_RESOURCE_SHOP
BR = 0
CALL CLOTHE_LIST_COMMON(PAGE,"買い物")
PRINTL
DRAWLINE
CALL ITEM_DETAIL_CLOTHE(PAGE,"買い物")
CALL PRINTL_ALIGN
CALL BUY_ITEM_JUDGE("衣服")
CALL ITEM_SHOP_FOOTER(PAGE,"目次")
BINPUT
PRINTL

;目次の時はページ変更
IF !PAGE && RESULT <= PAGE_MAX
	PAGE = RESULT
	RESTART
ENDIF
SELECTCASE RESULT
CASE 0,1
	CALL BUY_ITEM_COMMON(RESULT)
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 89
	PAGE = 0
	SELECT_ITEM = 0
CASE 90
	CALL BULK_BUYING_COMMON(PAGE,"ファッション")
CASE 99
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT
RESTART

