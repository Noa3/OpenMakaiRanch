
;アイテムとして所持orキャラが所持で着せられる
@CHANGE_CLOTHE_CHECK

;着替え可能なSELECT_ITEMかチェック
IF ITEMNAME:SELECT_ITEM == "" || SELECT_ITEM < 1000 || SELECT_ITEM >= 2000
	PRINTL
	RETURN
ENDIF

;0：所持中かのチェック
;着用中チェック
FOR LOCAL,0,20
	SIF EQUIP:LOCAL != SELECT_ITEM
		CONTINUE
	CALL PRINT_SELECT_ITEM_DETAIL(SELECT_ITEM,"着用中")
	PRINTL
	RETURN
NEXT

;もう持ってる場合
IF EQUIP:SELECT_ITEM
	CALL PRINT_SELECT_ITEM_DETAIL(SELECT_ITEM,"所持中")

;持ってない服をプレゼントする場合→コマンド1に統合
;未所持
ELSE
	CALL PRINTLC_WORD_COLOR("　Not Owned　","水色")
ENDIF
PRINTL



;新しい衣服のプレゼントチェック
@NEW_CLOTHE_CHECK

IF ITEMNAME:SELECT_ITEM == "" || SELECT_ITEM < 1000 || SELECT_ITEM >= 2000
	PRINTL
	RETURN
ENDIF

;もう持ってる場合→色柄変更可能かチェック
IF EQUIP:SELECT_ITEM
	CALL CHECK_EQUIP_DETAIL_CHANGE(ITEMNAME:SELECT_ITEM)
	IF !RESULT
		CALL PRINTL_WORD_COLOR("　Color can't be changed","灰")
	
	;セット自体は無理：一気に色変更とかする？
	ELSEIF SELECT_ITEM >= 1000 && SELECT_ITEM < 1050
		CALL PRINTL_WORD_COLOR("　個別に色柄変更をする必要があります","灰")
	
	;デフォ状態なら消費なしで変更可能
	ELSEIF CSTR:SELECT_ITEM == "" && EQUIP:SELECT_ITEM == 1
		PRINTFORML [  1] Set Clothing Color
	
	;アイテムとして所持していれば変更可能
	ELSEIF ITEM:SELECT_ITEM
		IF TARGET
			PRINTFORML [  1] Give new %ITEMS_ENG(ITEMNAME:SELECT_ITEM)%
		ELSE
			PRINTFORML [  1] Wear new %ITEMS_ENG(ITEMNAME:SELECT_ITEM)%
		ENDIF
	ELSE
		CALL PRINTL_WORD_COLOR,@"No replacement %ITEMS_ENG(ITEMNAME:SELECT_ITEM)%","灰"
	ENDIF
ELSEIF ITEM:SELECT_ITEM
	;メガネは元々持ってる場合のみ、伊達メガネは元々メガネだとダメ
	IF ITEMNAME:SELECT_ITEM == "メガネ"
		IF TARGET
			CALL PRINTL_WORD_COLOR,@"%ITEMS_ENG(ITEMNAME:SELECT_ITEM)% can only be worn by characters that need prescription glasses.","灰"
		ELSE
			CALL PRINTL_WORD_COLOR,@"%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%は元々持っている場合しかかけられません","灰"
		ENDIF
		RETURN
	ELSEIF ITEMNAME:SELECT_ITEM == "伊達メガネ" && EQUIP:メガネ
		IF TARGET
			CALL PRINTL_WORD_COLOR,@"%ITEMS_ENG(ITEMNAME:SELECT_ITEM)% can not be worn by characters that need prescription glasses.","灰"
		ELSE
			CALL PRINTL_WORD_COLOR,@"メガネを持っている場合%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%はかけられません","灰"
		ENDIF
		RETURN
	ENDIF
	IF TARGET
		PRINTFORML [  1] Give %ITEMS_ENG(ITEMNAME:SELECT_ITEM)%
	ELSE
		PRINTFORML [  1] Wear %ITEMS_ENG(ITEMNAME:SELECT_ITEM)%
	ENDIF
ELSE
	CALL PRINTL_WORD_COLOR,@"Requires %ITEMS_ENG(ITEMNAME:SELECT_ITEM)%","灰"
ENDIF

