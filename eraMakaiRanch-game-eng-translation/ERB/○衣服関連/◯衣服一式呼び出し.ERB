;指定アイテムを着せるか渡す
;ARGS→処理
;ARGS:1→アイテム名
;ARGS:2→アイテムの概要変更
;ARG→一式表示での改行
@EQUIP_CLOTHE_SET_COMBI(ARGS,ARGS:1,ARGS:2,ARG)

SELECT_ITEM = GETNUM(ITEM,ARGS:1)

;処理を呼ぶ
SELECTCASE ARGS
CASE "着用"
	CALL WEAR_CHARA_CLOTHE(0,1)
	SIF EQUIP:SELECT_ITEM
		RETURN
	SETBIT EQUIP:SELECT_ITEM,0

	;概要指定されていたら変更
	SELECTCASE ARGS:2
	CASE "授乳スリット"
		;置換できなかった
		SETBIT EQUIP:SELECT_ITEM,10

	CASE "ハート型"
		CSTR:SELECT_ITEM = ハート
	ENDSELECT

CASE "所持チェック"
	;持ってないときEXIST = 0にする
	SIF !EQUIP:SELECT_ITEM
		EXIST = 0

CASE "合計金額"
	;COSTに金額を加算
	COST += ITEMPRICE:SELECT_ITEM

CASE "一式表示"
	;表示していく
	IF ARGS:2 == ""
		PRINTFORM ＜%ARGS:1%＞
	ELSE
		PRINTFORM ＜%ARGS:1%（%ARGS:2%）＞
	ENDIF
	SIF ARG
		PRINTL
ENDSELECT

