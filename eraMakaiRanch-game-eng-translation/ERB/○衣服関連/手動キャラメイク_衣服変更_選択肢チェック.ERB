
;手動キャラメイク時の衣服変更チェック
@SELF_CHARA_MAKE_CHANGE_CLOTHE_CHECK

;着替え可能なSELECT_ITEMかチェック
IF ITEMNAME:SELECT_ITEM == "" || SELECT_ITEM < 1000 || SELECT_ITEM >= 2000
	PRINTL
	RETURN
ENDIF

;着用中チェック
FOR LOCAL,0,20
	SIF EQUIP:LOCAL != SELECT_ITEM
		CONTINUE
	PRINT 　Wearing：
	CALL PRINT_SELECT_ITEM_DETAIL(SELECT_ITEM)
	PRINTL
	RETURN
NEXT

;着用していなければ通常の着せるコマンド
PRINTFORML [ 0] Change To %ITEMS_ENG(ITEMNAME:SELECT_ITEM)%


