
;装備の変更
@SELF_CHARA_MAKE_CLOTHE
#DIM DYNAMIC PAGE

PAGE_MAX = 10
CLEARLINE LINECOUNT
CALL PRINT_PORTRAIT(1)
PRINTFORML Change %CALLNAME%'s default clothes.
CALL SHOW_EQUIP
CALL HALFLINE
EXIST = 0
BR = 0
CALL CLOTHE_LIST_COMMON(PAGE,"キャラメイク")
PRINTL
DRAWLINE
CALL ITEM_DETAIL_CLOTHE(PAGE,"キャラメイク")
CALL PRINTL_ALIGN
CALL PRINT_NOW_PAGE(PAGE,1,1)

;手動キャラメイク時の衣服変更チェック
CALL SELF_CHARA_MAKE_CHANGE_CLOTHE_CHECK
PRINTLC [ 90] Undress
PRINTLC [ 91] Randomize by Job

;Ｂ以外が露出している場合は終了できない
IF TFLAG:Ａ露出 || TFLAG:Ｃ露出 || TFLAG:Ｖ露出 || TFLAG:Ｎ露出
	CALL PRINTL_WORD_COLOR,@"%SAVESTR:表記／乳房%以外露出状態での決定不可","灰"
ELSE
	PRINTL [ 99] Done
ENDIF
BINPUT
PRINTL

;目次の時はページ変更
IF !PAGE && RESULT <= PAGE_MAX
	PAGE = RESULT
	RESTART
ENDIF
SELECTCASE RESULT
CASE 0
	CALL SELF_CHARA_MAKE_CHANGE_CLOTHE_ENTER
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
	SELECT_ITEM = 0
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
	SELECT_ITEM = 0
CASE 89
	PAGE = 0
	SELECT_ITEM = 0
CASE 90
	CALL CHARA_CLOTHE_STRIP
CASE 91
	CALL RANDOM_SLAVE_CLOTHE
CASE 99
	SELECT_ITEM = 0
	RETURN
CASEELSE
	SELECT_ITEM = RESULT
ENDSELECT

;今装備しているもの以外は手放す処理
CALL SELF_CHARA_MAKE_CLOTHE_EMPTY
RESTART



