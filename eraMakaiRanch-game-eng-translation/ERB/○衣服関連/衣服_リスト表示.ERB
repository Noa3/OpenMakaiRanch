
;衣服説明目次：衣服は別関数
;ARG→PAGE
;ARGS→店
;ITEM_ID_MIN,ITEM_ID_MAX指定済み
@CLOTHE_LIST_COMMON(ARG,ARGS)

;ページごとの商品説明を呼ぶ
SELECTCASE ARG
CASE 0
	CALL CLOTHE_LIST_INDEX(ARGS)
CASE 1
	CALL CLOTHE_LIST_CLOTHESET(ARGS)
CASE 2
	CALL CLOTHE_LIST_WORK(ARGS)
CASE 3
	CALL CLOTHE_LIST_LINGERIE(ARGS)
CASE 4
	CALL CLOTHE_LIST_ACCESSORY(ARGS)
CASE 5
	CALL CLOTHE_LIST_ADULT_LINGERIE(ARGS)
CASE 6
	CALL CLOTHE_LIST_ADULT_CLOTHE(ARGS)
CASE 7
	CALL CLOTHE_LIST_HUMAN_REPLICA(ARGS)
CASE 8
	CALL CLOTHE_LIST_OTHER_WORLD(ARGS)
CASE 9
	CALL CLOTHE_LIST_OTHER_WORLD_LINGERIE(ARGS)
CASE 10
	CALL CLOTHE_LIST_ARMOR(ARGS)
CASE 11
	CALL CLOTHE_LIST_TENTACLE(ARGS)
ENDSELECT



;目次
;ARGS→どの画面から参照するか
@CLOTHE_LIST_INDEX(ARGS)

PRINTL 　《 Index 》
PRINTL [  1] Clothing Sets
PRINTL [  2] Work Clothes
PRINTL [  3] Lingerie
PRINTL [  4] Accessories

;買い物時はマイルストーンによるアンロック
IF ARGS == "買い物"
	CALL MILESTONE_UNLOCK_CHECK("アダルト衣装","")
	RESULT:1 = RESULT
	CALL MILESTONE_UNLOCK_CHECK("乳牛セット衣装","")
	
	;どっちかが開いてるならOK
	IF RESULT || RESULT:1
		PRINTL [  5] Cow Costume and Adult Lingerie
	ELSE
		CALL PRINTL_WORD_COLOR,@"<  5> Cow Costume and Adult Lingerie","灰"
	ENDIF
	CALL MILESTONE_UNLOCK_CHECK("アダルト衣装","")
	IF !RESULT
		CALL PRINTL_WORD_COLOR,@"<  6> Adult Clothes","灰"
	ELSE
		PRINTL [  6] Adult Clothes
	ENDIF
	CALL MILESTONE_UNLOCK_CHECK("衣服レプリカ","")
	IF !RESULT
		CALL PRINTL_WORD_COLOR,@"<  7> Ningen Clothes","灰"
	ELSE
		PRINTL [  7] Ningen Clothes
	ENDIF
	CALL MILESTONE_UNLOCK_CHECK("異世界衣服","")
	IF !RESULT
		CALL PRINTL_WORD_COLOR,@"<  8> Otherworld Clothes","灰"
		CALL PRINTL_WORD_COLOR,@"<  9> Otherworld Lingerie","灰"
	ELSE
		PRINTL [  8] Otherworld Clothes
		PRINTL [  9] Otherworld Lingerie
	ENDIF

ELSE
	PRINTL [  5] Cow Costume and Adult Lingerie
	PRINTL [  6] Adult Clothes
	PRINTL [  7] Ningen Clothes
	PRINTL [  8] Otherworld Clothes
	PRINTL [  9] Otherworld Lingerie
ENDIF

;キャラメイク中だけ
IF ARGS == "キャラメイク"
	PRINTL [ 10] Armor
ELSE
	CALL PRINTL_WORD_COLOR,@"< 10> Armor","灰"
ENDIF

;着替えだけ
IF ARGS == "着替え"
	PRINTL [ 11] Training Clothes
ELSE
	CALL PRINTL_WORD_COLOR,@"< 11> Training Clothes","灰"
ENDIF



