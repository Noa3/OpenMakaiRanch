
;衣服セット一式持ってる判定
;SELECT_ITEM指定中
@EQUIP_CLOTHE_SET_CHECK
#DIM SAVE_SELECT_ITEM

;保存
SAVE_SELECT_ITEM = SELECT_ITEM
FOR LOCAL,1000,1050
	SIF ITEMNAME:LOCAL == "" || EQUIP:LOCAL
		CONTINUE
	
	;一式所持判定にするかチェック
	EXIST = 1
	SELECT_ITEM = LOCAL
	CALL EQUIP_CLOTHE_SET_COMMON("所持チェック")
	
	;EXISTを↑で消してなければ所持判定
	SIF EXIST
		EQUIP:LOCAL = 1
NEXT
SELECT_ITEM = SAVE_SELECT_ITEM




