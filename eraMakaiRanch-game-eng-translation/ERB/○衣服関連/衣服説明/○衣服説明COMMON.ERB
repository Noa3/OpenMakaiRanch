
;アイテム説明と購入数
;ARG→PAGE
;ARGS→どのメニューから来たか
;ITEM_ID_MIN,ITEM_ID_MAX指定済み
@ITEM_DETAIL_CLOTHE(ARG,ARGS)

;対応IDでないなら汎用出して帰る
IF SELECT_ITEM < ITEM_ID_MIN || SELECT_ITEM >= ITEM_ID_MAX || ITEMNAME:SELECT_ITEM == ""
	PRINTL  　《 Clothing Description Shown Here 》
	RETURN
ENDIF

;とりあえずアイテム名、価格、所持数を出す
SELECTCASE ARGS
CASE "買い物"
	;一式は所持数のみ
	IF ITEM_ID_MIN == 1000
		PRINTFORM 　《 %ITEMNAME:SELECT_ITEM% 》Owned {ITEM:SELECT_ITEM,2} 
	ELSE
		PRINTFORM 　《 %ITEMNAME:SELECT_ITEM% 》%VALUE_DIGIT(ITEMPRICE:SELECT_ITEM)%G Owned {ITEM:SELECT_ITEM,2} 
	ENDIF
CASE "着替え"
	PRINTFORM 　《 %ITEMNAME:SELECT_ITEM% Owned {ITEM:SELECT_ITEM,2} 
CASE "キャラメイク"
	PRINTFORM 　《 %ITEMNAME:SELECT_ITEM% 》
ENDSELECT

;対応ドットがある場合表示
;暫定的に＜布の服＞＜旅人の服＞は同じ
IF ITEMNAME:SELECT_ITEM == "旅人の服"
	SPRITECREATED @"布の服_標準_巨乳"
	SIF RESULT
		CALL PRINT_WORD_COLOR("＜Clothing has Graphics＞（Identical to ＜Simple Clothes＞）","黄")
ELSE
	SPRITECREATED @"%ITEMNAME:SELECT_ITEM%_標準_巨乳"
	IF RESULT
		CALL PRINT_WORD_COLOR("＜Clothing has Graphics＞","黄")
	ELSE
		SPRITECREATED @"%ITEMNAME:SELECT_ITEM%"
		SIF RESULT
			CALL PRINT_WORD_COLOR("＜Clothing has Graphics＞","黄")
	ENDIF
ENDIF
PRINTL

;ページで分割する：長いので
SELECTCASE ARG
CASE 1
	;一式は価格出すかの処理含む
	CALL ITEM_DETAIL_CLOTHE_CLOTHESET(ARGS)
CASE 2
	CALL ITEM_DETAIL_CLOTHE_WORK
CASE 3
	CALL ITEM_DETAIL_CLOTHE_LINGERIE
CASE 4
	CALL ITEM_DETAIL_CLOTHE_ACCESSORY
CASE 5
	CALL ITEM_DETAIL_CLOTHE_ADULT_LINGERIE
CASE 6
	CALL ITEM_DETAIL_CLOTHE_ADULT_CLOTHE
CASE 7
	CALL ITEM_DETAIL_CLOTHE_HUMAN_REPLICA
CASE 8
	CALL ITEM_DETAIL_CLOTHE_OTHER_WORLD
CASE 9
	CALL ITEM_DETAIL_CLOTHE_OTHER_WORLD_LINGERIE
CASE 10
	CALL ITEM_DETAIL_CLOTHE_ARMOR
ENDSELECT


