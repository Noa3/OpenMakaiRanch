
;現在装備している衣服以外を手放す処理
@SELF_CHARA_MAKE_CLOTHE_EMPTY

FOR LOCAL,1000,2000
	;空欄ならそのまま
	SIF !EQUIP:LOCAL && CSTR:LOCAL == ""
		CONTINUE
	CALL SELF_CHARA_MAKE_CLOTHE_EMPTY_CHECK(LOCAL)
NEXT



;着用中チェック
;ARG→EQUIPのID
@SELF_CHARA_MAKE_CLOTHE_EMPTY_CHECK(ARG)

FOR LOCAL,0,20
	SIF EQUIP:LOCAL == ARG
		RETURN
NEXT

;一致しなかったら消去処理
EQUIP:ARG = 0
CSTR:ARG =


