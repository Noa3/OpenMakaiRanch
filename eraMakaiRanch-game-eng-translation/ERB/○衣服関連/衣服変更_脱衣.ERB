
;脱衣処理
@CHARA_CLOTHE_STRIP

CALL CHANGE_CLOTHE_RESIST_CHECK
PRINTL What do you want to take off?
PRINTFORM [ 1] Clothes　　
CALL PART_EQUIP_ITEM("衣服")
PRINTFORM [ 3] Underwear（Top）   
CALL PART_EQUIP_ITEM("下着上")

;上下セットなら飛ばす
IF EQUIP:装備中ID／下着上 == EQUIP:装備中ID／下着下 && EQUIP:装備中ID／下着上
	CALL PRINT_WORD_COLOR("Underwear Full Set","灰")
ELSE
	PRINTFORM [ 4] Underwear（Bottom）
	CALL PART_EQUIP_ITEM("下着下")
ENDIF
PRINTL
PRINTFORM [10] %"Eyes", 10, LEFT%
CALL PART_EQUIP_ITEM("眼")
PRINTFORM [11] %"Face", 10, LEFT%
CALL PART_EQUIP_ITEM("頭")
PRINTFORM [12] %"Arms", 10, LEFT%
CALL PART_EQUIP_ITEM("腕")
PRINTFORM [13] %"Legs", 10, LEFT%
CALL PART_EQUIP_ITEM("脚")
PRINTFORM [14] %"Neck", 10, LEFT%
CALL PART_EQUIP_ITEM("首")
PRINTFORM [15] %"Coat", 10, LEFT%
CALL PART_EQUIP_ITEM("上着")
PRINTL
PRINTLC [90] Strip Naked
PRINTLC [91] Remove Clothes・Underwear
PRINTL [92] Remove All Accessories
PRINTL [99] Cancel
BINPUT
PRINTL
SELECTCASE RESULT
CASE 1
	CALL CLOTHE_STRIP_LINGERIE_OVERWRITE

CASE 3
	SIF EQUIP:装備中ID／下着上 == EQUIP:装備中ID／下着下
		EQUIP:装備中ID／下着下 = 0
	EQUIP:装備中ID／下着上 = 0

CASE 4
	SIF EQUIP:装備中ID／下着上 == EQUIP:装備中ID／下着下
		EQUIP:装備中ID／下着上 = 0
	EQUIP:装備中ID／下着下 = 0

CASE 10 TO 19
	EQUIP:RESULT = 0
CASE 90
	VARSET EQUIP,0,0,20
CASE 91
	VARSET EQUIP,0,0,10
CASE 92
	VARSET EQUIP,0,10,20
ENDSELECT
CALL CHANGE_CLOTHE_RESIST(2)



;装備している衣服
;ARGS→表示箇所
@PART_EQUIP_ITEM(ARGS)
#DIMS CLOTHE

PRINT  Current：
CLOTHE = 装備中ID／%ARGS%
IF !EQUIP:CLOTHE
	CALL PRINTL_WORD_COLOR("None","灰")
ELSE
	PRINTFORML %ITEMS_ENG(ITEMNAME:(EQUIP:CLOTHE))%
ENDIF

