
;衣服セット
;SELECT_ITEM指定中
@EQUIP_CLOTHE_SET_WEAR
#DIM SAVE_SELECT_ITEM

;常に確認
IF TARGET
	PRINTFORML 眼・首装備以外を外して%CALLNAME%に＜%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%＞を着せますか？
ELSE
	PRINTFORML 眼・首装備以外を外して%CALLNAME%が＜%ITEMS_ENG(ITEMNAME:SELECT_ITEM)%＞を着ますか？
ENDIF
PRINTL ※If unowned color pattern, will automatically set to default.
PRINTL 　眼・首装備が含まれる場合は上書きします。
CALL ASK_YN
SIF RESULT
	RETURN 1

;保存
SAVE_SELECT_ITEM = SELECT_ITEM

;共通で眼と首以外は脱ぐ
FOR LOCAL,0,20
	SIF GROUPMATCH(EQUIPNAME:LOCAL,"装備中ID／眼","装備中ID／首")
		CONTINUE
	EQUIP:LOCAL = 0
NEXT

;一式着せる処理呼び出し
CALL EQUIP_CLOTHE_SET_COMMON("着用")

;SELECT_ITEM自体を所持済みにする
SELECT_ITEM = SAVE_SELECT_ITEM

;未所持のときここで減らす必要がある
IF !EQUIP:SELECT_ITEM && !FLAG:キャラメイク中
	SETBIT EQUIP:SELECT_ITEM,0
	ITEM:SELECT_ITEM --
ENDIF

;キャラメイク中は終了
SIF FLAG:キャラメイク中
	RETURN
IF TARGET
	PRINTFORMW ＜%ITEMNAME:SELECT_ITEM%＞を着せました。
ELSE
	PRINTFORMW ＜%ITEMNAME:SELECT_ITEM%＞を着ました。
ENDIF




