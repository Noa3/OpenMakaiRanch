;おっぱい露出改造
@BUST_STRIP_MODIFICATION

SIF !ITEM:マジカル裁ちバサミ && !FLAG:キャラメイク中
	RETURN
PRINTFORML %ITEMNAME:SELECT_ITEM%を%SAVESTR:表記／乳房%露出改造しますか？
PRINTL [ 0] Sideboob Modification
PRINTL [ 1] Boob Window Modification
PRINTL [ 2] Cleavage Exposure
PRINTL [ 3] Sideboob＋Boob Window
PRINTL [ 4] 授乳スリット
PRINTL [ 5] 通常の衣服
PRINTL
PRINTL [99] Cancel
INPUT

;元の衣服状態を上書きしてキャンセルしないように一旦1にするのは内部で
;計算めんどい+間違ってたら修正めんどい
SELECTCASE RESULT
CASE 0
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,3
CASE 1
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,4
CASE 2
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,5
CASE 3
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,3
	SETBIT EQUIP:SELECT_ITEM,4
CASE 4
	SETBIT EQUIP:SELECT_ITEM,10
CASE 5
	EQUIP:SELECT_ITEM = 1
CASEELSE
	RETURN 1
ENDSELECT



;淫乱改造
@NASTY_MODIFICATION
#DIM BUST_STRIP

SIF !ITEM:マジカル裁ちバサミ && !FLAG:キャラメイク中
	RETURN
PRINTFORML Modify %ITEMS_ENG(ITEMNAME:SELECT_ITEM)% to be even more lewd?
PRINTFORML 《 %SAVESTR:表記／乳房% 》
PRINTL
PRINTL [ 0] Breast Curtains
PRINTFORML [ 1] Bare %SAVESTR:表記／乳房%
PRINTL [ 2] Leave As Is
PRINTL
PRINTL [99] Cancel
INPUT
SIF RESULT > 2 || RESULT < 0
	RETURN 1
BUST_STRIP = RESULT

PRINTFORML 《 %SAVESTR:表記／膣% 》
PRINTL
PRINTL [ 0] Apron
PRINTFORML [ 1] Bare %SAVESTR:表記／膣%
PRINTL [ 2] Leave As Is
PRINTL
PRINTL [99] Cancel
INPUT
SELECTCASE RESULT
CASE 0
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,7
CASE 1
	EQUIP:SELECT_ITEM = 1
	SETBIT EQUIP:SELECT_ITEM,9
CASE 2
	EQUIP:SELECT_ITEM = 1
CASEELSE
	RETURN 1
ENDSELECT
CALL NASTY_MODIFICATION_BUST(BUST_STRIP)



;おっぱい露出形状の適応
;ARG→BUST_STRIP
@NASTY_MODIFICATION_BUST(ARG)

SELECTCASE ARG
CASE 0
	SETBIT EQUIP:SELECT_ITEM,6
CASE 1
	SETBIT EQUIP:SELECT_ITEM,8
ENDSELECT


