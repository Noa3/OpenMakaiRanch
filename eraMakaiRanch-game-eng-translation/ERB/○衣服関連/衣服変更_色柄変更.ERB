
;色柄変更処理
;SELECT_ITEM指定で来ている
@EQUIP_DETAIL_CHANGE
#DIMS EQUIP_DETAIL
#DIM ITEM_DETAIL

EQUIP_DETAIL =
CALL CHECK_EQUIP_DETAIL_CHANGE(ITEMNAME:SELECT_ITEM)
ITEM_DETAIL = RESULT
SELECTCASE ITEM_DETAIL
CASE 0
	;なんもないやつ
	RETURN
CASE 1
	PRINTL Equipment is Color Changeable
CASE 2
	PRINTL Color・Pattern／Shape Changeable
CASE 3
	PRINTL Equipment is Color・Breast Exposure Changeable
	SIF !ITEM:マジカル裁ちバサミ && !FLAG:キャラメイク中
		CALL PRINTL_WORD_COLOR("※Requires ＜Magic Fabric Scissors＞","黄")
CASE 4
	PRINTL Equipment is Color・Lewdity Changeable
	SIF !ITEM:マジカル裁ちバサミ && !FLAG:キャラメイク中
		CALL PRINTL_WORD_COLOR("※Requires ＜Magic Fabric Scissors＞","黄")
ENDSELECT

CALL ITEM_COLOR_SELECT

;1が帰ってきたらキャンセル
SIF RESULT
	RETURN 1
EQUIP_DETAIL += RESULTS
SELECTCASE ITEM_DETAIL
CASE 2
	CALL ITEM_PATTERN_SELECT
	EQUIP_DETAIL += RESULTS
CASE 3
	CALL BUST_STRIP_MODIFICATION
CASE 4
	CALL NASTY_MODIFICATION
ENDSELECT
SIF RESULT
	RETURN 1

;最後までいったらCSTRに保存
CSTR:SELECT_ITEM = %EQUIP_DETAIL%

;逆バニーは上下丸出しにセットする
IF GROUPMATCH(ITEMNAME:SELECT_ITEM,"逆バニー")
	SETBIT EQUIP:SELECT_ITEM,8
	SETBIT EQUIP:SELECT_ITEM,9
ENDIF



;色変更
@ITEM_COLOR_SELECT

PRINTFORML Change color of %ITEMS_ENG(ITEMNAME:SELECT_ITEM)%?

;一部選択肢をちょっと変えたいね
SELECTCASE ITEMNAME:SELECT_ITEM
CASE "ドレス","バトルドレス","淫乱ドレス","ゴスロリ衣装","軍服","マント"
	STR_REF = 6720
CASEELSE
	STR_REF = 6700
ENDSELECT

FOR LOCAL,STR_REF,STR_REF +20
	SIF STR:LOCAL == ""
		CONTINUE
	PRINTFORMLC [{LOCAL -STR_REF,2}] %CLOTH_COLOR_ENG(STR:LOCAL)%
NEXT
CALL INPUTBUTTON(1)
INPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 20
	RESULTS = %STR:(STR_REF +RESULT)%
CASE 900
	RESULTS =
CASE 901
	PRINTL Enter a color
	INPUTS
CASE 999
	RETURN 1
ENDSELECT



;柄変更
@ITEM_PATTERN_SELECT

PRINTFORML Change pattern／shape of %ITEMS_ENG(ITEMNAME:SELECT_ITEM)%?

;一部選択肢をちょっと変えたいね
SELECTCASE ITEMNAME:SELECT_ITEM
CASE "和服"
	STR_REF = 6760
CASE "ニップレス"
	STR_REF = 6780
CASE "メガネ","伊達メガネ"
	STR_REF = 6800
CASEELSE
