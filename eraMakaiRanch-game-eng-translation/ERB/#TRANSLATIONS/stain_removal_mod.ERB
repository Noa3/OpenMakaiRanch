
;-------------------------------------------------
; Remove feces and smegma if corresponding config option is set
;-------------------------------------------------
@EN_STAIN_REMOVAL_MOD

; remove feces
SIF FECES_REMOVAL_MOD_FLAG
	CLEARBIT STAIN:アナル,2

; remove smegma
SIF SMEGMA_REMOVAL_MOD_FLAG
	CLEARBIT STAIN:0:ペニス,7


@EN_STAIN_CONFIG
CLEARLINE LINECOUNT
PRINTL Disable feces and smegma.
DRAWLINE

PRINTLC [ 0] Remove Feces
CALL PRINT_ONOFF(FECES_REMOVAL_MOD_FLAG,1)
PRINTLC [ 1] Remove Smegma
CALL PRINT_ONOFF(SMEGMA_REMOVAL_MOD_FLAG,1)
CALL PRINTL_ALIGN(-5)
CALL ON_OFF_BUTTON_FOOTER
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	INVERTBIT FECES_REMOVAL_MOD_FLAG,1
CASE 1
	INVERTBIT SMEGMA_REMOVAL_MOD_FLAG,1
CASE 82
	PRINTL For all toggable options, no explaination for [ON] will be given.
	CALL ASK_ONOFF
	FLAG:ON／OFF項目の詳細を飛ばして反転 = RESULT
CASE 98
	PRINTL Do you want to reset the stain removal settings to default?
	CALL ASK_YN
	SIF !RESULT
		CALL EN_DEFAULT_STAIN_MOD_CONFIG
CASE 99
	RETURN
	
ENDSELECT
RESTART

@EN_DEFAULT_STAIN_MOD_CONFIG
FECES_REMOVAL_MOD_FLAG = 0
SMEGMA_REMOVAL_MOD_FLAG = 0

@EN_SAVE_STAIN_MOD_CONFIG
FECES_REMOVAL_MOD_FLAG_G = FECES_REMOVAL_MOD_FLAG
SMEGMA_REMOVAL_MOD_FLAG_G = SMEGMA_REMOVAL_MOD_FLAG
SAVEGLOBAL

@EN_LOAD_STAIN_MOD_CONFIG
LOADGLOBAL
FECES_REMOVAL_MOD_FLAG = FECES_REMOVAL_MOD_FLAG_G
SMEGMA_REMOVAL_MOD_FLAG = SMEGMA_REMOVAL_MOD_FLAG_G
