
;戦闘中ステータス表示
@BATTLE_STATUS

DRAWLINE
ALIGNMENT CENTER
PRINTFORML --- TURN {TURN} ---
ALIGNMENT LEFT
PRINTL
PRINTFORML 　　%CALLNAME%%PRINT_EXIST_GROUP()%
CALL PRINT_TARGET_BATTLE_STATUS
ALIGNMENT CENTER
PRINTL VS

ALIGNMENT RIGHT
PRINTFORML %PRINT_MONSTER_GROUP()%　　
PRINTFORM Demon Combat Strength：%VALUE_DIGIT(TFLAG:バイト戦闘力)%／%VALUE_DIGIT(TFLAG:バイト戦闘力／最大値)% 
CALL PRINT_COLORBAR(TFLAG:バイト戦闘力,TFLAG:バイト戦闘力／最大値,8,BARCOLORSET("青緑"),RESULT:1)
PRINTL 　　
PRINTFORML Attack Count：%VALUE_DIGIT(TFLAG:バイト攻撃力)%×{TFLAG:バイト攻撃回数} 　　
ALIGNMENT LEFT
PRINTW
DRAWLINE



;プレイヤー戦闘中ステータス表示
@MASTER_BATTLE_STATUS

DRAWLINE
ALIGNMENT CENTER
PRINTFORML --- TURN {TURN} ---
ALIGNMENT LEFT
PRINTL
PRINTFORML 　　%CALLNAME%%PRINT_EXIST_GROUP()%
CALL PRINT_TARGET_BATTLE_STATUS
ALIGNMENT CENTER
PRINTL VS

ALIGNMENT RIGHT
PRINTFORML %CALLNAME:BATTLE_CHARA%　　
PRINTFORM 戦闘力：%VALUE_DIGIT(BASE:BATTLE_CHARA:戦闘力)%／%VALUE_DIGIT(MAXBASE:BATTLE_CHARA:戦闘力)% 
CALL PRINT_COLORBAR(BASE:BATTLE_CHARA:戦闘力 , MAXBASE:BATTLE_CHARA:戦闘力, 8 , BARCOLORSET("青緑") , RESULT:1)
PRINTL 　　
PRINTFORML 攻撃力：%VALUE_DIGIT(MAXBASE:BATTLE_CHARA:戦闘力 * BASE:BATTLE_CHARA:戦闘適性 / 500)%×{CFLAG:BATTLE_CHARA:攻撃回数} 　　
ALIGNMENT LEFT
PRINTW
DRAWLINE



;追跡者を表示
@PRINT_MONSTER
#FUNCTIONS

SELECTCASE CFLAG:追跡者
CASE 1
	RETURNF "The Goblin Army"
CASE 2
	RETURNF "The Rookie Mercenaries"
CASE 3
	RETURNF "The Veteran Mercenaries"
CASE 4
	RETURNF "The Oni Mercenaries"
CASEELSE
	LOCALS = エラー：追跡者番号{CFLAG:追跡者}
	RETURNF LOCALS
ENDSELECT



;追跡者グループを表示
@PRINT_MONSTER_GROUP
#FUNCTIONS
#DIMS GROUP

SELECTCASE CFLAG:追跡者
CASE 1
	GROUP = Goblin Army 
	GROUP += TOSTR(CFLAG:追跡人数)
	GROUP += " Troops"
	
CASE 2
	GROUP = Rookie Mercenaries 
	GROUP += TOSTR(CFLAG:追跡人数)
	GROUP += " Mercs"
	
CASE 3
	GROUP = Veteran Mercenaries 
	GROUP += TOSTR(CFLAG:追跡人数)
	GROUP += " Mercs"
	
CASE 4
	GROUP = Oni Mercenaries 
	GROUP += TOSTR(CFLAG:追跡人数)
	GROUP += " Mercs"
CASEELSE
	GROUP = エラー：追跡者番号{CFLAG:追跡者}・追跡人数{CFLAG:追跡人数}
ENDSELECT
RETURNF GROUP

