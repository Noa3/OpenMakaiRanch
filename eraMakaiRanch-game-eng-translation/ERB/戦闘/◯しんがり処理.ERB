
;戦闘中にターゲットだけを逃がす
@UNIT_ESCAPE_BATTLE

CALL UNIT_ESCAPE_BATTLE_MESSAGE
TFLAG:犠牲逃走 = 1



;しんがりに魔物側勝利
@TARGET_ESCAPE_DEFEAT

CALL TARGET_ESCAPE_DEFEAT_MESSAGE
CALL PURPOSE_CHANGE("合流退却")
BASE:疲労度 += 30
DAMAGE = 2 *TURN +RAND:5 +10
BASE:疲労度 = LIMIT(BASE:疲労度 +DAMAGE,0,MAXBASE:疲労度)
PRINTFORML %CALLNAME% Fatigue：{BASE:疲労度}



;しんがりに魔物側敗北
@TARGET_ESCAPE_WIN

CALL TARGET_ESCAPE_WIN_MESSAGE
CALL PURPOSE_CHANGE("合流退却")
BASE:仲間戦闘力1 = 0
BASE:疲労度 += 30




