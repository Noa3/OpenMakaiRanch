
;ターン経過でダメージ増加
@BATTLE_DAMAGE_FIX

;1ターンに20%増加・MAX300%
FIX = LIMIT(80 +TURN *20,100,300)
DAMAGE *= FIX
DAMAGE /= 100
CALL RANDOM_FIX(DAMAGE,5,"ダメージ")
DAMAGE += FIX



;傭兵攻撃のダメージ計算
@MONSTER_ATTACK_DAMAGE_CALC

DAMAGE = TFLAG:バイト攻撃力
CALL BATTLE_DAMAGE_FIX

;倍率コンフィグ
CALL DIFFICULTY_CONFIG_APPLY("戦闘与ダメージ")



;プレイヤー攻撃ダメージ計算
@PLAYER_ATTACK_DAMAGE_CALC

;戦闘力の20% * 戦闘適性%
DAMAGE = MAXBASE:BATTLE_CHARA:戦闘力 * BASE:BATTLE_CHARA:戦闘適性 / 500
CALL BATTLE_DAMAGE_FIX

;攻撃回数が2以上なら0.8倍
SIF CFLAG:BATTLE_CHARA:攻撃回数 >= 2
	TIMES DAMAGE,0.80
CALL DIFFICULTY_CONFIG_APPLY("戦闘与ダメージ")



;ターゲット攻撃ダメージ計算
@TARGET_ATTACK_DAMAGE_CALC

;戦闘力MAXの10%ダメージ
DAMAGE = MAXBASE:戦闘力 /10
CALL BATTLE_DAMAGE_FIX

;疲労度1%ごとに0.5%ダメージ減少
DAMAGE -= (DAMAGE *BASE:疲労度 /2 /100)
DAMAGE = LIMIT(DAMAGE,0,MAXBASE:戦闘力)
CALL DIFFICULTY_CONFIG_APPLY("戦闘被ダメージ")



;仲間たちの攻撃ダメージ計算
@GROUP_ATTACK_DAMAGE_CALC

;仲間戦闘力MAXの10%ダメージ
DAMAGE = MAXBASE:仲間戦闘力1 /10
CALL BATTLE_DAMAGE_FIX
DAMAGE -= (DAMAGE *BASE:疲労度 /2 /100)
DAMAGE = LIMIT(DAMAGE,0,MAXBASE:戦闘力)

;攻撃回数多いと1回は若干低下
SIF CFLAG:仲間規模 > 1
	TIMES DAMAGE,0.80
CALL DIFFICULTY_CONFIG_APPLY("戦闘被ダメージ")



;仲間のクリティカル判定計算
@CRITICAL_CALC_GROUP

;疲労度と仲間ランクによるクリティカル・ファンブル判定
ATTACK_RATE = LIMIT(50 -CFLAG:仲間ランク *4,0,50)
ATTACK_RATE += RAND:(BASE:疲労度 +1)



;本人のクリティカル判定計算
@CRITICAL_CALC_TARGET

;疲労度とランクによるクリティカル・ファンブル判定
ATTACK_RATE = LIMIT(50 -CFLAG:ランク *4,0,50)
ATTACK_RATE += RAND:(BASE:疲労度 +1)



;ATTACK_RATEから防御判定
@CRITICAL_CHECK_DEFFENSE

;90以上でファンブル　ダメージ倍
IF ATTACK_RATE >= 90
	TIMES DAMAGE,2.00
	SETCOLOR 0xFFFF70
	PRINT FUMBLE! 
	
;10以下でガード　ダメージ半減
ELSEIF ATTACK_RATE <= 10
	TIMES DAMAGE,0.50
	SETCOLOR 0x50C0FF
	PRINT GUARD! 
ENDIF



;ATTACK_RATEからクリティカル判定
;ARGS→技種類
@CRITICAL_CHECK_ATTACK(ARGS)

;疲労度50%以上のときランクを無視してミス判定→疲労度/4%
;大技時は除く
IF BASE:疲労度 >= 50 && ARGS != "大技"
	IF RAND:10000 < BASE:疲労度 *100 /4
		DAMAGE = 0
		SETCOLOR 0xFFFF70
		PRINT MISS! 
		RETURN
	ENDIF
ENDIF

;10未満ならクリティカル
IF ATTACK_RATE < 10
	TIMES DAMAGE,1.50
	SETCOLOR 0x50C0FF
	PRINT CRITICAL! 
	
;110以上だとミス→大技だとミスはしない
ELSEIF ATTACK_RATE >= 110 && ARGS != "大技"
	DAMAGE = 0
	SETCOLOR 0xFFFF70
	PRINT MISS! 
	
;90以上だとガードされる　ダメージ半減
ELSEIF ATTACK_RATE >= 90
	TIMES DAMAGE,0.50
	SETCOLOR 0xFFFF70
	PRINT BAD! 
ENDIF


