
;戦闘のターゲット行動
;MODメモ
;20221101 - あなた以外も戦闘へ投入できるよう改造
@MASTER_BATTLE_TARGET_ACTION_COMMON

;テレポート使うということで逃げ判断不可
IF CFLAG:非戦闘職
	CALL TARGET_NODAMAGE_ACTION
	RETURN
ENDIF
IF BASE:大技回数 && (TURN > 4 || BASE:戦闘力 < MAXBASE:戦闘力 *20 /100)
	CALL MASTER_BATTLE_TARGET_SPECIAL_ATTACK
	RETURN
ENDIF

;回復行動は関数同じでOK
IF BASE:回復回数
	IF BASE:戦闘力 < MAXBASE:戦闘力 *40 /100
		CALL TARGET_SPECIAL_HEAL_SELF
		RETURN
	ELSEIF BASE:仲間戦闘力1 < MAXBASE:仲間戦闘力1 *40 /100 && BASE:仲間戦闘力1 > 0
		CALL TARGET_SPECIAL_HEAL_GROUP
		RETURN
	ENDIF
ENDIF

;ダメージ・クリティカル判定計算
CALL TARGET_ATTACK_DAMAGE_CALC
CALL CRITICAL_CALC_TARGET

;ダメージ半減するとちょうどいい気がする
DAMAGE /= 2

CALL KOJO_PRINT("戦闘","攻撃")
PRINTFORM %CALLNAME% Attacks! 
CALL CRITICAL_CHECK_ATTACK
PRINTFORML %CALLNAME:BATTLE_CHARA% takes %VALUE_DIGIT(DAMAGE)% damage! 
BASE:BATTLE_CHARA:戦闘力 = LIMIT(BASE:BATTLE_CHARA:戦闘力 -DAMAGE,0,MAXBASE:BATTLE_CHARA:戦闘力)
RESETCOLOR



;大技
@MASTER_BATTLE_TARGET_SPECIAL_ATTACK

CALL KOJO_PRINT("戦闘","大技")
CALL PRINTL_WORD_COLOR,@"%CALLNAME% unleashes her signature move!!","水色"
BASE:大技回数 --
CALL TARGET_ATTACK_DAMAGE_CALC
DAMAGE /= 2

;大技のダメージ増加：4ターン目以下なら2.5倍、5ターン目以降1.5倍
IF TURN < 5
	TIMES DAMAGE,2.50
ELSE
	TIMES DAMAGE,1.50
ENDIF
CALL CRITICAL_CALC_TARGET
CALL CRITICAL_CHECK_ATTACK("大技")
PRINTFORML %CALLNAME:BATTLE_CHARA%に%VALUE_DIGIT(DAMAGE)% Damage!  
BASE:BATTLE_CHARA:戦闘力 = LIMIT(BASE:BATTLE_CHARA:戦闘力 -DAMAGE,0,MAXBASE:BATTLE_CHARA:戦闘力)

;疲労度+10%
BASE:疲労度 = LIMIT(BASE:疲労度 +10,0,MAXBASE:疲労度)
PRINTFORML Remaining Signature Moves：{BASE:大技回数} Fatigue+10



;仲間攻撃
@MASTER_BATTLE_TARGET_GROUP_ATTACK

;仲間の規模=攻撃回数　2回以上は0.8倍補正
PRINTFORM The Companions Attack!  
FOR LOCAL,0,CFLAG:仲間規模
	;ダメージ計算
	CALL GROUP_ATTACK_DAMAGE_CALC
	DAMAGE /= 2
	
	;2回目以降追撃
	SIF LOCAL
		PRINT CHASE! 
	
	;仲間のクリティカル判定計算
	CALL CRITICAL_CALC_GROUP
	CALL CRITICAL_CHECK_ATTACK
	PRINTFORML %CALLNAME:BATTLE_CHARA%に%VALUE_DIGIT(DAMAGE)%ダメージ！ 
	BASE:BATTLE_CHARA:戦闘力 = LIMIT(BASE:BATTLE_CHARA:戦闘力 -DAMAGE,0,MAXBASE:BATTLE_CHARA:戦闘力)
	RESETCOLOR
	
	;倒したらループ終了
	SIF !BASE:BATTLE_CHARA:戦闘力
		RETURN
NEXT
PRINTW


