
;事業提携先入り口
@BUISINESS_PARTNER

;FLAG:事業提携先奴隷数／ニンゲン搾乳牧場→740
;STR:ニンゲン搾乳牧場→8200
FLAG_REF = 740
STR_REF = 8200
CLEARLINE LINECOUNT
PRINTL 　《 事業提携先一覧 》
DRAWLINE
FOR LOCAL,0,10
	SIF FLAGNAME:(FLAG_REF +LOCAL) == ""
		CONTINUE
	PRINTFORML [{LOCAL,2}] %STR:(STR_REF +LOCAL),20%：奴隷{FLAG:(FLAG_REF +LOCAL)}匹 
NEXT
CALL PRINTL_ALIGN(-10)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(1,"戻る")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0 TO 9
	CALL BUISINESS_PARTNER_SLAVE(RESULT)
CASE 98
	CALL BROWSE_HINT("事業提携先")
CASE 99
	RETURN
ENDSELECT
RESTART



;選択後
;ARG→提携先
@BUISINESS_PARTNER_SLAVE(ARG)
#DIM MAX_SLAVE

CLEARLINE LINECOUNT

;今とりあえず汎用牧場だけなのでそこ用
MAX_SLAVE = 20 +FLAG:魔界レベル／酪農業 *5

;送った結果MAX以上にならないように
FLAG:(FLAG_REF +ARG) = LIMIT(FLAG:(FLAG_REF +ARG),0,MAX_SLAVE)
PRINTFORML %STR:(STR_REF +ARG)%：奴隷{FLAG:(FLAG_REF +ARG)}／{MAX_SLAVE}匹（現在数／最大数）
CALL BUISINESS_PARTNER_REWORD(ARG)
DRAWLINE

;MAXでも送る＝奴隷削除はできる
PRINTL [ 0] 奴隷を送る
CALL PRINTL_ALIGN(-10)
DRAWLINE
CALL RIGHT_RETURN_BUTTON(0,"戻る")
BINPUT
PRINTL
SELECTCASE RESULT
CASE 0
	CALL BUISINESS_PARTNER_SEND_SLAVE_SELECT(ARG)
CASE 99
	RETURN
ENDSELECT
RESTART



;提携事業の報酬
;ARG→提携先
@BUISINESS_PARTNER_REWORD(ARG)

PRINT 報酬：
SELECTCASE ARG
CASE 0
	PRINTFORML %VALUE_DIGIT(PARTNER_ALLSLAVE_REWORD)%G×奴隷数／日
ENDSELECT



;提携先に送る奴隷の選択
;ARG→提携先
@BUISINESS_PARTNER_SEND_SLAVE_SELECT(ARG)
#DIM DYNAMIC PAGE

PAGE_MAX = (CHARANUM -2)/20 +1
SIF PAGE < 1
	PAGE = 1
CLEARLINE LINECOUNT
PRINTFORML %STR:(STR_REF +ARG)%に送る奴隷を選択してください。
CALL PARTNER_SEND_SLAVE_TERM(ARG)
PRINTL
FOR TARGET_COUNT,1,21
	SIF TARGET_COUNT +(PAGE -1)*20 >= CHARANUM
		BREAK
	TARGET = TARGET_COUNT +(PAGE -1)*20
	IF CFLAG:追跡対象
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：Not Captured","灰"
		CONTINUE
	ELSEIF EQUIP:魔力枷
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：＜魔力枷＞適用中","灰"
		CONTINUE
	ELSEIF CSTR:居場所 == "体内"
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：In body","灰"
		CONTINUE
	ELSEIF GROUPMATCH(CSTR:状態／あなたの子,"成長中","成長後")
		CALL PRINTL_WORD_COLOR,@"%CALLNAME_DIGIT(4)%：愛娘","灰"
		CONTINUE
	ENDIF
	
	;提携先による条件に合わない場合もダメ
	CALL PARTNER_SEND_SLAVE_TERM_CHECK(ARG)
	SIF RESULT
		CONTINUE
	
	PRINTFORM [{TARGET +100}] %CALLNAME_DIGIT()%
	CALL PRINT_POST_C
	CALL TABLE_STATUS("提携先送り")
	PRINTL
NEXT
CALL PRINTL_ALIGN(-5)
CALL PRINT_NOW_PAGE(PAGE,1)
PRINTFORMLC [  8] Change Display Settings
PRINTLC 　
PRINTL [ 99] Cancel
BINPUT
SELECTCASE RESULT
CASE 8
	CALL CHANGE_TABLE_STATUS
CASE 80
	PAGE --
	SIF PAGE < 1
		PAGE = PAGE_MAX
CASE 81
	PAGE ++
	SIF PAGE > PAGE_MAX
		PAGE = 1
CASE 99
	RETURN
CASEELSE
	TARGET = RESULT -100
	PRINTFORML %STR:(STR_REF +ARG)%に%CALLNAME%を送ります。よろしいですか？
	CALL ASK_YN
	SIF RESULT
		RETURN
	
	;ダブルチェック
	CALL PRINTL_WORD_COLOR("送った奴隷はデータ上削除され、二度と会うことはできません。本当によろしいですか？","黄")
	CALL ASK_YN
	SIF RESULT
		RETURN
	
	;口上もあるといいかもしれない　まだ
	PRINTFORMW %STR:(STR_REF +ARG)%に%CALLNAME%を送りました。
	FLAG:(FLAG_REF +ARG) ++
	CALL TARGET_CHARA_DELETE
	CALL SCHEDULE_ADJUST
ENDSELECT
RESTART



;送る条件
;ARG→提携先
@PARTNER_SEND_SLAVE_TERM(ARG)

PRINTL 送れる奴隷：＜魔力枷＞取り外し済み・＜体内凌辱＞中ではない（共通）
SELECTCASE ARG
CASE 0
	;他の条件なし
	PRINTL
ENDSELECT



;送る条件をTARGETごとにチェックしてダメならRETURN1
;ARG→提携先
@PARTNER_SEND_SLAVE_TERM_CHECK(ARG)

SELECTCASE ARG
CASE 0
	;他の条件なし
ENDSELECT





